use core.fs;
use core.http;
use core.thread;
use core.log;

enum RouteKind {
    RouteHealth,
    RouteSessionsCreate,
    RouteSessionGet,
    RouteToolsRegister,
    RouteToolsList,
    RouteToolsDelete,
    RouteToolsRun,
    RouteMessagesPost,
    RouteRunGet,
    RouteNotFound,
}

fn boot() -> i32 {
    log.info("web.boot", apputil.log_fields2("component", "web", "phase", "boot"))
    configure_listener()
    return 0
}

fn configure_listener() -> i32 {
    runtime.config.load_host()
    runtime.config.load_port()
    runtime.config.load_workers()
    return 0
}

fn start_listener() -> i32 {
    configure_listener()
    let listener: HttpHandle = http.bind()
    http.listen(listener)
    log.info("web listener started", apputil.log_fields2("component", "web", "phase", "listener_started"))
    close(listener)
    return 0
}

fn serve_forever() -> i32 {
    configure_listener()
    let listener: HttpHandle = http.bind()
    defer close(listener)
    http.listen(listener)
    log.info("web listener started", apputil.log_fields2("component", "web", "phase", "listener_started"))
    log.info("web serve_forever entered", apputil.log_fields2("component", "web", "phase", "serve_forever"))
    let mut worker_idx: i32 = 0
    while worker_idx < runtime.config.worker_count() {
        let handle = spawn_ctx(serve_worker, worker_idx + 1)
        detach(handle)
        worker_idx = worker_idx + 1
    }
    loop {
        if runtime.supervisor.shutdown_requested() == 1 {
            break
        }
        checkpoint()
        yield()
    }
    return 0
}

fn serve_worker() -> i32 {
    loop {
        if runtime.supervisor.shutdown_requested() == 1 {
            return 0
        }
        let conn_owned: HttpHandle = http.accept()
        timeout(1000)
        discard http.read(conn_owned)
        discard dispatch(conn_owned)
        cancel()
        checkpoint()
        yield()
    }
}

fn accept_and_process() -> i32 {
    let conn_owned: HttpHandle = http.accept()
    timeout(1000)
    discard http.read(conn_owned)
    let status = dispatch(conn_owned)
    cancel()
    return status
}

fn request_artifact_path(request_id: str) -> str {
    return runtime.config.state_path(str.concat("http.request.", str.concat(request_id, ".json")))
}

fn capture_request_artifact_request(request_id: str, method: str, path: str, authorization_present: str, body: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    let payload = apputil.json_obj5(
        "request_id", json.str(request_id),
        "method", json.str(method),
        "path", json.str(path),
        "authorization_present", json.str(authorization_present),
        "body", json.str(if runtime.config.capture_request_bodies() == 1 { body } else { "" }),
    )
    runtime.config.ensure_state_root()
    discard fs.atomic_write(request_artifact_path(request_id), payload)
    return 0
}

fn tool_id_from_run_path(path: str) -> str {
    let prefix_len = str.len("/tools/")
    let path_len = str.len(path)
    if path_len <= prefix_len {
        return ""
    }
    let trimmed = str.slice(path, prefix_len, path_len)
    let suffix_len = str.len("/run")
    let trimmed_len = str.len(trimmed)
    if trimmed_len <= suffix_len {
        return ""
    }
    return str.slice(trimmed, 0, trimmed_len - suffix_len)
}

fn dispatch(conn: HttpHandle) -> i32 {
    let request_id = http.request_id(conn)
    let method = http.method(conn)
    let path = http.path(conn)
    let auth_header = http.header(conn, "authorization")
    let body = http.body(conn)
    let authorization_present = if auth_header == "" { "false" } else { "true" }
    discard capture_request_artifact_request(request_id, method, path, authorization_present, body)
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("web accepted connection", apputil.log_fields2("component", "web", "phase", "accept"))
        log.info("web dispatch route", apputil.log_fields3("component", "web", "phase", "dispatch", "route_path", path))
        log.info("web dispatch method", apputil.log_fields3("component", "web", "phase", "dispatch_method", "method", method))
    }
    let auth = security.auth_middleware_request(request_id, auth_header)
    if auth != 0 {
        discard http.write_json(conn, 401, model.types.request_guard_error_json("unauthorized"))
        return 0
    }
    let limited = security.rate_limit_request(request_id)
    if limited != 0 {
        discard http.write_json(conn, 429, model.types.request_guard_error_json("rate_limited"))
        return 0
    }
    let tool_id = if str.starts_with(path, "/tools/") == 1 && str.ends_with(path, "/run") == 1 {
        tool_id_from_run_path(path)
    } else {
        ""
    }
    let policy = security.policy_filter_request(tool_id, method, path)
    if policy != 0 {
        discard http.write_json(conn, 403, model.types.request_guard_error_json("policy_denied"))
        return 0
    }
    let route = route_kind(method, path)
    match route {
        RouteKind::RouteHealth => return services.http.handle_health(conn),
        RouteKind::RouteSessionGet => return services.http.handle_session_get(conn, path),
        RouteKind::RouteToolsList => return services.http.handle_tools_list(conn),
        RouteKind::RouteRunGet => return services.http.handle_runs(conn, path),
        RouteKind::RouteSessionsCreate => return services.http.handle_sessions(conn),
        RouteKind::RouteToolsRegister => return services.http.handle_tools_register(conn),
        RouteKind::RouteToolsRun => return services.http.handle_tools_run(conn, path),
        RouteKind::RouteMessagesPost => return services.http.handle_messages(conn, path),
        RouteKind::RouteToolsDelete => return services.http.handle_tools_delete(conn, path),
        _ => return dispatch_not_found(conn),
    }
    return 0
}

fn dispatch_not_found(conn: HttpHandle) -> i32 {
    log.warn("web route not found", apputil.log_fields2("component", "web", "phase", "not_found"))
    return write_text(conn, 404, str.concat(http.method(conn), str.concat(" ", http.path(conn))))
}

fn route_key(conn: HttpHandle) -> i32 {
    let route = route_kind(http.method(conn), http.path(conn))
    match route {
        RouteKind::RouteHealth => return 0,
        RouteKind::RouteSessionsCreate => return 1,
        RouteKind::RouteSessionGet => return 2,
        RouteKind::RouteToolsRegister => return 3,
        RouteKind::RouteToolsList => return 4,
        RouteKind::RouteToolsDelete => return 5,
        RouteKind::RouteToolsRun => return 6,
        RouteKind::RouteMessagesPost => return 7,
        RouteKind::RouteRunGet => return 8,
        _ => return 255,
    }
    return 255
}

fn route_kind(method: str, path: str) -> RouteKind {
    if method == "GET" && path == "/healthz" {
        return RouteKind::RouteHealth
    }
    if method == "GET" && str.starts_with(path, "/sessions/") == 1 && str.ends_with(path, "/messages") == 0 {
        return RouteKind::RouteSessionGet
    }
    if method == "GET" && path == "/tools" {
        return RouteKind::RouteToolsList
    }
    if method == "GET" && str.starts_with(path, "/runs/") == 1 {
        return RouteKind::RouteRunGet
    }
    if method == "POST" && path == "/sessions" {
        return RouteKind::RouteSessionsCreate
    }
    if method == "POST" && path == "/tools" {
        return RouteKind::RouteToolsRegister
    }
    if method == "POST" && str.starts_with(path, "/tools/") == 1 && str.ends_with(path, "/run") == 1 {
        return RouteKind::RouteToolsRun
    }
    if method == "POST" && str.starts_with(path, "/sessions/") == 1 && str.ends_with(path, "/messages") == 1 {
        return RouteKind::RouteMessagesPost
    }
    if method == "DELETE" && str.starts_with(path, "/tools/") == 1 {
        return RouteKind::RouteToolsDelete
    }
    return RouteKind::RouteNotFound
}

fn write_ok(conn: HttpHandle) -> i32 {
    http.write(conn, 200, "ok")
    return 0
}

fn write_json(conn: HttpHandle) -> i32 {
    http.write_json(conn, 200, "{}")
    return 0
}

fn write_not_found(conn: HttpHandle) -> i32 {
    route.write_404(conn)
    return 0
}

fn write_text(conn: HttpHandle, status: i32, body: str) -> i32 {
    http.write(conn, status, body)
    return 0
}
