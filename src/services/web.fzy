use core.http;
use core.thread;
use core.log;

enum RouteKind {
    RouteHealth,
    RouteSessionsCreate,
    RouteSessionGet,
    RouteToolsRegister,
    RouteToolsList,
    RouteToolsDelete,
    RouteToolsRun,
    RouteMessagesPost,
    RouteRunGet,
    RouteNotFound,
}

fn boot() -> i32 {
    log.info("web.boot", util.log_fields2("component", "web", "phase", "boot"))
    configure_listener()
    return 0
}

fn configure_listener() -> i32 {
    env.get("AGENT_HOST")
    env.get("AGENT_PORT")
    env.get("AGENT_WORKERS")
    return 0
}

fn start_listener() -> i32 {
    configure_listener()
    let listener: HttpHandle = http.bind()
    http.listen(listener)
    log.info("web listener started", util.log_fields2("component", "web", "phase", "listener_started"))
    close(listener)
    return 0
}

fn serve_forever() -> i32 {
    configure_listener()
    let listener: HttpHandle = http.bind()
    http.listen(listener)
    log.info("web listener started", util.log_fields2("component", "web", "phase", "listener_started"))
    log.info("web serve_forever entered", util.log_fields2("component", "web", "phase", "serve_forever"))
    loop {
        if runtime.supervisor.shutdown_requested() == 1 {
            break
        }
        accept_and_process()
        checkpoint()
        yield()
    }
    close(listener)
    return 0
}

fn accept_and_process() -> i32 {
    let conn: HttpHandle = http.accept()
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("web accepted connection", util.log_fields2("component", "web", "phase", "accept"))
    }
    read_request(conn)
    let allow = apply_middleware(conn)
    if allow == 0 {
        dispatch(conn)
    }
    close(conn)
    return 0
}

fn read_request(conn: HttpHandle) -> i32 {
    http.read(conn)
    capture_request_artifact(conn)
    return 0
}

fn request_artifact_path(request_id: str) -> str {
    return str.concat("/tmp/fzyagent/http.request.", str.concat(request_id, ".json"))
}

fn capture_request_artifact(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    let payload = map.new()
    discard map.set(payload, "request_id", json.str(http.request_id(conn)))
    discard map.set(payload, "method", json.str(http.method(conn)))
    discard map.set(payload, "path", json.str(http.path(conn)))
    discard map.set(payload, "authorization_present", json.str(if http.header(conn, "authorization") == "" { "false" } else { "true" }))
    discard map.set(payload, "body", json.str(http.body(conn)))
    fs.mkdir("/tmp/fzyagent")
    fs.write_file(request_artifact_path(http.request_id(conn)), json.object(payload))
    return 0
}

fn tool_id_from_run_path(path: str) -> str {
    let prefix_len = str.len("/tools/")
    let path_len = str.len(path)
    if path_len <= prefix_len {
        return ""
    }
    let trimmed = str.slice(path, prefix_len, path_len)
    let suffix_len = str.len("/run")
    let trimmed_len = str.len(trimmed)
    if trimmed_len <= suffix_len {
        return ""
    }
    return str.slice(trimmed, 0, trimmed_len - suffix_len)
}

fn apply_middleware(conn: HttpHandle) -> i32 {
    let auth = security.auth_middleware_conn(conn)
    if auth != 0 {
        http.write_json(conn, 401, model.types.request_guard_error_json("unauthorized"))
        return 1
    }
    let limited = security.rate_limit_conn(conn)
    if limited != 0 {
        http.write_json(conn, 429, model.types.request_guard_error_json("rate_limited"))
        return 1
    }
    let path = http.path(conn)
    let tool_id = if str.starts_with(path, "/tools/") == 1 && str.ends_with(path, "/run") == 1 { tool_id_from_run_path(path) } else { "" }
    let policy = security.policy_filter_request(tool_id, http.method(conn), path)
    if policy != 0 {
        http.write_json(conn, 403, model.types.request_guard_error_json("policy_denied"))
        return 1
    }
    checkpoint()
    return 0
}

fn dispatch(conn: HttpHandle) -> i32 {
    let method = http.method(conn)
    let path = http.path(conn)
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("web dispatch route", util.log_fields3("component", "web", "phase", "dispatch", "route_path", path))
        log.info("web dispatch method", util.log_fields3("component", "web", "phase", "dispatch_method", "method", method))
    }
    let route = route_kind(method, path)
    match route {
        RouteKind::RouteHealth => return services.http.handle_health(conn),
        RouteKind::RouteSessionsCreate => return services.http.handle_sessions(conn),
        RouteKind::RouteSessionGet => return services.http.handle_session_get(conn, path),
        RouteKind::RouteToolsRegister => return services.http.handle_tools_register(conn),
        RouteKind::RouteToolsList => return services.http.handle_tools_list(conn),
        RouteKind::RouteToolsDelete => return services.http.handle_tools_delete(conn, path),
        RouteKind::RouteToolsRun => return services.http.handle_tools_run(conn, path),
        RouteKind::RouteMessagesPost => return services.http.handle_messages(conn, path),
        RouteKind::RouteRunGet => return services.http.handle_runs(conn, path),
        _ => return dispatch_not_found(conn),
    }
    return 0
}

fn dispatch_not_found(conn: HttpHandle) -> i32 {
    log.warn("web route not found", util.log_fields2("component", "web", "phase", "not_found"))
    return write_not_found(conn)
}

fn route_key(conn: HttpHandle) -> i32 {
    let route = route_kind(http.method(conn), http.path(conn))
    match route {
        RouteKind::RouteHealth => return 0,
        RouteKind::RouteSessionsCreate => return 1,
        RouteKind::RouteSessionGet => return 2,
        RouteKind::RouteToolsRegister => return 3,
        RouteKind::RouteToolsList => return 4,
        RouteKind::RouteToolsDelete => return 5,
        RouteKind::RouteToolsRun => return 6,
        RouteKind::RouteMessagesPost => return 7,
        RouteKind::RouteRunGet => return 8,
        _ => return 255,
    }
    return 255
}

fn route_kind(method: str, path: str) -> RouteKind {
    if method == "GET" && path == "/healthz" {
        return RouteKind::RouteHealth
    }
    if method == "GET" && str.starts_with(path, "/sessions/") == 1 && str.ends_with(path, "/messages") == 0 {
        return RouteKind::RouteSessionGet
    }
    if method == "GET" && path == "/tools" {
        return RouteKind::RouteToolsList
    }
    if method == "GET" && str.starts_with(path, "/runs/") == 1 {
        return RouteKind::RouteRunGet
    }
    if method == "POST" && path == "/sessions" {
        return RouteKind::RouteSessionsCreate
    }
    if method == "POST" && path == "/tools" {
        return RouteKind::RouteToolsRegister
    }
    if method == "POST" && str.starts_with(path, "/tools/") == 1 && str.ends_with(path, "/run") == 1 {
        return RouteKind::RouteToolsRun
    }
    if method == "POST" && str.starts_with(path, "/sessions/") == 1 && str.ends_with(path, "/messages") == 1 {
        return RouteKind::RouteMessagesPost
    }
    if method == "DELETE" && str.starts_with(path, "/tools/") == 1 {
        return RouteKind::RouteToolsDelete
    }
    return RouteKind::RouteNotFound
}

fn write_ok(conn: HttpHandle) -> i32 {
    http.write(conn, 200, "ok")
    return 0
}

fn write_json(conn: HttpHandle) -> i32 {
    http.write_json(conn, 200, "{}")
    return 0
}

fn write_not_found(conn: HttpHandle) -> i32 {
    route.write_404(conn)
    return 0
}

fn write_text(conn: HttpHandle, status: i32, body: str) -> i32 {
    http.write(conn, status, body)
    return 0
}
