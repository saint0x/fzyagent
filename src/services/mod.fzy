mod store;
mod http;
mod web;
mod anthropic;
mod openai_compat;
mod provider;
mod registry;
mod tools;
mod sessions;
mod telemetry;
mod security;
mod openapi;
mod persistence;
mod chaos;
mod safety;
mod longrange;

use core.log;
use registry.list_tools as list_tools_alias;

pub use telemetry.boot_metrics;

fn boot_all() -> i32 {
    log.info("services.boot_all begin", apputil.log_fields2("component", "services", "phase", "boot_begin"))
    discard store.init()
    discard web.boot()
    discard sessions.boot()
    discard longrange.boot()
    discard registry.load_builtin()
    discard registry.refresh_runtime()
    discard registry.heartbeat()
    discard registry.planner_hints()
    discard runtime.events.emit_registry_update()

    discard tools.boot_runner()
    discard telemetry.boot_metrics()
    discard runtime.events.emit_health_tick()

    discard openapi.export_spec()
    discard openapi.validate_schema()
    discard persistence.load_session()

    log.info("services.boot_all complete", apputil.log_fields2("component", "services", "phase", "boot_complete"))
    discard list_tools_alias()
    return 0
}

fn boot_chat() -> i32 {
    discard store.init()
    discard sessions.boot()
    discard longrange.boot()
    discard registry.load_builtin()
    discard registry.refresh_runtime()
    discard tools.boot_runner()
    discard persistence.load_session()
    return 0
}
