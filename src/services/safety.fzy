use core.fs;

fn safety_path() -> str {
    return "/tmp/fzyagent/safety.last.json"
}

fn safety_runtime_mode() -> str {
    let mode = env.get("AGENT_SAFETY_MODE")
    if mode == "" {
        return "standard"
    }
    return mode
}

fn max_prompt_chars() -> i32 {
    if safety_runtime_mode() == "strict" {
        return 8000
    }
    return 16000
}

fn record(stage: str, status: str, details: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    fs.mkdir("/tmp/fzyagent")
    let payload = json.object(#{
        "stage": json.str(stage),
        "mode": json.str(safety_runtime_mode()),
        "status": json.str(status),
        "details": json.str(details),
    })
    fs.write_file(safety_path(), payload)
    return 0
}

fn filter_prompt() -> i32 {
    record("filter_prompt", "ok", "bootstrap")
    return 0
}

fn filter_prompt_text(prompt: str) -> str {
    let trimmed = if str.len(prompt) > max_prompt_chars() { str.slice(prompt, 0, max_prompt_chars()) } else { prompt }
    let blocked = if str.contains(trimmed, "BEGIN_PRIVATE_KEY") == 1 || str.contains(trimmed, "AWS_SECRET_ACCESS_KEY") == 1 { "blocked_secret_pattern" } else { "" }
    if blocked != "" {
        record("filter_prompt", "denied", blocked)
        return "[blocked: prompt matched protected secret pattern]"
    }
    record("filter_prompt", "ok", str.concat("chars=", str.from_i32(str.len(trimmed))))
    return trimmed
}

fn filter_tool_response() -> i32 {
    record("filter_tool_response", "ok", "bootstrap")
    return 0
}

fn redact_secret(text: str, secret: str) -> str {
    if secret == "" {
        return text
    }
    return str.replace(text, secret, "[redacted]")
}

fn filter_tool_response_text(text: str) -> str {
    let redacted_env = redact_secret(text, env.get("ANTHROPIC_API_KEY"))
    let redacted_openai = redact_secret(redacted_env, env.get("OPENAI_API_KEY"))
    let redacted_compat = redact_secret(redacted_openai, env.get("OPENAI_COMPAT_API_KEY"))
    let redacted_notify = redact_secret(redacted_compat, env.get("BRRR_NOTIFY_SECRET"))
    record("filter_tool_response", "ok", str.concat("chars=", str.from_i32(str.len(redacted_notify))))
    return redacted_notify
}

fn decide_policy() -> i32 {
    record("decide_policy", "ok", "bootstrap")
    return 0
}

fn allow_prompt(prompt: str) -> i32 {
    if safety_runtime_mode() == "strict" && str.contains(prompt, "rm -rf /") == 1 {
        record("decide_policy", "denied", "dangerous_shell_pattern")
        return 0
    }
    record("decide_policy", "ok", "allow")
    return 1
}
