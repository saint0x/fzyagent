use core.fs;
use core.log;
use core.proc;
use core.time;

fn db_dir() -> str {
    return "/tmp/fzyagent"
}

fn error_dir() -> str {
    return "/tmp/fzyagent/sqlite_errors"
}

fn mirror_dir() -> str {
    return "/tmp/fzyagent/sqlite_mirror"
}

pub fn db_path() -> str {
    return "/tmp/fzyagent/runtime.sqlite3"
}

fn helper_path() -> str {
    return "/Users/deepsaint/Desktop/fzyagent/scripts/sqlite_kv.py"
}

fn python_path() -> str {
    return "/usr/bin/python3"
}

fn default_env() -> ProcessEnv {
    let env_map: ProcessEnv = proc.env_new()
    discard proc.env_set(env_map, "TERM", "dumb")
    return env_map
}

fn shell_argv(command: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-lc")
    discard proc.argv_push(argv, command)
    return argv
}

fn helper_argv2(op: str, db: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, helper_path())
    discard proc.argv_push(argv, op)
    discard proc.argv_push(argv, db)
    return argv
}

fn helper_argv3(op: str, db: str, a: str) -> ProcessArgv {
    let argv = helper_argv2(op, db)
    discard proc.argv_push(argv, a)
    return argv
}

fn helper_argv4(op: str, db: str, a: str, b: str) -> ProcessArgv {
    let argv = helper_argv3(op, db, a)
    discard proc.argv_push(argv, b)
    return argv
}

fn helper_argv5(op: str, db: str, a: str, b: str, c: str) -> ProcessArgv {
    let argv = helper_argv4(op, db, a, b)
    discard proc.argv_push(argv, c)
    return argv
}

fn helper_result_failed(op: str, exit_code: i32, stderr: str, stdout: str, detail: str) -> i32 {
    fs.mkdir(error_dir())
    let mut payload = "ts="
    payload = str.concat(payload, str.from_i32(time.now()))
    payload = str.concat(payload, str.concat(" | op=", op))
    payload = str.concat(payload, str.concat(" | exit_code=", str.from_i32(exit_code)))
    payload = str.concat(payload, str.concat(" | detail=", detail))
    payload = str.concat(payload, str.concat(" | stderr=", stderr))
    payload = str.concat(payload, str.concat(" | stdout=", stdout))
    payload = str.concat(payload, "\n")
    let existing = if fs.exists("/tmp/fzyagent/sqlite_helper_errors.log") == 1 { fs.read_file("/tmp/fzyagent/sqlite_helper_errors.log") } else { "" }
    discard fs.write_file("/tmp/fzyagent/sqlite_helper_errors.log", str.concat(existing, payload))
    discard fs.write_file("/tmp/fzyagent/sqlite_helper_last_failure.txt", payload)
    let mut snapshot = "{"
    snapshot = str.concat(snapshot, str.concat(json.str("op"), str.concat(":", json.str(op))))
    snapshot = str.concat(snapshot, str.concat(",", str.concat(json.str("exit_code"), str.concat(":", json.str(str.from_i32(exit_code))))))
    snapshot = str.concat(snapshot, str.concat(",", str.concat(json.str("detail"), str.concat(":", json.str(detail)))))
    snapshot = str.concat(snapshot, str.concat(",", str.concat(json.str("stderr"), str.concat(":", json.str(stderr)))))
    snapshot = str.concat(snapshot, str.concat(",", str.concat(json.str("stdout"), str.concat(":", json.str(stdout)))))
    snapshot = str.concat(snapshot, "}")
    discard fs.write_file(str.concat3(error_dir(), "/", str.concat(str.from_i32(time.now()), ".json")), snapshot)
    log.error(
        "services.sqlite_store helper_failed",
        apputil.log_fields3("op", op, "exit_code", str.from_i32(exit_code), "detail", apputil.excerpt_head(detail, 220))
    )
    if stderr != "" {
        log.error("services.sqlite_store helper_stderr", apputil.log_fields2("op", op, "stderr", apputil.excerpt_head(stderr, 220)))
    }
    if stdout != "" {
        log.error("services.sqlite_store helper_stdout", apputil.log_fields2("op", op, "stdout", apputil.excerpt_head(stdout, 220)))
    }
    return 1
}

fn key_retries_on_empty(key: str) -> i32 {
    if str.starts_with(key, "kv:longrange:run:") == 1 {
        if str.ends_with(key, ":queue") == 1 {
            return 0
        }
        return 1
    }
    if str.starts_with(key, "kv:longrange:session:") == 1 && str.ends_with(key, ":active_run") == 1 {
        return 1
    }
    return 0
}

fn is_longrange_key(key: str) -> i32 {
    if str.starts_with(key, "kv:longrange:") == 1 {
        return 1
    }
    return 0
}

fn run_helper_stdout(argv: ProcessArgv, op: str, detail: str, timeout_ms: i32) -> str {
    let env_map = default_env()
    let handle = proc.spawn_cmd(python_path(), argv, env_map, "")
    defer proc.close(handle)
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    if exit_code != 0 {
        discard helper_result_failed(op, exit_code, stderr, stdout, detail)
        return "__FZY_SQLITE_FAILED__"
    }
    return stdout
}

fn run_helper_status(argv: ProcessArgv, op: str, detail: str, timeout_ms: i32) -> i32 {
    let env_map = default_env()
    let handle = proc.spawn_cmd(python_path(), argv, env_map, "")
    defer proc.close(handle)
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    if exit_code != 0 {
        return helper_result_failed(op, exit_code, stderr, stdout, detail)
    }
    return 0
}

fn run_getfile_shell(key: str, out_path: str) -> i32 {
    return run_helper_status(helper_argv4("getfile", db_path(), key, out_path), "getfile", key, 5000)
}

fn run_put_shell(key: str, value: str) -> i32 {
    return run_helper_status(helper_argv4("put", db_path(), key, value), "put", key, 5000)
}

fn run_delete_shell(key: str) -> i32 {
    return run_helper_status(helper_argv3("delete", db_path(), key), "delete", key, 5000)
}

fn run_longrange_update_turn_shell(
    state_key: str,
    progress_key: str,
    run_id: str,
    session_id: str,
    goal: str,
    run_status: str,
    plan_status: str,
    task_class: str,
    turns_completed: str,
    failure_count: str,
    last_progress_score: str,
    consecutive_low_score: str,
    last_evidence_count: str,
    completed_step_count: str,
    auto_continue_pending: str,
    active_message_kind: str,
    latest_summary: str,
    created_at: str,
    updated_at: str,
    current_step_id: str,
    last_request_id: str,
    completed_at: str,
    progress_phase: str,
    progress_message_kind: str,
    progress_recorded_at: str,
    progress_score: str,
    progress_evidence_count: str,
    progress_request_id: str,
    progress_detail: str,
) -> i32 {
    let debug_payload = apputil.json_obj6(
        "run_id", json.str(run_id),
        "run_status", json.str(run_status),
        "plan_status", json.str(plan_status),
        "progress_phase", json.str(progress_phase),
        "last_request_id", json.str(last_request_id),
        "progress_request_id", json.str(progress_request_id),
    )
    discard fs.atomic_write("/tmp/fzyagent/last_longrange_update_turn_spawn.json", debug_payload)
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, helper_path())
    discard proc.argv_push(argv, "longrange_update_turn")
    discard proc.argv_push(argv, db_path())
    discard proc.argv_push(argv, state_key)
    discard proc.argv_push(argv, progress_key)
    discard proc.argv_push(argv, run_id)
    discard proc.argv_push(argv, session_id)
    discard proc.argv_push(argv, goal)
    discard proc.argv_push(argv, run_status)
    discard proc.argv_push(argv, plan_status)
    discard proc.argv_push(argv, task_class)
    discard proc.argv_push(argv, turns_completed)
    discard proc.argv_push(argv, failure_count)
    discard proc.argv_push(argv, last_progress_score)
    discard proc.argv_push(argv, consecutive_low_score)
    discard proc.argv_push(argv, last_evidence_count)
    discard proc.argv_push(argv, completed_step_count)
    discard proc.argv_push(argv, auto_continue_pending)
    discard proc.argv_push(argv, active_message_kind)
    discard proc.argv_push(argv, latest_summary)
    discard proc.argv_push(argv, created_at)
    discard proc.argv_push(argv, updated_at)
    discard proc.argv_push(argv, current_step_id)
    discard proc.argv_push(argv, last_request_id)
    discard proc.argv_push(argv, completed_at)
    discard proc.argv_push(argv, progress_phase)
    discard proc.argv_push(argv, progress_message_kind)
    discard proc.argv_push(argv, progress_recorded_at)
    discard proc.argv_push(argv, progress_score)
    discard proc.argv_push(argv, progress_evidence_count)
    discard proc.argv_push(argv, progress_request_id)
    discard proc.argv_push(argv, progress_detail)
    let handle = proc.spawn_cmd(python_path(), argv, default_env(), "")
    defer proc.close(handle)
    discard proc.wait(handle, 5000)
    let exit_code = proc.exit_code(handle)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    if exit_code != 0 {
        return helper_result_failed("longrange_update_turn", exit_code, stderr, stdout, run_id)
    }
    return 0
}

