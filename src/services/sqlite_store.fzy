fn run_longrange_terminalize_shell(
    state_key: str,
    progress_key: str,
    session_active_key: str,
    summary_key: str,
    active_runs_key: str,
    run_id: str,
    session_id: str,
    goal: str,
    run_status: str,
    plan_status: str,
    task_class: str,
    turns_completed: str,
    failure_count: str,
    last_progress_score: str,
    consecutive_low_score: str,
    last_evidence_count: str,
    completed_step_count: str,
    active_message_kind: str,
    latest_summary: str,
    created_at: str,
    current_step_id: str,
    last_request_id: str,
    progress_phase: str,
    progress_message_kind: str,
    progress_score: str,
    progress_evidence_count: str,
    progress_request_id: str,
    progress_detail: str,
) -> i32 {
    let env_map = default_env()
    discard proc.env_set(env_map, "FZY_DB_PATH", db_path())
    discard proc.env_set(env_map, "FZY_STATE_KEY", state_key)
    discard proc.env_set(env_map, "FZY_PROGRESS_KEY", progress_key)
    discard proc.env_set(env_map, "FZY_SESSION_ACTIVE_KEY", session_active_key)
    discard proc.env_set(env_map, "FZY_SUMMARY_KEY", summary_key)
    discard proc.env_set(env_map, "FZY_ACTIVE_RUNS_KEY", active_runs_key)
    discard proc.env_set(env_map, "FZY_RUN_ID", run_id)
    discard proc.env_set(env_map, "FZY_SESSION_ID", session_id)
    discard proc.env_set(env_map, "FZY_GOAL", goal)
    discard proc.env_set(env_map, "FZY_RUN_STATUS", run_status)
    discard proc.env_set(env_map, "FZY_PLAN_STATUS", plan_status)
    discard proc.env_set(env_map, "FZY_TASK_CLASS", task_class)
    discard proc.env_set(env_map, "FZY_TURNS_COMPLETED", turns_completed)
    discard proc.env_set(env_map, "FZY_FAILURE_COUNT", failure_count)
    discard proc.env_set(env_map, "FZY_LAST_PROGRESS_SCORE", last_progress_score)
    discard proc.env_set(env_map, "FZY_CONSECUTIVE_LOW_SCORE", consecutive_low_score)
    discard proc.env_set(env_map, "FZY_LAST_EVIDENCE_COUNT", last_evidence_count)
    discard proc.env_set(env_map, "FZY_COMPLETED_STEP_COUNT", completed_step_count)
    discard proc.env_set(env_map, "FZY_ACTIVE_MESSAGE_KIND", active_message_kind)
    discard proc.env_set(env_map, "FZY_LATEST_SUMMARY", latest_summary)
    discard proc.env_set(env_map, "FZY_CREATED_AT", created_at)
    discard proc.env_set(env_map, "FZY_CURRENT_STEP_ID", current_step_id)
    discard proc.env_set(env_map, "FZY_LAST_REQUEST_ID", last_request_id)
    discard proc.env_set(env_map, "FZY_PROGRESS_PHASE", progress_phase)
    discard proc.env_set(env_map, "FZY_PROGRESS_MESSAGE_KIND", progress_message_kind)
    discard proc.env_set(env_map, "FZY_PROGRESS_SCORE", progress_score)
    discard proc.env_set(env_map, "FZY_PROGRESS_EVIDENCE_COUNT", progress_evidence_count)
    discard proc.env_set(env_map, "FZY_PROGRESS_REQUEST_ID", progress_request_id)
    discard proc.env_set(env_map, "FZY_PROGRESS_DETAIL", progress_detail)
    let command = str.concat3(python_path(), " ", helper_path())
    let shell_cmd = str.concat(
        command,
        " longrange_terminalize \"$FZY_DB_PATH\" \"$FZY_STATE_KEY\" \"$FZY_PROGRESS_KEY\" \"$FZY_SESSION_ACTIVE_KEY\" \"$FZY_SUMMARY_KEY\" \"$FZY_ACTIVE_RUNS_KEY\" \"$FZY_RUN_ID\" \"$FZY_SESSION_ID\" \"$FZY_GOAL\" \"$FZY_RUN_STATUS\" \"$FZY_PLAN_STATUS\" \"$FZY_TASK_CLASS\" \"$FZY_TURNS_COMPLETED\" \"$FZY_FAILURE_COUNT\" \"$FZY_LAST_PROGRESS_SCORE\" \"$FZY_CONSECUTIVE_LOW_SCORE\" \"$FZY_LAST_EVIDENCE_COUNT\" \"$FZY_COMPLETED_STEP_COUNT\" \"$FZY_ACTIVE_MESSAGE_KIND\" \"$FZY_LATEST_SUMMARY\" \"$FZY_CREATED_AT\" \"$FZY_CURRENT_STEP_ID\" \"$FZY_LAST_REQUEST_ID\" \"$FZY_PROGRESS_PHASE\" \"$FZY_PROGRESS_MESSAGE_KIND\" \"$FZY_PROGRESS_SCORE\" \"$FZY_PROGRESS_EVIDENCE_COUNT\" \"$FZY_PROGRESS_REQUEST_ID\" \"$FZY_PROGRESS_DETAIL\""
    )
    let handle = proc.spawn_cmd("/bin/sh", shell_argv(shell_cmd), env_map, "")
    defer proc.close(handle)
    discard proc.wait(handle, 5000)
    let exit_code = proc.exit_code(handle)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    if exit_code != 0 {
        return helper_result_failed("longrange_terminalize", exit_code, stderr, stdout, run_id)
    }
    return 0
}

fn get_scratch_dir() -> str {
    return "/tmp/fzyagent/sqlite_get"
}

fn get_scratch_path(key: str) -> str {
    fs.mkdir(get_scratch_dir())
    return str.concat3(get_scratch_dir(), "/", str.concat(str.from_i32(time.now()), ".json"))
}

fn refresh_mirror_from_db(key: str) -> i32 {
    let scratch = get_scratch_path(key)
    let rc = run_getfile_shell(key, scratch)
    if rc != 0 {
        return rc
    }
    let value = str.trim(fs.read_file(scratch))
    return fs.atomic_write(mirror_path(key), value)
}

fn mirror_path(key: str) -> str {
    fs.mkdir(mirror_dir())
    return str.concat3(mirror_dir(), "/", key)
}

pub fn boot() -> i32 {
    fs.mkdir(db_dir())
    fs.mkdir(error_dir())
    fs.mkdir(mirror_dir())
    return run_helper_status(helper_argv2("boot", db_path()), "boot", db_path(), 5000)
}

pub fn kv_get(key: str) -> str {
    if key == "" {
        return ""
    }
    if is_longrange_key(key) == 1 {
        let mut attempt: i32 = 0
        while attempt < 4 {
            let scratch = get_scratch_path(key)
            let rc = run_getfile_shell(key, scratch)
            if rc != 0 {
                return ""
            }
            let trimmed = str.trim(fs.read_file(scratch))
            if trimmed != "" || key_retries_on_empty(key) == 0 {
                return trimmed
            }
            attempt = attempt + 1
            discard time.sleep_ms(20 * attempt)
        }
        return ""
    }
    let mirror = mirror_path(key)
    if fs.exists(mirror) == 1 {
        let cached = str.trim(fs.read_file(mirror))
        if cached != "" || key_retries_on_empty(key) == 0 {
            return cached
        }
    }
    let mut attempt: i32 = 0
    while attempt < 4 {
        let scratch = get_scratch_path(key)
        let rc = run_getfile_shell(key, scratch)
        if rc != 0 {
            return ""
        }
        let trimmed = str.trim(fs.read_file(scratch))
        discard fs.atomic_write(mirror, trimmed)
        if trimmed != "" || key_retries_on_empty(key) == 0 {
            return trimmed
        }
        attempt = attempt + 1
        discard time.sleep_ms(20 * attempt)
    }
    return ""
}

pub fn kv_put(key: str, value: str) -> i32 {
    if key == "" {
        return 1
    }
    let rc = run_put_shell(key, value)
    if rc == 0 && is_longrange_key(key) == 0 {
        discard fs.atomic_write(mirror_path(key), value)
    }
    return rc
}

pub fn kv_delete(key: str) -> i32 {
    if key == "" {
        return 0
    }
    let rc = run_delete_shell(key)
    if rc == 0 && is_longrange_key(key) == 0 {
        discard fs.remove_file(mirror_path(key))
    }
    return rc
}

pub fn longrange_update_turn(
    state_key: str,
    progress_key: str,
    run_id: str,
    session_id: str,
    goal: str,
    run_status: str,
    plan_status: str,
    task_class: str,
    turns_completed: str,
    failure_count: str,
    last_progress_score: str,
    consecutive_low_score: str,
    last_evidence_count: str,
    completed_step_count: str,
    auto_continue_pending: str,
    active_message_kind: str,
    latest_summary: str,
    created_at: str,
    updated_at: str,
    current_step_id: str,
    last_request_id: str,
    completed_at: str,
    progress_phase: str,
    progress_message_kind: str,
    progress_recorded_at: str,
    progress_score: str,
    progress_evidence_count: str,
    progress_request_id: str,
    progress_detail: str,
) -> i32 {
    let rc = run_longrange_update_turn_shell(
        state_key,
        progress_key,
        run_id,
        session_id,
        goal,
        run_status,
        plan_status,
        task_class,
        turns_completed,
        failure_count,
        last_progress_score,
        consecutive_low_score,
        last_evidence_count,
        completed_step_count,
        auto_continue_pending,
        active_message_kind,
        latest_summary,
        created_at,
        updated_at,
        current_step_id,
        last_request_id,
        completed_at,
        progress_phase,
        progress_message_kind,
        progress_recorded_at,
        progress_score,
        progress_evidence_count,
        progress_request_id,
        progress_detail,
    )
    return rc
}

