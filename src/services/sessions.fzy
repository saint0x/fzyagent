fn boot() -> i32 {
    persistence.load_session()
    return 0
}

fn default_session_id() -> str {
    return persistence.default_session_id()
}

fn boot_session(session_id: str) -> i32 {
    persistence.load_session_for(session_id)
    return 0
}

fn create_session() -> i32 {
    return create_session_for(default_session_id(), "")
}

fn create_session_for(session_id: str, request_id: str) -> i32 {
    let id = persistence.normalize_session_id(session_id)
    boot_session(id)
    let payload = persistence.session_doc_for(id, "active", "0", "latest", "", "", request_id, "0")
    persistence.save_session_for(id, payload)
    persistence.save_session_event_current(id, "create_session", "active")
    return 0
}

fn reset_session_for(session_id: str, request_id: str) -> i32 {
    let id = persistence.normalize_session_id(session_id)
    discard persistence.clear_session_files(id)
    let payload = persistence.session_doc_for(id, "active", "0", "latest", "", "", request_id, "0")
    persistence.save_session_for(id, payload)
    persistence.save_session_event_current(id, "reset_session", "active")
    return 0
}

fn get_session() -> i32 {
    return get_session_for(default_session_id())
}

fn get_session_for(session_id: str) -> i32 {
    persistence.load_session_for(session_id)
    return 0
}

fn get_session_json() -> str {
    return get_session_json_for(default_session_id())
}

fn get_session_json_for(session_id: str) -> str {
    return persistence.load_session_json_for(session_id)
}

fn post_message() -> i32 {
    return post_message_for(default_session_id(), "", "", "")
}

fn post_message_for(session_id: str, prompt: str, request_id: str, run_id: str) -> i32 {
    let id = persistence.normalize_session_id(session_id)
    boot_session(id)
    discard persistence.append_message(id, "user", "prompt", prompt, run_id, request_id)
    discard persistence.mark_session_turn(id)
    let current = persistence.load_session_json_for(id)
    let parsed = json.parse(current)
    discard persistence.sync_session_summary(
        id,
        "active",
        run_id,
        prompt,
        persistence.session_last_assistant_message_value(parsed),
        request_id,
    )
    persistence.save_session_event_current(id, "post_message", "active")
    telemetry.emit_turn_latency()
    return 0
}

fn record_assistant_for(session_id: str, content: str, request_id: str, run_id: str, tool_count: str) -> i32 {
    let id = persistence.normalize_session_id(session_id)
    boot_session(id)
    discard persistence.append_message(id, "assistant", "response", content, run_id, request_id)
    let current = persistence.load_session_json_for(id)
    let parsed = json.parse(current)
    discard persistence.sync_session_summary(
        id,
        "active",
        run_id,
        persistence.session_last_user_message_value(parsed),
        content,
        request_id,
    )
    discard tool_count
    persistence.save_session_event_current(id, "assistant_response", "active")
    return 0
}

fn record_tool_run_for(session_id: str, tool_id: str, run_id: str, status: str) -> i32 {
    let id = persistence.normalize_session_id(session_id)
    boot_session(id)
    discard persistence.append_run_link(id, run_id, tool_id, status)
    let current = persistence.load_session_json_for(id)
    let parsed = json.parse(current)
    discard persistence.sync_session_summary(
        id,
        "active",
        run_id,
        persistence.session_last_user_message_value(parsed),
        persistence.session_last_assistant_message_value(parsed),
        persistence.session_last_request_id_value(parsed),
    )
    persistence.save_session_event_current(id, "tool_run", "active")
    return 0
}

fn transcript_excerpt(session_id: str) -> str {
    return persistence.transcript_excerpt(session_id)
}
