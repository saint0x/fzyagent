fn run_aegis_worker() -> i32 {
    return run_aegis()
}

fn run_parallel() -> i32 {
    log.info("tools.run_parallel start", util.log_fields2("component", "tools", "phase", "run_parallel_start"))
    runtime.events.emit_tool_started()
    ensure_dirs()
    enqueue_tool()
    enqueue_tool()

    let bash_task = spawn(run_parallel_bash_worker)
    let grep_task = spawn(run_parallel_grep_worker)
    let bash_status = join(bash_task)
    let grep_status = join(grep_task)

    dequeue_tool()
    dequeue_tool()

    let bash_result = safe_read(last_run_path_for("parallel_bash"))
    let grep_result = safe_read(last_run_path_for("parallel_grep"))
    let combined = util.json_obj2("parallel_bash", json.raw(bash_result), "parallel_grep", json.raw(grep_result))
    fs.write_file(last_parallel_path(), combined)
    runtime.events.emit_tool_finished()
    log.info("tools.run_parallel complete", util.log_fields2("component", "tools", "phase", "run_parallel_complete"))
    if bash_status == 0 && grep_status == 0 {
        return 0
    }
    return 13
}

fn run_release_audit() -> i32 {
    log.info("tools.run_release_audit start", util.log_fields2("component", "tools", "phase", "run_release_audit_start"))
    runtime.events.emit_tool_started()
    ensure_dirs()

    let bash_task = spawn(run_parallel_bash_worker)
    let grep_task = spawn(run_parallel_grep_worker)
    let inventory_task = spawn(run_release_inventory_worker)

    let bash_status = join(bash_task)
    let grep_status = join(grep_task)
    let inventory_status = join(inventory_task)

    let bash_result = safe_read(last_run_path_for("parallel_bash"))
    let grep_result = safe_read(last_run_path_for("parallel_grep"))
    let inventory_result = safe_read(inventory_path())
    let meta = util.json_obj3(
        "parallel_bash", json.str(status_from_exit_code(bash_status)),
        "parallel_grep", json.str(status_from_exit_code(grep_status)),
        "inventory", json.str(status_from_exit_code(inventory_status)),
    )
    let combined = util.json_obj4(
        "parallel_bash", json.raw(bash_result),
        "parallel_grep", json.raw(grep_result),
        "inventory", json.raw(inventory_result),
        "meta", json.raw(meta),
    )
    fs.write_file(last_run_path_for("release_audit"), combined)
    runtime.events.emit_tool_finished()
    log.info("tools.run_release_audit complete", util.log_fields2("component", "tools", "phase", "run_release_audit_complete"))
    if bash_status == 0 && grep_status == 0 && inventory_status == 0 {
        return 0
    }
    return 13
}

fn run_project_seed() -> i32 {
    log.info("tools.run_project_seed start", util.log_fields2("component", "tools", "phase", "run_project_seed_start"))
    runtime.events.emit_tool_started()
    ensure_dirs()

    let audit_task = spawn(run_release_audit)
    let digest_task = spawn(run_workspace_digest_worker)

    let audit_status = join(audit_task)
    let digest_status = join(digest_task)

    let audit_result = safe_read(last_run_path_for("release_audit"))
    let digest_result = safe_read(workspace_digest_path())
    let meta = util.json_obj2(
        "release_audit", json.str(status_from_exit_code(audit_status)),
        "workspace_digest", json.str(status_from_exit_code(digest_status)),
    )
    let combined = util.json_obj3(
        "release_audit", json.raw(audit_result),
        "workspace_digest", json.raw(digest_result),
        "meta", json.raw(meta),
    )
    fs.write_file("/tmp/fzyagent/runs/project_seed.json", combined)
    runtime.events.emit_tool_finished()
    log.info("tools.run_project_seed complete", util.log_fields2("component", "tools", "phase", "run_project_seed_complete"))
    if audit_status == 0 && digest_status == 0 {
        return 0
    }
    return 13
}

fn run_browser_ops_seed() -> i32 {
    log.info("tools.run_browser_ops_seed start", util.log_fields2("component", "tools", "phase", "run_browser_ops_seed_start"))
    runtime.events.emit_tool_started()
    ensure_dirs()

    let digest_task = spawn(run_workspace_digest_worker)
    let browser_task = spawn(run_aegis_worker)

    let digest_status = join(digest_task)
    let browser_status = join(browser_task)

    let digest_result = safe_read(workspace_digest_path())
    let browser_result = safe_read(aegis_path())
    let meta = util.json_obj2(
        "workspace_digest", json.str(status_from_exit_code(digest_status)),
        "aegis", json.str(status_from_exit_code(browser_status)),
    )
    let combined = util.json_obj3(
        "workspace_digest", json.raw(digest_result),
        "aegis", json.raw(browser_result),
        "meta", json.raw(meta),
    )
    fs.write_file("/tmp/fzyagent/runs/browser_ops_seed.json", combined)
    runtime.events.emit_tool_finished()
    log.info("tools.run_browser_ops_seed complete", util.log_fields2("component", "tools", "phase", "run_browser_ops_seed_complete"))
    if digest_status == 0 && browser_status == 0 {
        return 0
    }
    return 13
}

fn run_named(tool_id: str) -> i32 {
    if tool_id == "parallel_bash" {
        return run_parallel_bash()
    }
    if tool_id == "parallel_grep" {
        return run_parallel_grep()
    }
    if tool_id == "bash" {
        return run_bash_with_command("")
    }
    if tool_id == "grep_search" {
        return run_grep_search("", "")
    }
    if tool_id == "timeout_probe" {
        return run_with_timeout()
    }
    if tool_id == "release_audit" {
        return run_release_audit()
    }
    if tool_id == "workspace_digest" {
        return run_workspace_digest()
    }
    if tool_id == "aegis" || tool_id == "aegis_headless" {
        return run_aegis()
    }
    if tool_id == "project_seed" {
        return run_project_seed()
    }
    if tool_id == "browser_ops_seed" {
        return run_browser_ops_seed()
    }
    if tool_id == "toolsmith" {
        return run_toolsmith("protocol", "", "", "", "", "", "")
    }
    if tool_id == "promptsmith" {
        return run_promptsmith("get", "")
    }
    if tool_id == "fzydoc" {
        return run_fzydoc("spawn", "6")
    }
    if tool_id == "desktop_grep" {
        return run_parallel_grep()
    }
    if tool_id == "all" {
        return run_parallel()
    }
    if fs.exists(custom_tool_manifest_path(tool_id)) != 0 {
        return run_custom_tool(tool_id, "{}")
    }
    return 13
}

fn run_named_browser(tool_id: str, action: str, url: str, query: str, eval_js: str, commands_json: str, command: str, pattern: str, target: str, tool_input_json: str, description: str, command_template: str, input_schema_json: str, kind: str, mode: str, max_lines: str, requested_tool_id: str, content: str) -> i32 {
    if tool_id == "aegis" || tool_id == "aegis_headless" {
        return run_aegis_with_args(action, url, query, eval_js, commands_json)
    }
    if tool_id == "bash" {
        return run_bash_with_command(command)
    }
    if tool_id == "grep_search" {
        return run_grep_search(pattern, target)
    }
    if tool_id == "toolsmith" {
        let create_action = if action == "" { "protocol" } else { action }
        return run_toolsmith(create_action, requested_tool_id, description, command_template, input_schema_json, kind, mode)
    }
    if tool_id == "promptsmith" {
        let prompt_action = if action == "" { "get" } else { action }
        return run_promptsmith(prompt_action, content)
    }
    if tool_id == "fzydoc" {
        let doc_query = if query == "" { "spawn" } else { query }
        return run_fzydoc(doc_query, max_lines)
    }
    if tool_id == "all" {
        return run_parallel()
    }
    return run_custom_tool(tool_id, tool_input_json)
}

fn last_run_json(tool_id: str) -> str {
    if tool_id == "all" {
        return safe_read(last_parallel_path())
    }
    return safe_read(last_run_path_for(tool_id))
}

fn last_run_artifact_path(tool_id: str) -> str {
    if tool_id == "all" {
        return last_parallel_path()
    }
    return last_run_path_for(tool_id)
}

fn pipe_stdout_events() -> i32 {
    runtime.events.emit_stdout_chunk()
    return 0
}

fn pipe_stderr_events() -> i32 {
    runtime.events.emit_stderr_chunk()
    return 0
}

fn pipe_structured_events() -> i32 {
    runtime.events.emit_structured_event()
    return 0
}

fn run_with_timeout() -> i32 {
    let cmd = env_or("TOOL_TIMEOUT_CMD", "sleep 1 && echo timeout-window")
    return run_shell_to_file("timeout_probe", cmd, 700, last_run_path_for("timeout_probe"))
}

fn cancel_tool_run() -> i32 {
    return proc.exit_class()
}

fn retry_with_backoff() -> i32 {
    run_with_timeout()
    checkpoint()
    run_with_timeout()
    checkpoint()
    run_with_timeout()
    return 0
}

fn classify_failure() -> i32 {
    let _spawn_failure = runtime.failures.classify_spawn_failure()
    let _timeout = runtime.failures.classify_timeout()
    let _nonzero = runtime.failures.classify_nonzero_exit()
    let _malformed = runtime.failures.classify_malformed_output()
    classify_failure_kind(13)
    return 0
}

fn classify_failure_kind(code: i32) -> ToolFailureClass {
    if code == 11 {
        return ToolFailureClass::ToolSpawnFailure
    }
    if code == 12 {
        return ToolFailureClass::ToolTimeout
    }
    if code == 14 {
        return ToolFailureClass::ToolMalformedOutput
    }
    return ToolFailureClass::ToolNonzeroExit
}

fn failure_class_label(code: i32) -> str {
    let kind = classify_failure_kind(code)
    if kind == ToolFailureClass::ToolSpawnFailure {
        return "spawn_failure"
    }
    if kind == ToolFailureClass::ToolTimeout {
        return "timeout"
    }
    if kind == ToolFailureClass::ToolNonzeroExit {
        return "nonzero_exit"
    }
    return "malformed_output"
}
