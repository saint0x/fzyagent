fn toolsmith_request_path_for(action: str, tool_id: str) -> str {
    if tool_id == "" {
        return str.concat3("/tmp/fzyagent/tools/toolsmith.", action, ".request.json")
    }
    return str.concat2(str.concat4("/tmp/fzyagent/tools/toolsmith.", action, ".", tool_id), ".request.json")
}

fn toolsmith_response_path_for(action: str, tool_id: str) -> str {
    if tool_id == "" {
        return str.concat3("/tmp/fzyagent/tools/toolsmith.", action, ".response.json")
    }
    return str.concat2(str.concat4("/tmp/fzyagent/tools/toolsmith.", action, ".", tool_id), ".response.json")
}

fn promptsmith_request_path_for(action: str) -> str {
    return str.concat3("/tmp/fzyagent/tools/promptsmith.", action, ".request.json")
}

fn promptsmith_response_path_for(action: str) -> str {
    return str.concat3("/tmp/fzyagent/tools/promptsmith.", action, ".response.json")
}

fn fzydoc_path() -> str {
    return "/tmp/fzyagent/tools/fzydoc.json"
}

fn custom_tool_manifest_path(tool_id: str) -> str {
    return str.concat3("/Users/deepsaint/Desktop/fzyagent/custom_tools/", tool_id, "/tool.json")
}

fn custom_tool_last_run_path(tool_id: str) -> str {
    return str.concat3("/tmp/fzyagent/runs/custom_", tool_id, ".json")
}

fn custom_tool_state_path(tool_id: str) -> str {
    return str.concat3("/tmp/fzyagent/custom_tools/", tool_id, "/last.json")
}

fn custom_tool_request_path(tool_id: str) -> str {
    return str.concat3("/tmp/fzyagent/custom_tools/", tool_id, "/request.json")
}

fn custom_tool_state_dir(tool_id: str) -> str {
    return str.concat2("/tmp/fzyagent/custom_tools/", tool_id)
}

fn last_run_path_for(tool_id: str) -> str {
    if tool_id == "parallel_bash" {
        return "/tmp/fzyagent/runs/parallel_bash.json"
    }
    if tool_id == "parallel_grep" {
        return "/tmp/fzyagent/runs/parallel_grep.json"
    }
    if tool_id == "release_audit" {
        return "/tmp/fzyagent/runs/release_audit.json"
    }
    if tool_id == "workspace_digest" {
        return workspace_digest_path()
    }
    if tool_id == "aegis" || tool_id == "aegis_headless" {
        return aegis_path()
    }
    if tool_id == "bash" {
        return "/tmp/fzyagent/runs/bash.json"
    }
    if tool_id == "grep_search" {
        return "/tmp/fzyagent/runs/grep_search.json"
    }
    if tool_id == "timeout_probe" {
        return "/tmp/fzyagent/runs/timeout_probe.json"
    }
    if tool_id == "toolsmith" {
        return toolsmith_path()
    }
    if tool_id == "promptsmith" {
        return promptsmith_path()
    }
    if tool_id == "fzydoc" {
        return fzydoc_path()
    }
    if fs.exists(custom_tool_manifest_path(tool_id)) != 0 {
        return custom_tool_last_run_path(tool_id)
    }
    return "/tmp/fzyagent/runs/generic.json"
}

fn ensure_dirs() -> i32 {
    fs.mkdir(state_dir())
    fs.mkdir(tools_dir())
    fs.mkdir(runs_dir())
    return 0
}

fn env_or(key: str, fallback: str) -> str {
    let value = env.get(key)
    if value == "" {
        return fallback
    }
    return value
}

fn safe_read(path: str) -> str {
    if fs.exists(path) == 0 {
        return "{}"
    }
    let value = fs.read_file(path)
    if value == "" {
        return "{}"
    }
    return value
}

fn status_from_exit_code(code: i32) -> str {
    if code == 0 {
        return "ok"
    }
    if code == 1 {
        return "empty"
    }
    if code == -124 {
        return "timeout"
    }
    if code == -2 {
        return "running"
    }
    return "failed"
}

fn default_proc_env() -> ProcessEnv {
    let env_map: ProcessEnv = proc.env_new()
    discard proc.env_set(env_map, "TERM", "dumb")
    return env_map
}

fn shell_argv(command: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-lc")
    discard proc.argv_push(argv, command)
    return argv
}

fn grep_argv(pattern: str, target: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-R")
    discard proc.argv_push(argv, "--line-number")
    discard proc.argv_push(argv, pattern)
    discard proc.argv_push(argv, target)
    return argv
}

fn shell_result_code(exit_code: i32) -> i32 {
    if exit_code == 0 {
        return 0
    }
    if exit_code == -124 {
        return 12
    }
    return 13
}

fn grep_result_code(exit_code: i32) -> i32 {
    if exit_code == 0 {
        return 0
    }
    if exit_code == 1 {
        return 0
    }
    if exit_code == -124 {
        return 12
    }
    return 13
}

fn run_shell_to_file(tool_id: str, command: str, timeout_ms: i32, out_path: str) -> i32 {
    let env_map = default_proc_env()
    let argv = shell_argv(command)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    checkpoint()
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
    let meta = util.json_obj2("timeout_ms", json.str("managed"), "budget", json.str("bounded"))
    let payload = util.json_obj5("tool", json.str(tool_id), "status", json.str(status), "command", json.str(command), "streams", json.raw(streams), "meta", json.raw(meta))
    fs.write_file(out_path, payload)
    fs.write_file(last_run_path_for(tool_id), payload)
    return shell_result_code(exit_code)
}

fn run_grep_to_file(tool_id: str, pattern: str, target: str, timeout_ms: i32, out_path: str) -> i32 {
    let env_map = default_proc_env()
    let argv = grep_argv(pattern, target)
    let handle = proc.spawn_cmd("grep", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    checkpoint()
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
    let meta = util.json_obj2("pattern", json.str(pattern), "target", json.str(target))
    let payload = util.json_obj4("tool", json.str(tool_id), "status", json.str(status), "meta", json.raw(meta), "streams", json.raw(streams))
    fs.write_file(out_path, payload)
    fs.write_file(last_run_path_for(tool_id), payload)
    return grep_result_code(exit_code)
}

fn run_parallel_bash_slot_a() -> i32 {
    let cmd = env_or("TOOL_BASH_A", "echo parallel-bash-A")
    return run_shell_to_file("parallel_bash_a", cmd, 4000, bash_a_path())
}

fn run_parallel_bash_slot_b() -> i32 {
    let cmd = env_or("TOOL_BASH_B", "echo parallel-bash-B")
    return run_shell_to_file("parallel_bash_b", cmd, 4000, bash_b_path())
}

fn run_parallel_grep_slot_a() -> i32 {
    let pattern = env_or("TOOL_GREP_PATTERN_A", "fn ")
    let target = env_or("TOOL_GREP_TARGET_A", "src")
    return run_grep_to_file("parallel_grep_a", pattern, target, 5000, grep_a_path())
}

fn run_parallel_grep_slot_b() -> i32 {
    let pattern = env_or("TOOL_GREP_PATTERN_B", "use ")
    let target = env_or("TOOL_GREP_TARGET_B", "src")
    return run_grep_to_file("parallel_grep_b", pattern, target, 5000, grep_b_path())
}

fn run_grep_search(pattern: str, target: str) -> i32 {
    let grep_pattern = if pattern == "" { env_or("TOOL_GREP_PATTERN_A", "fn ") } else { pattern }
    let grep_target = if target == "" { env_or("TOOL_GREP_TARGET_A", "src") } else { target }
    return run_grep_to_file("grep_search", grep_pattern, grep_target, 15000, last_run_path_for("grep_search"))
}

fn run_release_inventory() -> i32 {
    let cmd = env_or("TOOL_RELEASE_INVENTORY", "printf 'files=%s\\nfunctions=%s\\nuses=%s\\nservices=%s\\n' \"$(rg --files src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src | wc -l | tr -d ' ')\" \"$(rg -n '^use ' src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/services | wc -l | tr -d ' ')\"")
    return run_shell_to_file("release_inventory", cmd, 8000, inventory_path())
}

fn run_workspace_digest() -> i32 {
    let cmd = env_or(
        "TOOL_WORKSPACE_DIGEST",
        "printf 'root=%s\\nfiles=%s\\nfunctions=%s\\nservices=%s\\nruntime=%s\\n\\n==files==\\n%s\\n\\n==top_http==\\n%s\\n\\n==top_tools==\\n%s\\n' \"$PWD\" \"$(rg --files src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/services | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/runtime | wc -l | tr -d ' ')\" \"$(rg --files src | sort | head -n 40)\" \"$(sed -n '1,220p' src/services/http.fzy)\" \"$(sed -n '1,260p' src/services/tools.fzy)\"",
    )
    return run_shell_to_file("workspace_digest", cmd, 12000, workspace_digest_path())
}

fn run_aegis() -> i32 {
    return run_aegis_with_args("", "", "", "", "")
}

fn run_bash_with_command(command: str) -> i32 {
    let cmd = if command == "" { env_or("TOOL_BASH", "echo bash-tool-default") } else { command }
    return run_shell_to_file("bash", cmd, 20000, last_run_path_for("bash"))
}

fn run_aegis_with_args(action: str, url: str, query: str, eval_js: str, commands_json: str) -> i32 {
    let cmd = env_or(
        "TOOL_AEGIS",
        "python3 /Users/deepsaint/Desktop/fzyagent/scripts/aegis_headless_tool.py",
    )
    let env_map = default_proc_env()
    if action != "" {
        discard proc.env_set(env_map, "AEGIS_ACTION", action)
    }
    if url != "" {
        discard proc.env_set(env_map, "AEGIS_URL", url)
    }
    if query != "" {
        discard proc.env_set(env_map, "AEGIS_QUERY", query)
    }
    if eval_js != "" {
        discard proc.env_set(env_map, "AEGIS_EVAL_JS", eval_js)
    }
    if commands_json != "" {
        discard proc.env_set(env_map, "AEGIS_COMMANDS_JSON", commands_json)
    }
    let argv = shell_argv(cmd)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, 120000)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    if exit_code != 0 {
        let meta = util.json_obj2("timeout_ms", json.str("managed"), "budget", json.str("browser"))
        let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
        let payload = util.json_obj4("tool", json.str("aegis"), "status", json.str(status), "streams", json.raw(streams), "meta", json.raw(meta))
        fs.write_file(aegis_path(), payload)
    }
    return shell_result_code(exit_code)
}

fn run_toolsmith(action: str, tool_id: str, description: str, command_template: str, input_schema_json: str, kind: str, mode: str) -> i32 {
    let env_map = default_proc_env()
    let request_path = toolsmith_request_path_for(action, tool_id)
    let response_path = toolsmith_response_path_for(action, tool_id)
    let meta = util.json_obj5(
        "tool_id", json.str(tool_id),
        "description", json.str(description),
        "kind", json.str(kind),
        "mode", json.str(mode),
        "command_template", json.str(command_template),
    )
    let schema = if input_schema_json == "" { "{}" } else { input_schema_json }
    let request = util.json_obj3("action", json.str(action), "meta", json.raw(meta), "input_schema", json.raw(schema))
    fs.write_file(request_path, request)
    let cmd = str.concat4("python3 /Users/deepsaint/Desktop/fzyagent/scripts/toolsmith_tool.py ", request_path, " ", response_path)
    let argv = shell_argv(cmd)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, 120000)
    let exit_code = proc.exit_code(handle)
    let payload = safe_read(response_path)
    if payload != "{}" {
        fs.write_file(toolsmith_path(), payload)
        fs.write_file(last_run_path_for("toolsmith"), payload)
    }
    return shell_result_code(exit_code)
}

