fn ensure_dirs() -> i32 {
    fs.mkdir(state_dir())
    fs.mkdir(tools_dir())
    fs.mkdir(runs_dir())
    fs.mkdir(queue_dir())
    return 0
}

fn env_or(key: str, fallback: str) -> str {
    let value = env.get(key)
    if value == "" {
        return fallback
    }
    return value
}

fn safe_read(path: str) -> str {
    if fs.exists(path) == 0 {
        return "{}"
    }
    let value = fs.read_file(path)
    if value == "" {
        return "{}"
    }
    return value
}

fn status_from_exit_code(code: i32) -> str {
    if code == 0 {
        return "ok"
    }
    if code == 1 {
        return "empty"
    }
    if code == -124 {
        return "timeout"
    }
    if code == -2 {
        return "running"
    }
    return "failed"
}

fn default_proc_env() -> ProcessEnv {
    let env_map: ProcessEnv = proc.env_new()
    discard proc.env_set(env_map, "TERM", "dumb")
    return env_map
}

fn default_input_schema() -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw("{}"))
    return json.object(schema)
}

fn shell_argv(command: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-lc")
    discard proc.argv_push(argv, command)
    return argv
}

fn grep_argv(pattern: str, target: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-R")
    discard proc.argv_push(argv, "--line-number")
    discard proc.argv_push(argv, pattern)
    discard proc.argv_push(argv, target)
    return argv
}

fn shell_result_code(exit_code: i32) -> i32 {
    if exit_code == 0 {
        return 0
    }
    if exit_code == -124 {
        return 12
    }
    return 13
}

fn grep_result_code(exit_code: i32) -> i32 {
    if exit_code == 0 {
        return 0
    }
    if exit_code == 1 {
        return 0
    }
    if exit_code == -124 {
        return 12
    }
    return 13
}

fn run_shell_to_file(tool_id: str, command: str, timeout_ms: i32, out_path: str) -> i32 {
    let env_map = default_proc_env()
    let argv = shell_argv(command)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    checkpoint()
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
    let meta = util.json_obj2("timeout_ms", json.str("managed"), "budget", json.str("bounded"))
    let payload = util.json_obj5("tool", json.str(tool_id), "status", json.str(status), "command", json.str(command), "streams", json.raw(streams), "meta", json.raw(meta))
    fs.write_file(out_path, payload)
    fs.write_file(last_run_path_for(tool_id), payload)
    return shell_result_code(exit_code)
}

fn run_grep_to_file(tool_id: str, pattern: str, target: str, timeout_ms: i32, out_path: str) -> i32 {
    let env_map = default_proc_env()
    let argv = grep_argv(pattern, target)
    let handle = proc.spawn_cmd("grep", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    checkpoint()
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
    let meta = util.json_obj2("pattern", json.str(pattern), "target", json.str(target))
    let payload = util.json_obj4("tool", json.str(tool_id), "status", json.str(status), "meta", json.raw(meta), "streams", json.raw(streams))
    fs.write_file(out_path, payload)
    fs.write_file(last_run_path_for(tool_id), payload)
    return grep_result_code(exit_code)
}

fn run_parallel_bash_slot_a() -> i32 {
    let cmd = env_or("TOOL_BASH_A", "echo parallel-bash-A")
    return run_shell_to_file("parallel_bash_a", cmd, 4000, bash_a_path())
}

fn run_parallel_bash_slot_b() -> i32 {
    let cmd = env_or("TOOL_BASH_B", "echo parallel-bash-B")
    return run_shell_to_file("parallel_bash_b", cmd, 4000, bash_b_path())
}

fn run_parallel_grep_slot_a() -> i32 {
    let pattern = env_or("TOOL_GREP_PATTERN_A", "fn ")
    let target = env_or("TOOL_GREP_TARGET_A", "src")
    return run_grep_to_file("parallel_grep_a", pattern, target, 5000, grep_a_path())
}

fn run_parallel_grep_slot_b() -> i32 {
    let pattern = env_or("TOOL_GREP_PATTERN_B", "use ")
    let target = env_or("TOOL_GREP_TARGET_B", "src")
    return run_grep_to_file("parallel_grep_b", pattern, target, 5000, grep_b_path())
}

fn run_grep_search(pattern: str, target: str) -> i32 {
    let grep_pattern = if pattern == "" { env_or("TOOL_GREP_PATTERN_A", "fn ") } else { pattern }
    let grep_target = if target == "" { env_or("TOOL_GREP_TARGET_A", "src") } else { target }
    return run_grep_to_file("grep_search", grep_pattern, grep_target, 15000, last_run_path_for("grep_search"))
}

fn run_release_inventory() -> i32 {
    let cmd = env_or("TOOL_RELEASE_INVENTORY", "printf 'files=%s\\nfunctions=%s\\nuses=%s\\nservices=%s\\n' \"$(rg --files src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src | wc -l | tr -d ' ')\" \"$(rg -n '^use ' src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/services | wc -l | tr -d ' ')\"")
    return run_shell_to_file("release_inventory", cmd, 8000, inventory_path())
}

fn run_workspace_digest() -> i32 {
    return run_workspace_digest_to(workspace_digest_path())
}

fn run_workspace_digest_to(out_path: str) -> i32 {
    let cmd = env_or(
        "TOOL_WORKSPACE_DIGEST",
        "printf 'root=%s\\nfiles=%s\\nfunctions=%s\\nservices=%s\\nruntime=%s\\n\\n==files==\\n%s\\n\\n==top_http==\\n%s\\n\\n==top_tools==\\n%s\\n' \"$PWD\" \"$(rg --files src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/services | wc -l | tr -d ' ')\" \"$(rg -n '^fn ' src/runtime | wc -l | tr -d ' ')\" \"$(rg --files src | sort | head -n 40)\" \"$(sed -n '1,220p' src/services/http.fzy)\" \"$(sed -n '1,260p' src/services/tools.fzy)\"",
    )
    return run_shell_to_file("workspace_digest", cmd, 12000, out_path)
}

fn run_aegis() -> i32 {
    return run_aegis_with_args("", "", "", "", "")
}

fn run_aegis_with_args_to(action: str, url: str, query: str, eval_js: str, commands_json: str, out_path: str) -> i32 {
    ensure_dirs()
    if ensure_aegis_server() != 0 {
        let failure = util.json_obj4(
            "tool", json.str("aegis"),
            "status", json.str("failed"),
            "server", json.str(aegis_addr()),
            "message", json.str("aegis server did not become ready"),
        )
        fs.write_file(out_path, failure)
        fs.write_file(aegis_path(), failure)
        return 13
    }
    let effective_action = if action == "" { "runtime" } else { action }
    let env_map = default_proc_env()
    let base = aegis_base_url()
    let mut command = str.concat("curl -sS ", str.concat(base, "/runtime"))
    if effective_action == "manifest" {
        command = str.concat("curl -sS ", str.concat(base, "/manifest"))
    } else if effective_action == "doctor" {
        command = str.concat("curl -sS ", str.concat(base, "/doctor"))
    } else if effective_action == "dom" {
        command = str.concat("curl -sS ", str.concat(base, "/dom"))
    } else if effective_action == "session" {
        command = str.concat("curl -sS ", str.concat(base, "/session"))
    } else if effective_action == "events" {
        command = str.concat("curl -sS ", str.concat(base, "/events?since=0"))
    } else if effective_action == "navigate" {
        let body = util.json_obj1("url", json.str(url))
        discard proc.env_set(env_map, "AEGIS_BODY", body)
        command = str.concat("curl -sS -H 'content-type: application/json' -X POST --data \"$AEGIS_BODY\" ", str.concat(base, "/navigate"))
    } else if effective_action == "execute" {
        let body = util.json_obj1("commands", json.raw(if commands_json == "" { "[]" } else { commands_json }))
        discard proc.env_set(env_map, "AEGIS_BODY", body)
        command = str.concat("curl -sS -H 'content-type: application/json' -X POST --data \"$AEGIS_BODY\" ", str.concat(base, "/execute"))
    } else if effective_action == "eval" {
        let commands = list.new()
        discard list.push(commands, json.raw(util.json_obj2("type", json.str("eval"), "code", json.str(eval_js))))
        let body = util.json_obj1("commands", json.raw(json.array(commands)))
        discard proc.env_set(env_map, "AEGIS_BODY", body)
        command = str.concat("curl -sS -H 'content-type: application/json' -X POST --data \"$AEGIS_BODY\" ", str.concat(base, "/execute"))
    } else if effective_action == "search_eval" {
        let encoded = text.replace(query, " ", "+")
        let target_url = str.concat("https://duckduckgo.com/?q=", encoded)
        let commands = list.new()
        discard list.push(commands, json.raw(util.json_obj2("type", json.str("eval"), "code", json.str(str.concat("window.location.href = ", str.concat(json.str(target_url), ";"))))))
        let body = util.json_obj1("commands", json.raw(json.array(commands)))
        discard proc.env_set(env_map, "AEGIS_BODY", body)
        command = str.concat("curl -sS -H 'content-type: application/json' -X POST --data \"$AEGIS_BODY\" ", str.concat(base, "/execute"))
    }
    let payload = shell_payload_with_env(command, env_map, 180000)
    let parsed = json.parse(payload)
    let status = json.get_str(parsed, "status")
    let stdout = json.get_str(json.get(json.get(parsed, "streams"), "stdout"), "raw")
    let wrapped = util.json_obj5(
        "tool", json.str("aegis"),
        "status", json.str(status),
        "action", json.str(effective_action),
        "server", json.str(aegis_addr()),
        "response", json.raw(stdout),
    )
    fs.write_file(out_path, wrapped)
    fs.write_file(aegis_path(), wrapped)
    if status == "ok" {
        return 0
    }
    return 13
}

fn run_bash_with_command(command: str) -> i32 {
    let cmd = if command == "" { env_or("TOOL_BASH", "echo bash-tool-default") } else { command }
    return run_shell_to_file("bash", cmd, 20000, last_run_path_for("bash"))
}

fn ensure_aegis_server() -> i32 {
    fs.mkdir(aegis_state_dir())
    let env_map = default_proc_env()
    let ready_cmd = str.concat("curl -s -o /dev/null -w '%{http_code}' ", str.concat(aegis_base_url(), "/readyz"))
    let initial = text.trim(shell_stdout_with_env(ready_cmd, env_map, 5000))
    if initial == "200" || initial == "503" {
        return 0
    }
    let launch_cmd = str.concat(
        str.concat("./aegis.sh --mode headless serve --addr ", aegis_addr()),
        str.concat(" >", str.concat(aegis_log_path(), " 2>&1 & echo $!")),
    )
    let pid = text.trim(shell_stdout_with_env(launch_cmd, env_map, 15000))
    if pid != "" {
        fs.write_file(aegis_pid_path(), pid)
    }
    let mut attempt: i32 = 0
    while attempt < 80 {
        let code = text.trim(shell_stdout_with_env(ready_cmd, env_map, 5000))
        if code == "200" {
            return 0
        }
        time.sleep_ms(250)
        attempt += 1
    }
    return 13
}

fn run_aegis_with_args(action: str, url: str, query: str, eval_js: str, commands_json: str) -> i32 {
    return run_aegis_with_args_to(action, url, query, eval_js, commands_json, aegis_path())
}

fn run_toolsmith(action: str, tool_id: str, description: str, command_template: str, input_schema_json: str, kind: str, mode: str) -> i32 {
    return run_toolsmith_to(action, tool_id, description, command_template, input_schema_json, kind, mode, toolsmith_path())
}

fn run_toolsmith_to(action: str, tool_id: str, description: str, command_template: str, input_schema_json: str, kind: str, mode: str, out_path: str) -> i32 {
    ensure_dirs()
    let effective_action = if action == "" { "protocol" } else { action }
    let request_path = toolsmith_request_path_for(effective_action, tool_id)
    let response_path = toolsmith_response_path_for(effective_action, tool_id)
    let meta = util.json_obj5(
        "tool_id", json.str(tool_id),
        "description", json.str(description),
        "kind", json.str(kind),
        "mode", json.str(mode),
        "command_template", json.str(command_template),
    )
    let schema = if input_schema_json == "" { default_input_schema() } else { input_schema_json }
    let request = util.json_obj3("action", json.str(effective_action), "meta", json.raw(meta), "input_schema", json.raw(schema))
    fs.write_file(request_path, request)
    let mut payload = "{}"
    if effective_action == "protocol" {
        payload = util.json_obj5(
            "tool", json.str("toolsmith"),
            "status", json.str("ok"),
            "action", json.str("protocol"),
            "actions", json.raw(util.json_arr4(json.str("protocol"), json.str("create"), json.str("list"), json.str("inspect"))),
            "requirements", json.raw(util.json_obj3("tool_id", json.str("lowercase snake_case, starts with a letter"), "command_template", json.str("shell command that uses TOOL_ARG_<FIELD> env vars"), "input_schema", json.str("JSON schema object with properties and optional required list"))),
        )
    } else if effective_action == "list" {
        let entries = list.new()
        if fs.exists(custom_tools_root()) == 1 {
            let discovered = fs.listdir(custom_tools_root())
            let mut copy_idx: i32 = 0
            while copy_idx < list.len(discovered) {
                discard list.push(entries, list.get(discovered, copy_idx))
                copy_idx += 1
            }
        }
        let items = list.new()
        let mut idx: i32 = 0
        while idx < list.len(entries) {
            let entry = list.get(entries, idx)
            let manifest_path = path.join(path.join(custom_tools_root(), entry), "tool.json")
            if fs.exists(manifest_path) == 1 {
                let raw = fs.read_file(manifest_path)
                if raw != "" {
                    let manifest = json.parse(raw)
                    let item = util.json_obj5(
                        "id", json.str(json.get_str(manifest, "id")),
                        "description", json.str(json.get_str(manifest, "description")),
                        "kind", json.str(json.get_str(manifest, "kind")),
                        "mode", json.str(json.get_str(manifest, "mode")),
                        "manifest_path", json.str(manifest_path),
                    )
                    discard list.push(items, json.raw(item))
                }
            }
            idx += 1
        }
        payload = util.json_obj4("tool", json.str("toolsmith"), "status", json.str("ok"), "action", json.str("list"), "tools", json.raw(json.array(items)))
    } else if effective_action == "inspect" {
        let manifest_path = custom_tool_manifest_path(tool_id)
        if tool_id == "" || valid_tool_id(tool_id) == 0 || fs.exists(manifest_path) == 0 {
            payload = util.json_obj4("tool", json.str("toolsmith"), "status", json.str("error"), "action", json.str("inspect"), "message", json.str("custom tool not found"))
        } else {
            payload = util.json_obj5(
                "tool", json.str("toolsmith"),
                "status", json.str("ok"),
                "action", json.str("inspect"),
                "manifest", json.raw(fs.read_file(manifest_path)),
                "manifest_path", json.str(manifest_path),
            )
        }
    } else {
        if valid_tool_id(tool_id) == 0 || description == "" || command_template == "" {
            payload = util.json_obj4("tool", json.str("toolsmith"), "status", json.str("error"), "action", json.str("create"), "message", json.str("tool_id, description, and command_template are required"))
        } else {
            let tool_dir = path.join(custom_tools_root(), tool_id)
            fs.mkdir(custom_tools_root())
            fs.mkdir(tool_dir)
            let manifest = map.new()
            discard map.set(manifest, "id", json.str(tool_id))
            discard map.set(manifest, "description", json.str(description))
            discard map.set(manifest, "kind", json.str(if kind == "" { "process" } else { kind }))
            discard map.set(manifest, "mode", json.str(if mode == "" { "single" } else { mode }))
            discard map.set(manifest, "runner", json.str("shell"))
            discard map.set(manifest, "command_template", json.str(command_template))
            discard map.set(manifest, "input_schema", json.raw(schema))
            let manifest_path = path.join(tool_dir, "tool.json")
            let readme_path = path.join(tool_dir, "README.md")
            fs.write_file(manifest_path, json.object(manifest))
            fs.write_file(readme_path, str.concat("# ", str.concat(tool_id, str.concat("\n\n", str.concat(description, str.concat("\n\n## Command Template\n\n```sh\n", str.concat(command_template, str.concat("\n```\n\n## Input Schema\n\n```json\n", str.concat(schema, "\n```\n")))))))))
            discard services.registry.refresh_runtime()
            let registry_entry = json.parse(services.registry.get_tool_json(tool_id))
            let verified = if json.get_str(registry_entry, "id") == tool_id { "true" } else { "false" }
            let created = map.new()
            discard map.set(created, "tool", json.str("toolsmith"))
            discard map.set(created, "status", json.str("ok"))
            discard map.set(created, "action", json.str("create"))
            discard map.set(created, "created_tool", json.str(tool_id))
            discard map.set(created, "manifest_path", json.str(manifest_path))
            discard map.set(created, "readme_path", json.str(readme_path))
            discard map.set(created, "manifest_exists", json.raw("true"))
            discard map.set(created, "readme_exists", json.raw("true"))
            discard map.set(created, "verified_in_registry", json.raw(verified))
            discard map.set(created, "warnings", json.raw(template_lint_warnings(command_template)))
            payload = json.object(created)
        }
    }
    fs.write_file(response_path, payload)
    fs.write_file(out_path, payload)
    fs.write_file(toolsmith_path(), payload)
    fs.write_file(last_run_path_for("toolsmith"), payload)
    return if json.get_str(json.parse(payload), "status") == "ok" { 0 } else { 13 }
}

fn run_fzydoc(query: str, max_lines: str) -> i32 {
    return run_fzydoc_to(query, max_lines, fzydoc_path())
}

fn run_fzydoc_to(query: str, max_lines: str, out_path: str) -> i32 {
    let env_map = default_proc_env()
    let effective_query = if query == "" { "spawn" } else { query }
    let line_budget = if max_lines == "" { "6" } else { max_lines }
    let cmd = str.concat("grep -R -n -C 2 -- ", str.concat(json.str(effective_query), str.concat(" ", docs_root())))
    let stdout = shell_stdout_with_env(cmd, env_map, 60000)
    let payload = util.json_obj5(
        "tool", json.str("fzydoc"),
        "status", json.str("ok"),
        "query", json.str(effective_query),
        "max_lines", json.str(line_budget),
        "hits", json.str(stdout),
    )
    fs.write_file(out_path, payload)
    fs.write_file(fzydoc_path(), payload)
    fs.write_file(last_run_path_for("fzydoc"), payload)
    return 0
}

fn run_promptsmith(action: str, content: str) -> i32 {
    return run_promptsmith_to(action, content, promptsmith_path())
}

fn run_promptsmith_to(action: str, content: str, out_path: str) -> i32 {
    discard ensure_prompt_files()
    let effective_action = if action == "" { "get" } else { action }
    let request_path = promptsmith_request_path_for(effective_action)
    let response_path = promptsmith_response_path_for(effective_action)
    let request = util.json_obj2("action", json.str(effective_action), "content", json.str(content))
    fs.write_file(request_path, request)
    let mut payload = "{}"
    if effective_action == "protocol" {
        payload = util.json_obj5(
            "tool", json.str("promptsmith"),
            "status", json.str("ok"),
            "action", json.str("protocol"),
            "actions", json.raw(util.json_arr4(json.str("protocol"), json.str("get"), json.str("set"), json.str("append"))),
            "requirements", json.raw(util.json_obj1("content", json.str("full prompt text for set, appended text for append"))),
        )
    } else if effective_action == "reset" {
        let default_text = fs.read_file(prompt_default_path())
        fs.write_file(prompt_active_path(), default_text)
        payload = util.json_obj5("tool", json.str("promptsmith"), "status", json.str("ok"), "action", json.str("reset"), "content", json.str(default_text), "meta", json.raw(prompt_meta_json(default_text)))
    } else if effective_action == "set" {
        if text.trim(content) == "" {
            payload = util.json_obj4("tool", json.str("promptsmith"), "status", json.str("error"), "action", json.str("set"), "message", json.str("content is required"))
        } else {
            fs.write_file(prompt_active_path(), content)
            payload = util.json_obj5("tool", json.str("promptsmith"), "status", json.str("ok"), "action", json.str("set"), "content", json.str(content), "meta", json.raw(prompt_meta_json(content)))
        }
    } else if effective_action == "append" {
        if text.trim(content) == "" {
            payload = util.json_obj4("tool", json.str("promptsmith"), "status", json.str("error"), "action", json.str("append"), "message", json.str("content is required"))
        } else {
            let current = fs.read_file(prompt_active_path())
            let updated = str.concat(current, str.concat("\n\n", str.concat(text.trim(content), "\n")))
            fs.write_file(prompt_active_path(), updated)
            payload = util.json_obj5("tool", json.str("promptsmith"), "status", json.str("ok"), "action", json.str("append"), "content", json.str(updated), "meta", json.raw(prompt_meta_json(updated)))
        }
    } else {
        let current = fs.read_file(prompt_active_path())
        payload = util.json_obj5("tool", json.str("promptsmith"), "status", json.str("ok"), "action", json.str("get"), "content", json.str(current), "meta", json.raw(prompt_meta_json(current)))
    }
    fs.write_file(response_path, payload)
    fs.write_file(out_path, payload)
    fs.write_file(promptsmith_path(), payload)
    fs.write_file(last_run_path_for("promptsmith"), payload)
    return if json.get_str(json.parse(payload), "status") == "ok" { 0 } else { 13 }
}

fn run_custom_tool(tool_id: str, tool_input_json: str) -> i32 {
    return run_custom_tool_to(tool_id, tool_input_json, custom_tool_last_run_path(tool_id))
}

fn run_custom_tool_to(tool_id: str, tool_input_json: str, out_path: str) -> i32 {
    let manifest_path = custom_tool_manifest_path(tool_id)
    if fs.exists(manifest_path) == 0 {
        let missing = util.json_obj4("tool", json.str(tool_id), "status", json.str("failed"), "message", json.str("custom tool manifest not found"), "manifest_path", json.str(manifest_path))
        fs.write_file(custom_tool_state_path(tool_id), missing)
        fs.write_file(out_path, missing)
        fs.write_file(custom_tool_last_run_path(tool_id), missing)
        return 13
    }
    let manifest = json.parse(fs.read_file(manifest_path))
    let command_template = json.get_str(manifest, "command_template")
    if command_template == "" {
        let invalid = util.json_obj4("tool", json.str(tool_id), "status", json.str("failed"), "message", json.str("custom tool missing command_template"), "manifest_path", json.str(manifest_path))
        fs.write_file(custom_tool_state_path(tool_id), invalid)
        fs.write_file(out_path, invalid)
        fs.write_file(custom_tool_last_run_path(tool_id), invalid)
        return 13
    }
    let env_map = default_proc_env()
    let raw_input = if tool_input_json == "" { "{}" } else { tool_input_json }
    let request = util.json_obj2("tool_id", json.str(tool_id), "tool_input", json.raw(raw_input))
    let request_path = custom_tool_request_path(tool_id)
    fs.mkdir("/tmp/fzyagent/custom_tools")
    fs.mkdir(custom_tool_state_dir(tool_id))
    fs.write_file(request_path, request)
    discard proc.env_set(env_map, "TOOL_INPUT_JSON", raw_input)
    let parsed_input = json.parse(raw_input)
    let keys = json.keys(parsed_input)
    let exported_keys = list.new()
    let mut idx: i32 = 0
    while idx < list.len(keys) {
        let key = list.get(keys, idx)
        let child = json.get(parsed_input, key)
        let scalar = json.get_str(parsed_input, key)
        let raw = json.get_str(child, "raw")
        let value = if scalar == "" { raw } else { scalar }
        let upper_key = sanitize_env_fragment(key)
        discard proc.env_set(env_map, str.concat("TOOL_ARG_", upper_key), value)
        discard list.push(exported_keys, json.str(str.concat("TOOL_ARG_", upper_key)))
        idx += 1
    }
    let argv = shell_argv(command_template)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, 180000)
    let exit_code = proc.exit_code(handle)
    let status = if exit_code == 0 { "ok" } else { "failed" }
    let streams = util.json_obj2("stdout", json.str(proc.stdout(handle)), "stderr", json.str(proc.stderr(handle)))
    let meta = util.json_obj2("runner", json.str(json.get_str(manifest, "runner")), "exit_code", json.str(str.from_i32(exit_code)))
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool_id))
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "manifest_path", json.str(manifest_path))
    discard map.set(payload, "command_template", json.str(command_template))
    discard map.set(payload, "input", json.raw(raw_input))
    discard map.set(payload, "exported_env_keys", json.raw(json.array(exported_keys)))
    discard map.set(payload, "streams", json.raw(streams))
    discard map.set(payload, "meta", json.raw(meta))
    let encoded = json.object(payload)
    fs.write_file(custom_tool_state_path(tool_id), encoded)
    fs.write_file(out_path, encoded)
    fs.write_file(custom_tool_last_run_path(tool_id), encoded)
    fs.write_file(last_run_path_for(tool_id), encoded)
    return if exit_code == 0 { 0 } else { 13 }
}

fn assemble_pair(path_a: str, path_b: str) -> str {
    let left = safe_read(path_a)
    let right = safe_read(path_b)
    return util.json_obj2("left", json.raw(left), "right", json.raw(right))
}

fn boot_runner() -> i32 {
    ensure_dirs()
    init_tool_queue()
    return 0
}

fn queue_summary_doc(pending_count: i32, active_count: i32, completed_count: i32, cancelled_count: i32, last_tool_id: str, last_status: str) -> str {
    return util.json_obj6(
        "pending_count", json.str(str.from_i32(pending_count)),
        "active_count", json.str(str.from_i32(active_count)),
        "completed_count", json.str(str.from_i32(completed_count)),
        "cancelled_count", json.str(str.from_i32(cancelled_count)),
        "last_tool_id", json.str(last_tool_id),
        "last_status", json.str(last_status),
    )
}

fn queue_summary_json() -> str {
    let payload = safe_read(queue_summary_path())
    if payload == "{}" {
        return queue_summary_doc(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, "", "idle")
    }
    return payload
}

fn write_queue_summary(pending_count: i32, active_count: i32, completed_count: i32, cancelled_count: i32, last_tool_id: str, last_status: str) -> i32 {
    fs.write_file(queue_summary_path(), queue_summary_doc(pending_count, active_count, completed_count, cancelled_count, last_tool_id, last_status))
    return 0
}

fn queue_event(tool_id: str, run_id: str, state: str, status: str) -> str {
    return util.json_obj5(
        "tool_id", json.str(tool_id),
        "run_id", json.str(run_id),
        "state", json.str(state),
        "status", json.str(status),
        "recorded_at", json.str(str.from_i32(time.now())),
    )
}

fn init_tool_queue() -> i32 {
    ensure_dirs()
    if fs.exists(queue_pending_path()) == 0 {
        fs.write_file(queue_pending_path(), "")
    }
    if fs.exists(queue_active_path()) == 0 {
        fs.write_file(queue_active_path(), "")
    }
    if fs.exists(queue_summary_path()) == 0 {
        discard write_queue_summary(0, 0, 0, 0, "", "idle")
    }
    if fs.exists(queue_monitor_path()) == 0 {
        fs.write_file(queue_monitor_path(), util.json_obj3("status", json.str("ok"), "phase", json.str("boot"), "queue", json.raw(safe_read(queue_summary_path()))))
    }
    return 0
}

fn enqueue_tool_named(tool_id: str, run_id: str) -> i32 {
    discard init_tool_queue()
    discard storage.atomic_append(queue_pending_path(), str.concat(queue_event(tool_id, run_id, "pending", "queued"), "\n"))
    QUEUE_PENDING_COUNT += 1
    discard write_queue_summary(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, tool_id, "queued")
    return 0
}

fn enqueue_tool() -> i32 {
    return enqueue_tool_named("generic", "latest")
}

fn dequeue_tool_named(tool_id: str, run_id: str, status: str) -> i32 {
    discard init_tool_queue()
    discard storage.atomic_append(queue_active_path(), str.concat(queue_event(tool_id, run_id, "completed", status), "\n"))
    if QUEUE_PENDING_COUNT > 0 {
        QUEUE_PENDING_COUNT -= 1
    }
    if QUEUE_ACTIVE_COUNT > 0 {
        QUEUE_ACTIVE_COUNT -= 1
    }
    QUEUE_COMPLETED_COUNT += 1
    discard write_queue_summary(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, tool_id, status)
    return 0
}

fn dequeue_tool() -> i32 {
    return dequeue_tool_named("generic", "latest", "completed")
}

fn process_background() -> i32 {
    discard init_tool_queue()
    let payload = util.json_obj4(
        "status", json.str("ok"),
        "phase", json.str("process_background"),
        "queue", json.raw(queue_summary_json()),
        "updated_at", json.str(str.from_i32(time.now())),
    )
    fs.write_file(queue_monitor_path(), payload)
    return 0
}

fn spawn_background() -> i32 {
    discard init_tool_queue()
    QUEUE_ACTIVE_COUNT += QUEUE_PENDING_COUNT
    QUEUE_PENDING_COUNT = 0
    discard write_queue_summary(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, "background", "spawned")
    discard process_background()
    return 0
}

fn monitor_background() -> i32 {
    discard init_tool_queue()
    let payload = util.json_obj5(
        "status", json.str("ok"),
        "phase", json.str("monitor_background"),
        "queue", json.raw(queue_summary_json()),
        "cancel_signal", json.str(if fs.exists(queue_cancel_path()) == 1 { "present" } else { "absent" }),
        "updated_at", json.str(str.from_i32(time.now())),
    )
    fs.write_file(queue_monitor_path(), payload)
    return 0
}

fn spawn_probe_worker() -> i32 {
    return 7
}

fn kill_background() -> i32 {
    discard init_tool_queue()
    fs.write_file(queue_cancel_path(), "kill")
    QUEUE_ACTIVE_COUNT = 0
    QUEUE_CANCELLED_COUNT += 1
    discard write_queue_summary(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, "background", "killed")
    discard monitor_background()
    return 0
}

fn run_parallel_bash() -> i32 {
    runtime.events.emit_tool_started()
    ensure_dirs()
    let probe = spawn(spawn_probe_worker)
    let probe_result = join(probe)
    let left = spawn(run_parallel_bash_slot_a)
    let right = spawn(run_parallel_bash_slot_b)
    let left_result = join(left)
    let right_result = join(right)
    let payload = assemble_pair(bash_a_path(), bash_b_path())
    let probe_label = if probe_result == 7 { "ok" } else if probe_result == -1 { "neg1" } else if probe_result == -2 { "neg2" } else { "other" }
    let left_label = if left_result == 0 { "ok" } else if left_result == -1 { "neg1" } else if left_result == -2 { "neg2" } else { "other" }
    let right_label = if right_result == 0 { "ok" } else if right_result == -1 { "neg1" } else if right_result == -2 { "neg2" } else { "other" }
    let meta = util.json_obj3("probe_result", json.str(probe_label), "left_result", json.str(left_label), "right_result", json.str(right_label))
    let combined = util.json_obj2("pair", json.raw(payload), "meta", json.raw(meta))
    fs.write_file(last_run_path_for("parallel_bash"), combined)
    runtime.events.emit_tool_finished()
    if probe_result == 7 && left_result == 0 && right_result == 0 {
        return 0
    }
    return 13
}

