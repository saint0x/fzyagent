    let left_label = if left_result == 0 { "ok" } else if left_result == -1 { "neg1" } else if left_result == -2 { "neg2" } else { "other" }
    let right_label = if right_result == 0 { "ok" } else if right_result == -1 { "neg1" } else if right_result == -2 { "neg2" } else { "other" }
