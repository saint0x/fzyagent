fn dispatch_tool_request(tool_id: str, input_raw: str) -> i32 {
    let parsed = json.parse(if input_raw == "" { "{}" } else { input_raw })
    let nested_input = json.get(parsed, "tool_input")
    let action = json.get_str(parsed, "action")
    let op = json.get_str(parsed, "op")
    let effective_action = if op == "" { action } else { op }
    let url = if json.get_str(parsed, "url") == "" { json.get_str(nested_input, "url") } else { json.get_str(parsed, "url") }
    let query = if json.get_str(parsed, "query") == "" { json.get_str(nested_input, "query") } else { json.get_str(parsed, "query") }
    let eval_js = if json.get_str(parsed, "eval_js") == "" { json.get_str(nested_input, "eval_js") } else { json.get_str(parsed, "eval_js") }
    let commands_json = if json.get_str(parsed, "commands_json") == "" { json.get_str(nested_input, "commands_json") } else { json.get_str(parsed, "commands_json") }
    let commands_raw = json.get_str(json.get(parsed, "commands"), "raw")
    let nested_commands_raw = json.get_str(json.get(nested_input, "commands"), "raw")
    let command = if json.get_str(parsed, "command") == "" { json.get_str(nested_input, "command") } else { json.get_str(parsed, "command") }
    let pattern = if json.get_str(parsed, "pattern") == "" { json.get_str(nested_input, "pattern") } else { json.get_str(parsed, "pattern") }
    let target = if json.get_str(parsed, "target") == "" { json.get_str(nested_input, "target") } else { json.get_str(parsed, "target") }
    let requested_tool_id = json.get_str(parsed, "tool_id")
    let create_tool_id = json.get_str(parsed, "create_tool_id")
    let description = json.get_str(parsed, "description")
    let command_template = json.get_str(parsed, "command_template")
    let input_schema_json = json.get_str(parsed, "input_schema_json")
    let input_schema_raw = json.get_str(json.get(parsed, "input_schema"), "raw")
    let kind = json.get_str(parsed, "kind")
    let mode = json.get_str(parsed, "mode")
    let max_lines = json.get_str(parsed, "max_lines")
    let content = json.get_str(parsed, "content")
    let tool_input_raw = json.get_str(json.get(parsed, "tool_input"), "raw")
    let effective_commands = if commands_json == "" {
        if commands_raw == "" { nested_commands_raw } else { commands_raw }
    } else {
        commands_json
    }
    let effective_requested_tool_id = if requested_tool_id == "" { create_tool_id } else { requested_tool_id }
    let effective_input_schema = if input_schema_json == "" { input_schema_raw } else { input_schema_json }
    let kind_tag = dispatch_kind(tool_id)
    match kind_tag {
        DispatchKind::DispatchAegis => return run_aegis_with_args(effective_action, url, query, eval_js, effective_commands),
        DispatchKind::DispatchBash => return run_bash_with_command(command),
        DispatchKind::DispatchGrepSearch => return run_grep_search(pattern, target),
        DispatchKind::DispatchParallelBash => return run_parallel_bash(),
        DispatchKind::DispatchParallelGrep => return run_parallel_grep(),
        DispatchKind::DispatchReleaseAudit => return run_release_audit(),
        DispatchKind::DispatchWorkspaceDigest => return run_workspace_digest(),
        DispatchKind::DispatchProjectSeed => return run_project_seed(),
        DispatchKind::DispatchBrowserOpsSeed => return run_browser_ops_seed(),
        DispatchKind::DispatchTimeoutProbe => return run_with_timeout(),
        DispatchKind::DispatchToolsmith => return run_toolsmith(if effective_action == "" { "protocol" } else { effective_action }, effective_requested_tool_id, description, command_template, effective_input_schema, kind, mode),
        DispatchKind::DispatchPromptsmith => return run_promptsmith(if effective_action == "" { "get" } else { effective_action }, content),
        DispatchKind::DispatchFzydoc => return run_fzydoc(if query == "" { "spawn" } else { query }, max_lines),
        DispatchKind::DispatchToolSequence => return run_tool_sequence(input_raw),
        DispatchKind::DispatchToolParallel => return run_tool_parallel(input_raw),
        DispatchKind::DispatchAll => return run_parallel(),
        _ => return run_custom_tool(tool_id, if tool_input_raw == "" { input_raw } else { tool_input_raw }),
    }
    return 13
}

fn dispatch_tool_request_isolated(tool_id: str, input_raw: str, out_path: str) -> i32 {
    let parsed = json.parse(if input_raw == "" { "{}" } else { input_raw })
    let nested_input = json.get(parsed, "tool_input")
    let action = json.get_str(parsed, "action")
    let op = json.get_str(parsed, "op")
    let effective_action = if op == "" { action } else { op }
    let url = if json.get_str(parsed, "url") == "" { json.get_str(nested_input, "url") } else { json.get_str(parsed, "url") }
    let query = if json.get_str(parsed, "query") == "" { json.get_str(nested_input, "query") } else { json.get_str(parsed, "query") }
    let eval_js = if json.get_str(parsed, "eval_js") == "" { json.get_str(nested_input, "eval_js") } else { json.get_str(parsed, "eval_js") }
    let commands_json = if json.get_str(parsed, "commands_json") == "" { json.get_str(nested_input, "commands_json") } else { json.get_str(parsed, "commands_json") }
    let commands_raw = json.get_str(json.get(parsed, "commands"), "raw")
    let nested_commands_raw = json.get_str(json.get(nested_input, "commands"), "raw")
    let command = if json.get_str(parsed, "command") == "" { json.get_str(nested_input, "command") } else { json.get_str(parsed, "command") }
    let pattern = if json.get_str(parsed, "pattern") == "" { json.get_str(nested_input, "pattern") } else { json.get_str(parsed, "pattern") }
    let target = if json.get_str(parsed, "target") == "" { json.get_str(nested_input, "target") } else { json.get_str(parsed, "target") }
    let requested_tool_id = json.get_str(parsed, "tool_id")
    let create_tool_id = json.get_str(parsed, "create_tool_id")
    let description = json.get_str(parsed, "description")
    let command_template = json.get_str(parsed, "command_template")
    let input_schema_json = json.get_str(parsed, "input_schema_json")
    let input_schema_raw = json.get_str(json.get(parsed, "input_schema"), "raw")
    let kind = json.get_str(parsed, "kind")
    let mode = json.get_str(parsed, "mode")
    let max_lines = json.get_str(parsed, "max_lines")
    let content = json.get_str(parsed, "content")
    let tool_input_raw = json.get_str(json.get(parsed, "tool_input"), "raw")
    let effective_commands = if commands_json == "" {
        if commands_raw == "" { nested_commands_raw } else { commands_raw }
    } else {
        commands_json
    }
    let effective_requested_tool_id = if requested_tool_id == "" { create_tool_id } else { requested_tool_id }
    let effective_input_schema = if input_schema_json == "" { input_schema_raw } else { input_schema_json }
    let kind_tag = dispatch_kind(tool_id)
    match kind_tag {
        DispatchKind::DispatchAegis => return run_aegis_with_args_to(effective_action, url, query, eval_js, effective_commands, out_path),
        DispatchKind::DispatchBash => return run_shell_to_file("bash", if command == "" { env_or("TOOL_BASH", "echo bash-tool-default") } else { command }, 20000, out_path),
        DispatchKind::DispatchGrepSearch => return run_grep_to_file("grep_search", if pattern == "" { env_or("TOOL_GREP_PATTERN_A", "fn ") } else { pattern }, if target == "" { env_or("TOOL_GREP_TARGET_A", "src") } else { target }, 15000, out_path),
        DispatchKind::DispatchWorkspaceDigest => return run_workspace_digest_to(out_path),
        DispatchKind::DispatchToolsmith => return run_toolsmith_to(if effective_action == "" { "protocol" } else { effective_action }, effective_requested_tool_id, description, command_template, effective_input_schema, kind, mode, out_path),
        DispatchKind::DispatchPromptsmith => return run_promptsmith_to(if effective_action == "" { "get" } else { effective_action }, content, out_path),
        DispatchKind::DispatchFzydoc => return run_fzydoc_to(if query == "" { "spawn" } else { query }, max_lines, out_path),
        DispatchKind::DispatchCustom => return run_custom_tool_to(tool_id, if tool_input_raw == "" { input_raw } else { tool_input_raw }, out_path),
        _ => return dispatch_tool_request_copy(tool_id, input_raw, out_path),
    }
    return 13
}

fn dispatch_tool_request_copy(tool_id: str, input_raw: str, out_path: str) -> i32 {
    let status = dispatch_tool_request(tool_id, input_raw)
    fs.write_file(out_path, last_run_json(tool_id))
    return status
}

fn tool_step_result_json(step_id: str, tool_id: str, status_code: i32) -> str {
    return tool_step_result_from_payload_json(step_id, tool_id, status_code, last_run_json(tool_id))
}

fn tool_step_result_from_payload_json(step_id: str, tool_id: str, status_code: i32, result_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "step_id", json.str(step_id))
    discard map.set(payload, "tool_id", json.str(tool_id))
    discard map.set(payload, "status", json.str(if status_code == 0 { "ok" } else { "error" }))
    discard map.set(payload, "result", json.raw(result_json))
    return json.object(payload)
}

fn tool_step_skipped_json(step_id: str) -> str {
    let payload = map.new()
    discard map.set(payload, "step_id", json.str(step_id))
    discard map.set(payload, "tool_id", json.str(""))
    discard map.set(payload, "status", json.str("skipped"))
    discard map.set(payload, "result", json.raw("{}"))
    return json.object(payload)
}

fn parallel_step_request_json(step_raw: str) -> str {
    if step_raw == "" {
        return util.json_obj3("step_id", json.str(""), "tool_id", json.str(""), "tool_input", json.raw("{}"))
    }
    return step_raw
}

fn run_parallel_step_ctx() -> i32 {
    let context_id = thread.context_id()
    let request_raw = safe_read(parallel_step_request_path(context_id))
    let step = json.parse(request_raw)
    let step_id = json.get_str(step, "step_id")
    let tool_id = json.get_str(step, "tool_id")
    if tool_id == "" {
        fs.write_file(parallel_step_result_path(context_id), tool_step_skipped_json(step_id))
        return 0
    }
    let tool_input = json.get_str(json.get(step, "tool_input"), "raw")
    let payload_path = parallel_step_payload_path(context_id)
    let status = dispatch_tool_request_isolated(tool_id, if tool_input == "" { "{}" } else { tool_input }, payload_path)
    fs.write_file(parallel_step_result_path(context_id), tool_step_result_from_payload_json(if step_id == "" { str.from_i32(context_id) } else { step_id }, tool_id, status, safe_read(payload_path)))
    return status
}

fn run_tool_sequence(request_json: str) -> i32 {
    let parsed = json.parse(if request_json == "" { "{}" } else { request_json })
    let steps = json.get(parsed, "steps")
    let items = list.new()
    let mut idx: i32 = 0
    let mut overall: i32 = 0
    while idx < 32 {
        let step = json.get(steps, str.from_i32(idx))
        let step_raw = json.get_str(step, "raw")
        if step_raw == "" {
            break
        }
        let step_id = json.get_str(step, "step_id")
        let tool_id = json.get_str(step, "tool_id")
        let tool_input = json.get_str(json.get(step, "tool_input"), "raw")
        let status = dispatch_tool_request(tool_id, if tool_input == "" { "{}" } else { tool_input })
        discard list.push(items, json.raw(tool_step_result_json(if step_id == "" { str.from_i32(idx) } else { step_id }, tool_id, status)))
        if status != 0 && overall == 0 {
            overall = status
            break
        }
        idx += 1
    }
    let payload = util.json_obj3("tool", json.str("tool_sequence"), "status", json.str(if overall == 0 { "ok" } else { "error" }), "steps", json.raw(json.array(items)))
    fs.write_file("/tmp/fzyagent/runs/tool_sequence.json", payload)
    return overall
}

fn run_tool_parallel(request_json: str) -> i32 {
    let parsed = json.parse(if request_json == "" { "{}" } else { request_json })
    let steps = json.get(parsed, "steps")
    let step0 = json.get(steps, "0")
    let step1 = json.get(steps, "1")
    let step2 = json.get(steps, "2")
    let step3 = json.get(steps, "3")
    let overflow = json.get_str(json.get(steps, "4"), "raw")
    if overflow != "" {
        let payload = util.json_obj4(
            "tool", json.str("tool_parallel"),
            "status", json.str("error"),
            "message", json.str("parallel step limit exceeded"),
            "limit", json.str(str.from_i32(parallel_step_limit())),
        )
        fs.write_file("/tmp/fzyagent/runs/tool_parallel.json", payload)
        return 13
    }

    let base = next_parallel_context_base()
    let ctx0 = base + 1
    let ctx1 = base + 2
    let ctx2 = base + 3
    let ctx3 = base + 4

    let step0_raw = json.get_str(step0, "raw")
    let step1_raw = json.get_str(step1, "raw")
    let step2_raw = json.get_str(step2, "raw")
    let step3_raw = json.get_str(step3, "raw")

    fs.write_file(parallel_step_request_path(ctx0), parallel_step_request_json(step0_raw))
    fs.write_file(parallel_step_request_path(ctx1), parallel_step_request_json(step1_raw))
    fs.write_file(parallel_step_request_path(ctx2), parallel_step_request_json(step2_raw))
    fs.write_file(parallel_step_request_path(ctx3), parallel_step_request_json(step3_raw))

    let handle0 = spawn_ctx(run_parallel_step_ctx, ctx0)
    let handle1 = spawn_ctx(run_parallel_step_ctx, ctx1)
    let handle2 = spawn_ctx(run_parallel_step_ctx, ctx2)
    let handle3 = spawn_ctx(run_parallel_step_ctx, ctx3)

    let status0 = join(handle0)
    let status1 = join(handle1)
    let status2 = join(handle2)
    let status3 = join(handle3)

    let items = list.new()
    let mut overall: i32 = 0
    if step0_raw != "" {
        discard list.push(items, json.raw(safe_read(parallel_step_result_path(ctx0))))
        if status0 != 0 && overall == 0 {
            overall = status0
        }
    }
    if step1_raw != "" {
        discard list.push(items, json.raw(safe_read(parallel_step_result_path(ctx1))))
        if status1 != 0 && overall == 0 {
            overall = status1
        }
    }
    if step2_raw != "" {
        discard list.push(items, json.raw(safe_read(parallel_step_result_path(ctx2))))
        if status2 != 0 && overall == 0 {
            overall = status2
        }
    }
    if step3_raw != "" {
        discard list.push(items, json.raw(safe_read(parallel_step_result_path(ctx3))))
        if status3 != 0 && overall == 0 {
            overall = status3
        }
    }
    let payload = util.json_obj3("tool", json.str("tool_parallel"), "status", json.str(if overall == 0 { "ok" } else { "error" }), "steps", json.raw(json.array(items)))
    fs.write_file("/tmp/fzyagent/runs/tool_parallel.json", payload)
    return overall
}

fn last_run_json(tool_id: str) -> str {
    if canonical_tool_id(tool_id) == "all" {
        return safe_read(last_parallel_path())
    }
    return safe_read(last_run_path_for(tool_id))
}

fn last_run_artifact_path(tool_id: str) -> str {
    if canonical_tool_id(tool_id) == "all" {
        return last_parallel_path()
    }
    return last_run_path_for(tool_id)
}

fn pipe_stdout_events() -> i32 {
    runtime.events.emit_stdout_chunk()
    return 0
}

fn pipe_stderr_events() -> i32 {
    runtime.events.emit_stderr_chunk()
    return 0
}

fn pipe_structured_events() -> i32 {
    runtime.events.emit_structured_event()
    return 0
}

fn run_with_timeout() -> i32 {
    let cmd = env_or("TOOL_TIMEOUT_CMD", "sleep 1 && echo timeout-window")
    return run_shell_to_file("timeout_probe", cmd, 700, last_run_path_for("timeout_probe"))
}

fn cancel_tool_run() -> i32 {
    discard init_tool_queue()
    fs.write_file(queue_cancel_path(), "cancel")
    QUEUE_CANCELLED_COUNT += 1
    discard write_queue_summary(QUEUE_PENDING_COUNT, QUEUE_ACTIVE_COUNT, QUEUE_COMPLETED_COUNT, QUEUE_CANCELLED_COUNT, "generic", "cancelled")
    discard monitor_background()
    return 0
}

fn retry_with_backoff() -> i32 {
    run_with_timeout()
    checkpoint()
    run_with_timeout()
    checkpoint()
    run_with_timeout()
    return 0
}

fn classify_failure() -> i32 {
    let _spawn_failure = runtime.failures.classify_spawn_failure()
    let _timeout = runtime.failures.classify_timeout()
    let _nonzero = runtime.failures.classify_nonzero_exit()
    let _malformed = runtime.failures.classify_malformed_output()
    classify_failure_kind(13)
    return 0
}

fn classify_failure_kind(code: i32) -> ToolFailureClass {
    match code {
        11 => return ToolFailureClass::ToolSpawnFailure,
        12 => return ToolFailureClass::ToolTimeout,
        14 => return ToolFailureClass::ToolMalformedOutput,
        _ => return ToolFailureClass::ToolNonzeroExit,
    }
    return ToolFailureClass::ToolNonzeroExit
}

fn failure_class_label(code: i32) -> str {
    let kind = classify_failure_kind(code)
    match kind {
        ToolFailureClass::ToolSpawnFailure => return "spawn_failure",
        ToolFailureClass::ToolTimeout => return "timeout",
        ToolFailureClass::ToolNonzeroExit => return "nonzero_exit",
        _ => return "malformed_output",
    }
    return "malformed_output"
}
