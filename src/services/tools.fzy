    checkpoint()
    return 0
}

fn spawn_background() -> i32 {
    checkpoint()
    return 0
}

fn monitor_background() -> i32 {
    checkpoint()
    return 0
}

fn spawn_probe_worker() -> i32 {
    return 7
}

fn kill_background() -> i32 {
    return proc.exit_class()
}

fn run_parallel_bash() -> i32 {
    runtime.events.emit_tool_started()
    ensure_dirs()
    let probe = spawn(spawn_probe_worker)
    let probe_result = join(probe)
    let left = spawn(run_parallel_bash_slot_a)
    let right = spawn(run_parallel_bash_slot_b)
    let left_result = join(left)
    let right_result = join(right)
    let payload = assemble_pair(bash_a_path(), bash_b_path())
    let probe_label = if probe_result == 7 { "ok" } else if probe_result == -1 { "neg1" } else if probe_result == -2 { "neg2" } else { "other" }
    let left_label = if left_result == 0 { "ok" } else if left_result == -1 { "neg1" } else if left_result == -2 { "neg2" } else { "other" }
    let right_label = if right_result == 0 { "ok" } else if right_result == -1 { "neg1" } else if right_result == -2 { "neg2" } else { "other" }
    let meta = util.json_obj3("probe_result", json.str(probe_label), "left_result", json.str(left_label), "right_result", json.str(right_label))
    let combined = util.json_obj2("pair", json.raw(payload), "meta", json.raw(meta))
    fs.write_file(last_run_path_for("parallel_bash"), combined)
    runtime.events.emit_tool_finished()
    if probe_result == 7 && left_result == 0 && right_result == 0 {
        return 0
    }
    return 13
}

fn run_parallel_grep() -> i32 {
    runtime.events.emit_tool_started()
    ensure_dirs()
    let probe = spawn(spawn_probe_worker)
    let probe_result = join(probe)
    let left = spawn(run_parallel_grep_slot_a)
    let right = spawn(run_parallel_grep_slot_b)
    let left_result = join(left)
    let right_result = join(right)
    let payload = assemble_pair(grep_a_path(), grep_b_path())
    let probe_label = if probe_result == 7 { "ok" } else if probe_result == -1 { "neg1" } else if probe_result == -2 { "neg2" } else { "other" }
    let left_label = if left_result == 0 { "ok" } else if left_result == -1 { "neg1" } else if left_result == -2 { "neg2" } else { "other" }
    let right_label = if right_result == 0 { "ok" } else if right_result == -1 { "neg1" } else if right_result == -2 { "neg2" } else { "other" }
    let meta = util.json_obj3("probe_result", json.str(probe_label), "left_result", json.str(left_label), "right_result", json.str(right_label))
    let combined = util.json_obj2("pair", json.raw(payload), "meta", json.raw(meta))
    fs.write_file(last_run_path_for("parallel_grep"), combined)
    runtime.events.emit_tool_finished()
    if probe_result == 7 && left_result == 0 && right_result == 0 {
        return 0
    }
    return 13
}

