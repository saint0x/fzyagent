    return str.concat("http://", aegis_addr())
}

fn shell_stdout_with_env(command: str, env_map: ProcessEnv, timeout_ms: i32) -> str {
    let argv = shell_argv(command)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    return proc.stdout(handle)
}

fn shell_status_with_env(command: str, env_map: ProcessEnv, timeout_ms: i32) -> i32 {
    let argv = shell_argv(command)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    return proc.exit_code(handle)
}

fn shell_payload_with_env(command: str, env_map: ProcessEnv, timeout_ms: i32) -> str {
    let argv = shell_argv(command)
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, timeout_ms)
    let exit_code = proc.exit_code(handle)
    let status = status_from_exit_code(exit_code)
    let stdout = proc.stdout(handle)
    let stderr = proc.stderr(handle)
    let streams = util.json_obj2("stdout", json.str(stdout), "stderr", json.str(stderr))
    let payload = util.json_obj3("status", json.str(status), "exit_code", json.str(str.from_i32(exit_code)), "streams", json.raw(streams))
    return payload
}

fn is_lower_letter(ch: str) -> i32 {
    if ch == "a" || ch == "b" || ch == "c" || ch == "d" || ch == "e" || ch == "f" || ch == "g" || ch == "h" || ch == "i" || ch == "j" || ch == "k" || ch == "l" || ch == "m" || ch == "n" || ch == "o" || ch == "p" || ch == "q" || ch == "r" || ch == "s" || ch == "t" || ch == "u" || ch == "v" || ch == "w" || ch == "x" || ch == "y" || ch == "z" {
        return 1
    }
    return 0
}

fn is_digit_char(ch: str) -> i32 {
    if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" {
        return 1
    }
    return 0
}

fn uppercase_ascii(ch: str) -> str {
    if ch == "a" { return "A" }
    if ch == "b" { return "B" }
    if ch == "c" { return "C" }
    if ch == "d" { return "D" }
    if ch == "e" { return "E" }
    if ch == "f" { return "F" }
    if ch == "g" { return "G" }
    if ch == "h" { return "H" }
    if ch == "i" { return "I" }
    if ch == "j" { return "J" }
    if ch == "k" { return "K" }
    if ch == "l" { return "L" }
    if ch == "m" { return "M" }
    if ch == "n" { return "N" }
    if ch == "o" { return "O" }
    if ch == "p" { return "P" }
    if ch == "q" { return "Q" }
    if ch == "r" { return "R" }
    if ch == "s" { return "S" }
    if ch == "t" { return "T" }
    if ch == "u" { return "U" }
    if ch == "v" { return "V" }
    if ch == "w" { return "W" }
    if ch == "x" { return "X" }
    if ch == "y" { return "Y" }
    if ch == "z" { return "Z" }
    return ch
}

fn valid_tool_id(tool_id: str) -> i32 {
    let env_map = default_proc_env()
    discard proc.env_set(env_map, "FZY_TOOL_ID", tool_id)
    let cmd = "printf '%s' \"$FZY_TOOL_ID\" | grep -Eq '^[a-z][a-z0-9_]{1,63}$'"
    let exit_code = shell_status_with_env(cmd, env_map, 5000)
    if exit_code == 0 {
        return 1
    }
    return 0
}

fn dispatch_kind(tool_id: str) -> DispatchKind {
    if tool_id == "aegis" || tool_id == "aegis_headless" {
        return DispatchKind::DispatchAegis
    }
    if tool_id == "bash" {
        return DispatchKind::DispatchBash
    }
    if tool_id == "grep_search" {
        return DispatchKind::DispatchGrepSearch
    }
    if tool_id == "parallel_bash" {
        return DispatchKind::DispatchParallelBash
    }
    if tool_id == "parallel_grep" {
        return DispatchKind::DispatchParallelGrep
    }
    if tool_id == "release_audit" {
        return DispatchKind::DispatchReleaseAudit
    }
    if tool_id == "workspace_digest" {
        return DispatchKind::DispatchWorkspaceDigest
    }
    if tool_id == "project_seed" {
        return DispatchKind::DispatchProjectSeed
    }
    if tool_id == "browser_ops_seed" {
        return DispatchKind::DispatchBrowserOpsSeed
    }
    if tool_id == "timeout_probe" {
        return DispatchKind::DispatchTimeoutProbe
    }
    if tool_id == "toolsmith" {
        return DispatchKind::DispatchToolsmith
    }
    if tool_id == "promptsmith" {
        return DispatchKind::DispatchPromptsmith
    }
    if tool_id == "fzydoc" {
        return DispatchKind::DispatchFzydoc
    }
    if tool_id == "tool_sequence" {
        return DispatchKind::DispatchToolSequence
    }
    if tool_id == "tool_parallel" {
        return DispatchKind::DispatchToolParallel
    }
    if tool_id == "all" {
        return DispatchKind::DispatchAll
    }
    return DispatchKind::DispatchCustom
}

fn canonical_tool_id(tool_id: str) -> str {
    if tool_id == "aegis_headless" {
        return "aegis"
    }
    return tool_id
}

fn sanitize_env_fragment(value: str) -> str {
    let mut out = ""
    let mut idx: i32 = 0
    while idx < str.len(value) {
        let ch = str.slice(value, idx, idx + 1)
        if is_lower_letter(ch) == 1 || is_digit_char(ch) == 1 || ch == "_" {
            out = str.concat(out, uppercase_ascii(ch))
        } else {
            out = str.concat(out, "_")
        }
        idx += 1
    }
    return out
}

fn prompt_line_count(text_value: str) -> i32 {
    if text_value == "" {
        return 0
    }
    let mut count: i32 = 1
    let mut idx: i32 = 0
    while idx < str.len(text_value) {
        if str.slice(text_value, idx, idx + 1) == "\n" {
            count += 1
        }
        idx += 1
    }
    return count
}

fn prompt_preview(text_value: str) -> str {
    if str.len(text_value) <= 400 {
        return text_value
    }
    return str.slice(text_value, 0, 400)
}

fn prompt_meta_json(text_value: str) -> str {
    return util.json_obj5(
        "active_path", json.str(prompt_active_path()),
        "default_path", json.str(prompt_default_path()),
        "chars", json.str(str.from_i32(str.len(text_value))),
        "lines", json.str(str.from_i32(prompt_line_count(text_value))),
        "preview", json.str(prompt_preview(text_value)),
    )
}

fn ensure_prompt_files() -> i32 {
    fs.mkdir(prompt_config_dir())
    if fs.exists(prompt_default_path()) == 0 {
        fs.write_file(prompt_default_path(), "You are the fzyagent agent CLI.\n")
    }
    if fs.exists(prompt_active_path()) == 0 {
        fs.write_file(prompt_active_path(), fs.read_file(prompt_default_path()))
    }
    return 0
}

fn template_lint_warnings(command_template: str) -> str {
    let env_map = default_proc_env()
    discard proc.env_set(env_map, "FZY_TEMPLATE", command_template)
    let has_token = shell_status_with_env("printf '%s' \"$FZY_TEMPLATE\" | grep -q 'TOOL_ARG_'", env_map, 5000)
    let has_dollar = shell_status_with_env("printf '%s' \"$FZY_TEMPLATE\" | grep -q '\\$TOOL_ARG_'", env_map, 5000)
    let has_brace = shell_status_with_env("printf '%s' \"$FZY_TEMPLATE\" | grep -q '\\${TOOL_ARG_'", env_map, 5000)
    let warnings = list.new()
    if has_token == 0 && has_dollar != 0 && has_brace != 0 {
        discard list.push(warnings, json.str("command_template references TOOL_ARG_* tokens without shell variable expansion; use $TOOL_ARG_FIELD or ${TOOL_ARG_FIELD}"))
    }
    return json.array(warnings)
}

fn last_run_path_for(tool_id: str) -> str {
    let normalized = canonical_tool_id(tool_id)
    if normalized == "parallel_bash" {
        return "/tmp/fzyagent/runs/parallel_bash.json"
    }
    if normalized == "parallel_grep" {
        return "/tmp/fzyagent/runs/parallel_grep.json"
    }
    if normalized == "release_audit" {
        return "/tmp/fzyagent/runs/release_audit.json"
    }
    if normalized == "workspace_digest" {
        return workspace_digest_path()
    }
    if normalized == "aegis" {
        return aegis_path()
    }
    if normalized == "bash" {
        return "/tmp/fzyagent/runs/bash.json"
    }
    if normalized == "grep_search" {
        return "/tmp/fzyagent/runs/grep_search.json"
    }
    if normalized == "timeout_probe" {
        return "/tmp/fzyagent/runs/timeout_probe.json"
    }
    if normalized == "tool_sequence" {
        return "/tmp/fzyagent/runs/tool_sequence.json"
    }
    if normalized == "tool_parallel" {
        return "/tmp/fzyagent/runs/tool_parallel.json"
    }
    if normalized == "toolsmith" {
        return toolsmith_path()
    }
    if normalized == "promptsmith" {
        return promptsmith_path()
    }
    if normalized == "fzydoc" {
        return fzydoc_path()
    }
    if fs.exists(custom_tool_manifest_path(normalized)) != 0 {
        return custom_tool_last_run_path(normalized)
    }
    return "/tmp/fzyagent/runs/generic.json"
}

