    ensure_dirs()
    return 0
}

fn init_tool_queue() -> i32 {
    ensure_dirs()
    return 0
}

fn enqueue_tool() -> i32 {
    checkpoint()
    return 0
}

fn dequeue_tool() -> i32 {
    checkpoint()
    return 0
}

