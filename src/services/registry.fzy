fn append_builtin_tools(tools: ListHandle, anthropic: ListHandle, openai: ListHandle) -> i32 {
    let empty_schema = default_input_schema()
    let command_schema = tool_schema_command()
    let grep_schema = tool_schema_grep()
    let queue_enqueue_schema = tool_schema_queue_enqueue()
    let steps_schema = tool_schema_steps()
    let aegis_schema = tool_schema_aegis()
    let toolsmith_schema = tool_schema_toolsmith()
    let promptsmith_schema = tool_schema_promptsmith()
    let fzydoc_schema = tool_schema_fzydoc()
    let runtime_control_schema = tool_schema_runtime_control()
    let plan_write_schema = tool_schema_plan_write()
    let goal_complete_schema = tool_schema_goal_complete()
    let longrange_start_schema = tool_schema_longrange_start()
    let longrange_message_schema = tool_schema_longrange_message()
    let longrange_select_schema = tool_schema_longrange_select()

    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("bash", "Run a shell command in the shared workspace.", "process", "single", "single", "true", "true", command_schema), anthropic_tool_json("bash", "Run a shell command in the shared workspace.", command_schema), openai_tool_json("bash", "Run a shell command in the shared workspace.", command_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("parallel_bash", "Run two shell commands in parallel.", "process", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("parallel_bash", "Run two shell commands in parallel.", empty_schema), openai_tool_json("parallel_bash", "Run two shell commands in parallel.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("grep_search", "Search the workspace with grep.", "process", "search", "single", "true", "true", grep_schema), anthropic_tool_json("grep_search", "Search the workspace with grep.", grep_schema), openai_tool_json("grep_search", "Search the workspace with grep.", grep_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("queue_status", "Inspect the background queue control-plane state.", "workflow", "control", "single", "true", "true", empty_schema), anthropic_tool_json("queue_status", "Inspect the background queue control-plane state.", empty_schema), openai_tool_json("queue_status", "Inspect the background queue control-plane state.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("queue_enqueue", "Queue a tool request for later background execution.", "workflow", "control", "single", "true", "false", queue_enqueue_schema), anthropic_tool_json("queue_enqueue", "Queue a tool request for later background execution.", queue_enqueue_schema), openai_tool_json("queue_enqueue", "Queue a tool request for later background execution.", queue_enqueue_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("queue_spawn", "Spawn detached background processing for queued work.", "workflow", "control", "single", "true", "false", empty_schema), anthropic_tool_json("queue_spawn", "Spawn detached background processing for queued work.", empty_schema), openai_tool_json("queue_spawn", "Spawn detached background processing for queued work.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("queue_process", "Drain queued work through the background executor.", "workflow", "control", "single", "true", "false", empty_schema), anthropic_tool_json("queue_process", "Drain queued work through the background executor.", empty_schema), openai_tool_json("queue_process", "Drain queued work through the background executor.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("queue_cancel", "Request cancellation for queued background work.", "workflow", "control", "single", "true", "false", empty_schema), anthropic_tool_json("queue_cancel", "Request cancellation for queued background work.", empty_schema), openai_tool_json("queue_cancel", "Request cancellation for queued background work.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("parallel_grep", "Run two grep searches in parallel.", "process", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("parallel_grep", "Run two grep searches in parallel.", empty_schema), openai_tool_json("parallel_grep", "Run two grep searches in parallel.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("tool_sequence", "Run multiple tools in a deterministic sequence and capture each step result by id.", "workflow", "sequence", "sequential", "true", "false", steps_schema), anthropic_tool_json("tool_sequence", "Run multiple tools in a deterministic sequence and capture each step result by id.", steps_schema), openai_tool_json("tool_sequence", "Run multiple tools in a deterministic sequence and capture each step result by id.", steps_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("tool_parallel", "Run multiple tools in parallel and return each step result by id.", "workflow", "parallel", "parallel", "false", "true", steps_schema), anthropic_tool_json("tool_parallel", "Run multiple tools in parallel and return each step result by id.", steps_schema), openai_tool_json("tool_parallel", "Run multiple tools in parallel and return each step result by id.", steps_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("release_audit", "Run a release-oriented multi-signal workflow.", "workflow", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("release_audit", "Run a release-oriented multi-signal workflow.", empty_schema), openai_tool_json("release_audit", "Run a release-oriented multi-signal workflow.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("timeout_probe", "Intentionally probe timeout and error behavior.", "process", "bounded", "single", "true", "true", empty_schema), anthropic_tool_json("timeout_probe", "Intentionally probe timeout and error behavior.", empty_schema), openai_tool_json("timeout_probe", "Intentionally probe timeout and error behavior.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("workspace_digest", "Summarize the current workspace.", "process", "analysis", "single", "true", "true", empty_schema), anthropic_tool_json("workspace_digest", "Summarize the current workspace.", empty_schema), openai_tool_json("workspace_digest", "Summarize the current workspace.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("project_seed", "Assemble a richer project context bundle.", "workflow", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("project_seed", "Assemble a richer project context bundle.", empty_schema), openai_tool_json("project_seed", "Assemble a richer project context bundle.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("aegis", "Use the Aegis browser runtime.", "browser", "headless", "single", "true", "true", aegis_schema), anthropic_tool_json("aegis", "Use the Aegis browser runtime.", aegis_schema), openai_tool_json("aegis", "Use the Aegis browser runtime.", aegis_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("browser_ops_seed", "Assemble a browser-oriented context bundle.", "workflow", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("browser_ops_seed", "Assemble a browser-oriented context bundle.", empty_schema), openai_tool_json("browser_ops_seed", "Assemble a browser-oriented context bundle.", empty_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("toolsmith", "Create and inspect custom runtime tools.", "workflow", "authoring", "single", "true", "false", toolsmith_schema), anthropic_tool_json("toolsmith", "Create and inspect custom runtime tools.", toolsmith_schema), openai_tool_json("toolsmith", "Create and inspect custom runtime tools.", toolsmith_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("promptsmith", "Inspect and update the agent system prompt.", "workflow", "authoring", "single", "true", "false", promptsmith_schema), anthropic_tool_json("promptsmith", "Inspect and update the agent system prompt.", promptsmith_schema), openai_tool_json("promptsmith", "Inspect and update the agent system prompt.", promptsmith_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("fzydoc", "Search local FZY docs and showcase material.", "docs", "analysis", "single", "true", "true", fzydoc_schema), anthropic_tool_json("fzydoc", "Search local FZY docs and showcase material.", fzydoc_schema), openai_tool_json("fzydoc", "Search local FZY docs and showcase material.", fzydoc_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("runtime_checkpoint", "Persist the current runtime checkpoint and supervisor state.", "workflow", "control", "single", "true", "false", runtime_control_schema), anthropic_tool_json("runtime_checkpoint", "Persist the current runtime checkpoint and supervisor state.", runtime_control_schema), openai_tool_json("runtime_checkpoint", "Persist the current runtime checkpoint and supervisor state.", runtime_control_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("runtime_recover", "Restore the current runtime checkpoint and refresh inflight control-plane state.", "workflow", "control", "single", "true", "false", runtime_control_schema), anthropic_tool_json("runtime_recover", "Restore the current runtime checkpoint and refresh inflight control-plane state.", runtime_control_schema), openai_tool_json("runtime_recover", "Restore the current runtime checkpoint and refresh inflight control-plane state.", runtime_control_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("runtime_shutdown", "Request graceful runtime shutdown and persist shutdown artifacts.", "workflow", "control", "single", "true", "false", runtime_control_schema), anthropic_tool_json("runtime_shutdown", "Request graceful runtime shutdown and persist shutdown artifacts.", runtime_control_schema), openai_tool_json("runtime_shutdown", "Request graceful runtime shutdown and persist shutdown artifacts.", runtime_control_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("longrange_start", "Start an autonomous long-range run for a goal.", "workflow", "control", "single", "true", "false", longrange_start_schema), anthropic_tool_json("longrange_start", "Start an autonomous long-range run for a goal.", longrange_start_schema), openai_tool_json("longrange_start", "Start an autonomous long-range run for a goal.", longrange_start_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("longrange_status", "Inspect the active autonomous long-range run.", "workflow", "control", "single", "true", "false", longrange_select_schema), anthropic_tool_json("longrange_status", "Inspect the active autonomous long-range run.", longrange_select_schema), openai_tool_json("longrange_status", "Inspect the active autonomous long-range run.", longrange_select_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("longrange_cancel", "Cancel the active autonomous long-range run.", "workflow", "control", "single", "true", "false", longrange_select_schema), anthropic_tool_json("longrange_cancel", "Cancel the active autonomous long-range run.", longrange_select_schema), openai_tool_json("longrange_cancel", "Cancel the active autonomous long-range run.", longrange_select_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("longrange_steer", "Queue or interrupt the next autonomous long-range turn with a steering message.", "workflow", "control", "single", "true", "false", longrange_message_schema), anthropic_tool_json("longrange_steer", "Queue or interrupt the next autonomous long-range turn with a steering message.", longrange_message_schema), openai_tool_json("longrange_steer", "Queue or interrupt the next autonomous long-range turn with a steering message.", longrange_message_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("plan_create", "Create the durable plan and success criteria for the active long-range run.", "workflow", "planning", "single", "true", "false", plan_write_schema), anthropic_tool_json("plan_create", "Create the durable plan and success criteria for the active long-range run.", plan_write_schema), openai_tool_json("plan_create", "Create the durable plan and success criteria for the active long-range run.", plan_write_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("plan_update", "Update the durable plan and current step for the active long-range run.", "workflow", "planning", "single", "true", "false", plan_write_schema), anthropic_tool_json("plan_update", "Update the durable plan and current step for the active long-range run.", plan_write_schema), openai_tool_json("plan_update", "Update the durable plan and current step for the active long-range run.", plan_write_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("plan_view", "Read the durable plan for the active long-range run.", "workflow", "planning", "single", "true", "false", longrange_select_schema), anthropic_tool_json("plan_view", "Read the durable plan for the active long-range run.", longrange_select_schema), openai_tool_json("plan_view", "Read the durable plan for the active long-range run.", longrange_select_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("goal_complete", "Mark the active long-range run fully complete.", "workflow", "planning", "single", "true", "false", goal_complete_schema), anthropic_tool_json("goal_complete", "Mark the active long-range run fully complete.", goal_complete_schema), openai_tool_json("goal_complete", "Mark the active long-range run fully complete.", goal_complete_schema))
    discard append_tool_triplet(tools, anthropic, openai, built_tool_json("all", "Run the default parallel tool set.", "workflow", "parallel", "parallel", "false", "true", empty_schema), anthropic_tool_json("all", "Run the default parallel tool set.", empty_schema), openai_tool_json("all", "Run the default parallel tool set.", empty_schema))
    return 0
}

fn append_custom_tools(tools: ListHandle, anthropic: ListHandle, openai: ListHandle) -> i32 {
    if fs.exists(custom_tools_root()) == 0 {
        return 0
    }
    discard tools
    discard anthropic
    discard openai
    return 0
}

fn build_registry_payload() -> str {
    let tools = list.new()
    let anthropic = list.new()
    let openai = list.new()
    discard append_builtin_tools(tools, anthropic, openai)
    discard append_custom_tools(tools, anthropic, openai)
    let meta = model.types.registry_meta_json("2026-05-27", configured_provider_name(), "true", "fzyagent")
    fs.write_file(anthropic_tools_array_path(), json.array(anthropic))
    fs.write_file(openai_tools_array_path(), json.array(openai))
    return model.types.registry_payload_json(json.array(tools), meta)
}

fn registry_status(message: str) -> str {
    return model.types.registry_status_json(message, str.from_i32(time.now()))
}

fn tool_handle(parsed: JsonHandle, idx: i32) -> JsonHandle {
    return json.get(json.get(parsed, "tools"), str.from_i32(idx))
}

fn tool_id_at(parsed: JsonHandle, idx: i32) -> str {
    return json.get_str(tool_handle(parsed, idx), "id")
}

fn tool_kind_at(parsed: JsonHandle, idx: i32) -> str {
    return json.get_str(tool_handle(parsed, idx), "kind")
}

fn tool_origin_at(parsed: JsonHandle, idx: i32) -> str {
    let origin = json.get_str(tool_handle(parsed, idx), "origin")
    if origin == "" {
        return "builtin"
    }
    return origin
}

fn tool_mode_at(parsed: JsonHandle, idx: i32) -> str {
    return json.get_str(tool_handle(parsed, idx), "mode")
}

fn tool_health_at(parsed: JsonHandle, idx: i32) -> str {
    return json.get_str(tool_handle(parsed, idx), "health")
}

fn tool_raw_at(parsed: JsonHandle, idx: i32) -> str {
    return json.get_str(tool_handle(parsed, idx), "raw")
}

fn add_tool_to_arrays(parsed: JsonHandle, idx: i32, ids: ListHandle, search: ListHandle, browser: ListHandle, authoring: ListHandle, workflows: ListHandle) -> i32 {
    let tool_id = tool_id_at(parsed, idx)
    if tool_id == "" {
        return 0
    }
    discard list.push(ids, json.str(tool_id))
    let kind = tool_kind_at(parsed, idx)
    if tool_id == "grep_search" || tool_id == "workspace_digest" || tool_id == "fzydoc" {
        discard list.push(search, json.str(tool_id))
    }
    if tool_id == "aegis" {
        discard list.push(browser, json.str(tool_id))
    }
    if tool_id == "toolsmith" || tool_id == "promptsmith" {
        discard list.push(authoring, json.str(tool_id))
    }
    if kind == "workflow" {
        discard list.push(workflows, json.str(tool_id))
    }
    return 0
}

fn export_index_and_summary() -> i32 {
    let payload = fs.read_file(registry_path())
    if payload == "" {
        fs.write_file(summary_path(), registry_status("missing_registry_payload"))
        return 13
    }
    let parsed = json.parse(payload)
    let ids = list.new()
    let search = list.new()
    let browser = list.new()
    let authoring = list.new()
    let workflows = list.new()
    let index = map.new()
    let mut total: i32 = 0
    let mut builtin: i32 = 0
    let mut custom: i32 = 0
    let mut process_tools: i32 = 0
    let mut workflow_tools: i32 = 0
    let mut browser_tools: i32 = 0
    let mut docs_tools: i32 = 0
    let mut healthy_tools: i32 = 0
    let mut idx: i32 = 0
    while idx < 128 {
        let tool_id = tool_id_at(parsed, idx)
        if tool_id != "" {
            total = total + 1
            let kind = tool_kind_at(parsed, idx)
            let origin = tool_origin_at(parsed, idx)
            if origin == "custom" {
                custom = custom + 1
            } else {
                builtin = builtin + 1
            }
            if kind == "process" {
                process_tools = process_tools + 1
            }
            if kind == "workflow" {
                workflow_tools = workflow_tools + 1
            }
            if kind == "browser" {
                browser_tools = browser_tools + 1
            }
            if kind == "docs" {
                docs_tools = docs_tools + 1
            }
            if tool_health_at(parsed, idx) == "ready" {
                healthy_tools = healthy_tools + 1
            }
            let raw = tool_raw_at(parsed, idx)
            if raw != "" {
                discard map.set(index, tool_id, json.raw(raw))
            }
            discard add_tool_to_arrays(parsed, idx, ids, search, browser, authoring, workflows)
        }
        idx = idx + 1
    }

    let mode_counts = model.types.registry_kind_counts_json(
        str.from_i32(process_tools),
        str.from_i32(workflow_tools),
        str.from_i32(browser_tools),
        str.from_i32(docs_tools),
    )
    let origin_counts = model.types.registry_origin_counts_json(
        str.from_i32(builtin),
        str.from_i32(custom),
    )
    let summary = model.types.registry_summary_json(str.from_i32(total), str.from_i32(healthy_tools), origin_counts, mode_counts, json.array(ids))
    let hints = model.types.registry_hints_json(json.array(search), json.array(browser), json.array(authoring), json.array(workflows))
    fs.write_file(summary_path(), summary)
    fs.write_file(tool_index_path(), json.object(index))
    fs.write_file(hints_path(), hints)
    return 0
}

fn rebuild_registry() -> i32 {
    ensure_state_dir()
    fs.write_file(registry_path(), build_registry_payload())
    return export_index_and_summary()
}

fn write_tools_array() -> i32 {
    let payload = fs.read_file(registry_path())
    if payload == "" {
        return 13
    }
    let parsed = json.parse(payload)
    let tools = json.get(parsed, "tools")
    let raw = json.get_str(tools, "raw")
    if raw == "" {
        return 13
    }
    fs.write_file(tools_array_path(), raw)
    return 0
}

fn refresh_derived_state() -> i32 {
    discard write_tools_array()
    return export_index_and_summary()
}

fn load_builtin() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    discard record_audit("load_builtin")
    return 0
}

fn register_tool() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    discard record_audit("register_tool")
    return 0
}

fn unregister_tool() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    discard record_audit("unregister_tool")
    return 0
}

fn update_tool() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    discard record_audit("update_tool")
    return 0
}

fn get_tool() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    return 0
}

fn get_tool_json(tool_id: str) -> str {
    discard get_tool()
    let payload = fs.read_file(tool_index_path())
    if payload == "" {
        return model.types.registry_lookup_error_json(tool_id, "registry_unavailable")
    }
    let parsed = json.parse(payload)
    let tool = json.get(parsed, tool_id)
    let raw = json.get_str(tool, "raw")
    if raw == "" {
        return model.types.registry_lookup_error_json(tool_id, "tool_missing")
    }
    return raw
}

fn list_tools() -> i32 {
    discard rebuild_registry()
    discard refresh_derived_state()
    return 0
}

fn list_tools_json() -> str {
    discard list_tools()
    let payload = fs.read_file(registry_path())
    if payload == "" {
        return registry_status("empty_registry")
    }
    return payload
}

fn refresh_runtime() -> i32 {
    discard rebuild_registry()
    discard record_audit("refresh_runtime")
    return 0
}

fn hot_reload() -> i32 {
    discard rebuild_registry()
    return 0
}

fn list_tool_definitions_json() -> str {
    discard list_tools()
    let path = if configured_provider_name() == "openai_compat" { openai_tools_array_path() } else { anthropic_tools_array_path() }
    let payload = fs.read_file(path)
    if payload == "" {
        return "[]"
    }
    return payload
}

fn append_provider_tool(items: ListHandle, tool_id: str, description: str, input_schema_json: str) -> i32 {
    let encoded = if configured_provider_name() == "openai_compat" {
        openai_tool_json(tool_id, description, input_schema_json)
    } else {
        anthropic_tool_json(tool_id, description, input_schema_json)
    }
    discard list.push(items, json.raw(encoded))
    return 0
}

fn longrange_planning_tool_definitions_json() -> str {
    let items = list.new()
    let plan_write_schema = tool_schema_plan_write()
    discard append_provider_tool(items, "plan_create", "Create the durable plan and success criteria for the active long-range run.", plan_write_schema)
    return json.array(items)
}

fn longrange_execution_tool_definitions_json() -> str {
    let items = list.new()
    let command_schema = tool_schema_command()
    let grep_schema = tool_schema_grep()
    let plan_update_schema = tool_schema_plan_update_compact()
    let goal_complete_schema = tool_schema_goal_complete()
    discard append_provider_tool(items, "bash", "Run a shell command in the shared workspace.", command_schema)
    discard append_provider_tool(items, "grep_search", "Search the workspace with grep.", grep_schema)
    discard append_provider_tool(items, "plan_update", "Update the durable plan and current step for the active long-range run.", plan_update_schema)
    discard append_provider_tool(items, "goal_complete", "Mark the active long-range run fully complete.", goal_complete_schema)
    return json.array(items)
}

fn evict_stale() -> i32 {
    discard audit_evict()
    return 0
}

fn planner_hints() -> i32 {
    if fs.exists(hints_path()) == 0 {
        discard export_index_and_summary()
    }
    return 4
}

fn metadata_contract() -> i32 {
    if fs.exists(summary_path()) == 0 {
        discard export_index_and_summary()
    }
    return 0
}

fn planner_hints_json() -> str {
    discard planner_hints()
    let payload = fs.read_file(hints_path())
    if payload == "" {
        return registry_status("missing_hints")
    }
    return payload
}

fn summary_json() -> str {
    discard metadata_contract()
    let payload = fs.read_file(summary_path())
    if payload == "" {
        return registry_status("missing_summary")
    }
    return payload
}

fn heartbeat() -> i32 {
    discard export_index_and_summary()
    discard record_audit("heartbeat")
    return 0
}

fn record_invocation_decision() -> i32 {
    discard record_audit("record_invocation_decision")
    return 0
}

fn audit_register() -> i32 {
    return record_audit("audit_register")
}

fn audit_unregister() -> i32 {
    return record_audit("audit_unregister")
}

fn audit_update() -> i32 {
    return record_audit("audit_update")
}

fn audit_evict() -> i32 {
    return record_audit("audit_evict")
}

fn record_audit(event: str) -> i32 {
    ensure_state_dir()
    let line = model.types.audit_record_json(event, model.types.control_ok_label(), str.from_i32(time.now()), summary_path())
    discard storage.atomic_append(audit_path(), line)
    return 0
}
fn join_path(base: str, leaf: str) -> str {
    if base == "" {
        return leaf
    }
    if str.ends_with(base, "/") == 1 {
        return str.concat(base, leaf)
    }
    return str.concat(base, "/", leaf)
}
