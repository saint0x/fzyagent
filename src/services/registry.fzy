use core.fs;
use core.io;
use core.path;
use core.storage;
use core.time;

fn registry_path() -> str {
    return "/tmp/fzyagent/registry.json"
}

fn tools_array_path() -> str {
    return "/tmp/fzyagent/registry.tools.json"
}

fn anthropic_tools_array_path() -> str {
    return "/tmp/fzyagent/registry.anthropic.tools.json"
}

fn summary_path() -> str {
    return "/tmp/fzyagent/registry.summary.json"
}

fn tool_index_path() -> str {
    return "/tmp/fzyagent/registry.by_id.json"
}

fn hints_path() -> str {
    return "/tmp/fzyagent/registry.hints.json"
}

fn audit_path() -> str {
    return "/tmp/fzyagent/registry.audit.log"
}

fn ensure_state_dir() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    return 0
}

fn custom_tools_root() -> str {
    return "/Users/deepsaint/Desktop/fzyagent/custom_tools"
}

fn default_input_schema() -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw("{}"))
    return json.object(schema)
}

fn built_tool_json(tool_id: str, description: str, kind: str, mode: str, execution_model: str, supports_sequence: str, supports_parallel: str, input_schema_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "id", json.str(tool_id))
    discard map.set(payload, "name", json.str(tool_id))
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "kind", json.str(kind))
    discard map.set(payload, "health", json.str("ready"))
    discard map.set(payload, "mode", json.str(mode))
    discard map.set(payload, "origin", json.str("builtin"))
    discard map.set(payload, "execution_model", json.str(execution_model))
    discard map.set(payload, "supports_sequence", json.raw(supports_sequence))
    discard map.set(payload, "supports_parallel", json.raw(supports_parallel))
    discard map.set(payload, "rpc_protocol", json.str(api.rpc.tool_protocol_version()))
    discard map.set(payload, "transport", json.str("http+routed-rpc"))
    discard map.set(payload, "input_schema", json.raw(input_schema_json))
    return json.object(payload)
}

fn anthropic_tool_json(tool_id: str, description: str, input_schema_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "name", json.str(tool_id))
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "input_schema", json.raw(input_schema_json))
    return json.object(payload)
}

fn custom_tool_json(tool_id: str, description: str, kind: str, mode: str, input_schema_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "id", json.str(tool_id))
    discard map.set(payload, "name", json.str(tool_id))
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "kind", json.str(kind))
    discard map.set(payload, "health", json.str("ready"))
    discard map.set(payload, "mode", json.str(mode))
    discard map.set(payload, "origin", json.str("custom"))
    discard map.set(payload, "execution_model", json.str("single"))
    discard map.set(payload, "supports_sequence", json.raw("true"))
    discard map.set(payload, "supports_parallel", json.raw("true"))
    discard map.set(payload, "rpc_protocol", json.str(api.rpc.tool_protocol_version()))
    discard map.set(payload, "transport", json.str("http+routed-rpc"))
    discard map.set(payload, "input_schema", json.raw(input_schema_json))
    return json.object(payload)
}

fn append_tool_pair(tools: ListHandle, anthropic: ListHandle, tool_json: str, anthropic_json: str) -> i32 {
    discard list.push(tools, json.raw(tool_json))
    discard list.push(anthropic, json.raw(anthropic_json))
    return 0
}

fn tool_schema_command() -> str {
    let properties = map.new()
    discard map.set(properties, "command", json.raw(util.json_obj1("type", json.str("string"))))
    let required = list.new()
    discard list.push(required, json.str("command"))
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    discard map.set(schema, "required", json.raw(json.array(required)))
    return json.object(schema)
}

