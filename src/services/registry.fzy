    let properties = map.new()
    discard map.set(properties, "pattern", json.raw(util.json_obj1("type", json.str("string"))))
    discard map.set(properties, "target", json.raw(util.json_obj1("type", json.str("string"))))
    let required = list.new()
    discard list.push(required, json.str("pattern"))
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    discard map.set(schema, "required", json.raw(json.array(required)))
    return json.object(schema)
}

fn tool_schema_steps() -> str {
    let step_properties = map.new()
    discard map.set(step_properties, "step_id", json.raw(util.json_obj1("type", json.str("string"))))
    discard map.set(step_properties, "tool_id", json.raw(util.json_obj1("type", json.str("string"))))
    discard map.set(step_properties, "tool_input", json.raw(util.json_obj1("type", json.str("object"))))
    let step_required = list.new()
    discard list.push(step_required, json.str("tool_id"))
    let step_item = map.new()
    discard map.set(step_item, "type", json.str("object"))
    discard map.set(step_item, "properties", json.raw(json.object(step_properties)))
    discard map.set(step_item, "required", json.raw(json.array(step_required)))
    let properties = map.new()
    discard map.set(properties, "steps", json.raw(util.json_obj2("type", json.str("array"), "items", json.raw(json.object(step_item)))))
    let required = list.new()
    discard list.push(required, json.str("steps"))
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    discard map.set(schema, "required", json.raw(json.array(required)))
    return json.object(schema)
}

