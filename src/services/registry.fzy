use core.fs;
use core.storage;
use core.time;

fn registry_path() -> str {
    return "/tmp/fzyagent/registry.json"
}

fn tools_array_path() -> str {
    return "/tmp/fzyagent/registry.tools.json"
}

fn anthropic_tools_array_path() -> str {
    return "/tmp/fzyagent/registry.anthropic.tools.json"
}

fn openai_tools_array_path() -> str {
    return "/tmp/fzyagent/registry.openai_compat.tools.json"
}

fn summary_path() -> str {
    return "/tmp/fzyagent/registry.summary.json"
}

fn tool_index_path() -> str {
    return "/tmp/fzyagent/registry.by_id.json"
}

fn hints_path() -> str {
    return "/tmp/fzyagent/registry.hints.json"
}

fn audit_path() -> str {
    return "/tmp/fzyagent/registry.audit.log"
}

fn configured_provider_name() -> str {
    let provider = env.get("AGENT_PROVIDER")
    if provider == "openai" || provider == "openai_compat" || provider == "local" || provider == "local_openai" {
        return "openai_compat"
    }
    return "anthropic"
}

fn ensure_state_dir() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    return 0
}

fn custom_tools_root() -> str {
    return "/Users/deepsaint/Desktop/fzyagent/custom_tools"
}

fn default_input_schema() -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw("{}"))
    return json.object(schema)
}

fn schema_string_json() -> str {
    return apputil.json_obj1("type", json.str("string"))
}

fn schema_object_json() -> str {
    return apputil.json_obj1("type", json.str("object"))
}

fn schema_array_items_json(items_json: str) -> str {
    return apputil.json_obj2("type", json.str("array"), "items", json.raw(items_json))
}

fn required1(a: str) -> ListHandle {
    let required = list.new()
    discard list.push(required, json.str(a))
    return required
}

fn object_schema_json(properties: MapHandle, required: ListHandle) -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    if list.len(required) > 0 {
        discard map.set(schema, "required", json.raw(json.array(required)))
    }
    return json.object(schema)
}

fn built_tool_json(tool_id: str, description: str, kind: str, mode: str, execution_model: str, supports_sequence: str, supports_parallel: str, input_schema_json: str) -> str {
    return model.types.registry_tool_json(tool_id, description, kind, "ready", mode, "builtin", execution_model, supports_sequence, supports_parallel, api.rpc.tool_protocol_version(), "http+native-rpc", input_schema_json)
}

fn anthropic_tool_json(tool_id: str, description: str, input_schema_json: str) -> str {
    return model.types.provider_tool_json(tool_id, description, input_schema_json)
}

fn openai_tool_json(tool_id: str, description: str, input_schema_json: str) -> str {
    return model.types.provider_tool_json_openai(tool_id, description, input_schema_json)
}

fn custom_tool_json(tool_id: str, description: str, kind: str, mode: str, input_schema_json: str) -> str {
    return model.types.registry_tool_json(tool_id, description, kind, "ready", mode, "custom", "single", "true", "true", api.rpc.tool_protocol_version(), "http+native-rpc", input_schema_json)
}

fn append_tool_triplet(tools: ListHandle, anthropic: ListHandle, openai: ListHandle, tool_json: str, anthropic_json: str, openai_json: str) -> i32 {
    discard list.push(tools, json.raw(tool_json))
    discard list.push(anthropic, json.raw(anthropic_json))
    discard list.push(openai, json.raw(openai_json))
    return 0
}

fn tool_schema_command() -> str {
    let properties = map.new()
    discard map.set(properties, "command", json.raw(schema_string_json()))
    return object_schema_json(properties, required1("command"))
}

fn tool_schema_grep() -> str {
    let properties = map.new()
    discard map.set(properties, "pattern", json.raw(schema_string_json()))
    discard map.set(properties, "target", json.raw(schema_string_json()))
    return object_schema_json(properties, required1("pattern"))
}

fn tool_schema_queue_enqueue() -> str {
    let properties = map.new()
    discard map.set(properties, "queue_tool_id", json.raw(schema_string_json()))
    discard map.set(properties, "queued_run_id", json.raw(schema_string_json()))
    discard map.set(properties, "input", json.raw(schema_object_json()))
    return object_schema_json(properties, required1("queue_tool_id"))
}

fn tool_schema_steps() -> str {
    let step_properties = map.new()
    discard map.set(step_properties, "step_id", json.raw(schema_string_json()))
    discard map.set(step_properties, "tool_id", json.raw(schema_string_json()))
    discard map.set(step_properties, "input", json.raw(schema_object_json()))
    let step_item = object_schema_json(step_properties, required1("tool_id"))
    let properties = map.new()
    discard map.set(properties, "steps", json.raw(schema_array_items_json(step_item)))
    return object_schema_json(properties, required1("steps"))
}

