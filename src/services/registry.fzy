use core.fs;
use core.proc;
use core.time;

fn registry_path() -> str {
    return "/tmp/fzyagent/registry.json"
}

fn tools_array_path() -> str {
    return "/tmp/fzyagent/registry.tools.json"
}

fn anthropic_tools_array_path() -> str {
    return "/tmp/fzyagent/registry.anthropic.tools.json"
}

fn audit_path() -> str {
    return "/tmp/fzyagent/registry.audit.log"
}

fn ensure_state_dir() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    return 0
}

fn default_proc_env() -> ProcessEnv {
    let env_map: ProcessEnv = proc.env_new()
    discard proc.env_set(env_map, "TERM", "dumb")
    return env_map
}

fn shell_argv(command: str) -> ProcessArgv {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, "-lc")
    discard proc.argv_push(argv, command)
    return argv
}

fn rebuild_registry() -> i32 {
    ensure_state_dir()
    let env_map = default_proc_env()
    let argv = shell_argv("python3 /Users/deepsaint/Desktop/fzyagent/scripts/custom_tool_registry.py")
    let handle = proc.spawn_cmd("/bin/sh", argv, env_map, "")
    discard proc.wait(handle, 15000)
    let exit_code = proc.exit_code(handle)
    if exit_code != 0 {
        let stdout = proc.stdout(handle)
        if stdout != "" {
            fs.write_file(registry_path(), stdout)
        }
        return 13
    }
    return 0
}

fn write_tools_array() -> i32 {
    let payload = fs.read_file(registry_path())
    if payload == "" {
        return 13
    }
    let parsed = json.parse(payload)
    let tools = json.get(parsed, "tools")
    let raw = json.get_str(tools, "raw")
    if raw == "" {
        return 13
    }
    fs.write_file(tools_array_path(), raw)
    return 0
}

fn load_builtin() -> i32 {
    rebuild_registry()
    write_tools_array()
    record_audit("load_builtin")
    register_tool()
    return 0
}

fn register_tool() -> i32 {
    rebuild_registry()
    write_tools_array()
    record_audit("register_tool")
    return 0
}

fn unregister_tool() -> i32 {
    rebuild_registry()
    write_tools_array()
    record_audit("unregister_tool")
    return 0
}

fn update_tool() -> i32 {
    rebuild_registry()
    write_tools_array()
    record_audit("update_tool")
    return 0
}

fn get_tool() -> i32 {
    rebuild_registry()
    return 0
}

fn list_tools() -> i32 {
    rebuild_registry()
    write_tools_array()
    return 0
}

fn list_tools_json() -> str {
    list_tools()
    let payload = fs.read_file(registry_path())
    if payload == "" {
        rebuild_registry()
        return fs.read_file(registry_path())
    }
    return payload
}

fn refresh_runtime() -> i32 {
    hot_reload()
    fs.flush()
    record_audit("refresh_runtime")
    return 0
}

fn hot_reload() -> i32 {
    rebuild_registry()
    write_tools_array()
    return 0
}

fn list_tool_definitions_json() -> str {
    list_tools()
    let payload = fs.read_file(anthropic_tools_array_path())
    if payload == "" {
        write_tools_array()
        return fs.read_file(anthropic_tools_array_path())
    }
    return payload
}

fn evict_stale() -> i32 {
    fs.flush()
    audit_evict()
    return 0
}

fn planner_hints() -> i32 {
    metadata_contract()
    return 1
}

fn metadata_contract() -> i32 {
    return 0
}

fn heartbeat() -> i32 {
    record_audit("heartbeat")
    fs.flush()
    return 0
}

fn record_invocation_decision() -> i32 {
    record_audit("record_invocation_decision")
    return 0
}

fn audit_register() -> i32 {
    record_audit("audit_register")
    return 0
}

fn audit_unregister() -> i32 {
    record_audit("audit_unregister")
    return 0
}

fn audit_update() -> i32 {
    record_audit("audit_update")
    return 0
}

fn audit_evict() -> i32 {
    record_audit("audit_evict")
    return 0
}

fn record_audit(event: str) -> i32 {
    ensure_state_dir()
    discard time.now()
    let line = util.json_obj3("event", json.str(event), "status", json.str("ok"), "clock", json.str("sampled"))
    fs.write_file(audit_path(), line)
    return 0
}
