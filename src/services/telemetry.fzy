use core.time;
use core.fs;

fn telemetry_path() -> str {
    return "/tmp/fzyagent/telemetry.last.json"
}

fn boot_metrics() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    discard time.now()
    let runtime = util.json_obj3(
        "workers", json.str(env.get("AGENT_WORKERS")),
        "host", json.str(env.get("AGENT_HOST")),
        "port", json.str(env.get("AGENT_PORT")),
    )
    let payload = util.json_obj4("event", json.str("boot_metrics"), "status", json.str("ok"), "clock", json.str("sampled"), "runtime", json.raw(runtime))
    fs.write_file(telemetry_path(), payload)
    return 0
}

fn emit_turn_latency() -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    discard time.now()
    let payload = util.json_obj3("event", json.str("emit_turn_latency"), "status", json.str("ok"), "clock", json.str("sampled"))
    fs.write_file(telemetry_path(), payload)
    return 0
}
