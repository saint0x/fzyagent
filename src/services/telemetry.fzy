use core.time;
use core.fs;

fn telemetry_path() -> str {
    return "/tmp/fzyagent/telemetry.last.json"
}

fn boot_metrics() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    discard time.now()
    let runtime = model.types.telemetry_runtime_json(env.get("AGENT_WORKERS"), env.get("AGENT_HOST"), env.get("AGENT_PORT"))
    let payload = model.types.telemetry_payload_json("boot_metrics", "ok", "sampled", runtime)
    fs.write_file(telemetry_path(), payload)
    return 0
}

fn emit_turn_latency() -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    discard time.now()
    let payload = model.types.telemetry_payload_json("emit_turn_latency", "ok", "sampled", "")
    fs.write_file(telemetry_path(), payload)
    return 0
}
