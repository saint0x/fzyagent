    return plan_difficulty(json.parse(load_plan_json(run_id)))
}

fn estimated_effort(run_id: str) -> str {
    return plan_estimated_effort(json.parse(load_plan_json(run_id)))
}

fn expected_total_turns_text(run_id: str) -> str {
    return str.from_i32(expected_total_turns(run_id))
}

fn prompt_context(session_id: str) -> str {
    if has_active_run_for_session(session_id) == 0 {
        return ""
    }
    let run_id = active_run_id_for_session(session_id)
    let state_payload = load_state_json(run_id)
    let state_parsed = json.parse(state_payload)
    let plan_payload = load_plan_json(run_id)
    let plan_parsed = json.parse(plan_payload)
    let mut out = "ACTIVE LONG RANGE RUN\n"
    out = str.concat(out, str.concat("run_id: ", run_id))
    out = str.concat(out, str.concat("\nrun_status: ", state_status(state_parsed)))
    out = str.concat(out, str.concat("\nplan_status: ", state_plan_status(state_parsed)))
    out = str.concat(out, str.concat("\ntask_class: ", task_class(run_id)))
    out = str.concat(out, str.concat("\nexecution_outlook: ", execution_outlook(run_id)))
    out = str.concat(out, str.concat("\nplanning_style: ", planning_style(run_id)))
    out = str.concat(out, str.concat("\nexpected_total_turns: ", expected_total_turns_text(run_id)))
    out = str.concat(out, str.concat("\ncurrent_step: ", current_step_id(run_id)))
    out = str.concat(out, str.concat("\ncurrent_step_type: ", current_step_type(run_id)))
    out = str.concat(out, str.concat("\nevidence_mode: ", current_step_evidence_mode(run_id)))
    out = str.concat(out, str.concat("\ncurrent_step_outlook: ", current_step_outlook(run_id)))
    out = str.concat(out, str.concat("\ncurrent_step_target_turns: ", str.from_i32(current_step_target_turns(run_id))))
    out = str.concat(out, str.concat("\ngoal_summary: ", plan_goal_summary(plan_parsed)))
    out = str.concat(out, str.concat("\nfinished_definition: ", plan_finished_definition(plan_parsed)))
    out = str.concat(out, str.concat("\nplan_summary: ", plan_summary_value(plan_parsed)))
    out = str.concat(out, str.concat("\nlatest_summary: ", state_latest_summary(state_parsed)))
    return out
}
