fn meta_json(session_id: str, goal: str, created_at: str) -> str {
    let payload = map.new()
    discard map.set(payload, "session_id", json.str(session_id))
    discard map.set(payload, "goal", json.str(goal))
    discard map.set(payload, "created_at", json.str(created_at))
    return json.object(payload)
}

fn first_non_empty2(primary: str, fallback: str) -> str {
    if primary != "" {
        return primary
    }
    return fallback
}

fn first_non_empty3(primary: str, fallback_a: str, fallback_b: str) -> str {
    if primary != "" {
        return primary
    }
    if fallback_a != "" {
        return fallback_a
    }
    return fallback_b
}

fn contains_any(text_value: str, a: str, b: str, c: str, d: str) -> i32 {
    let hay = apputil.lower_ascii(text_value)
    if a != "" && str.contains(hay, a) == 1 {
        return 1
    }
    if b != "" && str.contains(hay, b) == 1 {
        return 1
    }
    if c != "" && str.contains(hay, c) == 1 {
        return 1
    }
    if d != "" && str.contains(hay, d) == 1 {
        return 1
    }
    return 0
}

fn classify_goal(goal: str) -> str {
    let lowered = apputil.lower_ascii(goal)
    let mut file_mentions: i32 = 0
    let mut idx: i32 = 0
    while idx < str.len(lowered) - 3 {
        if str.slice(lowered, idx, idx + 4) == ".fzy" {
            file_mentions = file_mentions + 1
        }
        idx = idx + 1
    }
    if contains_any(lowered, "tiny", "simple", "minimal", "checklist") == 1 && file_mentions == 0 {
        return "micro"
    }
    if file_mentions >= 4 || contains_any(lowered, "architecture", "bottleneck", "end-to-end", "complex") == 1 {
        return "deep"
    }
    return "standard"
}

fn default_completion_mode(task_class: str, goal: str) -> str {
    let lowered = apputil.lower_ascii(goal)
    if contains_any(lowered, "summary", "summarize", "inspection", "inspect") == 1 {
        return "summary"
    }
    if task_class == "micro" {
        return "direct"
    }
    return "verified"
}

fn normalize_completion_mode(mode: str, task_class: str, goal: str) -> str {
    let lowered = apputil.lower_ascii(mode)
    if lowered == "direct" || lowered == "summary" || lowered == "verified" {
        return lowered
    }
    if contains_any(lowered, "summary", "structure", "defined", "inspect") == 1 {
        return "summary"
    }
    if contains_any(lowered, "verify", "verified", "proof", "validation") == 1 {
        return "verified"
    }
    if contains_any(lowered, "direct", "immediate", "fast", "tight") == 1 {
        return "direct"
    }
    return default_completion_mode(task_class, goal)
}

fn default_expected_total_turns(task_class: str, goal: str) -> str {
    let lowered = apputil.lower_ascii(goal)
    if task_class == "micro" {
        return "2"
    }
    if contains_any(lowered, "architecture", "end-to-end", "benchmark", "stress") == 1 {
        return "10"
    }
    if task_class == "deep" {
        return "8"
    }
    return "5"
}

fn default_execution_outlook(task_class: str, goal: str) -> str {
    let lowered = apputil.lower_ascii(goal)
    if task_class == "micro" {
        return "tight direct finish"
    }
    if contains_any(lowered, "inspect", "summary", "summarize", "review") == 1 {
        return "light inspect then summarize"
    }
    if task_class == "deep" {
        return "iterative deep work with checkpoints"
    }
    return "adaptive multi-step execution"
}

fn default_planning_style(task_class: str) -> str {
    if task_class == "micro" {
        return "lightweight"
    }
    if task_class == "deep" {
        return "deliberate"
    }
    return "adaptive"
}

fn infer_step_type(step_id: str, title: str, description: str) -> str {
    let probe = apputil.lower_ascii(str.concat3(step_id, " ", str.concat(title, " ", description)))
    if contains_any(probe, "summary", "summarize", "synthesize", "document") == 1 {
        return "summarize"
    }
    if contains_any(probe, "verify", "test", "check", "validate") == 1 {
        return "verify"
    }
    if contains_any(probe, "implement", "fix", "edit", "build") == 1 || contains_any(probe, "execute", "apply", "change", "write") == 1 {
        return "execute"
    }
    return "inspect"
}

fn default_evidence_mode(step_type: str) -> str {
    if step_type == "execute" || step_type == "verify" {
        return "tool"
    }
    if step_type == "summarize" {
        return "summary"
    }
    return "tool_or_summary"
}

fn default_completion_signal(step_type: str, task_class: str) -> str {
    if step_type == "summarize" {
        return "goal_complete"
    }
    if task_class == "micro" {
        return "plan_update_or_goal_complete"
    }
    return "plan_update"
}

fn default_step_outlook(step_type: str, task_class: str) -> str {
    if step_type == "summarize" {
        return "close the loop cleanly"
    }
    if step_type == "verify" {
        return "gather direct proof before moving on"
    }
    if step_type == "execute" {
        if task_class == "micro" {
            return "single concrete action"
        }
        return "real work before plan narration"
    }
    return "gather evidence and refine understanding"
}

fn default_step_target_turns(step_type: str, task_class: str) -> str {
    if step_type == "summarize" || step_type == "verify" {
        return "1"
    }
    if step_type == "execute" {
        if task_class == "deep" {
            return "3"
        }
        return "2"
    }
    if task_class == "deep" {
        return "3"
    }
    return "2"
}

fn load_meta_json(run_id: str) -> str {
    discard ensure_run(run_id)
    let payload = safe_read(run_meta_path(run_id))
    if corrupt_json(payload) == 1 {
        return meta_json("", "", "")
    }
    return payload
}

fn save_meta(run_id: str, session_id: str, goal: str, created_at: str) -> i32 {
    discard ensure_run(run_id)
    let current = json.parse(load_meta_json(run_id))
    let next_session_id = if session_id == "" { meta_session_id(current) } else { session_id }
    let next_goal = if goal == "" { meta_goal(current) } else { goal }
    let next_created_at = if created_at == "" { meta_created_at(current) } else { created_at }
    discard atomic_write_text(run_meta_path(run_id), meta_json(next_session_id, next_goal, next_created_at))
    discard atomic_write_text(run_session_id_path(run_id), next_session_id)
    discard atomic_write_text(run_goal_path(run_id), next_goal)
    discard atomic_write_text(run_created_at_path(run_id), next_created_at)
    return 0
}

fn persisted_state_or_empty(run_id: str) -> JsonHandle {
    let payload = safe_read(run_state_path(run_id))
    if corrupt_json(payload) == 1 {
        return json.parse("{}")
    }
    let parsed = json.parse(payload)
    if json.get_str(parsed, "run_id") == "" {
        return json.parse("{}")
    }
    return parsed
}

fn persisted_plan_or_empty(run_id: str) -> JsonHandle {
    let payload = safe_read(run_plan_path(run_id))
    if corrupt_json(payload) == 1 {
        return json.parse("{}")
    }
    let parsed = json.parse(payload)
    if json.get_str(parsed, "run_id") == "" {
        return json.parse("{}")
    }
    return parsed
}

fn inferred_plan_status(run_id: str, current_value: str) -> str {
    if current_value != "" && current_value != "missing" {
        return current_value
    }
    let plan = persisted_plan_or_empty(run_id)
    if json.get_str(plan, "run_id") != "" && plan_goal_summary(plan) != "" {
        return "ready"
    }
    return "missing"
}

fn save_state(run_id: str, patch_json: str) -> i32 {
    discard ensure_run(run_id)
    let current_raw = load_state_json(run_id)
    if looks_like_object_json(patch_json) == 0 {
        log.error(
            "services.longrange save_state_bad_patch",
            apputil.log_fields3("run_id", run_id, "bytes", str.from_i32(str.len(patch_json)), "head", apputil.excerpt_head(patch_json, 220))
        )
    }
    let next_session_id = first_non_empty3(quoted_json_field(patch_json, "session_id"), raw_state_field(current_raw, "session_id"), meta_session_id_text(run_id))
    let next_goal = first_non_empty3(quoted_json_field(patch_json, "goal"), raw_state_field(current_raw, "goal"), meta_goal_text(run_id))
    let requested_status = first_non_empty2(quoted_json_field(patch_json, "run_status"), raw_state_field(current_raw, "run_status"))
    let next_plan_status = inferred_plan_status(run_id, first_non_empty2(quoted_json_field(patch_json, "plan_status"), raw_state_field(current_raw, "plan_status")))
    let next_created_at = first_non_empty3(quoted_json_field(patch_json, "created_at"), raw_state_field(current_raw, "created_at"), meta_created_at_text(run_id))
    let next_completed_at = first_non_empty2(quoted_json_field(patch_json, "completed_at"), raw_state_field(current_raw, "completed_at"))
    let next_task_class = first_non_empty3(quoted_json_field(patch_json, "task_class"), raw_state_field(current_raw, "task_class"), classify_goal(next_goal))
    let next_turns_completed = first_non_empty2(quoted_json_field(patch_json, "turns_completed"), raw_state_field(current_raw, "turns_completed"))
    let next_failure_count = first_non_empty2(quoted_json_field(patch_json, "failure_count"), raw_state_field(current_raw, "failure_count"))
    let next_auto_continue_pending = first_non_empty2(quoted_json_field(patch_json, "auto_continue_pending"), raw_state_field(current_raw, "auto_continue_pending"))
    let next_active_message_kind = first_non_empty2(quoted_json_field(patch_json, "active_message_kind"), raw_state_field(current_raw, "active_message_kind"))
    let next_latest_summary = first_non_empty2(quoted_json_field(patch_json, "latest_summary"), raw_state_field(current_raw, "latest_summary"))
    let next_current_step_id = first_non_empty2(quoted_json_field(patch_json, "current_step_id"), raw_state_field(current_raw, "current_step_id"))
    let next_last_request_id = first_non_empty2(quoted_json_field(patch_json, "last_request_id"), raw_state_field(current_raw, "last_request_id"))
    let next_last_progress_score = first_non_empty2(quoted_json_field(patch_json, "last_progress_score"), first_non_empty2(raw_state_field(current_raw, "last_progress_score"), "0"))
    let next_consecutive_low_score = first_non_empty2(quoted_json_field(patch_json, "consecutive_low_score"), first_non_empty2(raw_state_field(current_raw, "consecutive_low_score"), "0"))
    let next_last_evidence_count = first_non_empty2(quoted_json_field(patch_json, "last_evidence_count"), first_non_empty2(raw_state_field(current_raw, "last_evidence_count"), "0"))
    let next_completed_step_count = first_non_empty2(quoted_json_field(patch_json, "completed_step_count"), first_non_empty2(raw_state_field(current_raw, "completed_step_count"), "0"))
    if requested_status == "" {
        log.error(
            "services.longrange save_state_empty_status",
            apputil.log_fields3("run_id", run_id, "patch_head", apputil.excerpt_head(patch_json, 220), "current_head", apputil.excerpt_head(current_raw, 220))
        )
        discard atomic_write_text(debug_payload_path(run_id, "state.patch.bad.json"), patch_json)
    }
    log.info(
        "services.longrange save_state",
        apputil.log_fields3("run_id", run_id, "status", requested_status, "turns", next_turns_completed)
    )
    discard append_state_debug(run_id, "save_state_input", requested_status, next_turns_completed, next_plan_status)
    let payload = state_doc_json(
        run_id,
        next_session_id,
        next_goal,
        requested_status,
        next_plan_status,
        next_task_class,
        next_turns_completed,
        next_failure_count,
        next_last_progress_score,
        next_consecutive_low_score,
        next_last_evidence_count,
        next_completed_step_count,
        next_auto_continue_pending,
        next_active_message_kind,
        next_latest_summary,
        next_created_at,
        now_label(),
        next_current_step_id,
        next_last_request_id,
        next_completed_at,
    )
    return write_state_payload(run_id, payload)
}

fn reconciled_terminal_state_payload(run_id: str, session_id: str, goal: str, status: str, plan_status: str, current_step_id: str, last_request_id: str, turns_completed: str, failure_count: str, active_message_kind: str, latest_summary: str, created_at: str, completed_at: str) -> str {
    let current_raw = load_state_json(run_id)
    let plan = persisted_plan_or_empty(run_id)
    let next_session_id = first_non_empty3(session_id, raw_state_field(current_raw, "session_id"), meta_session_id_text(run_id))
    let next_goal = first_non_empty3(goal, raw_state_field(current_raw, "goal"), meta_goal_text(run_id))
    let next_plan_status = inferred_plan_status(run_id, first_non_empty2(plan_status, raw_state_field(current_raw, "plan_status")))
    let next_current_step_id = first_non_empty3(current_step_id, raw_state_field(current_raw, "current_step_id"), plan_current_step_id(plan))
    let next_created_at = first_non_empty3(created_at, raw_state_field(current_raw, "created_at"), meta_created_at_text(run_id))
    let next_turns = if turns_completed == "" {
        str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(current_raw, "turns_completed"), "0")), persisted_turn_event_count(run_id)))
    } else {
        turns_completed
    }
    let next_failures = if failure_count == "" {
        str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(current_raw, "failure_count"), "0")), persisted_failure_turn_count(run_id)))
    } else {
        failure_count
    }
    let next_task_class = first_non_empty3(raw_state_field(current_raw, "task_class"), plan_task_class(plan), classify_goal(next_goal))
    let next_completed_steps = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(current_raw, "completed_step_count"), "0")), completed_step_count(run_id)))
    return state_doc_json(
        run_id,
        next_session_id,
        next_goal,
        status,
        next_plan_status,
        next_task_class,
        next_turns,
        next_failures,
        first_non_empty2(raw_state_field(current_raw, "last_progress_score"), "0"),
        first_non_empty2(raw_state_field(current_raw, "consecutive_low_score"), "0"),
        first_non_empty2(raw_state_field(current_raw, "last_evidence_count"), "0"),
        next_completed_steps,
        "false",
        active_message_kind,
        latest_summary,
        next_created_at,
        now_label(),
        next_current_step_id,
        last_request_id,
        completed_at,
    )
}

fn save_plan(run_id: str, goal_summary: str, finished_definition: str, difficulty: str, estimated_effort: str, current_step_id: str, plan_summary: str, steps_json: str, task_class: str, completion_mode: str, expected_total_turns: str, execution_outlook: str, planning_style: str) -> i32 {
    discard ensure_run(run_id)
    discard mark_stage(run_id, "save_plan.enter")
    let current = persisted_plan_or_empty(run_id)
    let next_goal_summary = if goal_summary == "" { plan_goal_summary(current) } else { goal_summary }
    let next_finished_definition = if finished_definition == "" { plan_finished_definition(current) } else { finished_definition }
    let next_difficulty = if difficulty == "" { plan_difficulty(current) } else { difficulty }
    let next_estimated_effort = if estimated_effort == "" { plan_estimated_effort(current) } else { estimated_effort }
    let next_current_step_id = if current_step_id == "" { plan_current_step_id(current) } else { current_step_id }
    let next_plan_summary = if plan_summary == "" { plan_summary_value(current) } else { plan_summary }
    let next_steps_json = if steps_json == "" { plan_steps_raw(current) } else { steps_json }
    discard mark_stage(run_id, "save_plan.before_load_state")
    let state = json.parse(load_state_json(run_id))
    discard mark_stage(run_id, "save_plan.after_load_state")
    let next_task_class = first_non_empty3(task_class, plan_task_class(current), state_task_class(state))
    let effective_task_class = if next_task_class == "" { classify_goal(state_goal(state)) } else { next_task_class }
    let raw_completion_mode = first_non_empty3(completion_mode, plan_completion_mode(current), default_completion_mode(effective_task_class, state_goal(state)))
    let next_completion_mode = normalize_completion_mode(raw_completion_mode, effective_task_class, state_goal(state))
    let next_expected_total_turns = first_non_empty3(expected_total_turns, plan_expected_total_turns(current), default_expected_total_turns(effective_task_class, state_goal(state)))
    let next_execution_outlook = first_non_empty3(execution_outlook, plan_execution_outlook(current), default_execution_outlook(effective_task_class, state_goal(state)))
    let next_planning_style = first_non_empty3(planning_style, plan_planning_style(current), default_planning_style(effective_task_class))
    let payload = model.types.longrange_plan_json(
        run_id,
        next_goal_summary,
        next_finished_definition,
        next_difficulty,
        next_estimated_effort,
        next_current_step_id,
        next_plan_summary,
        if next_steps_json == "" { "[]" } else { next_steps_json },
        now_label(),
        effective_task_class,
        next_completion_mode,
        next_expected_total_turns,
        next_execution_outlook,
        next_planning_style,
    )
    if plan_payload_valid(payload) == 0 {
        discard mark_stage(run_id, "save_plan.invalid_payload")
        log.error(
            "services.longrange invalid_plan_payload",
            apputil.log_fields3("run_id", run_id, "bytes", str.from_i32(str.len(payload)), "head", apputil.excerpt_head(payload, 220))
        )
        discard atomic_write_text(debug_payload_path(run_id, "plan.invalid.json"), payload)
        return 1
    }
    let rc = atomic_write_text(run_plan_path(run_id), payload)
    if rc != 0 {
        discard mark_stage(run_id, "save_plan.write_failed")
        log.error(
            "services.longrange write_plan_failed",
            apputil.log_fields3("run_id", run_id, "code", str.from_i32(rc), "path", run_plan_path(run_id))
        )
        return 1
    }
    discard mark_stage(run_id, "save_plan.done")
    return 0
}

fn write_initial_plan(run_id: str, goal: str, task_class: str) -> i32 {
    discard ensure_run(run_id)
    let effective_task_class = if task_class == "" { classify_goal(goal) } else { task_class }
    let mut payload = "{"
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "goal_summary", "")
    payload = patch_add_field(payload, "finished_definition", "")
    payload = patch_add_field(payload, "difficulty", "")
    payload = patch_add_field(payload, "estimated_effort", "")
    payload = patch_add_field(payload, "task_class", effective_task_class)
    payload = patch_add_field(payload, "completion_mode", default_completion_mode(effective_task_class, goal))
    payload = patch_add_field(payload, "expected_total_turns", default_expected_total_turns(effective_task_class, goal))
    payload = patch_add_field(payload, "execution_outlook", default_execution_outlook(effective_task_class, goal))
    payload = patch_add_field(payload, "planning_style", default_planning_style(effective_task_class))
    payload = patch_add_field(payload, "plan_summary", "")
    payload = str.concat(payload, ",\"steps\":[]")
    payload = patch_add_field(payload, "updated_at", now_label())
    payload = patch_finish(payload)
    if plan_payload_valid(payload) == 0 {
        log.error(
            "services.longrange invalid_initial_plan_payload",
            apputil.log_fields3("run_id", run_id, "task_class", effective_task_class, "head", apputil.excerpt_head(payload, 220))
        )
        discard fs.write_file(runtime.config.state_path("last_invalid_initial_plan.json"), payload)
        return 1
    }
    return atomic_write_text(run_plan_path(run_id), payload)
}

fn write_terminal_state(run_id: str, session_id: str, goal: str, status: str, plan_status: str, current_step_id: str, last_request_id: str, turns_completed: str, failure_count: str, active_message_kind: str, latest_summary: str, created_at: str, completed_at: str) -> i32 {
    discard ensure_run(run_id)
    let payload = reconciled_terminal_state_payload(
        run_id,
        session_id,
        goal,
        status,
        plan_status,
        current_step_id,
        last_request_id,
        turns_completed,
        failure_count,
        active_message_kind,
        latest_summary,
        created_at,
        completed_at,
    )
    log.warn(
        "services.longrange terminal_payload",
        apputil.log_fields3("run_id", run_id, "status", status, "head", apputil.excerpt_head(payload, 220))
    )
    let debug_rc = atomic_write_text(debug_payload_path(run_id, "state.terminal.json"), payload)
    if debug_rc != 0 {
        log.error(
            "services.longrange write_terminal_state_debug_failed",
            apputil.log_fields3("run_id", run_id, "code", str.from_i32(debug_rc), "path", debug_payload_path(run_id, "state.terminal.json"))
        )
    }
    return write_state_payload(run_id, payload)
}

fn load_state_json(run_id: str) -> str {
    discard ensure_run(run_id)
    let payload = safe_read(run_state_path(run_id))
    if corrupt_json(payload) == 1 || quoted_json_field(payload, "run_status") == "" {
        log.warn(
            "services.longrange load_state_json_missing_or_corrupt",
            apputil.log_fields2("run_id", run_id, "head", apputil.excerpt_head(payload, 220))
        )
        discard atomic_write_text(debug_payload_path(run_id, "state.last.read.corrupt.json"), payload)
        discard append_state_debug(run_id, "load_state_json_corrupt", apputil.excerpt_head(payload, 80), "", "")
        let rebuilt_payload = projected_state_json(run_id)
        if quoted_json_field(rebuilt_payload, "run_status") != "missing" || quoted_json_field(rebuilt_payload, "plan_status") != "missing" || quoted_json_field(rebuilt_payload, "goal") != "" {
            return rebuilt_payload
        }
        return state_doc_json(
            run_id,
            "",
            "",
            "missing",
            "missing",
            "",
            "0",
            "0",
            "0",
            "0",
            "0",
            "0",
            "false",
            "",
            "",
            now_label(),
            now_label(),
            "",
            "",
            "",
        )
    }
    let parsed = json.parse(payload)
    let raw_session_id = quoted_json_field(payload, "session_id")
    let raw_goal = quoted_json_field(payload, "goal")
    let raw_status = quoted_json_field(payload, "run_status")
    let raw_plan_status = quoted_json_field(payload, "plan_status")
    let raw_created_at = quoted_json_field(payload, "created_at")
    let raw_turns = quoted_json_field(payload, "turns_completed")
    let raw_failures = quoted_json_field(payload, "failure_count")
    let raw_completed_steps = quoted_json_field(payload, "completed_step_count")
    let raw_auto_continue = quoted_json_field(payload, "auto_continue_pending")
    let raw_message_kind = quoted_json_field(payload, "active_message_kind")
    let repaired_session_id = first_non_empty2(raw_session_id, meta_session_id_text(run_id))
    let repaired_goal = first_non_empty2(raw_goal, meta_goal_text(run_id))
    let repaired_created_at = first_non_empty2(raw_created_at, meta_created_at_text(run_id))
    let repaired_turns = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_turns, "0")), persisted_turn_event_count(run_id)))
    let repaired_failures = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_failures, "0")), persisted_failure_turn_count(run_id)))
    let progress_status = inferred_run_status_from_progress(run_id)
    let repaired_status = if progress_status == "completed" || progress_status == "failed" || progress_status == "cancelled" {
        progress_status
    } else {
        first_non_empty2(raw_status, "missing")
    }
    let repaired_plan_status = inferred_plan_status(run_id, raw_plan_status)
    let repaired_completed_steps = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_completed_steps, "0")), completed_step_count_from_plan_handle(persisted_plan_or_empty(run_id))))
    let repaired_auto_continue = first_non_empty2(raw_auto_continue, if repaired_status == "planning" || repaired_status == "active" { "true" } else { "false" })
    let repaired_message_kind = first_non_empty2(raw_message_kind, if repaired_auto_continue == "true" { "continue" } else { "" })
    if repaired_session_id == raw_session_id && repaired_goal == raw_goal && repaired_created_at == raw_created_at && repaired_turns == raw_turns && repaired_failures == raw_failures && repaired_status == raw_status && repaired_plan_status == raw_plan_status && repaired_completed_steps == raw_completed_steps {
        discard append_state_debug(run_id, "load_state_json_ok", raw_status, raw_turns, raw_plan_status)
        return payload
    }
    log.warn(
        "services.longrange repair_state_json",
        apputil.log_fields3("run_id", run_id, "status", repaired_status, "head", apputil.excerpt_head(payload, 220))
    )
    discard append_state_debug(run_id, "load_state_json_repair", repaired_status, repaired_turns, repaired_plan_status)
    return state_doc_json(
        run_id,
        repaired_session_id,
        repaired_goal,
        repaired_status,
        repaired_plan_status,
        first_non_empty3(quoted_json_field(payload, "task_class"), plan_task_class(persisted_plan_or_empty(run_id)), classify_goal(repaired_goal)),
        repaired_turns,
        repaired_failures,
        first_non_empty2(quoted_json_field(payload, "last_progress_score"), "0"),
        first_non_empty2(quoted_json_field(payload, "consecutive_low_score"), "0"),
        first_non_empty2(quoted_json_field(payload, "last_evidence_count"), "0"),
        repaired_completed_steps,
        repaired_auto_continue,
        repaired_message_kind,
        quoted_json_field(payload, "latest_summary"),
        repaired_created_at,
        now_label(),
        quoted_json_field(payload, "current_step_id"),
        quoted_json_field(payload, "last_request_id"),
        quoted_json_field(payload, "completed_at"),
    )
}

fn load_plan_json(run_id: str) -> str {
    discard ensure_run(run_id)
    let payload = safe_read(run_plan_path(run_id))
    if corrupt_json(payload) == 1 || quoted_json_field(payload, "run_id") == "" {
        let state = json.parse(load_state_json(run_id))
        let task_class = first_non_empty2(state_task_class(state), classify_goal(state_goal(state)))
        return model.types.longrange_plan_json(run_id, "", "", "", "", "", "", "[]", now_label(), task_class, default_completion_mode(task_class, state_goal(state)), default_expected_total_turns(task_class, state_goal(state)), default_execution_outlook(task_class, state_goal(state)), default_planning_style(task_class))
    }
    return payload
}

fn state_json(run_id: str) -> str {
    return load_state_json(run_id)
}

fn plan_json(run_id: str) -> str {
    return load_plan_json(run_id)
}

fn active_run_id_for_session(session_id: str) -> str {
    discard ensure_session(session_id)
    let run_id = str.trim(safe_read(session_active_run_path(session_id)))
    if run_id == "" {
        return ""
    }
    if active_run_is_fresh(run_id) == 1 {
        return run_id
    }
    discard fs.remove_file(session_active_run_path(session_id))
    return ""
}

fn has_active_run_for_session(session_id: str) -> i32 {
    let run_id = active_run_id_for_session(session_id)
    if run_id == "" {
        return 0
    }
    if active_run_is_fresh(run_id) == 1 {
        return 1
    }
    return 0
}

fn set_active_run_for_session(session_id: str, run_id: str) -> i32 {
    discard ensure_session(session_id)
    discard atomic_write_text(session_active_run_path(session_id), run_id)
    return 0
}

fn clear_active_run_for_session(session_id: str, run_id: str) -> i32 {
    let active = active_run_id_for_session(session_id)
    if active == run_id {
        discard fs.remove_file(session_active_run_path(session_id))
    }
    return 0
}

fn active_index_contains(run_id: str) -> i32 {
    let mut rest = safe_read(active_runs_path())
    while services.persistence.first_line(rest) != "" {
        if services.persistence.first_line(rest) == run_id {
            return 1
        }
        rest = services.persistence.drop_first_line(rest)
    }
    return 0
}

fn should_keep_active_run(run_id: str) -> i32 {
    if run_id == "" {
        return 0
    }
    let session_id = first_non_empty2(meta_session_id_text(run_id), run_session_id(run_id))
    if session_id == "" {
        return 0
    }
    let active_path = session_active_run_path(session_id)
    if fs.exists(active_path) == 0 {
        return 0
    }
    if str.trim(fs.read_file(active_path)) != run_id {
        return 0
    }
    if active_run_is_fresh(run_id) == 0 {
        return 0
    }
    return 1
}

fn normalized_active_runs_text() -> str {
    let mut next = ""
    let mut rest = safe_read(active_runs_path())
    while services.persistence.first_line(rest) != "" {
        let line = str.trim(services.persistence.first_line(rest))
        if line != "" && should_keep_active_run(line) == 1 {
            if text_has_line(next, line) < 0 {
                if next == "" {
                    next = line
                } else {
                    next = str.concat(str.concat(next, "\n"), line)
                }
            }
        }
        rest = services.persistence.drop_first_line(rest)
    }
    let session_names = list_dir_names(sessions_dir())
    let mut idx: i32 = 0
    while idx < list.len(session_names) {
        let session_id = list.get(session_names, idx)
        let active_path = session_active_run_path(session_id)
        if fs.exists(active_path) == 1 {
            let run_id = str.trim(fs.read_file(active_path))
            if run_id != "" {
                if should_keep_active_run(run_id) == 1 {
                    if text_has_line(next, run_id) < 0 {
                        if next == "" {
                            next = run_id
                        } else {
                            next = str.concat(str.concat(next, "\n"), run_id)
                        }
                    }
                } else {
                    discard fs.remove_file(active_path)
                }
            }
        }
        idx = idx + 1
    }
    return next
}

fn rewrite_active_runs_index() -> i32 {
    let next = normalized_active_runs_text()
    if next == "" {
        return atomic_write_text(active_runs_path(), "")
    }
    return atomic_write_text(active_runs_path(), str.concat(next, "\n"))
}

fn append_active_run(run_id: str) -> i32 {
    discard ensure_state()
    discard rewrite_active_runs_index()
    if active_index_contains(run_id) == 1 {
        return 0
    }
    discard append_text_line(active_runs_path(), run_id)
    return 0
}

fn remove_active_run(run_id: str) -> i32 {
    discard ensure_state()
    discard rewrite_active_runs_index()
    let mut next = ""
    let mut rest = safe_read(active_runs_path())
    while services.persistence.first_line(rest) != "" {
        let line = services.persistence.first_line(rest)
        if line != run_id {
            if next == "" {
                next = line
            } else {
                next = str.concat(str.concat(next, "\n"), line)
            }
        }
        rest = services.persistence.drop_first_line(rest)
    }
    if next == "" {
        discard atomic_write_text(active_runs_path(), "")
    } else {
        discard atomic_write_text(active_runs_path(), str.concat(next, "\n"))
    }
    return 0
}

fn pop_active_run_id() -> str {
    discard ensure_state()
    discard rewrite_active_runs_index()
    let active = safe_read(active_runs_path())
    let line = services.persistence.first_line(active)
    if line == "" {
        return ""
    }
    discard atomic_write_text(active_runs_path(), services.persistence.drop_first_line(active))
    return line
}

fn requeue_active_run_id(run_id: str) -> i32 {
    if run_id == "" {
        return 0
    }
    return append_active_run(run_id)
}

fn run_exists(run_id: str) -> i32 {
    if run_id == "" {
        return 0
    }
    if has_local_state_doc(run_id) == 1 || has_meaningful_local_progress(run_id) == 1 {
        return 1
    }
    return 0
}

fn cleanup_partial_run(run_id: str) -> i32 {
    if run_id == "" {
        return 0
    }
    discard services.sqlite_store.kv_delete(run_state_path(run_id))
    discard services.sqlite_store.kv_delete(run_progress_path(run_id))
    discard fs.remove_file(run_plan_path(run_id))
    discard fs.remove_file(run_meta_path(run_id))
    discard fs.remove_file(run_session_id_path(run_id))
    discard fs.remove_file(run_goal_path(run_id))
    discard fs.remove_file(run_created_at_path(run_id))
    discard fs.remove_file(run_queue_path(run_id))
    discard fs.remove_file(materialized_run_state_path(run_id))
    discard fs.remove_file(materialized_run_progress_path(run_id))
    discard fs.remove_file(debug_payload_path(run_id, "state.last.write.json"))
    discard fs.remove_file(debug_payload_path(run_id, "progress.last.candidate.json"))
    return 0
}

fn next_run_id(session_id: str) -> str {
    if session_id != "" {
        return session_id
    }
    return fresh_label()
}

fn append_progress(run_id: str, phase: str, message_kind: str, request_id: str, detail: str, progress_score: str, evidence_count: str) -> i32 {
    discard ensure_run(run_id)
    let line = progress_event_json(run_id, phase, message_kind, now_label(), progress_score, evidence_count, request_id, detail)
    discard atomic_write_text(debug_payload_path(run_id, "progress.last.created.json"), line)
    return append_progress_payload(run_id, line)
}

fn max_i32(a: i32, b: i32) -> i32 {
    if a >= b {
        return a
    }
    return b
}

fn persisted_turn_event_count(run_id: str) -> i32 {
    let events = json.parse(if looks_like_array_json(safe_read(run_progress_path(run_id))) == 1 { safe_read(run_progress_path(run_id)) } else { "[]" })
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            return count
        }
        if phase == "turn_completed" || phase == "turn_failed" {
            count = count + 1
        }
        idx = idx + 1
    }
    return count
}

fn persisted_failure_turn_count(run_id: str) -> i32 {
    let events = json.parse(if looks_like_array_json(safe_read(run_progress_path(run_id))) == 1 { safe_read(run_progress_path(run_id)) } else { "[]" })
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        if json.get_str(parsed, "phase") == "" && json.get_str(parsed, "run_id") == "" {
            return count
        }
        if json.get_str(parsed, "phase") == "turn_failed" {
            count = count + 1
        }
        idx = idx + 1
    }
    return count
}

fn last_progress_phase(run_id: str) -> str {
    let events = json.parse(if looks_like_array_json(safe_read(run_progress_path(run_id))) == 1 { safe_read(run_progress_path(run_id)) } else { "[]" })
    let mut last = ""
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            return last
        }
        if phase != "" {
            last = phase
        }
        idx = idx + 1
    }
    return last
}

fn last_progress_detail(run_id: str) -> str {
    let events = json.parse(if looks_like_array_json(safe_read(run_progress_path(run_id))) == 1 { safe_read(run_progress_path(run_id)) } else { "[]" })
    let mut last = ""
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        let detail = json.get_str(parsed, "detail")
        if detail == "" && json.get_str(parsed, "phase") == "" && json.get_str(parsed, "run_id") == "" {
            return last
        }
        if detail != "" {
            last = detail
        }
        idx = idx + 1
    }
    return last
}

fn inferred_run_status_from_progress(run_id: str) -> str {
    let phase = last_progress_phase(run_id)
    if phase == "completed" {
        return "completed"
    }
    if phase == "failed" {
        return "failed"
    }
    if phase == "cancelled" {
        return "cancelled"
    }
    if phase == "plan_created" || phase == "turn_completed" || phase == "turn_failed" {
        return "active"
    }
    if phase == "started" {
        return "planning"
    }
    return "missing"
}

fn projected_state_json(run_id: str) -> str {
    let rebuilt_goal = meta_goal_text(run_id)
    let rebuilt_status = inferred_run_status_from_progress(run_id)
    let persisted_plan = persisted_plan_or_empty(run_id)
    let rebuilt_plan_status = inferred_plan_status(run_id, "")
    let rebuilt_task_class = first_non_empty2(plan_task_class(persisted_plan), classify_goal(rebuilt_goal))
    let rebuilt_turns = str.from_i32(persisted_turn_event_count(run_id))
    let rebuilt_failures = str.from_i32(persisted_failure_turn_count(run_id))
    let rebuilt_completed_steps = str.from_i32(completed_step_count_from_plan_handle(persisted_plan))
    let rebuilt_detail = last_progress_detail(run_id)
    let rebuilt_map = map.new()
    discard map.set(rebuilt_map, "status", json.str(model.types.control_ok_label()))
    discard map.set(rebuilt_map, "run_id", json.str(run_id))
    discard map.set(rebuilt_map, "session_id", json.str(meta_session_id_text(run_id)))
    discard map.set(rebuilt_map, "goal", json.str(rebuilt_goal))
    discard map.set(rebuilt_map, "run_status", json.str(rebuilt_status))
    discard map.set(rebuilt_map, "plan_status", json.str(rebuilt_plan_status))
    discard map.set(rebuilt_map, "task_class", json.str(rebuilt_task_class))
    discard map.set(rebuilt_map, "turns_completed", json.str(rebuilt_turns))
    discard map.set(rebuilt_map, "failure_count", json.str(rebuilt_failures))
    discard map.set(rebuilt_map, "last_progress_score", json.str("0"))
    discard map.set(rebuilt_map, "consecutive_low_score", json.str("0"))
    discard map.set(rebuilt_map, "last_evidence_count", json.str("0"))
    discard map.set(rebuilt_map, "completed_step_count", json.str(rebuilt_completed_steps))
    discard map.set(rebuilt_map, "auto_continue_pending", json.str(if rebuilt_status == "planning" || rebuilt_status == "active" { "true" } else { "false" }))
    discard map.set(rebuilt_map, "active_message_kind", json.str(if rebuilt_status == "planning" || rebuilt_status == "active" { "continue" } else { rebuilt_status }))
    discard map.set(rebuilt_map, "latest_summary", json.str(rebuilt_detail))
    discard map.set(rebuilt_map, "created_at", json.str(meta_created_at_text(run_id)))
    discard map.set(rebuilt_map, "updated_at", json.str(now_label()))
    return json.object(rebuilt_map)
}

fn completed_step_count_from_plan_handle(plan: JsonHandle) -> i32 {
    let steps = json.get(plan, "steps")
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 16 {
        let step = json.get(steps, str.from_i32(idx))
        let step_id = json.get_str(step, "step_id")
        if step_id == "" {
            return count
        }
        let status = apputil.lower_ascii(json.get_str(step, "status"))
        if status == "done" || status == "completed" || status == "complete" {
            count = count + 1
        }
        idx = idx + 1
    }
    return count
}

fn create_run(session_id: str, goal: str, request_id: str) -> str {
    discard ensure_state()
    let existing = active_run_id_for_session(session_id)
    if existing != "" && has_active_run_for_session(session_id) == 1 {
        log.info(
            "services.longrange reuse_run",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "run_id", existing)
        )
        return existing
    }
    let run_id = next_run_id(session_id)
    let task_class = classify_goal(goal)
    let completion_mode = default_completion_mode(task_class, goal)
    let expected_total_turns = default_expected_total_turns(task_class, goal)
    let execution_outlook = default_execution_outlook(task_class, goal)
    let planning_style = default_planning_style(task_class)
    log.info(
        "services.longrange create_run",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "run_id", run_id)
    )
    let ensure_rc = ensure_run(run_id)
    discard mark_stage(run_id, "create_run.after_ensure")
    if ensure_rc != 0 {
        log.error(
            "services.longrange create_run ensure_failed",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "run_id", run_id)
        )
        return ""
    }
    let created_at = now_label()
    let bootstrap_rc = services.sqlite_store.longrange_bootstrap_run(
        run_state_path(run_id),
        run_progress_path(run_id),
        run_id,
        session_id,
        goal,
        task_class,
        completion_mode,
        expected_total_turns,
        execution_outlook,
        planning_style,
        request_id,
        created_at,
    )
    discard mark_stage(run_id, "create_run.after_bootstrap")
    if bootstrap_rc != 0 {
        log.error(
            "services.longrange create_run bootstrap_failed",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "run_id", run_id)
        )
        discard cleanup_partial_run(run_id)
        return ""
    }
    discard set_active_run_for_session(session_id, run_id)
    discard append_active_run(run_id)
    discard refresh_summary(run_id, "planning")
    discard mark_stage(run_id, "create_run.done")
    return run_id
}

fn queue_depth_for(run_id: str) -> i32 {
    return count_lines(safe_read(run_queue_path(run_id)))
}

fn enqueue_message(run_id: str, kind: str, content: str, request_id: str, interrupt: i32) -> i32 {
    discard ensure_run(run_id)
    let line = model.types.longrange_message_json(kind, content, request_id, now_label(), bool_text(interrupt))
    if interrupt == 1 {
        let current = safe_read(run_queue_path(run_id))
        if current == "" {
            discard atomic_write_text(run_queue_path(run_id), str.concat(line, "\n"))
        } else {
            discard atomic_write_text(run_queue_path(run_id), str.concat3(line, "\n", current))
        }
    } else {
        discard append_text_line(run_queue_path(run_id), line)
    }
    discard append_progress(run_id, "queued_message", kind, request_id, content, "0", "0")
    return 0
}

fn enqueue_steer_for_session(session_id: str, content: str, request_id: str, interrupt: i32) -> str {
    let run_id = active_run_id_for_session(session_id)
    if run_id == "" {
        return ""
    }
    discard enqueue_message(run_id, "steer", content, request_id, interrupt)
    return run_id
}

fn dequeue_next_message_json(run_id: str) -> str {
    discard ensure_run(run_id)
    let payload = safe_read(run_queue_path(run_id))
    let line = services.persistence.first_line(payload)
    if line == "" {
        return ""
    }
    discard atomic_write_text(run_queue_path(run_id), services.persistence.drop_first_line(payload))
    return line
}

fn set_auto_continue(run_id: str, flag: i32, message_kind: str) -> i32 {
    let mut patch = patch_start()
    patch = patch_add_field(patch, "auto_continue_pending", bool_text(flag))
    patch = patch_add_field(patch, "active_message_kind", message_kind)
    return save_state(run_id, patch_finish(patch))
}

fn plan_status_ready(run_id: str) -> i32 {
    if quoted_json_field(load_state_json(run_id), "plan_status") == "ready" {
        return 1
    }
    return 0
}

fn apply_plan_create(run_id: str, goal_summary: str, finished_definition: str, difficulty: str, estimated_effort: str, current_step_id: str, plan_summary: str, steps_json: str, request_id: str, task_class: str, completion_mode: str, expected_total_turns: str, execution_outlook: str, planning_style: str) -> i32 {
    log.info(
        "services.longrange plan_create",
        apputil.log_fields3("run_id", run_id, "request_id", request_id, "current_step_id", current_step_id)
    )
    let plan_rc = save_plan(run_id, goal_summary, finished_definition, difficulty, estimated_effort, current_step_id, plan_summary, steps_json, task_class, completion_mode, expected_total_turns, execution_outlook, planning_style)
    let raw = load_state_json(run_id)
    let effective_task_class = first_non_empty3(task_class, raw_state_field(raw, "task_class"), classify_goal(first_non_empty2(raw_state_field(raw, "goal"), meta_goal_text(run_id))))
    let state_rc = write_state_payload(
        run_id,
        state_doc_json(
            run_id,
            first_non_empty2(raw_state_field(raw, "session_id"), meta_session_id_text(run_id)),
            first_non_empty2(raw_state_field(raw, "goal"), meta_goal_text(run_id)),
            "active",
            "ready",
            effective_task_class,
            first_non_empty2(raw_state_field(raw, "turns_completed"), "0"),
            first_non_empty2(raw_state_field(raw, "failure_count"), "0"),
            first_non_empty2(raw_state_field(raw, "last_progress_score"), "0"),
            first_non_empty2(raw_state_field(raw, "consecutive_low_score"), "0"),
            first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0"),
            first_non_empty2(raw_state_field(raw, "completed_step_count"), "0"),
            "true",
            "plan_create",
            plan_summary,
            first_non_empty2(raw_state_field(raw, "created_at"), meta_created_at_text(run_id)),
            now_label(),
            current_step_id,
            request_id,
            raw_state_field(raw, "completed_at"),
        ),
    )
    let progress_rc = append_progress(run_id, "plan_created", "plan_create", request_id, plan_summary, "0", "0")
    let summary_rc = refresh_summary(run_id, "active")
    if plan_rc != 0 || state_rc != 0 || progress_rc != 0 || summary_rc != 0 {
        log.error(
            "services.longrange plan_create_failed",
            apputil.log_fields3("run_id", run_id, "request_id", request_id, "codes", str.concat(str.from_i32(plan_rc), str.concat("/", str.concat(str.from_i32(state_rc), str.concat("/", str.concat(str.from_i32(progress_rc), str.concat("/", str.from_i32(summary_rc))))))))
        )
        return 1
    }
    return 0
}

fn apply_plan_update(run_id: str, goal_summary: str, finished_definition: str, difficulty: str, estimated_effort: str, current_step_id: str, plan_summary: str, steps_json: str, request_id: str, task_class: str, completion_mode: str, expected_total_turns: str, execution_outlook: str, planning_style: str) -> i32 {
    let current_plan = json.parse(load_plan_json(run_id))
    log.info(
        "services.longrange plan_update",
        apputil.log_fields3("run_id", run_id, "request_id", request_id, "current_step_id", current_step_id)
    )
    let next_goal_summary = if goal_summary == "" { plan_goal_summary(current_plan) } else { goal_summary }
    let next_finished_definition = if finished_definition == "" { plan_finished_definition(current_plan) } else { finished_definition }
    let next_difficulty = if difficulty == "" { plan_difficulty(current_plan) } else { difficulty }
    let next_estimated_effort = if estimated_effort == "" { plan_estimated_effort(current_plan) } else { estimated_effort }
    let next_current_step_id = if current_step_id == "" { plan_current_step_id(current_plan) } else { current_step_id }
    let next_plan_summary = if plan_summary == "" { plan_summary_value(current_plan) } else { plan_summary }
    let next_steps_json = if steps_json == "" || steps_json == "[]" { plan_steps_raw(current_plan) } else { steps_json }
    let next_task_class = if task_class == "" { plan_task_class(current_plan) } else { task_class }
    let next_completion_mode = if completion_mode == "" { plan_completion_mode(current_plan) } else { completion_mode }
    let next_expected_total_turns = if expected_total_turns == "" { plan_expected_total_turns(current_plan) } else { expected_total_turns }
    let next_execution_outlook = if execution_outlook == "" { plan_execution_outlook(current_plan) } else { execution_outlook }
    let next_planning_style = if planning_style == "" { plan_planning_style(current_plan) } else { planning_style }
    return apply_plan_create(run_id, next_goal_summary, next_finished_definition, next_difficulty, next_estimated_effort, next_current_step_id, next_plan_summary, next_steps_json, request_id, next_task_class, next_completion_mode, next_expected_total_turns, next_execution_outlook, next_planning_style)
}

fn mark_completed(run_id: str, summary_text: str, request_id: str) -> i32 {
    let raw = load_state_json(run_id)
    let terminal_session_id = first_non_empty2(raw_state_field(raw, "session_id"), meta_session_id_text(run_id))
    let terminal_goal = first_non_empty2(raw_state_field(raw, "goal"), meta_goal_text(run_id))
    let terminal_plan_status = inferred_plan_status(run_id, raw_state_field(raw, "plan_status"))
    let terminal_created_at = first_non_empty2(raw_state_field(raw, "created_at"), meta_created_at_text(run_id))
    let terminal_turns = max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "turns_completed"), "0")), persisted_turn_event_count(run_id)) + 1
    let terminal_failures = max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "failure_count"), "0")), persisted_failure_turn_count(run_id))
    log.info(
        "services.longrange completed",
        apputil.log_fields3("run_id", run_id, "request_id", request_id, "summary", apputil.excerpt_head(summary_text, 220))
    )
    let state_rc = write_state_payload(
        run_id,
        state_doc_json(
            run_id,
            terminal_session_id,
            terminal_goal,
            "completed",
            terminal_plan_status,
            first_non_empty3(raw_state_field(raw, "task_class"), plan_task_class(persisted_plan_or_empty(run_id)), classify_goal(terminal_goal)),
            str.from_i32(terminal_turns),
            str.from_i32(terminal_failures),
            first_non_empty2(raw_state_field(raw, "last_progress_score"), "3"),
            first_non_empty2(raw_state_field(raw, "consecutive_low_score"), "0"),
            first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0"),
            str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "completed_step_count"), "0")), completed_step_count(run_id))),
            "false",
            "goal_complete",
            summary_text,
            terminal_created_at,
            now_label(),
            raw_state_field(raw, "current_step_id"),
            request_id,
            now_label(),
        ),
    )
    discard clear_active_run_for_session(terminal_session_id, run_id)
    discard remove_active_run(run_id)
    let progress_rc = append_progress(run_id, "completed", "goal_complete", request_id, summary_text, "3", first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0"))
    discard write_terminal_summary(run_id, "completed")
    if state_rc != 0 || progress_rc != 0 {
        return 1
    }
    return 0
}

fn terminal_failure_progress_json(run_id: str, recorded_at: str, progress_score: str, evidence_count: str, request_id: str, detail: str) -> str {
    let mut payload = "{"
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "phase", "failed")
    payload = patch_add_field(payload, "message_kind", "failed")
    payload = patch_add_field(payload, "recorded_at", recorded_at)
    payload = patch_add_field(payload, "progress_score", progress_score)
    payload = patch_add_field(payload, "evidence_count", evidence_count)
    if request_id != "" {
        payload = patch_add_field(payload, "request_id", request_id)
    }
    if detail != "" {
        payload = patch_add_field(payload, "detail", detail)
    }
    return patch_finish(payload)
}

fn active_message_kind(success: i32) -> str {
    if success == 1 {
        return "continue"
    }
    return "retry"
}

fn active_next_status(success: i32, plan_status: str) -> str {
    if success == 1 {
        if plan_status == "missing" {
            return "planning"
        }
        return "active"
    }
    return "active"
}

fn active_state_payload_json(run_id: str, session_id: str, goal: str, run_status: str, plan_status: str, task_class: str, turns_completed: str, failure_count: str, progress_score: str, low_score: str, evidence_count: str, completed_step_count_text: str, message_kind: str, summary_text: str, created_at: str, updated_at: str, current_step_id: str, request_id: str, completed_at: str) -> str {
    let mut payload = patch_start()
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "session_id", session_id)
    payload = patch_add_field(payload, "goal", goal)
    payload = patch_add_field(payload, "run_status", run_status)
    payload = patch_add_field(payload, "plan_status", plan_status)
    payload = patch_add_field(payload, "task_class", task_class)
    payload = patch_add_field(payload, "turns_completed", turns_completed)
    payload = patch_add_field(payload, "failure_count", failure_count)
    payload = patch_add_field(payload, "last_progress_score", progress_score)
    payload = patch_add_field(payload, "consecutive_low_score", low_score)
    payload = patch_add_field(payload, "last_evidence_count", evidence_count)
    payload = patch_add_field(payload, "completed_step_count", completed_step_count_text)
    payload = patch_add_field(payload, "auto_continue_pending", "true")
    payload = patch_add_field(payload, "active_message_kind", message_kind)
    payload = patch_add_field(payload, "latest_summary", summary_text)
    payload = patch_add_field(payload, "created_at", created_at)
    payload = patch_add_field(payload, "updated_at", updated_at)
    if current_step_id != "" {
        payload = patch_add_field(payload, "current_step_id", current_step_id)
    }
    payload = patch_add_field(payload, "last_request_id", request_id)
    if completed_at != "" {
        payload = patch_add_field(payload, "completed_at", completed_at)
    }
    return patch_finish(payload)
}

fn active_progress_payload_json(run_id: str, phase: str, message_kind: str, recorded_at: str, progress_score: str, evidence_count: str, request_id: str, detail: str) -> str {
    let mut payload = patch_start()
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "phase", phase)
    payload = patch_add_field(payload, "message_kind", message_kind)
    payload = patch_add_field(payload, "recorded_at", recorded_at)
    payload = patch_add_field(payload, "progress_score", progress_score)
    payload = patch_add_field(payload, "evidence_count", evidence_count)
    payload = patch_add_field(payload, "request_id", request_id)
    payload = patch_add_field(payload, "detail", detail)
    return patch_finish(payload)
}

fn failed_state_payload_json(run_id: str, session_id: str, goal: str, plan_status: str, turns_text: str, failure_count: str, progress_score: str, evidence_count: str, detail: str, created_at: str, updated_at: str, current_step_id: str, request_id: str) -> str {
    let mut payload = patch_start()
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "session_id", session_id)
    payload = patch_add_field(payload, "goal", goal)
    payload = patch_add_field(payload, "run_status", "failed")
    payload = patch_add_field(payload, "plan_status", plan_status)
    payload = patch_add_field(payload, "turns_completed", turns_text)
    payload = patch_add_field(payload, "failure_count", failure_count)
    payload = patch_add_field(payload, "last_progress_score", progress_score)
    payload = patch_add_field(payload, "last_evidence_count", evidence_count)
    payload = patch_add_field(payload, "auto_continue_pending", "false")
    payload = patch_add_field(payload, "active_message_kind", "failed")
    payload = patch_add_field(payload, "latest_summary", detail)
    payload = patch_add_field(payload, "created_at", created_at)
    payload = patch_add_field(payload, "updated_at", updated_at)
    if current_step_id != "" {
        payload = patch_add_field(payload, "current_step_id", current_step_id)
    }
    if request_id != "" {
        payload = patch_add_field(payload, "last_request_id", request_id)
    }
    payload = patch_add_field(payload, "completed_at", updated_at)
    return patch_finish(payload)
}

fn failed_state_payload_minimal_json(run_id: str, session_id: str, goal: str, plan_status: str, turns_text: str, failure_count: str, detail: str, created_at: str, updated_at: str, request_id: str) -> str {
    let mut payload = patch_start()
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "session_id", session_id)
    payload = patch_add_field(payload, "goal", goal)
    payload = patch_add_field(payload, "run_status", "failed")
    payload = patch_add_field(payload, "plan_status", plan_status)
    payload = patch_add_field(payload, "turns_completed", turns_text)
    payload = patch_add_field(payload, "failure_count", failure_count)
    payload = patch_add_field(payload, "last_progress_score", "0")
    payload = patch_add_field(payload, "last_evidence_count", "0")
    payload = patch_add_field(payload, "auto_continue_pending", "false")
    payload = patch_add_field(payload, "active_message_kind", "failed")
    payload = patch_add_field(payload, "latest_summary", detail)
    payload = patch_add_field(payload, "created_at", created_at)
    payload = patch_add_field(payload, "updated_at", updated_at)
    if request_id != "" {
        payload = patch_add_field(payload, "last_request_id", request_id)
    }
    payload = patch_add_field(payload, "completed_at", updated_at)
    return patch_finish(payload)
}

fn terminalize_failed_run(run_id: str, detail: str, request_id: str) -> i32 {
    let raw = load_state_json(run_id)
    let session_id = first_non_empty2(raw_state_field(raw, "session_id"), meta_session_id_text(run_id))
    let goal = first_non_empty2(raw_state_field(raw, "goal"), meta_goal_text(run_id))
    let plan_status = inferred_plan_status(run_id, raw_state_field(raw, "plan_status"))
    let created_at = first_non_empty2(raw_state_field(raw, "created_at"), meta_created_at_text(run_id))
    let turns_text = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "turns_completed"), "0")), persisted_turn_event_count(run_id)))
    let failure_count = str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "failure_count"), "0")), persisted_failure_turn_count(run_id)) + 1)
    let progress_score = first_non_empty2(raw_state_field(raw, "last_progress_score"), "0")
    let evidence_count = first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0")
    let stamp = now_label()
    let current_step = raw_state_field(raw, "current_step_id")
    log.info(
        "services.longrange terminalize_failed_run enter",
        apputil.log_fields3("run_id", run_id, "request_id", request_id, "detail", apputil.excerpt_head(detail, 180))
    )
    let state_rc = services.sqlite_store.longrange_update_turn(
        run_state_path(run_id),
        run_progress_path(run_id),
        run_id,
        session_id,
        goal,
        "failed",
        plan_status,
        first_non_empty3(raw_state_field(raw, "task_class"), plan_task_class(persisted_plan_or_empty(run_id)), classify_goal(goal)),
        turns_text,
        failure_count,
        progress_score,
        first_non_empty2(raw_state_field(raw, "consecutive_low_score"), "0"),
        evidence_count,
        first_non_empty2(raw_state_field(raw, "completed_step_count"), "0"),
        "false",
        "failed",
        detail,
        created_at,
        stamp,
        current_step,
        request_id,
        stamp,
        "failed",
        "failed",
        stamp,
        progress_score,
        evidence_count,
        request_id,
        detail,
    )
    log.info(
        "services.longrange terminalize_failed_run result",
        apputil.log_fields3("run_id", run_id, "request_id", request_id, "state_rc", str.from_i32(state_rc))
    )
    if state_rc == 0 {
        discard clear_active_run_for_session(session_id, run_id)
        discard remove_active_run(run_id)
        discard rewrite_active_runs_index()
        discard write_terminal_summary(run_id, "failed")
        return 0
    }
    return 1
}

fn mark_failed(run_id: str, detail: str, request_id: str) -> i32 {
    return terminalize_failed_run(run_id, detail, request_id)
}

fn force_terminal_fail(run_id: str, detail: str, request_id: str) -> i32 {
    return terminalize_failed_run(run_id, detail, request_id)
}

fn record_terminal_failure_event(run_id: str, detail: str, request_id: str) -> i32 {
    return terminalize_failed_run(run_id, detail, request_id)
}

fn cancel_run(run_id: str, reason: str, request_id: str) -> i32 {
    let raw = load_state_json(run_id)
    let terminal_session_id = first_non_empty2(raw_state_field(raw, "session_id"), meta_session_id_text(run_id))
    let terminal_goal = first_non_empty2(raw_state_field(raw, "goal"), meta_goal_text(run_id))
    let terminal_plan_status = inferred_plan_status(run_id, raw_state_field(raw, "plan_status"))
    let terminal_created_at = first_non_empty2(raw_state_field(raw, "created_at"), meta_created_at_text(run_id))
    let terminal_turns = max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "turns_completed"), "0")), persisted_turn_event_count(run_id))
    let terminal_failures = max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "failure_count"), "0")), persisted_failure_turn_count(run_id))
    let state_rc = write_state_payload(
        run_id,
        state_doc_json(
            run_id,
            terminal_session_id,
            terminal_goal,
            "cancelled",
            terminal_plan_status,
            first_non_empty3(raw_state_field(raw, "task_class"), plan_task_class(persisted_plan_or_empty(run_id)), classify_goal(terminal_goal)),
            str.from_i32(terminal_turns),
            str.from_i32(terminal_failures),
            first_non_empty2(raw_state_field(raw, "last_progress_score"), "0"),
            first_non_empty2(raw_state_field(raw, "consecutive_low_score"), "0"),
            first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0"),
            str.from_i32(max_i32(apputil.parse_i32(first_non_empty2(raw_state_field(raw, "completed_step_count"), "0")), completed_step_count(run_id))),
            "false",
            "cancel",
            reason,
            terminal_created_at,
            now_label(),
            raw_state_field(raw, "current_step_id"),
            request_id,
            now_label(),
        ),
    )
    discard clear_active_run_for_session(terminal_session_id, run_id)
    discard remove_active_run(run_id)
    let progress_rc = append_progress(run_id, "cancelled", "cancel", request_id, reason, first_non_empty2(raw_state_field(raw, "last_progress_score"), "0"), first_non_empty2(raw_state_field(raw, "last_evidence_count"), "0"))
    discard write_terminal_summary(run_id, "cancelled")
    if state_rc != 0 || progress_rc != 0 {
        return 1
    }
    return 0
}

fn low_score_limit(run_id: str) -> i32 {
    let mut limit: i32 = if task_class(run_id) == "micro" { 4 } else { 3 }
    let planning = planning_style(run_id)
    let expected = expected_total_turns(run_id)
    if planning == "adaptive" {
        limit = limit + 1
    } else if planning == "deliberate" {
        limit = limit + 2
    }
    if expected >= 8 {
        limit = limit + 1
    }
    if current_step_type(run_id) == "inspect" {
        limit = limit + 1
    }
    if current_step_target_turns(run_id) >= 3 {
        limit = limit + 1
    }
    if limit > 8 {
        return 8
    }
    return limit
}

fn should_fail_for_low_progress(run_id: str) -> i32 {
    let parsed = json.parse(load_state_json(run_id))
    if apputil.parse_i32(state_consecutive_low_score(parsed)) >= low_score_limit(run_id) {
        return 1
    }
    return 0
}

pub fn tool_only_streak(run_id: str) -> i32 {
    let payload = safe_read(run_progress_path(run_id))
    if looks_like_array_json(payload) == 0 {
        return 0
    }
    let events = json.parse(payload)
    let mut event_count: i32 = 0
    while event_count < 256 {
        let parsed = json.get(events, str.from_i32(event_count))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            break
        }
        event_count = event_count + 1
    }
    let mut streak: i32 = 0
    let mut idx: i32 = event_count - 1
    while idx >= 0 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase != "turn_completed" && phase != "turn_failed" {
            idx = idx - 1
            continue
        }
        let detail = json.get_str(parsed, "detail")
        if is_tool_only_summary(detail) == 1 {
            streak = streak + 1
            idx = idx - 1
            continue
        }
        break
    }
    return streak
}

pub fn should_fail_for_tool_only_loop(run_id: str) -> i32 {
    if tool_only_streak(run_id) >= 2 {
        return 1
    }
    return 0
}

pub fn should_fail_for_missing_plan_loop(run_id: str) -> i32 {
    let state_raw = load_state_json(run_id)
    if quoted_json_field(state_raw, "plan_status") == "ready" {
        return 0
    }
    if looks_like_plaintext_plan_attempt(quoted_json_field(state_raw, "latest_summary")) == 0 {
        return 0
    }
    if apputil.parse_i32(quoted_json_field(state_raw, "consecutive_low_score")) >= 3 {
        return 1
    }
    return 0
}

pub fn should_fail_for_missing_plan_attempt(run_id: str, assistant_summary: str) -> i32 {
    if plan_status_ready(run_id) == 1 {
        return 0
    }
    if looks_like_plaintext_plan_attempt(assistant_summary) == 0 {
        return 0
    }
    if turns_completed(run_id) >= 3 {
        return 1
    }
    return 0
}

pub fn should_auto_complete_after_plan_create(run_id: str, result_kind: str, control_tool: str, control_outcome: str) -> i32 {
    if result_kind != "control_tool" || control_tool != "plan_create" || control_outcome != "ok" {
        return 0
    }
    if completion_mode(run_id) != "direct" {
        return 0
    }
    if task_class(run_id) == "planning" || expected_total_turns(run_id) <= 2 {
        return 1
    }
    return 0
}

fn should_auto_complete(run_id: str, assistant_summary: str) -> i32 {
    if assistant_summary == "control_plane_tool_executed:plan_create" && completion_mode(run_id) == "direct" && (task_class(run_id) == "planning" || expected_total_turns(run_id) <= 2) {
        return 1
    }
    let parsed = json.parse(load_state_json(run_id))
    return completion_gate_ready(run_id, assistant_summary, apputil.parse_i32(state_last_evidence_count(parsed)))
}

fn auto_completion_summary(run_id: str) -> str {
    let plan = json.parse(load_plan_json(run_id))
    let summary = plan_summary_value(plan)
    if summary != "" {
        return str.concat("runtime_auto_complete: ", summary)
    }
    return str.concat("runtime_auto_complete: goal satisfied for ", goal_summary(run_id))
}

fn allow_goal_complete(run_id: str, summary_text: str) -> i32 {
    let parsed = json.parse(load_state_json(run_id))
    let evidence = apputil.parse_i32(state_last_evidence_count(parsed))
    if goal_complete_gate_ready(run_id, summary_text, evidence) == 1 {
        return 1
    }
    return 0
}

fn goal_complete_effective_done_steps(run_id: str, summary_text: str, evidence_count: i32) -> i32 {
    let total_steps = step_count(run_id)
    let mut done_steps = completed_step_count(run_id)
    if total_steps <= 0 {
        return done_steps
    }
    if evidence_count > 0 && current_step_type(run_id) != "summarize" && done_steps < total_steps {
        done_steps = done_steps + 1
    }
    if completion_mode(run_id) == "summary" && summary_text != "" && done_steps < total_steps {
        done_steps = done_steps + 1
    }
    if done_steps > total_steps {
        return total_steps
    }
    return done_steps
}

fn goal_complete_gate_ready(run_id: str, summary_text: str, evidence_count: i32) -> i32 {
    if plan_status_ready(run_id) == 0 {
        return 0
    }
    if summary_text == "" {
        return 0
    }
    let total_steps = step_count(run_id)
    if total_steps == 0 {
        return 0
    }
    let mode = completion_mode(run_id)
    let effective_done = goal_complete_effective_done_steps(run_id, summary_text, evidence_count)
    if mode == "direct" {
        if effective_done >= total_steps {
            return 1
        }
        return 0
    }
    if mode == "summary" {
        if effective_done >= total_steps {
            return 1
        }
        return 0
    }
    if effective_done >= total_steps && evidence_count > 0 {
        return 1
    }
    return 0
}

fn goal_complete_block_reason(run_id: str, summary_text: str) -> str {
    if plan_status_ready(run_id) == 0 {
        return "durable plan is not ready yet"
    }
    if summary_text == "" {
        return "completion summary is empty"
    }
    let total_steps = step_count(run_id)
    let done_steps = completed_step_count(run_id)
    let effective_done = goal_complete_effective_done_steps(run_id, summary_text, last_evidence_count(run_id))
    let class = task_class(run_id)
    let mode = completion_mode(run_id)
    if total_steps == 0 {
        return "plan has no steps yet"
    }
    if goal_complete_gate_ready(run_id, summary_text, last_evidence_count(run_id)) == 1 {
        return ""
    }
    if class == "micro" && mode == "summary" {
        if effective_done < total_steps {
            return str.concat("finish more of the goal before completing; effective_completed=", str.concat(str.from_i32(effective_done), str.concat(" total=", str.from_i32(total_steps))))
        }
        return "the final summary is still missing or unsupported by direct evidence"
    }
    if all_steps_done(run_id) == 0 {
        return str.concat("all plan steps are not complete yet; durable_completed=", str.concat(str.from_i32(done_steps), str.concat(" effective_completed=", str.concat(str.from_i32(effective_done), str.concat(" total=", str.from_i32(total_steps))))))
    }
    if mode == "verified" {
        let parsed = json.parse(load_state_json(run_id))
        if apputil.parse_i32(state_last_evidence_count(parsed)) <= 0 {
            return "verification-oriented completion needs direct evidence from tool work before finishing"
        }
    }
    return "finished definition is not yet satisfied according to the durable plan state"
}

fn update_after_turn(run_id: str, request_id: str, assistant_summary: str, success: i32, evidence_count: i32, result_kind: str, control_tool: str, control_outcome: str) -> i32 {
    let current_state = load_state_json(run_id)
    let safe_request_id = first_non_empty2(request_id, str.concat("longrange-turn-", now_label()))
    let safe_summary = if assistant_summary == "" { if success == 1 { "turn_completed_without_summary" } else { "turn_failed_without_summary" } } else { assistant_summary }
    let safe_plan_status = inferred_plan_status(run_id, raw_state_field(current_state, "plan_status"))
    let safe_session_id = first_non_empty2(raw_state_field(current_state, "session_id"), meta_session_id_text(run_id))
    let safe_goal = first_non_empty2(raw_state_field(current_state, "goal"), meta_goal_text(run_id))
    let safe_created_at = first_non_empty2(raw_state_field(current_state, "created_at"), meta_created_at_text(run_id))
    let safe_task_class = first_non_empty3(raw_state_field(current_state, "task_class"), plan_task_class(persisted_plan_or_empty(run_id)), classify_goal(safe_goal))
    let safe_current_step_id = raw_state_field(current_state, "current_step_id")
    let safe_completed_at = raw_state_field(current_state, "completed_at")
    let next_turns = apputil.parse_i32(raw_state_field(current_state, "turns_completed")) + 1
    let next_failures = if success == 1 { 0 } else { apputil.parse_i32(raw_state_field(current_state, "failure_count")) + 1 }
    let previous_completed_steps = apputil.parse_i32(raw_state_field(current_state, "completed_step_count"))
    let next_completed_steps = completed_step_count(run_id)
    let next_evidence_count = evidence_count
    let next_progress_score = turn_progress_score_typed(run_id, safe_summary, next_evidence_count, previous_completed_steps, result_kind, control_tool, control_outcome)
    let next_low_score = if next_progress_score <= 0 { apputil.parse_i32(raw_state_field(current_state, "consecutive_low_score")) + 1 } else { 0 }
    let next_status = active_next_status(success, safe_plan_status)
    let message_kind = active_message_kind(success)
    let turns_text = str.from_i32(next_turns)
    let failures_text = str.from_i32(next_failures)
    let progress_score_text = str.from_i32(next_progress_score)
    let low_score_text = str.from_i32(next_low_score)
    let evidence_text = str.from_i32(next_evidence_count)
    let completed_steps_text = str.from_i32(next_completed_steps)
    let progress_phase = if success == 1 { "turn_completed" } else { "turn_failed" }
    let updated_at = now_label()
    log.info(
        "services.longrange update_after_turn",
        apputil.log_fields3("run_id", run_id, "request_id", safe_request_id, "progress_score", str.from_i32(next_progress_score))
    )
    let rc = services.sqlite_store.longrange_update_turn(
        run_state_path(run_id),
        run_progress_path(run_id),
        run_id,
        safe_session_id,
        safe_goal,
        next_status,
        safe_plan_status,
        safe_task_class,
        turns_text,
        failures_text,
        progress_score_text,
        low_score_text,
        evidence_text,
        completed_steps_text,
        "true",
        message_kind,
        safe_summary,
        safe_created_at,
        updated_at,
        safe_current_step_id,
        safe_request_id,
        safe_completed_at,
        progress_phase,
        message_kind,
        updated_at,
        progress_score_text,
        evidence_text,
        safe_request_id,
        safe_summary,
    )
    discard refresh_summary(run_id, next_status)
    if rc != 0 {
        log.error(
            "services.longrange update_after_turn_failed",
            apputil.log_fields3("run_id", run_id, "request_id", safe_request_id, "summary", apputil.excerpt_head(safe_summary, 180))
        )
        return 1
    }
    return 0
}

fn failure_count(run_id: str) -> i32 {
    return apputil.parse_i32(quoted_json_field(load_state_json(run_id), "failure_count"))
}

fn turns_completed(run_id: str) -> i32 {
    return apputil.parse_i32(quoted_json_field(load_state_json(run_id), "turns_completed"))
}

fn auto_continue_pending(run_id: str) -> i32 {
    let raw = load_state_json(run_id)
    let flag = quoted_json_field(raw, "auto_continue_pending")
    if flag == "true" {
        return 1
    }
    if flag == "" {
        let status = quoted_json_field(raw, "run_status")
        if status == "planning" || status == "active" {
            return 1
        }
    }
    let local_raw = local_materialized_state_json(run_id)
    let local_flag = quoted_json_field(local_raw, "auto_continue_pending")
    if local_flag == "true" {
        return 1
    }
    let local_status = quoted_json_field(local_raw, "run_status")
    if local_status == "planning" || local_status == "active" {
        return 1
    }
    return 0
}

fn run_status(run_id: str) -> str {
    return quoted_json_field(load_state_json(run_id), "run_status")
}

fn run_session_id(run_id: str) -> str {
    return quoted_json_field(load_state_json(run_id), "session_id")
}

fn run_goal(run_id: str) -> str {
    return quoted_json_field(load_state_json(run_id), "goal")
}

fn latest_summary(run_id: str) -> str {
    return quoted_json_field(load_state_json(run_id), "latest_summary")
}

fn last_evidence_count(run_id: str) -> i32 {
    return apputil.parse_i32(quoted_json_field(load_state_json(run_id), "last_evidence_count"))
}

fn current_step_id(run_id: str) -> str {
    let state_parsed = json.parse(load_state_json(run_id))
    if state_current_step_id(state_parsed) != "" {
        return state_current_step_id(state_parsed)
    }
    return plan_current_step_id(json.parse(load_plan_json(run_id)))
}

fn step_handle(steps: JsonHandle, idx: i32) -> JsonHandle {
    return json.get(steps, str.from_i32(idx))
}

fn step_field(step: JsonHandle, key: str) -> str {
    return json.get_str(step, key)
}

fn step_count(run_id: str) -> i32 {
    let plan = json.parse(load_plan_json(run_id))
    let steps = json.get(plan, "steps")
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 16 {
        if step_field(step_handle(steps, idx), "step_id") == "" {
            return count
        }
        count = count + 1
        idx = idx + 1
    }
    return count
}

fn completed_step_count(run_id: str) -> i32 {
    let plan = json.parse(load_plan_json(run_id))
    let steps = json.get(plan, "steps")
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 16 {
        let step = step_handle(steps, idx)
        let step_id = step_field(step, "step_id")
        if step_id == "" {
            return count
        }
        let status = apputil.lower_ascii(step_field(step, "status"))
        if status == "done" || status == "completed" || status == "complete" {
            count = count + 1
        }
        idx = idx + 1
    }
    return count
}

fn all_steps_done(run_id: str) -> i32 {
    let total = step_count(run_id)
    if total == 0 {
        return 0
    }
    if completed_step_count(run_id) >= total {
        return 1
    }
    return 0
}

fn current_step_handle(run_id: str) -> JsonHandle {
    let target = current_step_id(run_id)
    let plan = json.parse(load_plan_json(run_id))
    let steps = json.get(plan, "steps")
    let mut idx: i32 = 0
    while idx < 16 {
        let step = step_handle(steps, idx)
        let step_id = step_field(step, "step_id")
        if step_id == "" {
            return json.parse("{}")
        }
        if step_id == target {
            return step
        }
        idx = idx + 1
    }
    return json.parse("{}")
}

fn current_step_type(run_id: str) -> str {
    let step = current_step_handle(run_id)
    let explicit = step_field(step, "step_type")
    if explicit != "" {
        return explicit
    }
    return infer_step_type(step_field(step, "step_id"), step_field(step, "title"), step_field(step, "description"))
}

