use core.fs;
use core.log;
use core.proc;
use core.storage;
use core.time;

fn runtime_root_dir() -> str {
    return runtime.config.state_subdir("longrange")
}

fn debug_root_dir() -> str {
    return runtime.config.state_subdir("longrange_debug")
}

fn runs_dir() -> str {
    return str.concat(runtime_root_dir(), "/runs")
}

fn sessions_dir() -> str {
    return str.concat(runtime_root_dir(), "/sessions")
}

fn debug_runs_dir() -> str {
    return str.concat(debug_root_dir(), "/runs")
}

fn debug_sessions_dir() -> str {
    return str.concat(debug_root_dir(), "/sessions")
}

fn ensure_local_dir(path: str) -> i32 {
    return services.localfs.ensure_dir(path)
}

fn active_runs_path() -> str {
    return apputil.path_join2(runtime_root_dir(), "active_runs.txt")
}

fn summary_path() -> str {
    return apputil.path_join2(runtime_root_dir(), "summary.json")
}

fn run_dir(run_id: str) -> str {
    return apputil.path_join2(runs_dir(), run_id)
}

fn run_state_path(run_id: str) -> str {
    return str.concat("kv:longrange:state:", run_id)
}

fn run_plan_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "plan.json")
}

fn run_progress_path(run_id: str) -> str {
    return str.concat("kv:longrange:progress:", run_id)
}

fn materialized_run_state_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "state.materialized.json")
}

fn materialized_run_progress_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "progress.materialized.json")
}

fn run_queue_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "queue.jsonl")
}

fn run_meta_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "meta.json")
}

fn run_session_id_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "session_id.txt")
}

fn run_goal_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "goal.txt")
}

fn run_created_at_path(run_id: str) -> str {
    return str.concat3(run_dir(run_id), "/", "created_at.txt")
}

fn session_dir(session_id: str) -> str {
    return apputil.path_join2(sessions_dir(), session_id)
}

fn session_active_run_path(session_id: str) -> str {
    return str.concat3(session_dir(session_id), "/", "active_run.txt")
}

fn label_counter_path() -> str {
    return str.concat(runtime_root_dir(), "/label_counter.txt")
}

fn digit_text(value: i32) -> str {
    if value == 0 { return "0" }
    if value == 1 { return "1" }
    if value == 2 { return "2" }
    if value == 3 { return "3" }
    if value == 4 { return "4" }
    if value == 5 { return "5" }
    if value == 6 { return "6" }
    if value == 7 { return "7" }
    if value == 8 { return "8" }
    return "9"
}

fn next_decimal_text(raw: str) -> str {
    let text = str.trim(raw)
    if text == "" {
        return "1"
    }
    let mut idx: i32 = str.len(text) - 1
    let mut carry: i32 = 1
    let mut out = ""
    while idx >= 0 {
        let ch = str.slice(text, idx, idx + 1)
        let next = apputil.parse_i32(ch) + carry
        if next >= 10 {
            out = str.concat("0", out)
            carry = 1
        } else {
            out = str.concat(digit_text(next), out)
            carry = 0
        }
        idx = idx - 1
    }
    if carry == 1 {
        return str.concat("1", out)
    }
    return out
}

fn next_fallback_label() -> str {
    discard ensure_state()
    let next = next_decimal_text(safe_read(label_counter_path()))
    discard fs.write_file(label_counter_path(), next)
    return next
}

fn now_label() -> str {
    let direct = str.from_i32(time.now())
    if direct != "" {
        return direct
    }
    return next_fallback_label()
}

fn fresh_label() -> str {
    return next_fallback_label()
}

fn active_run_freshness_window_ms() -> i32 {
    return 600000
}

fn run_id_from_state_key(path: str) -> str {
    let direct_prefix = "kv:longrange:state:"
    if str.starts_with(path, direct_prefix) == 1 {
        return str.slice(path, str.len(direct_prefix), str.len(path))
    }
    let legacy_prefix = "kv:longrange:run:"
    let legacy_suffix = ":state"
    if str.starts_with(path, legacy_prefix) == 0 || str.ends_with(path, legacy_suffix) == 0 {
        return ""
    }
    return str.slice(path, str.len(legacy_prefix), str.len(path) - str.len(legacy_suffix))
}

fn run_id_from_progress_key(path: str) -> str {
    let direct_prefix = "kv:longrange:progress:"
    if str.starts_with(path, direct_prefix) == 1 {
        return str.slice(path, str.len(direct_prefix), str.len(path))
    }
    let legacy_prefix = "kv:longrange:run:"
    let legacy_suffix = ":progress"
    if str.starts_with(path, legacy_prefix) == 0 || str.ends_with(path, legacy_suffix) == 0 {
        return ""
    }
    return str.slice(path, str.len(legacy_prefix), str.len(path) - str.len(legacy_suffix))
}

fn safe_read(path: str) -> str {
    let state_run_id = run_id_from_state_key(path)
    if state_run_id != "" {
        let local = materialized_run_state_path(state_run_id)
        if fs.exists(local) == 1 {
            let payload = fs.read_file(local)
            if payload != "" {
                return payload
            }
            discard append_text_line(debug_payload_path(state_run_id, "state.read.trace.log"), apputil.json_obj3("source", json.str("local_state_materialized_empty"), "bytes", json.str("0"), "path", json.str(local)))
        }
        let kv_payload = services.sqlite_store.kv_get(path)
        if kv_payload != "" {
            discard append_text_line(debug_payload_path(state_run_id, "state.read.trace.log"), apputil.json_obj3("source", json.str("sqlite_state_fallback"), "bytes", json.str(str.from_i32(str.len(kv_payload))), "path", json.str(path)))
            discard services.localfs.write_text(local, kv_payload)
            return kv_payload
        }
        discard append_text_line(debug_payload_path(state_run_id, "state.read.trace.log"), apputil.json_obj3("source", json.str("local_state_missing"), "bytes", json.str("0"), "path", json.str(local)))
        return ""
    }
    let progress_run_id = run_id_from_progress_key(path)
    if progress_run_id != "" {
        let local = materialized_run_progress_path(progress_run_id)
        if fs.exists(local) == 1 {
            let payload = fs.read_file(local)
            if payload != "" {
                return payload
            }
            discard append_text_line(debug_payload_path(progress_run_id, "progress.read.trace.log"), apputil.json_obj3("source", json.str("local_progress_materialized_empty"), "bytes", json.str("0"), "path", json.str(local)))
        }
        let kv_payload = services.sqlite_store.kv_get(path)
        if kv_payload != "" {
            discard append_text_line(debug_payload_path(progress_run_id, "progress.read.trace.log"), apputil.json_obj3("source", json.str("sqlite_progress_fallback"), "bytes", json.str(str.from_i32(str.len(kv_payload))), "path", json.str(path)))
            discard services.localfs.write_text(local, kv_payload)
            return kv_payload
        }
        discard append_text_line(debug_payload_path(progress_run_id, "progress.read.trace.log"), apputil.json_obj3("source", json.str("local_progress_missing"), "bytes", json.str("0"), "path", json.str(local)))
        return ""
    }
    if str.starts_with(path, "kv:") == 1 {
        return services.sqlite_store.kv_get(path)
    }
    if fs.exists(path) == 0 {
        return ""
    }
    return fs.read_file(path)
}

fn parent_dir_path(path: str) -> str {
    let mut idx: i32 = str.len(path) - 1
    while idx >= 0 {
        if str.slice(path, idx, idx + 1) == "/" {
            return str.slice(path, 0, idx)
        }
        idx = idx - 1
    }
    return ""
}

fn atomic_write_text(path: str, payload: str) -> i32 {
    if str.starts_with(path, "kv:") == 1 {
        return services.sqlite_store.kv_put(path, payload)
    }
    return services.localfs.write_text(path, payload)
}

fn append_text_line(path: str, line: str) -> i32 {
    let rc = services.localfs.append_text_line(path, line)
    if rc != 0 {
        log.error(
            "services.longrange append_text_line_failed",
            apputil.log_fields3("path", path, "code", str.from_i32(rc), "head", apputil.excerpt_head(line, 220))
        )
    }
    return rc
}

fn text_index_of(hay: str, needle: str) -> i32 {
    if needle == "" {
        return 0
    }
    if str.len(needle) > str.len(hay) {
        return -1
    }
    let mut idx: i32 = 0
    while idx + str.len(needle) <= str.len(hay) {
        if str.slice(hay, idx, idx + str.len(needle)) == needle {
            return idx
        }
        idx = idx + 1
    }
    return -1
}

fn quoted_json_field(raw: str, key: str) -> str {
    if raw == "" || key == "" {
        return ""
    }
    let parsed_value = apputil.json_field_or_empty(raw, key)
    if parsed_value != "" {
        return parsed_value
    }
    let marker = str.concat3("\"", key, "\":\"")
    let start = text_index_of(raw, marker)
    if start < 0 {
        return ""
    }
    let mut idx: i32 = start + str.len(marker)
    let mut out = ""
    let mut escaping: i32 = 0
    while idx < str.len(raw) {
        let ch = str.slice(raw, idx, idx + 1)
        if escaping == 1 {
            if ch == "n" {
                out = str.concat(out, "\n")
            } else if ch == "t" {
                out = str.concat(out, "\t")
            } else if ch == "r" {
                out = str.concat(out, "\r")
            } else if ch == "\"" {
                out = str.concat(out, "\"")
            } else if ch == "\\" {
                out = str.concat(out, "\\")
            } else {
                out = str.concat(out, ch)
            }
            escaping = 0
            idx = idx + 1
            continue
        }
        if ch == "\\" {
            escaping = 1
            idx = idx + 1
            continue
        }
        if ch == "\"" {
            return out
        }
        out = str.concat(out, ch)
        idx = idx + 1
    }
    return out
}

fn corrupt_json(payload: str) -> i32 {
    if payload == "" || str.trim(payload) == "{}" {
        return 1
    }
    return 0
}

fn looks_like_object_json(payload: str) -> i32 {
    let trimmed = str.trim(payload)
    if trimmed == "" {
        return 0
    }
    if str.slice(trimmed, 0, 1) != "{" {
        return 0
    }
    if str.slice(trimmed, str.len(trimmed) - 1, str.len(trimmed)) != "}" {
        return 0
    }
    return 1
}

fn looks_like_array_json(payload: str) -> i32 {
    let trimmed = str.trim(payload)
    if trimmed == "[]" {
        return 1
    }
    if str.len(trimmed) < 2 {
        return 0
    }
    if str.slice(trimmed, 0, 1) != "[" {
        return 0
    }
    if str.slice(trimmed, str.len(trimmed) - 1, str.len(trimmed)) != "]" {
        return 0
    }
    return 1
}

fn state_payload_valid(payload: str) -> i32 {
    if looks_like_object_json(payload) == 0 {
        return 0
    }
    if quoted_json_field(payload, "run_id") == "" {
        return 0
    }
    if quoted_json_field(payload, "run_status") == "" {
        return 0
    }
    if quoted_json_field(payload, "plan_status") == "" {
        return 0
    }
    return 1
}

fn progress_payload_valid(payload: str) -> i32 {
    if looks_like_object_json(payload) == 0 {
        return 0
    }
    if quoted_json_field(payload, "run_id") == "" {
        return 0
    }
    if quoted_json_field(payload, "phase") == "" {
        return 0
    }
    return 1
}

fn plan_payload_valid(payload: str) -> i32 {
    if looks_like_object_json(payload) == 0 {
        return 0
    }
    if quoted_json_field(payload, "run_id") == "" {
        return 0
    }
    if quoted_json_field(payload, "status") == "" {
        return 0
    }
    if quoted_json_field(payload, "task_class") == "" {
        return 0
    }
    return 1
}

fn debug_payload_path(run_id: str, name: str) -> str {
    return str.concat3(run_dir(run_id), "/", name)
}

fn mark_stage(run_id: str, stage: str) -> i32 {
    if run_id == "" {
        return 0
    }
    return services.localfs.write_text(debug_payload_path(run_id, "create_run.stage.txt"), stage)
}

fn append_state_debug(run_id: str, event: str, a: str, b: str, c: str) -> i32 {
    let mut line = "{\"ts\":"
    line = str.concat(line, json.str(now_label()))
    line = str.concat(line, str.concat(",\"event\":", json.str(event)))
    line = str.concat(line, str.concat(",\"a\":", json.str(a)))
    line = str.concat(line, str.concat(",\"b\":", json.str(b)))
    line = str.concat(line, str.concat(",\"c\":", json.str(c)))
    line = str.concat(line, "}")
    return append_text_line(debug_payload_path(run_id, "state.debug.jsonl"), line)
}

fn progress_event_json(run_id: str, phase: str, message_kind: str, recorded_at: str, progress_score: str, evidence_count: str, request_id: str, detail: str) -> str {
    let mut line = "{"
    line = patch_add_field(line, "run_id", run_id)
    line = patch_add_field(line, "phase", phase)
    line = patch_add_field(line, "message_kind", message_kind)
    line = patch_add_field(line, "recorded_at", recorded_at)
    line = patch_add_field(line, "progress_score", progress_score)
    line = patch_add_field(line, "evidence_count", evidence_count)
    if request_id != "" {
        line = patch_add_field(line, "request_id", request_id)
    }
    if detail != "" {
        line = patch_add_field(line, "detail", detail)
    }
    return patch_finish(line)
}

fn state_doc_json(run_id: str, session_id: str, goal: str, run_status: str, plan_status: str, task_class: str, turns_completed: str, failure_count: str, last_progress_score: str, consecutive_low_score: str, last_evidence_count: str, completed_step_count: str, auto_continue_pending: str, active_message_kind: str, latest_summary: str, created_at: str, updated_at: str, current_step_id: str, last_request_id: str, completed_at: str) -> str {
    let mut payload = "{"
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "run_id", run_id)
    payload = patch_add_field(payload, "session_id", session_id)
    payload = patch_add_field(payload, "goal", goal)
    payload = patch_add_field(payload, "run_status", run_status)
    payload = patch_add_field(payload, "plan_status", plan_status)
    payload = patch_add_field(payload, "task_class", task_class)
    payload = patch_add_field(payload, "turns_completed", turns_completed)
    payload = patch_add_field(payload, "failure_count", failure_count)
    payload = patch_add_field(payload, "last_progress_score", last_progress_score)
    payload = patch_add_field(payload, "consecutive_low_score", consecutive_low_score)
    payload = patch_add_field(payload, "last_evidence_count", last_evidence_count)
    payload = patch_add_field(payload, "completed_step_count", completed_step_count)
    payload = patch_add_field(payload, "auto_continue_pending", auto_continue_pending)
    payload = patch_add_field(payload, "active_message_kind", active_message_kind)
    payload = patch_add_field(payload, "latest_summary", latest_summary)
    payload = patch_add_field(payload, "created_at", created_at)
    payload = patch_add_field(payload, "updated_at", updated_at)
    if current_step_id != "" {
        payload = patch_add_field(payload, "current_step_id", current_step_id)
    }
    if last_request_id != "" {
        payload = patch_add_field(payload, "last_request_id", last_request_id)
    }
    if completed_at != "" {
        payload = patch_add_field(payload, "completed_at", completed_at)
    }
    return patch_finish(payload)
}

fn patch_start() -> str {
    return "{"
}

fn patch_add_field(payload: str, key: str, value: str) -> str {
    let head = str.concat3("\"", key, "\":")
    let part = str.concat(head, json.str(value))
    if payload == "{" {
        return str.concat(payload, part)
    }
    return str.concat3(payload, ",", part)
}

fn patch_finish(payload: str) -> str {
    return str.concat(payload, "}")
}

fn write_state_payload(run_id: str, payload: str) -> i32 {
    if state_payload_valid(payload) == 0 {
        log.error(
            "services.longrange invalid_state_payload",
            apputil.log_fields3("run_id", run_id, "bytes", str.from_i32(str.len(payload)), "head", apputil.excerpt_head(payload, 220))
        )
        discard atomic_write_text(debug_payload_path(run_id, "state.invalid.json"), payload)
        discard append_text_line(debug_payload_path(run_id, "state.invalid.log"), payload)
        return 1
    }
    let debug_rc = atomic_write_text(debug_payload_path(run_id, "state.last.write.json"), payload)
    if debug_rc != 0 {
        log.error(
            "services.longrange write_state_payload_debug_failed",
            apputil.log_fields3("run_id", run_id, "code", str.from_i32(debug_rc), "path", debug_payload_path(run_id, "state.last.write.json"))
        )
    }
    discard append_state_debug(run_id, "write_state_payload", quoted_json_field(payload, "run_status"), quoted_json_field(payload, "turns_completed"), quoted_json_field(payload, "plan_status"))
    let terminal_status = quoted_json_field(payload, "run_status")
    if terminal_status == "failed" || terminal_status == "completed" || terminal_status == "cancelled" {
        log.warn(
            "services.longrange write_state_payload_terminal",
            apputil.log_fields3("run_id", run_id, "status", terminal_status, "head", apputil.excerpt_head(payload, 220))
        )
        let terminal_debug_rc = atomic_write_text(debug_payload_path(run_id, "state.last.write.terminal.json"), payload)
        if terminal_debug_rc != 0 {
            log.error(
                "services.longrange write_state_payload_terminal_debug_failed",
                apputil.log_fields3("run_id", run_id, "code", str.from_i32(terminal_debug_rc), "path", debug_payload_path(run_id, "state.last.write.terminal.json"))
            )
        }
    }
    let state_rc = atomic_write_text(run_state_path(run_id), payload)
    if state_rc != 0 {
        log.error(
            "services.longrange write_state_payload_failed",
            apputil.log_fields3("run_id", run_id, "code", str.from_i32(state_rc), "path", run_state_path(run_id))
        )
        return 1
    }
    discard services.localfs.write_text(materialized_run_state_path(run_id), payload)
    return 0
}

fn append_progress_payload(run_id: str, payload: str) -> i32 {
    discard atomic_write_text(debug_payload_path(run_id, "progress.last.candidate.json"), payload)
    if progress_payload_valid(payload) == 0 {
        log.error(
            "services.longrange invalid_progress_payload",
            apputil.log_fields3("run_id", run_id, "bytes", str.from_i32(str.len(payload)), "head", apputil.excerpt_head(payload, 220))
        )
        discard atomic_write_text(debug_payload_path(run_id, "progress.invalid.json"), payload)
        discard append_text_line(debug_payload_path(run_id, "progress.invalid.log"), payload)
        return 1
    }
    let current = safe_read(run_progress_path(run_id))
    let base = if looks_like_array_json(current) == 1 { str.trim(current) } else { "[]" }
    let next = if base == "[]" {
        str.concat3("[", payload, "]")
    } else {
        str.concat3(str.slice(base, 0, str.len(base) - 1), str.concat(",", payload), "]")
    }
    let rc = atomic_write_text(run_progress_path(run_id), next)
    if rc != 0 {
        log.error(
            "services.longrange append_progress_payload_failed",
            apputil.log_fields3("run_id", run_id, "code", str.from_i32(rc), "head", apputil.excerpt_head(payload, 220))
        )
        return 1
    }
    discard services.localfs.write_text(materialized_run_progress_path(run_id), next)
    return 0
}

fn bool_text(flag: i32) -> str {
    if flag == 1 {
        return "true"
    }
    return "false"
}

fn ensure_state() -> i32 {
    fs.mkdir(runtime_root_dir())
    fs.mkdir(debug_root_dir())
    fs.mkdir(runs_dir())
    fs.mkdir(sessions_dir())
    fs.mkdir(debug_runs_dir())
    fs.mkdir(debug_sessions_dir())
    if safe_read(active_runs_path()) == "" {
        discard atomic_write_text(active_runs_path(), "")
    }
    if safe_read(summary_path()) == "" {
        discard atomic_write_text(summary_path(), model.types.longrange_summary_json("0", "0", "0", "0", "", "idle"))
    }
    return 0
}

fn boot() -> i32 {
    discard ensure_state()
    return rebuild_runtime_projection()
}

fn ensure_run(run_id: str) -> i32 {
    discard ensure_state()
    if ensure_local_dir(run_dir(run_id)) != 0 {
        return 1
    }
    if safe_read(run_progress_path(run_id)) == "" {
        discard atomic_write_text(run_progress_path(run_id), "[]")
    }
    if safe_read(run_queue_path(run_id)) == "" {
        discard atomic_write_text(run_queue_path(run_id), "")
    }
    return 0
}

fn ensure_session(session_id: str) -> i32 {
    discard ensure_state()
    return ensure_local_dir(session_dir(session_id))
}

fn summary_json() -> str {
    discard ensure_state()
    let payload = safe_read(summary_path())
    if corrupt_json(payload) == 1 || json.get_str(json.parse(payload), "status") == "" {
        discard rebuild_runtime_projection()
        let repaired = safe_read(summary_path())
        if corrupt_json(repaired) == 0 && json.get_str(json.parse(repaired), "status") != "" {
            return repaired
        }
        return model.types.longrange_summary_json("0", "0", "0", "0", "", "idle")
    }
    return payload
}

fn summary_active_runs(parsed: JsonHandle) -> i32 {
    return apputil.parse_i32(json.get_str(parsed, "active_runs"))
}

fn summary_completed_runs(parsed: JsonHandle) -> i32 {
    return apputil.parse_i32(json.get_str(parsed, "completed_runs"))
}

fn summary_failed_runs(parsed: JsonHandle) -> i32 {
    return apputil.parse_i32(json.get_str(parsed, "failed_runs"))
}

fn summary_cancelled_runs(parsed: JsonHandle) -> i32 {
    return apputil.parse_i32(json.get_str(parsed, "cancelled_runs"))
}

fn count_lines(text_value: str) -> i32 {
    if text_value == "" {
        return 0
    }
    let mut count: i32 = 0
    let mut rest = text_value
    while services.persistence.first_line(rest) != "" {
        count = count + 1
        rest = services.persistence.drop_first_line(rest)
    }
    return count
}

fn text_has_line(text_value: str, line: str) -> i32 {
    if text_value == "" || line == "" {
        return -1
    }
    return text_index_of(str.concat("\n", str.concat(text_value, "\n")), str.concat("\n", str.concat(line, "\n")))
}

fn list_dir_names(path: str) -> ListHandle {
    if fs.exists(path) == 0 {
        return list.new()
    }
    return fs.listdir(path)
}

fn local_materialized_state_json(run_id: str) -> str {
    let path = materialized_run_state_path(run_id)
    if fs.exists(path) == 0 {
        return ""
    }
    return fs.read_file(path)
}

fn local_materialized_progress_json(run_id: str) -> str {
    let path = materialized_run_progress_path(run_id)
    if fs.exists(path) == 0 {
        return ""
    }
    return fs.read_file(path)
}

fn has_local_state_doc(run_id: str) -> i32 {
    let raw = local_materialized_state_json(run_id)
    if looks_like_object_json(raw) == 0 {
        return 0
    }
    if quoted_json_field(raw, "run_id") == "" || quoted_json_field(raw, "run_status") == "" {
        return 0
    }
    return 1
}

fn has_meaningful_local_progress(run_id: str) -> i32 {
    let raw = str.trim(local_materialized_progress_json(run_id))
    if looks_like_array_json(raw) == 0 {
        return 0
    }
    if raw == "[]" {
        return 0
    }
    let events = json.parse(raw)
    let first = json.get(events, "0")
    if json.get_str(first, "run_id") == "" && json.get_str(first, "phase") == "" {
        return 0
    }
    return 1
}

fn projection_run_is_complete_enough(run_id: str) -> i32 {
    if has_local_state_doc(run_id) == 1 {
        return 1
    }
    if has_meaningful_local_progress(run_id) == 1 {
        return 1
    }
    return 0
}

fn inferred_run_status_from_progress_payload(payload: str) -> str {
    if looks_like_array_json(payload) == 0 {
        return "missing"
    }
    let events = json.parse(payload)
    let mut last = ""
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            break
        }
        if phase != "" {
            last = phase
        }
        idx = idx + 1
    }
    if last == "completed" {
        return "completed"
    }
    if last == "failed" {
        return "failed"
    }
    if last == "cancelled" {
        return "cancelled"
    }
    if last == "plan_created" || last == "turn_completed" || last == "turn_failed" {
        return "active"
    }
    if last == "started" {
        return "planning"
    }
    return "missing"
}

fn projection_run_status(run_id: str) -> str {
    if projection_run_is_complete_enough(run_id) == 0 {
        return ""
    }
    let raw = local_materialized_state_json(run_id)
    let status = quoted_json_field(raw, "run_status")
    if status != "" {
        return status
    }
    return inferred_run_status_from_progress_payload(local_materialized_progress_json(run_id))
}

fn run_state_updated_at_ms(run_id: str) -> i32 {
    let raw = local_materialized_state_json(run_id)
    return apputil.parse_i32(first_non_empty3(quoted_json_field(raw, "updated_at"), quoted_json_field(raw, "created_at"), "0"))
}

fn active_run_is_fresh(run_id: str) -> i32 {
    if run_id == "" {
        return 0
    }
    let status = projection_run_status(run_id)
    if status != "planning" && status != "active" {
        return 0
    }
    let updated_at = run_state_updated_at_ms(run_id)
    if updated_at <= 0 {
        return 0
    }
    let now_ms = apputil.parse_i32(now_label())
    if now_ms <= 0 {
        return 0
    }
    let age = now_ms - updated_at
    if age < 0 {
        return 1
    }
    if age > active_run_freshness_window_ms() {
        return 0
    }
    return 1
}

fn run_state_stamp(run_id: str) -> i32 {
    if projection_run_is_complete_enough(run_id) == 0 {
        return 0
    }
    let raw = local_materialized_state_json(run_id)
    let stamp = first_non_empty3(quoted_json_field(raw, "completed_at"), quoted_json_field(raw, "updated_at"), meta_created_at_text(run_id))
    return apputil.parse_i32(stamp)
}

fn rebuild_summary_snapshot_json() -> str {
    let run_ids = list_dir_names(runs_dir())
    let mut completed: i32 = 0
    let mut failed: i32 = 0
    let mut cancelled: i32 = 0
    let mut latest_run_id = ""
    let mut latest_status = "idle"
    let mut latest_stamp: i32 = 0
    let mut idx: i32 = 0
    while idx < list.len(run_ids) {
        let run_id = list.get(run_ids, idx)
        if projection_run_is_complete_enough(run_id) == 0 {
            idx = idx + 1
            continue
        }
        let status = projection_run_status(run_id)
        if status == "completed" {
            completed = completed + 1
        } else if status == "failed" {
            failed = failed + 1
        } else if status == "cancelled" {
            cancelled = cancelled + 1
        }
        let stamp = run_state_stamp(run_id)
        if latest_run_id == "" || stamp >= latest_stamp {
            latest_run_id = run_id
            latest_status = if status == "" { "idle" } else { status }
            latest_stamp = stamp
        }
        idx = idx + 1
    }
    return summary_doc_json(
        str.from_i32(active_run_count()),
        str.from_i32(completed),
        str.from_i32(failed),
        str.from_i32(cancelled),
        latest_run_id,
        latest_status,
    )
}

fn active_run_count() -> i32 {
    discard rewrite_active_runs_index()
    return count_lines(safe_read(active_runs_path()))
}

fn summary_doc_json(active_runs: str, completed_runs: str, failed_runs: str, cancelled_runs: str, latest_run_id: str, latest_status: str) -> str {
    let mut payload = "{"
    payload = patch_add_field(payload, "status", model.types.control_ok_label())
    payload = patch_add_field(payload, "active_runs", active_runs)
    payload = patch_add_field(payload, "completed_runs", completed_runs)
    payload = patch_add_field(payload, "failed_runs", failed_runs)
    payload = patch_add_field(payload, "cancelled_runs", cancelled_runs)
    payload = patch_add_field(payload, "latest_run_id", latest_run_id)
    payload = patch_add_field(payload, "latest_status", latest_status)
    return patch_finish(payload)
}

fn write_summary_counts(completed_runs: i32, failed_runs: i32, cancelled_runs: i32, latest_run_id: str, latest_status: str) -> i32 {
    let active_runs = active_run_count()
    let payload = summary_doc_json(
        str.from_i32(active_runs),
        str.from_i32(completed_runs),
        str.from_i32(failed_runs),
        str.from_i32(cancelled_runs),
        latest_run_id,
        latest_status,
    )
    discard atomic_write_text(str.concat(summary_path(), ".last.write.json"), payload)
    discard atomic_write_text(summary_path(), payload)
    return 0
}

fn rebuild_runtime_projection() -> i32 {
    discard ensure_state()
    let rc = services.sqlite_store.longrange_rebuild_projection()
    if rc != 0 {
        log.error(
            "services.longrange rebuild_runtime_projection_failed",
            apputil.log_fields2("code", str.from_i32(rc), "summary_file", summary_path())
        )
    }
    return rc
}

fn refresh_summary(latest_run_id: str, latest_status: str) -> i32 {
    return rebuild_runtime_projection()
}

fn write_terminal_summary(latest_run_id: str, latest_status: str) -> i32 {
    return rebuild_runtime_projection()
}

