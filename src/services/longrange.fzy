pub fn tool_event_count(tool_events_json: str) -> i32 {
    if tool_events_json == "" || tool_events_json == "[]" {
        return 0
    }
    let parsed = json.parse(tool_events_json)
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < 32 {
        if json.get_str(json.get(parsed, str.from_i32(idx)), "tool") == "" {
            return count
        }
        count = count + 1
        idx = idx + 1
    }
    return count
}

fn looks_like_plaintext_plan_attempt(summary: str) -> i32 {
    if summary == "" {
        return 0
    }
    if str.starts_with(summary, "```json") == 1 {
        if str.contains(summary, "\"goal_summary\"") == 1 || str.contains(summary, "\"steps\"") == 1 || str.contains(summary, "\"current_step_id\"") == 1 {
            return 1
        }
    }
    if str.starts_with(summary, "```bash") == 1 {
        if str.contains(summary, "plan_create ") == 1 || str.contains(summary, "plan_update ") == 1 {
            return 1
        }
    }
    return 0
}

fn completion_gate_ready(run_id: str, assistant_summary: str, evidence_count: i32) -> i32 {
    if plan_status_ready(run_id) == 0 {
        return 0
    }
    let class = task_class(run_id)
    let mode = completion_mode(run_id)
    let total_steps = step_count(run_id)
    let done_steps = completed_step_count(run_id)
    let final_step_ready = if total_steps > 0 && done_steps + 1 >= total_steps && assistant_summary != "" && is_passive_control_summary(assistant_summary) == 0 { 1 } else { 0 }
    if mode == "direct" {
        if all_steps_done(run_id) == 1 {
            return 1
        }
        return 0
    }
    if mode == "summary" {
        if all_steps_done(run_id) == 1 && assistant_summary != "" && is_passive_control_summary(assistant_summary) == 0 {
            return 1
        }
        if class == "micro" && all_steps_done(run_id) == 1 {
            return 1
        }
        if class == "micro" && final_step_ready == 1 {
            return 1
        }
        return 0
    }
    if all_steps_done(run_id) == 1 && evidence_count > 0 {
        return 1
    }
    return 0
}

fn turn_progress_score(run_id: str, assistant_summary: str, tool_events_json: str, previous_completed_steps: i32) -> i32 {
    let evidence_count = tool_event_count(tool_events_json)
    let current_completed_steps = completed_step_count(run_id)
    if plan_status_ready(run_id) == 0 && looks_like_plaintext_plan_attempt(assistant_summary) == 1 {
        return 0
    }
    if str.starts_with(assistant_summary, "control_plane_tool_executed:goal_complete") == 1 {
        return 3
    }
    if completion_gate_ready(run_id, assistant_summary, evidence_count) == 1 {
        return 3
    }
    if current_completed_steps > previous_completed_steps {
        return 2
    }
    if evidence_count > 0 {
        return 2
    }
    if assistant_summary == "control_plane_tool_executed:plan_create" || assistant_summary == "control_plane_tool_executed:plan_update" {
        return 1
    }
    if str.starts_with(assistant_summary, "control_plane_tool_failed:") == 1 {
        return 0
    }
    if assistant_summary != "" && assistant_summary != "empty_assistant_response" && is_passive_control_summary(assistant_summary) == 0 {
        return 1
    }
    return 0
}

fn turn_progress_score_typed(run_id: str, assistant_summary: str, evidence_count: i32, previous_completed_steps: i32, result_kind: str, control_tool: str, control_outcome: str) -> i32 {
    let current_completed_steps = completed_step_count(run_id)
    if plan_status_ready(run_id) == 0 && result_kind != "control_tool" && looks_like_plaintext_plan_attempt(assistant_summary) == 1 {
        return 0
    }
    if result_kind == "control_tool" && control_tool == "goal_complete" && control_outcome == "ok" {
        return 3
    }
    if completion_gate_ready(run_id, assistant_summary, evidence_count) == 1 {
        return 3
    }
    if current_completed_steps > previous_completed_steps {
        return 2
    }
    if evidence_count > 0 {
        return 2
    }
    if result_kind == "control_tool" && (control_tool == "plan_create" || control_tool == "plan_update") && control_outcome == "ok" {
        return 1
    }
    if result_kind == "control_tool" && control_outcome == "error" {
        return 0
    }
    if result_kind == "planning_required" || result_kind == "tool_read_saturation" || result_kind == "tool_depth_limit" {
        return 0
    }
    if assistant_summary != "" && assistant_summary != "empty_assistant_response" && is_passive_control_summary(assistant_summary) == 0 {
        return 1
    }
    return 0
}

fn progress_excerpt(run_id: str) -> str {
    let payload = safe_read(run_progress_path(run_id))
    if looks_like_array_json(payload) == 0 {
        return ""
    }
    let events = json.parse(payload)
    let mut lines = list.new()
    let mut idx: i32 = 0
    while idx < 256 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            break
        }
        let message_kind = json.get_str(parsed, "message_kind")
        let detail = json.get_str(parsed, "detail")
        let score = json.get_str(parsed, "progress_score")
        let evidence = json.get_str(parsed, "evidence_count")
        let compact_detail = if detail == "" { "" } else { if str.len(detail) <= 120 { detail } else { str.concat(str.slice(detail, 0, 120), "...") } }
        let mut summary_line = str.concat(phase, str.concat(" [", str.concat(message_kind, "]")))
        if score != "" && evidence != "" {
            summary_line = str.concat(summary_line, str.concat(" score=", str.concat(score, str.concat(" evidence=", evidence))))
        }
        if compact_detail != "" {
            summary_line = str.concat(summary_line, str.concat(": ", compact_detail))
        }
        discard list.push(lines, summary_line)
        idx = idx + 1
    }
    let total = list.len(lines)
    let start = if total <= 4 { 0 } else { total - 4 }
    let mut out = ""
    let mut idx: i32 = start
    while idx < total {
        let item = list.get(lines, idx)
        if out == "" {
            out = item
        } else {
            out = str.concat(out, str.concat("\n", item))
        }
        idx = idx + 1
    }
    return out
}

fn is_passive_control_summary(summary: str) -> i32 {
    if summary == "control_plane_tool_executed:plan_create" || summary == "control_plane_tool_executed:plan_view" || summary == "control_plane_tool_executed:plan_update" || summary == "control_plane_tool_executed:longrange_status" {
        return 1
    }
    if summary == "control_plane_tool_failed:plan_create" || summary == "control_plane_tool_failed:plan_view" || summary == "control_plane_tool_failed:plan_update" || summary == "control_plane_tool_failed:goal_complete" || summary == "control_plane_tool_failed:longrange_status" {
        return 1
    }
    return 0
}

fn is_tool_only_summary(summary: str) -> i32 {
    if str.starts_with(summary, "tool_work_completed_without_final_message:") == 1 {
        return 1
    }
    return 0
}

fn passive_control_streak(run_id: str) -> i32 {
    let payload = safe_read(run_progress_path(run_id))
    if looks_like_array_json(payload) == 0 {
        return 0
    }
    let events = json.parse(payload)
    let mut event_count: i32 = 0
    while event_count < 256 {
        let parsed = json.get(events, str.from_i32(event_count))
        let phase = json.get_str(parsed, "phase")
        if phase == "" && json.get_str(parsed, "run_id") == "" {
            break
        }
        event_count = event_count + 1
    }
    let mut streak: i32 = 0
    let mut idx: i32 = event_count - 1
    while idx >= 0 {
        let parsed = json.get(events, str.from_i32(idx))
        let phase = json.get_str(parsed, "phase")
        if phase != "turn_completed" && phase != "turn_failed" {
            idx = idx - 1
            continue
        }
        let detail = json.get_str(parsed, "detail")
        if is_passive_control_summary(detail) == 1 {
            streak = streak + 1
            idx = idx - 1
            continue
        }
        break
    }
    return streak
}

fn plan_summary(run_id: str) -> str {
    return quoted_json_field(load_plan_json(run_id), "plan_summary")
}

fn goal_summary(run_id: str) -> str {
    return quoted_json_field(load_plan_json(run_id), "goal_summary")
}

fn tool_next_step(run_id: str) -> str {
    if run_id == "" || run_exists(run_id) == 0 {
        return "longrange_start"
    }
    if plan_status_ready(run_id) == 0 {
        return "plan_create"
    }
    if all_steps_done(run_id) == 1 {
        return "goal_complete"
    }
    if current_step_id(run_id) != "" {
        return str.concat("execute_step:", current_step_id(run_id))
    }
    return "plan_update"
}

fn tool_guidance(run_id: str) -> str {
    if run_id == "" || run_exists(run_id) == 0 {
        return "Start a long-range run, then create a durable plan before attempting plan or completion tools."
    }
    let status = run_status(run_id)
    if status == "completed" {
        return "This run is already complete. Do not continue it; start a new run only if there is a new goal."
    }
    if status == "cancelled" {
        return "This run was cancelled. Start a new run if work should resume."
    }
    if status == "failed" {
        return "This run has already failed. Inspect the durable state and progress logs before retrying with a fresh run."
    }
    if plan_status_ready(run_id) == 0 {
        return "Create the durable plan first. Include a goal summary, finished definition, current step, and ordered steps with statuses."
    }
    if all_steps_done(run_id) == 1 {
        return "The durable plan shows all steps complete. If the finished definition is satisfied, call goal_complete with a concise completion summary."
    }
    let step_id = current_step_id(run_id)
    let step_title = current_step_title(run_id)
    let step_type = current_step_type(run_id)
    let outlook = current_step_outlook(run_id)
    if step_id == "" {
        return "The plan is ready but no current step is set. Use plan_update to set current_step_id and mark the next step clearly."
    }
    return str.concat(
        "Continue the current step ",
        str.concat(
            step_id,
            str.concat(
                " (",
                str.concat(
                    step_title,
                    str.concat(
                        "). Step type: ",
                        str.concat(step_type, str.concat(". Outlook: ", outlook)),
                    ),
                ),
            ),
        ),
    )
}

fn tool_success_guidance(tool: str, run_id: str) -> str {
    if tool == "longrange_start" {
        return "Long-range mode is active. Create the durable plan next before attempting deep execution."
    }
    if tool == "longrange_cancel" {
        return "Do not continue this run. Start a new long-range run only if you need to resume work under a new execution lifecycle."
    }
    if tool == "longrange_steer" {
        return "Incorporate the queued steering message on the next autonomous turn, then continue the current durable step."
    }
    if tool == "plan_create" {
        return "The durable plan is ready. Move into real execution on the current step and use plan_update only when the durable plan truly changes."
    }
    if tool == "plan_update" {
        if all_steps_done(run_id) == 1 {
            return "The durable plan now appears complete. If the finished definition is satisfied, finish with goal_complete instead of more plan narration."
        }
        return "The durable plan is updated. Continue real work on the current step and only update the plan again when step status or structure changes."
    }
    if tool == "plan_view" || tool == "longrange_status" {
        return tool_guidance(run_id)
    }
    if tool == "goal_complete" {
        return "The goal is complete. Stop autonomous continuation and do not enqueue more work for this run."
    }
    return tool_guidance(run_id)
}

fn tool_error_guidance(tool: str, run_id: str, message: str) -> str {
    if message == "goal is required" {
        return "Retry longrange_start with the literal goal text that defines what finished looks like."
    }
    if message == "message is required" {
        return "Retry longrange_steer with the actual steering instruction to inject into the active run."
    }
    if message == "summary is required" {
        return "Retry goal_complete with a concise completion summary that states what was actually achieved."
    }
    if message == "no active long-range run found" {
        return "Start or recover a long-range run before retrying this tool."
    }
    if tool == "goal_complete" {
        return str.concat(message, str.concat(" Next: ", tool_guidance(run_id)))
    }
    if run_id != "" && run_exists(run_id) == 1 {
        return tool_guidance(run_id)
    }
    return "Inspect the tool inputs, then retry with the missing run or required arguments corrected."
}

