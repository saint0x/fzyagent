use core.http;
use core.time;
use core.log;
use core.fs;
use core.proc;

enum ModelClass {
    ClaudeHaiku45,
}

enum ProviderClass {
    AnthropicPrimary,
    AnthropicFallback,
}

fn env_or(key: str, fallback: str) -> str {
    let v = env.get(key)
    if v == "" {
        return fallback
    }
    return v
}

fn endpoint() -> str {
    return env_or("ANTHROPIC_ENDPOINT", "https://api.anthropic.com/v1/messages")
}

fn api_key() -> str {
    return env_or("ANTHROPIC_API_KEY", "")
}

fn request_version() -> str {
    return env_or("ANTHROPIC_VERSION", "2023-06-01")
}

fn queue_headers() -> i32 {
    discard http.header_set("x-api-key", api_key())
    discard http.header_set("anthropic-version", request_version())
    return 0
}

fn smoke() -> i32 {
    log.info("anthropic.smoke start", apputil.log_fields2("component", "anthropic", "phase", "smoke_start"))
    let message = apputil.json_obj2("role", json.str("user"), "content", json.str("Give a short agent runtime status update"))
    let messages = apputil.json_arr1(message)
    let body = build_request_payload(messages, "[]", "You are the fzyagent runtime.", "128")
    queue_headers()
    discard http.post_json_capture(endpoint(), body)
    let status = http.last_status()
    let status_text = status_label(status)
    log.info("anthropic.smoke response", apputil.log_fields3("component", "anthropic", "phase", "smoke_response", "status", status_text))
    time.sleep_ms(8)
    return status
}

fn request_max_tokens() -> str {
    let configured = env.get("ANTHROPIC_MAX_TOKENS")
    if configured == "" {
        return "8192"
    }
    return configured
}

fn build_request_payload(messages_json: str, tools_json: str, system_prompt: str, max_tokens: str) -> str {
    let mut payload = "{\"model\":"
    payload = str.concat(payload, json.str(default_model_name()))
    payload = str.concat(payload, str.concat(",\"system\":", json.str(system_prompt)))
    payload = str.concat(payload, str.concat(",\"max_tokens\":", max_tokens))
    payload = str.concat(payload, ",\"stream\":false")
    payload = str.concat(payload, str.concat(",\"messages\":", messages_json))
    payload = str.concat(payload, str.concat(",\"tools\":", tools_json))
    return str.concat(payload, "}")
}

fn response_meta_json() -> str {
    return apputil.json_obj2(
        "status", json.str(last_status_text()),
        "error", json.str(last_error()),
    )
}

fn helper_path() -> str {
    return apputil.path_join2(runtime.config.scripts_dir(), "anthropic_request.py")
}

fn python_path() -> str {
    return "/usr/bin/python3"
}

fn helper_out_path() -> str {
    return runtime.config.state_path("anthropic.helper.response.raw")
}

fn helper_meta_path() -> str {
    return runtime.config.state_path("anthropic.helper.response.meta.json")
}

fn helper_payload_path() -> str {
    return runtime.config.state_path("anthropic.helper.request.json")
}

fn last_status_text() -> str {
    if fs.exists(helper_meta_path()) == 0 {
        return str.from_i32(http.last_status())
    }
    return apputil.json_field_or_empty(fs.read_file(helper_meta_path()), "status")
}

fn helper_status_value() -> i32 {
    return apputil.parse_i32(last_status_text())
}

fn helper_error_text() -> str {
    if fs.exists(helper_meta_path()) == 0 {
        return http.last_error()
    }
    return apputil.json_field_or_empty(fs.read_file(helper_meta_path()), "error")
}

fn request_via_helper(payload: str) -> str {
    let argv: ProcessArgv = proc.argv_new()
    discard proc.argv_push(argv, helper_path())
    discard proc.argv_push(argv, endpoint())
    discard proc.argv_push(argv, api_key())
    discard proc.argv_push(argv, request_version())
    discard proc.argv_push(argv, helper_payload_path())
    discard proc.argv_push(argv, helper_out_path())
    discard proc.argv_push(argv, helper_meta_path())
    discard proc.argv_push(argv, "60")
    let env_map: ProcessEnv = proc.env_new()
    discard proc.env_set(env_map, "TERM", "dumb")
    discard proc.env_set(env_map, "ANTHROPIC_INLINE_PAYLOAD", payload)
    let handle = proc.spawn_cmd(python_path(), argv, env_map, "")
    defer proc.close(handle)
    discard proc.wait(handle, 70000)
    let stdout = proc.stdout(handle)
    let file_body = if fs.exists(helper_out_path()) == 1 { fs.read_file(helper_out_path()) } else { "" }
    if file_body != "" {
        return file_body
    }
    return stdout
}

fn request_messages_sync(messages_json: str, tools_json: str, system_prompt: str, max_tokens: str) -> str {
    let payload = build_request_payload(messages_json, tools_json, system_prompt, max_tokens)
    let stamp = str.from_i32(time.now())
    let meta_payload = apputil.json_obj5(
        "stamp", json.str(stamp),
        "message_bytes", json.str(str.from_i32(str.len(messages_json))),
        "tool_bytes", json.str(str.from_i32(str.len(tools_json))),
        "system_bytes", json.str(str.from_i32(str.len(system_prompt))),
        "payload_bytes", json.str(str.from_i32(str.len(payload))),
    )
    log.info(
        "anthropic.request",
        apputil.log_fields3("stamp", stamp, "message_bytes", str.from_i32(str.len(messages_json)), "payload_bytes", str.from_i32(str.len(payload)))
    )
    if runtime.config.persist_request_artifacts() == 1 {
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), "anthropic.request.meta.current.json"), meta_payload)
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.request.meta.", str.concat(stamp, ".json"))), meta_payload)
    }
    if messages_json == "" || payload == "" {
        log.error(
            "anthropic.request.empty_payload",
            apputil.log_fields3("stamp", stamp, "message_bytes", str.from_i32(str.len(messages_json)), "tool_bytes", str.from_i32(str.len(tools_json)))
        )
        if runtime.config.persist_request_artifacts() == 1 {
            discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), "anthropic.request.json"), payload)
            discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.request.", str.concat(stamp, ".json"))), payload)
            discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.request.", str.concat(stamp, ".meta.json"))), apputil.json_obj3("status", json.str("error"), "message_bytes", json.str(str.from_i32(str.len(messages_json))), "tool_bytes", json.str(str.from_i32(str.len(tools_json)))))
        }
        return ""
    }
    if runtime.config.persist_request_artifacts() == 1 {
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), "anthropic.request.json"), payload)
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.request.", str.concat(stamp, ".json"))), payload)
    }
    let out = request_via_helper(payload)
    if runtime.config.persist_request_artifacts() == 1 {
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), "anthropic.response.raw"), out)
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), "anthropic.response.meta.json"), response_meta_json())
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.response.", str.concat(stamp, ".raw"))), out)
        discard services.localfs.write_text(apputil.path_join2(runtime.config.state_subdir("provider.debug"), str.concat("anthropic.response.", str.concat(stamp, ".meta.json"))), response_meta_json())
    }
    return out
}

fn last_status() -> i32 {
    return helper_status_value()
}

fn last_error() -> str {
    return helper_error_text()
}

fn status_label(status: i32) -> str {
    if status >= 200 {
        if status < 300 {
            return "ok"
        }
        return "upstream_error"
    }
    return "transport_error"
}

fn default_model() -> i32 {
    return model_code(default_model_class())
}

fn default_model_class() -> ModelClass {
    return ModelClass::ClaudeHaiku45
}

fn default_model_name() -> str {
    let configured = env.get("AGENT_MODEL")
    if configured != "" {
        return configured
    }
    let model = env.get("ANTHROPIC_MODEL")
    if model != "" {
        return model
    }
    return "claude-haiku-4-5-20251001"
}

fn model_code(model: ModelClass) -> i32 {
    match model {
        ModelClass::ClaudeHaiku45 => return 45,
        _ => return 45,
    }
    return 45
}

fn model_name(model: ModelClass) -> str {
    match model {
        ModelClass::ClaudeHaiku45 => return env.get("ANTHROPIC_MODEL"),
        _ => return env.get("ANTHROPIC_MODEL"),
    }
    return env.get("ANTHROPIC_MODEL")
}
