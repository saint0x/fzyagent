use core.http;
use core.thread;
use core.log;

fn configure_server() -> i32 {
    env.get("AGENT_HOST")
    env.get("AGENT_PORT")
    env.get("AGENT_WORKERS")
    return 0
}

fn start_server() -> i32 {
    log.info("http.start_server", util.log_fields2("component", "http", "phase", "start_server"))
    web.start_listener()
    return 0
}

fn graceful_stop() -> i32 {
    checkpoint()
    return 0
}

fn listen_public() -> i32 {
    let listener: HttpHandle = http.bind()
    http.listen(listener)
    close(listener)
    return 0
}

fn accept_once() -> i32 {
    let conn: HttpHandle = http.accept()
    http.read(conn)
    http.write(conn, 200, "ok")
    close(conn)
    return 0
}

fn accept_and_dispatch() -> i32 {
    web.accept_and_process()
    return 0
}

fn post_sessions() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.create_session()
    return 0
}

fn get_session() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.get_session()
    return 0
}

fn post_session_messages() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.post_message()
    return 0
}

fn get_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.list_tools()
    return 0
}

fn post_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.register_tool()
    return 0
}

fn delete_tool() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.unregister_tool()
    return 0
}

fn post_tool_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    tools.run_parallel()
    tools.classify_failure()
    persistence.save_tool_run()
    return 0
}

fn get_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    persistence.load_session()
    return 0
}

fn route_sessions() -> i32 {
    post_sessions()
    get_session()
    return 0
}

fn route_messages() -> i32 {
    post_session_messages()
    return 0
}

fn route_tools() -> i32 {
    get_tools()
    post_tools()
    delete_tool()
    return 0
}

fn route_runs() -> i32 {
    post_tool_run()
    get_run()
    return 0
}

fn resolve_workdir() -> str {
    return "."
}

fn path_after_prefix(path: str, prefix: str) -> str {
    let prefix_len = str.len(prefix)
    let path_len = str.len(path)
    if path_len <= prefix_len {
        return ""
    }
    return str.slice(path, prefix_len, path_len)
}

fn path_before_suffix(path: str, suffix: str) -> str {
    let path_len = str.len(path)
    let suffix_len = str.len(suffix)
    if path_len <= suffix_len {
        return ""
    }
    return str.slice(path, 0, path_len - suffix_len)
}

fn session_id_from_session_path(path: str) -> str {
    return path_after_prefix(path, "/sessions/")
}

fn session_id_from_message_path(path: str) -> str {
    let prefix_trimmed = path_after_prefix(path, "/sessions/")
    return path_before_suffix(prefix_trimmed, "/messages")
}

fn tool_id_from_tool_path(path: str) -> str {
    return path_after_prefix(path, "/tools/")
}

fn tool_id_from_run_path(path: str) -> str {
    let prefix_trimmed = path_after_prefix(path, "/tools/")
    return path_before_suffix(prefix_trimmed, "/run")
}

fn run_id_from_path(path: str) -> str {
    return path_after_prefix(path, "/runs/")
}

fn handle_sessions(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_sessions", util.log_fields2("component", "http", "handler", "sessions_create"))
    }
    let request = http.body_json(conn)
    let requested = json.get_str(request, "session_id")
    let reset = json.get_str(request, "reset")
    let session_id = if requested == "" { sessions.default_session_id() } else { requested }
    if reset == "true" {
        discard sessions.reset_session_for(session_id, http.request_id(conn))
    } else {
        discard sessions.create_session_for(session_id, http.request_id(conn))
    }
    let session = sessions.get_session_json_for(session_id)
    let event = if reset == "true" { "session_reset" } else { "session_created" }
    let body = util.json_obj3("status", json.str("ok"), "event", json.str(event), "session", json.raw(session))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_session_get(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_session_get", util.log_fields2("component", "http", "handler", "session_get"))
    }
    let session_id = session_id_from_session_path(path)
    discard sessions.get_session_for(session_id)
    let state = model.types.active_session_state_label()
    let details = sessions.get_session_json_for(session_id)
    let body = util.json_obj4("status", json.str("ok"), "event", json.str("session_loaded"), "session_id", json.str(session_id), "details", json.raw(details))
    if state == "active" {
        checkpoint()
    }
    http.write_json(conn, 200, body)
    return 0
}

fn handle_messages(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_messages start", util.log_fields3("component", "http", "handler", "messages_post", "phase", "start"))
    }
    let session_id = session_id_from_message_path(path)
    let request_id = http.request_id(conn)
    let prompt = safety.filter_prompt_text(prompt_from_request(conn))
    if safety.allow_prompt(prompt) == 0 {
        let denied = util.json_obj3("status", json.str("error"), "session_id", json.str(session_id), "message", json.str("prompt_denied"))
        http.write_json(conn, 403, denied)
        return 0
    }

    discard sessions.post_message_for(session_id, prompt, request_id, "anthropic_latest")
    let result = runtime.agent.run_session_turn(session_id, prompt, request_id)
    let parsed = json.parse(result)
    let assistant = safety.filter_tool_response_text(json.get_str(parsed, "assistant"))
    let raw_response = json.get_str(parsed, "raw_response")
    let tool_events = json.get_str(json.get(parsed, "tool_events"), "raw")
    let provider_payload_map = map.new()
    discard map.set(provider_payload_map, "provider", json.str("anthropic"))
    discard map.set(provider_payload_map, "assistant", json.str(assistant))
    discard map.set(provider_payload_map, "raw_response", json.str(raw_response))
    discard map.set(provider_payload_map, "tool_events", json.raw(if tool_events == "" { "[]" } else { tool_events }))
    let provider_payload = json.object(provider_payload_map)
    if runtime.agent.turn_response_is_ok(parsed) == 1 {
        let body = util.json_obj4("status", json.str("ok"), "session_id", json.str(session_id), "request_id", json.str(request_id), "data", json.raw(provider_payload))
        http.write_json(conn, 200, body)
        return 0
    }
    let body = util.json_obj4("status", json.str("error"), "session_id", json.str(session_id), "request_id", json.str(request_id), "data", json.raw(result))
    http.write_json(conn, 502, body)
    return 0
}

fn prompt_from_request(conn: HttpHandle) -> str {
    let raw_body = http.body(conn)
    let parsed = json.parse(if raw_body == "" { "{}" } else { raw_body })
    let prompt = json.get_str(parsed, "message")
    if prompt == "" {
        return "runtime status"
    }
    return prompt
}

fn handle_tools_register(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_register", util.log_fields2("component", "http", "handler", "tools_register"))
    }
    post_tools()
    let body = util.json_obj3("status", json.str("ok"), "event", json.str("tool_registered"), "tools", json.raw(registry.list_tools_json()))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_tools_list(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_list", util.log_fields2("component", "http", "handler", "tools_list"))
    }
    get_tools()
    http.write_json(conn, 200, registry.list_tools_json())
    return 0
}

fn handle_tools_delete(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_delete", util.log_fields2("component", "http", "handler", "tools_delete"))
    }
    delete_tool()
    let tool_id = tool_id_from_tool_path(path)
    let body = util.json_obj3("status", json.str("ok"), "event", json.str("tool_deleted"), "tool_id", json.str(tool_id))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_tools_run(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_run start", util.log_fields3("component", "http", "handler", "tools_run", "phase", "start"))
    }
    let tool_id = tool_id_from_run_path(path)
    let raw_body = http.body(conn)
    let normalized = api.rpc.normalize_tool_request(tool_id, raw_body)
    let rpc_error = api.rpc.validate_normalized_tool_request(normalized)
    if rpc_error != "" {
        http.write_json(conn, 400, rpc_error)
        return 0
    }
    let parsed = json.parse(normalized)
    let request_id = json.get_str(parsed, "request_id")
    let rpc_kind = api.rpc.request_kind(parsed)
    let rpc_kind_code = api.rpc.request_kind_code(rpc_kind)
    let dispatch_tool_id = json.get_str(parsed, "tool_id")
    let effective_tool_id = if dispatch_tool_id == "" { tool_id } else { dispatch_tool_id }
    let tool_status = if rpc_kind_code == 2 || tool_id == "tool_sequence" {
        tools.run_tool_sequence(normalized)
    } else if rpc_kind_code == 3 || tool_id == "tool_parallel" {
        tools.run_tool_parallel(normalized)
    } else if tool_id == "all" {
        tools.run_parallel()
    } else {
        tools.dispatch_tool_request(effective_tool_id, normalized)
    }
    let run_id = tools.run_id_for_tool(effective_tool_id)
    let result = tools.last_run_json(effective_tool_id)
    let body = api.rpc.tool_response_json(request_id, effective_tool_id, run_id, tool_status, tools.last_run_artifact_path(effective_tool_id), result)
    persistence.save_named_run(run_id, body)
    let session_id = json.get_str(parsed, "session_id")
    if session_id != "" {
        discard sessions.record_tool_run_for(session_id, effective_tool_id, run_id, api.rpc.tool_result_status(tool_status))
    }
    let code = if tool_status == 0 { 200 } else { 500 }
    http.write_json(conn, code, body)
    return 0
}

fn handle_runs(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_runs", util.log_fields2("component", "http", "handler", "runs_get"))
    }
    get_run()
    let run_id = run_id_from_path(path)
    let payload = persistence.load_run_json(run_id)
    http.write_json(conn, 200, payload)
    return 0
}

fn handle_health(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_health", util.log_fields2("component", "http", "handler", "health"))
    }
    let model_name = anthropic.default_model_name()
    let body = util.json_obj4("status", json.str("ok"), "service", json.str("agent_runtime"), "provider", json.str("anthropic"), "model", json.str(model_name))
    http.write_json(conn, 200, body)
    return 0
}
