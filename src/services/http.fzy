use core.http;
use core.log;

fn configure_server() -> i32 {
    env.get("AGENT_HOST")
    env.get("AGENT_PORT")
    env.get("AGENT_WORKERS")
    return 0
}

fn start_server() -> i32 {
    log.info("http.start_server", util.log_fields2("component", "http", "phase", "start_server"))
    web.start_listener()
    return 0
}

fn graceful_stop() -> i32 {
    checkpoint()
    return 0
}

fn listen_public() -> i32 {
    let listener: HttpHandle = http.bind()
    http.listen(listener)
    close(listener)
    return 0
}

fn accept_once() -> i32 {
    let conn: HttpHandle = http.accept()
    http.read(conn)
    http.write(conn, 200, "ok")
    close(conn)
    return 0
}

fn accept_and_dispatch() -> i32 {
    web.accept_and_process()
    return 0
}

fn post_sessions() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.create_session()
    return 0
}

fn get_session() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.get_session()
    return 0
}

fn post_session_messages() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    sessions.post_message()
    return 0
}

fn get_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.list_tools()
    return 0
}

fn post_tools() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.register_tool()
    return 0
}

fn delete_tool() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    registry.unregister_tool()
    return 0
}

fn post_tool_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    tools.run_parallel()
    tools.classify_failure()
    persistence.save_tool_run()
    return 0
}

fn get_run() -> i32 {
    security.auth_middleware()
    security.rate_limit()
    persistence.load_session()
    return 0
}

fn route_sessions() -> i32 {
    post_sessions()
    get_session()
    return 0
}

fn route_messages() -> i32 {
    post_session_messages()
    return 0
}

fn route_tools() -> i32 {
    get_tools()
    post_tools()
    delete_tool()
    return 0
}

fn route_runs() -> i32 {
    post_tool_run()
    get_run()
    return 0
}

fn resolve_workdir() -> str {
    return "."
}

fn path_after_prefix(path: str, prefix: str) -> str {
    let prefix_len = str.len(prefix)
    let path_len = str.len(path)
    if path_len <= prefix_len {
        return ""
    }
    return str.slice(path, prefix_len, path_len)
}

fn path_before_suffix(path: str, suffix: str) -> str {
    let path_len = str.len(path)
    let suffix_len = str.len(suffix)
    if path_len <= suffix_len {
        return ""
    }
    return str.slice(path, 0, path_len - suffix_len)
}

fn session_id_from_session_path(path: str) -> str {
    return path_after_prefix(path, "/sessions/")
}

fn session_id_from_message_path(path: str) -> str {
    let prefix_trimmed = path_after_prefix(path, "/sessions/")
    return path_before_suffix(prefix_trimmed, "/messages")
}

fn tool_id_from_tool_path(path: str) -> str {
    return path_after_prefix(path, "/tools/")
}

fn tool_id_from_run_path(path: str) -> str {
    let prefix_trimmed = path_after_prefix(path, "/tools/")
    return path_before_suffix(prefix_trimmed, "/run")
}

fn run_id_from_path(path: str) -> str {
    return path_after_prefix(path, "/runs/")
}

fn handle_sessions(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_sessions", util.log_fields2("component", "http", "handler", "sessions_create"))
    }
    post_sessions()
    let session = sessions.get_session_json()
    let body = util.json_obj3("status", json.str("ok"), "event", json.str("session_created"), "session", json.raw(session))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_session_get(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_session_get", util.log_fields2("component", "http", "handler", "session_get"))
    }
    get_session()
    let session_id = session_id_from_session_path(path)
    let state = model.types.active_session_state_label()
    let details = sessions.get_session_json()
    let body = util.json_obj4("status", json.str("ok"), "event", json.str("session_loaded"), "session_id", json.str(session_id), "details", json.raw(details))
    if state == "active" {
        checkpoint()
    }
    http.write_json(conn, 200, body)
    return 0
}

fn handle_messages(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_messages start", util.log_fields3("component", "http", "handler", "messages_post", "phase", "start"))
    }
    post_session_messages()
    safety.filter_prompt()
    safety.filter_tool_response()
    safety.decide_policy()

    let prompt = prompt_from_request(conn)
    let message = util.json_obj2("role", json.str("user"), "content", json.str(prompt))
    let messages = util.json_arr1(message)
    let payload = util.json_obj3(
        "model", json.str(anthropic.default_model_name()),
        "max_tokens", json.raw("300"),
        "messages", messages,
    )

    let out = anthropic.request_messages_sync(payload)
    let status = anthropic.last_status()
    let transport_error = anthropic.last_error()
    let provider_payload = util.json_obj2("provider", json.str("anthropic"), "response", json.str(out))
    let session_id = session_id_from_message_path(path)

    if status >= 200 {
        if status < 300 {
            let body = util.json_obj3("status", json.str("ok"), "session_id", json.str(session_id), "data", json.raw(provider_payload))
            http.write_json(conn, 200, body)
        } else {
            let body = util.json_obj3("status", json.str("error"), "session_id", json.str(session_id), "data", json.raw(provider_payload))
            http.write_json(conn, 502, body)
        }
    } else {
        let body = util.json_obj4("status", json.str("error"), "message", json.str("anthropic_invalid_status"), "raw_response", json.str(out), "transport_error", json.str(transport_error))
        http.write_json(conn, 502, body)
    }
    return 0
}

fn prompt_from_request(conn: HttpHandle) -> str {
    let parsed = http.body_json(conn)
    let prompt = json.get_str(parsed, "message")
    if prompt == "" {
        return "runtime status"
    }
    return prompt
}

fn handle_tools_register(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_register", util.log_fields2("component", "http", "handler", "tools_register"))
    }
    post_tools()
    let body = util.json_obj3("status", json.str("ok"), "event", json.str("tool_registered"), "tools", json.raw(registry.list_tools_json()))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_tools_list(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_list", util.log_fields2("component", "http", "handler", "tools_list"))
    }
    get_tools()
    http.write_json(conn, 200, registry.list_tools_json())
    return 0
}

fn handle_tools_delete(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_delete", util.log_fields2("component", "http", "handler", "tools_delete"))
    }
    delete_tool()
    let tool_id = tool_id_from_tool_path(path)
    let body = util.json_obj3("status", json.str("ok"), "event", json.str("tool_deleted"), "tool_id", json.str(tool_id))
    http.write_json(conn, 200, body)
    return 0
}

fn handle_tools_run(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_tools_run start", util.log_fields3("component", "http", "handler", "tools_run", "phase", "start"))
    }
    security.auth_middleware()
    security.rate_limit()
    let tool_id = tool_id_from_run_path(path)
    let parsed = http.body_json(conn)
    let action = json.get_str(parsed, "action")
    let op = json.get_str(parsed, "op")
    let url = json.get_str(parsed, "url")
    let query = json.get_str(parsed, "query")
    let eval_js = json.get_str(parsed, "eval_js")
    let commands_json = json.get_str(parsed, "commands_json")
    let command = json.get_str(parsed, "command")
    let pattern = json.get_str(parsed, "pattern")
    let target = json.get_str(parsed, "target")
    let requested_tool_id = json.get_str(parsed, "create_tool_id")
    let description = json.get_str(parsed, "description")
    let command_template = json.get_str(parsed, "command_template")
    let input_schema_json = json.get_str(parsed, "input_schema_json")
    let kind = json.get_str(parsed, "kind")
    let mode = json.get_str(parsed, "mode")
    let max_lines = json.get_str(parsed, "max_lines")
    let content = json.get_str(parsed, "content")
    let tool_input_json = json.get_str(parsed, "tool_input_json")
    let tool_action = if op == "" { action } else { op }
    let tool_status = if tool_id == "aegis" || tool_id == "aegis_headless" {
        tools.run_aegis_with_args(tool_action, url, query, eval_js, commands_json)
    } else if tool_id == "bash" {
        tools.run_bash_with_command(command)
    } else if tool_id == "grep_search" {
        tools.run_grep_search(pattern, target)
    } else if tool_id == "toolsmith" {
        tools.run_toolsmith(if tool_action == "" { "protocol" } else { tool_action }, requested_tool_id, description, command_template, input_schema_json, kind, mode)
    } else if tool_id == "promptsmith" {
        tools.run_promptsmith(if tool_action == "" { "get" } else { tool_action }, content)
    } else if tool_id == "fzydoc" {
        tools.run_fzydoc(if query == "" { "spawn" } else { query }, max_lines)
    } else if tool_id == "all" {
        tools.run_parallel()
    } else {
        tools.run_custom_tool(tool_id, tool_input_json)
    }
    let run_id = if tool_id == "promptsmith" { "promptsmith_latest" } else { run_id_for_tool(tool_id) }
    let result = if tool_id == "promptsmith" { tools.safe_read(tools.promptsmith_path()) } else { tools.last_run_json(tool_id) }
    let body_status = if tool_status == 0 { "ok" } else { "error" }
    let body = if tool_id == "aegis" || tool_id == "aegis_headless" {
        util.json_obj5(
            "status", json.str(body_status),
            "tool_id", json.str(tool_id),
            "run_id", json.str(run_id),
            "artifact_path", json.str(tools.last_run_artifact_path(tool_id)),
            "result_text", json.str(result),
        )
    } else {
        util.json_obj4("status", json.str(body_status), "tool_id", json.str(tool_id), "run_id", json.str(run_id), "result", json.raw(result))
    }
    persistence.save_named_run(run_id, body)
    let code = if tool_status == 0 { 200 } else { 500 }
    http.write_json(conn, code, body)
    return 0
}

fn run_id_for_tool(tool_id: str) -> str {
    if tool_id == "parallel_bash" {
        return "parallel_bash_latest"
    }
    if tool_id == "parallel_grep" {
        return "parallel_grep_latest"
    }
    if tool_id == "release_audit" {
        return "release_audit_latest"
    }
    if tool_id == "workspace_digest" {
        return "workspace_digest_latest"
    }
    if tool_id == "aegis" || tool_id == "aegis_headless" {
        return "aegis_latest"
    }
    if tool_id == "browser_ops_seed" {
        return "browser_ops_seed_latest"
    }
    if tool_id == "project_seed" {
        return "project_seed_latest"
    }
    if tool_id == "bash" {
        return "bash_latest"
    }
    if tool_id == "grep_search" {
        return "grep_search_latest"
    }
    if tool_id == "timeout_probe" {
        return "timeout_probe_latest"
    }
    if tool_id == "toolsmith" {
        return "toolsmith_latest"
    }
    if tool_id == "promptsmith" {
        return "promptsmith_latest"
    }
    if tool_id == "fzydoc" {
        return "fzydoc_latest"
    }
    return "latest"
}

fn handle_runs(conn: HttpHandle, path: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_runs", util.log_fields2("component", "http", "handler", "runs_get"))
    }
    get_run()
    let run_id = run_id_from_path(path)
    let payload = persistence.load_run_json(run_id)
    http.write_json(conn, 200, payload)
    return 0
}

fn handle_health(conn: HttpHandle) -> i32 {
    if runtime.config.persist_request_artifacts() == 1 {
        log.info("http.handle_health", util.log_fields2("component", "http", "handler", "health"))
    }
    let model_name = anthropic.default_model_name()
    let body = util.json_obj4("status", json.str("ok"), "service", json.str("agent_runtime"), "provider", json.str("anthropic"), "model", json.str(model_name))
    http.write_json(conn, 200, body)
    return 0
}
