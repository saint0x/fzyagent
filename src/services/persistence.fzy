use core.fs;
use core.storage;
use core.time;

fn state_dir() -> str {
    return "/tmp/fzyagent"
}

fn sessions_dir() -> str {
    return "/tmp/fzyagent/sessions"
}

fn sessions_path() -> str {
    return "/tmp/fzyagent/sessions.json"
}

fn runs_dir() -> str {
    return "/tmp/fzyagent/runs"
}

fn transcript_excerpt_limit() -> i32 {
    return 12000
}

fn default_session_id() -> str {
    return "demo"
}

fn normalize_session_id(session_id: str) -> str {
    if session_id == "" {
        return default_session_id()
    }
    return session_id
}

fn session_dir(session_id: str) -> str {
    return str.concat("/tmp/fzyagent/sessions/", normalize_session_id(session_id))
}

fn session_state_path(session_id: str) -> str {
    return str.concat(session_dir(session_id), "/session.json")
}

fn session_messages_path(session_id: str) -> str {
    return str.concat(session_dir(session_id), "/messages.jsonl")
}

fn session_turns_path(session_id: str) -> str {
    return str.concat(session_dir(session_id), "/turns.log")
}

fn session_runs_path(session_id: str) -> str {
    return str.concat(session_dir(session_id), "/runs.jsonl")
}

fn run_path(run_id: str) -> str {
    if run_id == "latest" {
        return "/tmp/fzyagent/runs/latest.json"
    }
    return str.concat(str.concat("/tmp/fzyagent/runs/", run_id), ".json")
}

fn ensure_state() -> i32 {
    fs.mkdir(state_dir())
    fs.mkdir(sessions_dir())
    fs.mkdir(runs_dir())
    return 0
}

fn atomic_write_text(path: str, payload: str) -> i32 {
    return fs.atomic_write(path, payload)
}

fn json_doc_missing_or_corrupt(payload: str) -> i32 {
    if payload == "" || str.trim(payload) == "{}" {
        return 1
    }
    return 0
}

fn ensure_session(session_id: str) -> i32 {
    ensure_state()
    fs.mkdir(session_dir(session_id))
    return 0
}

fn clear_session_files(session_id: str) -> i32 {
    ensure_session(session_id)
    discard fs.remove_file(session_state_path(session_id))
    discard fs.remove_file(session_messages_path(session_id))
    discard fs.remove_file(session_turns_path(session_id))
    discard fs.remove_file(session_runs_path(session_id))
    return 0
}

fn static_index_path() -> str {
    return "/tmp/fzyagent/sessions.json"
}

fn now_label() -> str {
    return str.from_i32(time.now())
}

fn excerpt(text: str, max_chars: i32) -> str {
    let size = str.len(text)
    if size <= max_chars {
        return text
    }
    return str.slice(text, size - max_chars, size)
}

fn session_doc_for(session_id: str, state: str, turn_count: str, last_run_id: str, last_user_message: str, last_assistant_message: str, last_request_id: str, tool_count: str) -> str {
    let meta = model.types.session_meta_json(
        now_label(),
        services.provider.current_provider_name(),
        services.provider.default_model_name(),
        session_messages_path(session_id),
        session_runs_path(session_id),
    )
    return model.types.session_doc_json(
        normalize_session_id(session_id),
        state,
        turn_count,
        last_run_id,
        last_user_message,
        last_assistant_message,
        last_request_id,
        tool_count,
        meta,
    )
}

fn default_session_doc_for(session_id: str) -> str {
    return session_doc_for(session_id, "active", "0", "latest", "", "", "", "0")
}

fn write_session_index(session_id: str, state: str) -> i32 {
    let payload = model.types.session_index_json(normalize_session_id(session_id), state, now_label(), session_state_path(session_id))
    discard atomic_write_text(static_index_path(), payload)
    return 0
}

fn save_session_for(session_id: str, payload: str) -> i32 {
    ensure_session(session_id)
    discard atomic_write_text(session_state_path(session_id), payload)
    write_session_index(session_id, session_state_value(json.parse(payload)))
    return 0
}

fn save_session() -> i32 {
    let payload = default_session_doc_for(default_session_id())
    return save_session_for(default_session_id(), payload)
}

fn append_line(path: str, line: str) -> i32 {
    let current = if fs.exists(path) == 1 { fs.read_file(path) } else { "" }
    let next = if current == "" {
        str.concat(line, "\n")
    } else {
        str.concat3(current, line, "\n")
    }
    return atomic_write_text(path, next)
}

fn count_lines(text_value: str) -> i32 {
    if text_value == "" {
        return 0
    }
    let mut count: i32 = 0
    let mut idx: i32 = 0
    while idx < str.len(text_value) {
        if str.slice(text_value, idx, idx + 1) == "\n" {
            count = count + 1
        }
        idx = idx + 1
    }
    if count == 0 {
        return 1
    }
    return count
}

fn first_line(text_value: str) -> str {
    let mut idx: i32 = 0
    while idx < str.len(text_value) {
        if str.slice(text_value, idx, idx + 1) == "\n" {
            return str.slice(text_value, 0, idx)
        }
        idx = idx + 1
    }
    return text_value
}

fn drop_first_line(text_value: str) -> str {
    let mut idx: i32 = 0
    while idx < str.len(text_value) {
        if str.slice(text_value, idx, idx + 1) == "\n" {
            if idx + 1 >= str.len(text_value) {
                return ""
            }
            return str.slice(text_value, idx + 1, str.len(text_value))
        }
        idx = idx + 1
    }
    return ""
}

fn count_turn_markers(text_value: str) -> i32 {
    if text_value == "" {
        return 0
    }
    let mut count: i32 = 0
    let mut remaining = text_value
    while remaining != "" {
        let line = first_line(remaining)
        if line == "turn" {
            count = count + 1
        }
        remaining = drop_first_line(remaining)
    }
    return count
}

fn session_turn_count(session_id: str) -> str {
    ensure_session(session_id)
    return str.from_i32(count_turn_markers(fs.read_file(session_turns_path(session_id))))
}

fn session_tool_count(session_id: str) -> str {
    ensure_session(session_id)
    return str.from_i32(count_lines(fs.read_file(session_runs_path(session_id))))
}

fn save_session_event(session_id: str, event: str, state: str, turn_count: str) -> i32 {
    ensure_session(session_id)
    let current = load_session_json_for(session_id)
    let parsed = json.parse(current)
    let last_run_id = session_last_run_id_value(parsed)
    let last_request_id = session_last_request_id_value(parsed)
    let last_user = session_last_user_message_value(parsed)
    let last_assistant = session_last_assistant_message_value(parsed)
    let tool_count = session_tool_count(session_id)
    let payload = session_doc_for(session_id, state, turn_count, last_run_id, last_user, last_assistant, last_request_id, tool_count)
    let event_line = model.types.session_event_json(event, state, turn_count, now_label())
    discard atomic_write_text(session_state_path(session_id), payload)
    append_line(session_turns_path(session_id), event_line)
    write_session_index(session_id, state)
    return 0
}

fn save_session_event_legacy(event: str, state: str, turn_count: str) -> i32 {
    return save_session_event(default_session_id(), event, state, turn_count)
}

fn load_session_for(session_id: str) -> i32 {
    ensure_session(session_id)
    if fs.exists(session_state_path(session_id)) == 0 {
        save_session_for(session_id, default_session_doc_for(session_id))
    }
    return 0
}

fn load_session() -> i32 {
    return load_session_for(default_session_id())
}

fn load_session_json_for(session_id: str) -> str {
    load_session_for(session_id)
    let payload = fs.read_file(session_state_path(session_id))
    if json_doc_missing_or_corrupt(payload) == 1 {
        return default_session_doc_for(session_id)
    }
    return payload
}

fn load_session_json() -> str {
    return load_session_json_for(default_session_id())
}

fn session_state_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "state")
}

fn session_last_run_id_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "last_run_id")
}

fn session_last_request_id_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "last_request_id")
}

fn session_last_user_message_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "last_user_message")
}

fn session_last_assistant_message_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "last_assistant_message")
}

fn session_turn_count_value(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "turn_count")
}

fn sync_session_summary(session_id: str, state: str, last_run_id: str, last_user_message: str, last_assistant_message: str, last_request_id: str) -> i32 {
    ensure_session(session_id)
    let current_turn_count = session_turn_count(session_id)
    let payload = session_doc_for(session_id, state, current_turn_count, last_run_id, last_user_message, last_assistant_message, last_request_id, session_tool_count(session_id))
    return save_session_for(session_id, payload)
}

fn update_session_summary(session_id: str, state: str, last_run_id: str, last_user_message: str, last_assistant_message: str, last_request_id: str, tool_count: str) -> i32 {
    ensure_session(session_id)
    let current_turn_count = session_turn_count(session_id)
    let payload = session_doc_for(session_id, state, current_turn_count, last_run_id, last_user_message, last_assistant_message, last_request_id, tool_count)
    return save_session_for(session_id, payload)
}

fn save_session_event_current(session_id: str, event: str, state: str) -> i32 {
    return save_session_event(session_id, event, state, session_turn_count(session_id))
}

fn mark_session_turn(session_id: str) -> i32 {
    ensure_session(session_id)
    append_line(session_turns_path(session_id), "turn")
    let current = load_session_json_for(session_id)
    let parsed = json.parse(current)
    let payload = session_doc_for(
        session_id,
        session_state_value(parsed),
        session_turn_count(session_id),
        session_last_run_id_value(parsed),
        session_last_user_message_value(parsed),
        session_last_assistant_message_value(parsed),
        session_last_request_id_value(parsed),
        session_tool_count(session_id),
    )
    return save_session_for(session_id, payload)
}

fn append_message(session_id: str, role: str, kind: str, content: str, run_id: str, request_id: str) -> i32 {
    ensure_session(session_id)
    let entry = model.types.session_message_entry_json(normalize_session_id(session_id), role, kind, content, run_id, request_id, now_label())
    append_line(session_messages_path(session_id), entry)
    return 0
}

fn append_run_link(session_id: str, run_id: str, tool_id: str, status: str) -> i32 {
    ensure_session(session_id)
    let entry = model.types.session_run_link_json(normalize_session_id(session_id), run_id, tool_id, status, now_label())
    append_line(session_runs_path(session_id), entry)
    return 0
}

fn transcript_excerpt(session_id: str) -> str {
    ensure_session(session_id)
    let payload = fs.read_file(session_messages_path(session_id))
    if payload == "" {
        return ""
    }
    return excerpt(payload, transcript_excerpt_limit())
}

fn save_tool_run() -> i32 {
    ensure_state()
    let payload = tools.last_run_json("all")
    discard atomic_write_text(run_path("latest"), payload)
    return 0
}

fn save_named_run(run_id: str, payload: str) -> i32 {
    ensure_state()
    discard atomic_write_text(run_path(run_id), payload)
    discard atomic_write_text(run_path("latest"), payload)
    return 0
}

fn load_run_json(run_id: str) -> str {
    ensure_state()
    let path = run_path(run_id)
    if fs.exists(path) == 0 {
        return model.types.run_state_error_json(run_id, "missing", now_label())
    }
    let payload = fs.read_file(path)
    if payload == "" {
        return model.types.run_state_error_json(run_id, "empty", now_label())
    }
    return payload
}
