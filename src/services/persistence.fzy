use core.fs;
use core.time;

fn state_dir() -> str {
    return "/tmp/fzyagent"
}

fn sessions_path() -> str {
    return "/tmp/fzyagent/sessions.json"
}

fn runs_dir() -> str {
    return "/tmp/fzyagent/runs"
}

fn run_path(run_id: str) -> str {
    if run_id == "latest" {
        return "/tmp/fzyagent/runs/latest.json"
    }
    if run_id == "parallel_bash_latest" {
        return "/tmp/fzyagent/runs/parallel_bash_latest.json"
    }
    if run_id == "parallel_grep_latest" {
        return "/tmp/fzyagent/runs/parallel_grep_latest.json"
    }
    if run_id == "bash_latest" {
        return "/tmp/fzyagent/runs/bash_latest.json"
    }
    if run_id == "grep_search_latest" {
        return "/tmp/fzyagent/runs/grep_search_latest.json"
    }
    if run_id == "release_audit_latest" {
        return "/tmp/fzyagent/runs/release_audit_latest.json"
    }
    if run_id == "timeout_probe_latest" {
        return "/tmp/fzyagent/runs/timeout_probe_latest.json"
    }
    if run_id == "workspace_digest_latest" {
        return "/tmp/fzyagent/runs/workspace_digest_latest.json"
    }
    if run_id == "project_seed_latest" {
        return "/tmp/fzyagent/runs/project_seed_latest.json"
    }
    if run_id == "aegis_latest" {
        return "/tmp/fzyagent/runs/aegis_latest.json"
    }
    if run_id == "browser_ops_seed_latest" {
        return "/tmp/fzyagent/runs/browser_ops_seed_latest.json"
    }
    if run_id == "toolsmith_latest" {
        return "/tmp/fzyagent/runs/toolsmith_latest.json"
    }
    if run_id == "promptsmith_latest" {
        return "/tmp/fzyagent/runs/promptsmith_latest.json"
    }
    if run_id == "fzydoc_latest" {
        return "/tmp/fzyagent/runs/fzydoc_latest.json"
    }
    return "/tmp/fzyagent/runs/generic_latest.json"
}

fn ensure_state() -> i32 {
    fs.mkdir(state_dir())
    fs.mkdir(runs_dir())
    return 0
}

fn session_doc(event: str, state: str, turn_count: str, last_run_id: str) -> str {
    discard time.now()
    let meta = util.json_obj4(
        "event", json.str(event),
        "updated_at", json.str("sampled"),
        "provider", json.str("anthropic"),
        "model", json.str(services.anthropic.default_model_name()),
    )
    return util.json_obj5(
        "status", json.str("ok"),
        "session_id", json.str("demo"),
        "state", json.str(state),
        "turn_count", json.str(turn_count),
        "meta", json.raw(meta),
    )
}

fn save_session() -> i32 {
    ensure_state()
    let payload = session_doc("save_session", "active", "0", "latest")
    fs.write_file(sessions_path(), payload)
    return 0
}

fn save_session_event(event: str, state: str, turn_count: str) -> i32 {
    ensure_state()
    let payload = session_doc(event, state, turn_count, "latest")
    fs.write_file(sessions_path(), payload)
    return 0
}

fn load_session() -> i32 {
    ensure_state()
    if fs.exists(sessions_path()) == 0 {
        save_session()
    }
    return 0
}

fn load_session_json() -> str {
    load_session()
    let payload = fs.read_file(sessions_path())
    if payload == "" {
        return session_doc("load_session_empty", "active", "0", "latest")
    }
    return payload
}

fn save_tool_run() -> i32 {
    ensure_state()
    let payload = tools.last_run_json("all")
    fs.write_file(run_path("latest"), payload)
    return 0
}

fn save_named_run(run_id: str, payload: str) -> i32 {
    ensure_state()
    fs.write_file(run_path(run_id), payload)
    fs.write_file(run_path("latest"), payload)
    return 0
}

fn load_run_json(run_id: str) -> str {
    ensure_state()
    let path = run_path(run_id)
    if fs.exists(path) == 0 {
        discard time.now()
        return util.json_obj4("status", json.str("error"), "run_id", json.str(run_id), "state", json.str("missing"), "updated_at", json.str("sampled"))
    }
    let payload = fs.read_file(path)
    if payload == "" {
        discard time.now()
        return util.json_obj4("status", json.str("error"), "run_id", json.str(run_id), "state", json.str("empty"), "updated_at", json.str("sampled"))
    }
    return payload
}
