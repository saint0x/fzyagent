fn log_fields2(k1: str, v1: str, k2: str, v2: str) -> str {
    let mut payload = "{"
    payload = str.concat(payload, str.concat(json.str(k1), str.concat(":", json.str(v1))))
    payload = str.concat(payload, str.concat(",", str.concat(json.str(k2), str.concat(":", json.str(v2)))))
    return str.concat(payload, "}")
}

