fn json_arr1(v1: str) -> str {
    let items = list.new()
    discard list.push(items, v1)
    return json.array(items)
}

fn json_arr3(v1: str, v2: str, v3: str) -> str {
    let items = list.new()
    discard list.push(items, v1)
    discard list.push(items, v2)
    discard list.push(items, v3)
    return json.array(items)
}

fn json_arr4(v1: str, v2: str, v3: str, v4: str) -> str {
    let items = list.new()
    discard list.push(items, v1)
    discard list.push(items, v2)
    discard list.push(items, v3)
    discard list.push(items, v4)
    return json.array(items)
}

fn digit_value(ch: str) -> i32 {
    if ch == "0" { return 0 }
    if ch == "1" { return 1 }
    if ch == "2" { return 2 }
    if ch == "3" { return 3 }
    if ch == "4" { return 4 }
    if ch == "5" { return 5 }
    if ch == "6" { return 6 }
    if ch == "7" { return 7 }
    if ch == "8" { return 8 }
    if ch == "9" { return 9 }
    return 0
}

fn parse_i32(text: str) -> i32 {
    if text == "" {
        return 0
    }
    let mut idx: i32 = 0
    let mut out: i32 = 0
    while idx < str.len(text) {
        out = (out * 10) + digit_value(str.slice(text, idx, idx + 1))
        idx = idx + 1
    }
    return out
}

fn lowercase_ascii(ch: str) -> str {
    if ch == "A" { return "a" }
    if ch == "B" { return "b" }
    if ch == "C" { return "c" }
    if ch == "D" { return "d" }
    if ch == "E" { return "e" }
    if ch == "F" { return "f" }
    if ch == "G" { return "g" }
    if ch == "H" { return "h" }
    if ch == "I" { return "i" }
    if ch == "J" { return "j" }
    if ch == "K" { return "k" }
    if ch == "L" { return "l" }
    if ch == "M" { return "m" }
    if ch == "N" { return "n" }
    if ch == "O" { return "o" }
    if ch == "P" { return "p" }
    if ch == "Q" { return "q" }
    if ch == "R" { return "r" }
    if ch == "S" { return "s" }
    if ch == "T" { return "t" }
    if ch == "U" { return "u" }
    if ch == "V" { return "v" }
    if ch == "W" { return "w" }
    if ch == "X" { return "x" }
    if ch == "Y" { return "y" }
    if ch == "Z" { return "z" }
    return ch
}

fn lower_ascii(text: str) -> str {
    let mut out = ""
    let mut idx: i32 = 0
    while idx < str.len(text) {
        out = str.concat(out, lowercase_ascii(str.slice(text, idx, idx + 1)))
        idx = idx + 1
    }
    return out
}

fn excerpt_head(text: str, max_chars: i32) -> str {
    if max_chars <= 0 {
        return ""
    }
    if str.len(text) <= max_chars {
        return text
    }
    return str.slice(text, 0, max_chars)
}

fn excerpt_tail(text: str, max_chars: i32) -> str {
    if max_chars <= 0 {
        return ""
    }
    if str.len(text) <= max_chars {
        return text
    }
    return str.slice(text, str.len(text) - max_chars, str.len(text))
}
