    payload = str.concat(payload, str.concat(",", str.concat(json.str(k3), str.concat(":", json.str(v3)))))
    return str.concat(payload, "}")
}

fn json_obj1(k1: str, v1: str) -> str {
    return str.concat("{", str.concat(json.str(k1), str.concat(":", str.concat(v1, "}"))))
}

