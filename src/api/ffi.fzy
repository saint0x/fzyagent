use core.fs;

fn ffi_manifest_path() -> str {
    return runtime.config.state_path("api.ffi.json")
}

fn ffi_touch() -> i32 {
    runtime.config.ensure_state_root()
    let exports = apputil.json_arr4(
        apputil.json_value(model.types.ffi_export_json("fzyagent_main", "entrypoint", "native")),
        apputil.json_value(model.types.ffi_export_json("fzyagent_chat", "cli", "interactive")),
        apputil.json_value(model.types.ffi_export_json("fzyagent_http", "service", "host_http")),
        apputil.json_value(model.types.ffi_export_json("fzyagent_tools", "runtime", "tooling")),
    )
    let rpc_schemas = apputil.json_obj4(
        "request", json.str(api.rpc.request_schema_name()),
        "single_request", json.str(api.rpc.single_request_schema_name()),
        "batch_request", json.str(api.rpc.batch_request_schema_name()),
        "response", json.str(api.rpc.response_schema_name())
    )
    let runtime_schema_map = map.new()
    discard map.set(runtime_schema_map, "session_request", json.str(api.rpc.session_request_schema_name()))
    discard map.set(runtime_schema_map, "session_response", json.str(api.rpc.session_response_schema_name()))
    discard map.set(runtime_schema_map, "message_request", json.str(api.rpc.message_request_schema_name()))
    discard map.set(runtime_schema_map, "message_response", json.str(api.rpc.message_response_schema_name()))
    discard map.set(runtime_schema_map, "tools_response", json.str(api.rpc.tools_response_schema_name()))
    discard map.set(runtime_schema_map, "run_response", json.str(api.rpc.run_response_schema_name()))
    discard map.set(runtime_schema_map, "health_response", json.str(api.rpc.health_response_schema_name()))
    let runtime_schemas = json.object(runtime_schema_map)
    let manifests = apputil.json_obj3("ffi", json.str(ffi_manifest_path()), "rpc", json.str(api.rpc.rpc_manifest_path()), "openapi", json.str(services.openapi.openapi_path()))
    let payload = model.types.ffi_manifest_json("c-compatible-descriptor", "fzyagent", exports, api.rpc.tool_protocol_version(), rpc_schemas, runtime_schemas, manifests)
    fs.write_file(ffi_manifest_path(), payload)
    return 0
}
