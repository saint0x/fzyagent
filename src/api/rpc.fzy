use core.fs;
use core.time;

enum ToolRequestKind {
    ToolRequestSingle,
    ToolRequestSequence,
    ToolRequestParallel,
    ToolRequestInvalid,
}

enum ToolResponseKind {
    ToolResponseOk,
    ToolResponseError,
}

fn rpc_manifest_path() -> str {
    return "/tmp/fzyagent/api.rpc.json"
}

fn tool_protocol_version() -> str {
    return "fzyagent.toolrpc.v1"
}

fn single_request_schema_name() -> str {
    return "ToolRpcSingleRequest"
}

fn batch_request_schema_name() -> str {
    return "ToolRpcBatchRequest"
}

fn request_schema_name() -> str {
    return "ToolRpcRequest"
}

fn response_schema_name() -> str {
    return "ToolRpcResponse"
}

fn session_request_schema_name() -> str {
    return "SessionRequest"
}

fn session_response_schema_name() -> str {
    return "SessionResponse"
}

fn message_request_schema_name() -> str {
    return "MessageRequest"
}

fn message_response_schema_name() -> str {
    return "MessageResponse"
}

fn tools_response_schema_name() -> str {
    return "ToolsResponse"
}

fn run_response_schema_name() -> str {
    return "RunResponse"
}

fn health_response_schema_name() -> str {
    return "HealthResponse"
}

fn schema_ref(schema_name: str) -> str {
    return util.json_obj1("$ref", json.str(str.concat("#/components/schemas/", schema_name)))
}

fn request_body_json(description: str, schema_name: str, required: str) -> str {
    let schema_obj = map.new()
    discard map.set(schema_obj, "schema", json.raw(schema_ref(schema_name)))
    let content = map.new()
    discard map.set(content, "application/json", json.raw(json.object(schema_obj)))
    let payload = map.new()
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "required", json.raw(required))
    discard map.set(payload, "content", json.raw(json.object(content)))
    return json.object(payload)
}

fn response_content_json(schema_name: str) -> str {
    let schema_obj = map.new()
    discard map.set(schema_obj, "schema", json.raw(schema_ref(schema_name)))
    let content = map.new()
    discard map.set(content, "application/json", json.raw(json.object(schema_obj)))
    return json.object(content)
}

fn response_object_json(description: str, schema_name: str) -> str {
    let payload = map.new()
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "content", json.raw(response_content_json(schema_name)))
    return json.object(payload)
}

fn schema_type_json(type_name: str) -> str {
    return util.json_obj1("type", json.str(type_name))
}

fn schema_string_json() -> str {
    return schema_type_json("string")
}

fn schema_object_json() -> str {
    return schema_type_json("object")
}

fn schema_array_items_json(items_json: str) -> str {
    return util.json_obj2("type", json.str("array"), "items", json.raw(items_json))
}

fn required_list1(a: str) -> ListHandle {
    let required = list.new()
    discard list.push(required, json.str(a))
    return required
}

fn required_list3(a: str, b: str, c: str) -> ListHandle {
    let required = list.new()
    discard list.push(required, json.str(a))
    discard list.push(required, json.str(b))
    discard list.push(required, json.str(c))
    return required
}

fn required_list4(a: str, b: str, c: str, d: str) -> ListHandle {
    let required = required_list3(a, b, c)
    discard list.push(required, json.str(d))
    return required
}

fn required_list5(a: str, b: str, c: str, d: str, e: str) -> ListHandle {
    let required = required_list4(a, b, c, d)
    discard list.push(required, json.str(e))
    return required
}

fn required_list7(a: str, b: str, c: str, d: str, e: str, f: str, g: str) -> ListHandle {
    let required = required_list5(a, b, c, d, e)
    discard list.push(required, json.str(f))
    discard list.push(required, json.str(g))
    return required
}

fn object_schema_json(properties: MapHandle, required: ListHandle) -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    if list.len(required) > 0 {
        discard map.set(schema, "required", json.raw(json.array(required)))
    }
    return json.object(schema)
}

fn object_schema_with_additional_json(properties: MapHandle, additional_raw: str) -> str {
    let schema = map.new()
    discard map.set(schema, "type", json.str("object"))
    discard map.set(schema, "properties", json.raw(json.object(properties)))
    discard map.set(schema, "additionalProperties", json.raw(additional_raw))
    return json.object(schema)
}

fn request_id_from(raw_body: str) -> str {
    let parsed = json.parse(if raw_body == "" { "{}" } else { raw_body })
    let request_id = json.get_str(parsed, "request_id")
    if request_id != "" {
        return request_id
    }
    return str.concat("req_", str.from_i32(time.now()))
}

fn step_schema_json() -> str {
    let properties = map.new()
    discard map.set(properties, "step_id", json.raw(schema_string_json()))
    discard map.set(properties, "tool_id", json.raw(schema_string_json()))
    discard map.set(properties, "tool_input", json.raw(schema_object_json()))
    return object_schema_json(properties, required_list1("tool_id"))
}

fn single_request_schema_json() -> str {
    let properties = map.new()
    discard map.set(properties, "protocol", json.raw(schema_string_json()))
    discard map.set(properties, "request_id", json.raw(schema_string_json()))
    discard map.set(properties, "op", json.raw(schema_string_json()))
    discard map.set(properties, "tool_id", json.raw(schema_string_json()))
    discard map.set(properties, "input", json.raw(schema_object_json()))
    return object_schema_json(properties, required_list4("protocol", "request_id", "op", "tool_id"))
}

fn batch_request_schema_json() -> str {
    let properties = map.new()
    discard map.set(properties, "protocol", json.raw(schema_string_json()))
    discard map.set(properties, "request_id", json.raw(schema_string_json()))
    discard map.set(properties, "op", json.raw(schema_string_json()))
    discard map.set(properties, "execution", json.raw(schema_string_json()))
    discard map.set(properties, "steps", json.raw(schema_array_items_json(step_schema_json())))
    return object_schema_json(properties, required_list5("protocol", "request_id", "op", "execution", "steps"))
}

fn request_schema_json() -> str {
    let properties = map.new()
    discard map.set(properties, "protocol", json.raw(schema_string_json()))
    discard map.set(properties, "request_id", json.raw(schema_string_json()))
    discard map.set(properties, "op", json.raw(schema_string_json()))
    discard map.set(properties, "execution", json.raw(schema_string_json()))
    discard map.set(properties, "tool_id", json.raw(schema_string_json()))
    discard map.set(properties, "input", json.raw(schema_object_json()))
    discard map.set(properties, "steps", json.raw(schema_array_items_json(step_schema_json())))
    return object_schema_json(properties, required_list3("protocol", "request_id", "op"))
}

fn response_schema_json() -> str {
    let properties = map.new()
    discard map.set(properties, "protocol", json.raw(schema_string_json()))
    discard map.set(properties, "request_id", json.raw(schema_string_json()))
    discard map.set(properties, "status", json.raw(schema_string_json()))
    discard map.set(properties, "tool_id", json.raw(schema_string_json()))
    discard map.set(properties, "run_id", json.raw(schema_string_json()))
    discard map.set(properties, "artifact_path", json.raw(schema_string_json()))
    discard map.set(properties, "result", json.raw(schema_object_json()))
    return object_schema_json(properties, required_list7("protocol", "request_id", "status", "tool_id", "run_id", "artifact_path", "result"))
}

