fn runtime_control_payload_json(tool: str, status: str, phase: str, message: str, checkpoint_json: str, recovery_json: str, supervisor_json: str, shutdown_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool))
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "phase", json.str(phase))
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if checkpoint_json != "" {
        discard map.set(payload, "checkpoint", apputil.json_value_or(checkpoint_json, "{}"))
    }
    if recovery_json != "" {
        discard map.set(payload, "recovery", apputil.json_value_or(recovery_json, "{}"))
    }
    if supervisor_json != "" {
        discard map.set(payload, "supervisor", apputil.json_value_or(supervisor_json, "{}"))
    }
    if shutdown_json != "" {
        discard map.set(payload, "shutdown", apputil.json_value_or(shutdown_json, "{}"))
    }
    return json.object(payload)
}
