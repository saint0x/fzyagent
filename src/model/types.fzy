fn registry_tool_json(tool_id: str, description: str, kind: str, health: str, mode: str, origin: str, execution_model: str, supports_sequence: str, supports_parallel: str, rpc_protocol: str, transport: str, input_schema_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "id", json.str(tool_id))
    discard map.set(payload, "name", json.str(tool_id))
    discard map.set(payload, "description", json.str(description))
    discard map.set(payload, "kind", json.str(kind))
    discard map.set(payload, "health", json.str(health))
    discard map.set(payload, "mode", json.str(mode))
    discard map.set(payload, "origin", json.str(origin))
    discard map.set(payload, "execution_model", json.str(execution_model))
    discard map.set(payload, "supports_sequence", apputil.json_value_or(supports_sequence, "false"))
    discard map.set(payload, "supports_parallel", apputil.json_value_or(supports_parallel, "false"))
    discard map.set(payload, "rpc_protocol", json.str(rpc_protocol))
    discard map.set(payload, "transport", json.str(transport))
    discard map.set(payload, "input_schema", apputil.json_value_or(input_schema_json, "{}"))
    return json.object(payload)
}

fn provider_tool_json(tool_id: str, description: str, input_schema_json: str) -> str {
    let mut payload = "{\"name\":"
    payload = str.concat(payload, json.str(tool_id))
    payload = str.concat(payload, str.concat(",\"description\":", json.str(description)))
    payload = str.concat(payload, str.concat(",\"input_schema\":", input_schema_json))
    return str.concat(payload, "}")
}

fn provider_tool_json_openai(tool_id: str, description: str, input_schema_json: str) -> str {
    let mut function_payload = "{\"name\":"
    function_payload = str.concat(function_payload, json.str(tool_id))
    function_payload = str.concat(function_payload, str.concat(",\"description\":", json.str(description)))
    function_payload = str.concat(function_payload, str.concat(",\"parameters\":", input_schema_json))
    function_payload = str.concat(function_payload, "}")
    let mut payload = "{\"type\":"
    payload = str.concat(payload, json.str("function"))
    payload = str.concat(payload, str.concat(",\"function\":", function_payload))
    return str.concat(payload, "}")
}

