    let mut payload = "{\"updated_at\":"
    payload = str.concat(payload, json.str(updated_at))
    payload = str.concat(payload, str.concat(",\"provider\":", json.str(provider)))
    payload = str.concat(payload, str.concat(",\"model\":", json.str(model)))
    payload = str.concat(payload, str.concat(",\"history_path\":", json.str(history_path)))
    payload = str.concat(payload, str.concat(",\"runs_path\":", json.str(runs_path)))
    return str.concat(payload, "}")
}

