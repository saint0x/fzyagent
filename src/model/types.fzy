}

fn recovery_checkpoint_json(status: str, scope: str, saved_at: str, config_json: str, limits_json: str, sandbox_json: str, supervisor_json: str, queue_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "scope", json.str(scope))
    discard map.set(payload, "saved_at", json.str(saved_at))
    discard map.set(payload, "config", json.raw(config_json))
    discard map.set(payload, "limits", json.raw(limits_json))
    discard map.set(payload, "sandbox", json.raw(sandbox_json))
    discard map.set(payload, "supervisor", json.raw(supervisor_json))
    discard map.set(payload, "queue", json.raw(queue_json))
    return json.object(payload)
