fn recovery_status_json(status: str, phase: str, checkpoint_json: str, recovered_at: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "phase", json.str(phase))
    discard map.set(payload, "checkpoint", json.raw(checkpoint_json))
    discard map.set(payload, "recovered_at", json.str(recovered_at))
