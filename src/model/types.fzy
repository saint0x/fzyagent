    discard map.set(payload, "last_tool_id", json.str(last_tool_id))
    discard map.set(payload, "last_status", json.str(last_status))
    return json.object(payload)
}

fn queue_state_payload_json(status: str, phase: str, queue_json: str, updated_at: str, cancel_signal: str, tool_id: str, run_id: str, final_status: str, processed_count: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "phase", json.str(phase))
    discard map.set(payload, "queue", json.raw(queue_json))
    if updated_at != "" {
        discard map.set(payload, "updated_at", json.str(updated_at))
    }
    if cancel_signal != "" {
        discard map.set(payload, "cancel_signal", json.str(cancel_signal))
    }
    if tool_id != "" {
        discard map.set(payload, "tool_id", json.str(tool_id))
    }
    if run_id != "" {
        discard map.set(payload, "run_id", json.str(run_id))
    }
    if final_status != "" {
        discard map.set(payload, "final_status", json.str(final_status))
    }
    if processed_count != "" {
        discard map.set(payload, "processed_count", json.str(processed_count))
    }
    return json.object(payload)
}

fn queue_tool_payload_json(tool: str, status: str, message: str, queue_json: str, before_json: str, after_json: str, queued_tool_id: str, queued_run_id: str, phase: str, limit: str) -> str {
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool))
    discard map.set(payload, "status", json.str(status))
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if phase != "" {
        discard map.set(payload, "phase", json.str(phase))
    }
    if queue_json != "" {
        discard map.set(payload, "queue", json.raw(queue_json))
    }
    if before_json != "" {
        discard map.set(payload, "before", json.raw(before_json))
    }
    if after_json != "" {
        discard map.set(payload, "after", json.raw(after_json))
    }
    if queued_tool_id != "" {
        discard map.set(payload, "queued_tool_id", json.str(queued_tool_id))
    }
    if queued_run_id != "" {
        discard map.set(payload, "queued_run_id", json.str(queued_run_id))
    }
    if limit != "" {
        discard map.set(payload, "limit", json.str(limit))
    }
    return json.object(payload)
}

