fn turn_result_json(status: ControlStatus, provider: str, assistant_text: str, raw_response: str, stop_reason: str, tool_events_json: str, http_status: str, message: str, transport_error: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(control_status_text(status)))
    discard map.set(payload, "provider", json.str(provider))
    if http_status != "" {
        discard map.set(payload, "http_status", json.str(http_status))
    }
    if assistant_text != "" {
        discard map.set(payload, "assistant", json.str(assistant_text))
    }
    if raw_response != "" {
        discard map.set(payload, "raw_response", json.str(raw_response))
    }
    if stop_reason != "" {
        discard map.set(payload, "stop_reason", json.str(stop_reason))
    }
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if transport_error != "" {
        discard map.set(payload, "transport_error", json.str(transport_error))
    }
    discard map.set(payload, "tool_events", json.raw(tool_events_json))
    return json.object(payload)
}

fn health_payload_json(service: str, provider: str, model: str) -> str {
    return util.json_obj4("status", json.str(control_ok_label()), "service", json.str(service), "provider", json.str(provider), "model", json.str(model))
}

