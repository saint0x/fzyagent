}

fn longrange_tool_payload_json(tool: str, status: str, run_id: str, message: str, guidance: str, next_step: str, state_json: str, plan_json: str, summary_json: str, queue_depth: str) -> str {
    let state_trimmed = str.trim(state_json)
    let plan_trimmed = str.trim(plan_json)
    let summary_trimmed = str.trim(summary_json)
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool))
    discard map.set(payload, "status", json.str(status))
    if run_id != "" {
        discard map.set(payload, "run_id", json.str(run_id))
    }
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if guidance != "" {
        discard map.set(payload, "guidance", json.str(guidance))
    }
    if next_step != "" {
        discard map.set(payload, "next_step", json.str(next_step))
    }
    if state_trimmed != "" && str.slice(state_trimmed, 0, 1) == "{" && str.slice(state_trimmed, str.len(state_trimmed) - 1, str.len(state_trimmed)) == "}" {
        discard map.set(payload, "state", apputil.json_value_or(state_trimmed, "{}"))
    }
    if plan_trimmed != "" && str.slice(plan_trimmed, 0, 1) == "{" && str.slice(plan_trimmed, str.len(plan_trimmed) - 1, str.len(plan_trimmed)) == "}" {
        discard map.set(payload, "plan", apputil.json_value_or(plan_trimmed, "{}"))
    }
    if summary_trimmed != "" && str.slice(summary_trimmed, 0, 1) == "{" && str.slice(summary_trimmed, str.len(summary_trimmed) - 1, str.len(summary_trimmed)) == "}" {
        discard map.set(payload, "summary", apputil.json_value_or(summary_trimmed, "{}"))
    }
    if queue_depth != "" {
        discard map.set(payload, "queue_depth", json.str(queue_depth))
    }
    return json.object(payload)
}

fn api_event_tools_json(event: str, tools_json: str) -> str {
    return apputil.json_obj3(
        "status", json.str(control_ok_label()),
        "event", json.str(event),
        "tools", apputil.json_value_or(tools_json, "[]"),
    )
}

fn api_event_tool_id_json(event: str, tool_id: str) -> str {
    return apputil.json_obj3(
        "status", json.str(control_ok_label()),
        "event", json.str(event),
        "tool_id", json.str(tool_id),
    )
}

fn turn_result_json(status: ControlStatus, provider: str, assistant_text: str, raw_response: str, stop_reason: str, tool_events_json: str, http_status: str, message: str, transport_error: str, result_kind: str, control_tool: str, control_outcome: str) -> str {
    let mut payload = "{\"status\":"
    payload = str.concat(payload, json.str(control_status_text(status)))
    payload = str.concat(payload, str.concat(",\"provider\":", json.str(provider)))
    if http_status != "" {
        payload = str.concat(payload, str.concat(",\"http_status\":", json.str(http_status)))
    }
    if assistant_text != "" {
        payload = str.concat(payload, str.concat(",\"assistant\":", json.str(assistant_text)))
    }
    if raw_response != "" {
        payload = str.concat(payload, str.concat(",\"raw_response\":", json.str(raw_response)))
    }
    if stop_reason != "" {
        payload = str.concat(payload, str.concat(",\"stop_reason\":", json.str(stop_reason)))
    }
    if message != "" {
        payload = str.concat(payload, str.concat(",\"message\":", json.str(message)))
    }
    if transport_error != "" {
        payload = str.concat(payload, str.concat(",\"transport_error\":", json.str(transport_error)))
    }
    if result_kind != "" {
        payload = str.concat(payload, str.concat(",\"result_kind\":", json.str(result_kind)))
    }
    if control_tool != "" {
        payload = str.concat(payload, str.concat(",\"control_tool\":", json.str(control_tool)))
    }
    if control_outcome != "" {
        payload = str.concat(payload, str.concat(",\"control_outcome\":", json.str(control_outcome)))
    }
    payload = str.concat(payload, str.concat(",\"tool_events\":", tool_events_json))
    return str.concat(payload, "}")
}

