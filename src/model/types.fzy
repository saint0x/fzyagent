fn run_state_error_json(run_id: str, state: str, updated_at: str) -> str {
    return apputil.json_obj4("status", json.str(control_error_label()), "run_id", json.str(run_id), "state", json.str(state), "updated_at", json.str(updated_at))
}

fn request_guard_error_json(message: str) -> str {
    return apputil.json_obj2("status", json.str(control_error_label()), "message", json.str(message))
}

fn session_response_json(event: str, session_json: str) -> str {
    return apputil.json_obj3("status", json.str(control_ok_label()), "event", json.str(event), "session", apputil.json_value_or(session_json, "{}"))
}

