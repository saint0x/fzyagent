fn session_message_entry_json(session_id: str, role: str, kind: str, content: str, run_id: str, request_id: str, recorded_at: str) -> str {
    let payload = map.new()
    discard map.set(payload, "session_id", json.str(session_id))
    discard map.set(payload, "role", json.str(role))
    discard map.set(payload, "kind", json.str(kind))
    discard map.set(payload, "content", json.str(content))
    discard map.set(payload, "run_id", json.str(run_id))
    discard map.set(payload, "request_id", json.str(request_id))
    discard map.set(payload, "recorded_at", json.str(recorded_at))
    return json.object(payload)
}

