#[repr(C)]
struct SessionRecord {
    id: i32,
    state: i32,
}

#[repr(C)]
struct ToolRecord {
    id: i32,
    healthy: i32,
}

#[repr(C)]
struct RunRecord {
    id: i32,
    state: i32,
}

enum SessionState {
    SessionPending,
    SessionActive,
    SessionClosing,
    SessionFailed,
}

enum ToolHealth {
    ToolUnknown,
    ToolHealthy,
    ToolDegraded,
    ToolOffline,
}

enum RunState {
    RunQueued,
    RunRunning,
    RunCompleted,
    RunFailed,
}

enum ControlStatus {
    ControlOk,
    ControlError,
}

enum QueuePhase {
    QueueIdle,
    QueueQueued,
    QueueRunning,
    QueueProcessed,
    QueueSpawned,
    QueueCancelled,
    QueueKilled,
    QueueStatusView,
    QueueMonitor,
    QueueWorkerLimit,
    QueueBoot,
}

enum SupervisorPhase {
    SupervisorConfigured,
    SupervisorRunning,
    SupervisorShutdown,
}

enum QueueRecordState {
    QueueRecordPending,
    QueueRecordCompleted,
}

struct SessionView {
    id: i32,
    state: SessionState,
}

struct ToolView {
    id: i32,
    health: ToolHealth,
}

struct RunView {
    id: i32,
    state: RunState,
}

fn session_state_code(state: SessionState) -> i32 {
    match state {
        SessionState::SessionPending => return 0,
        SessionState::SessionActive => return 1,
        SessionState::SessionClosing => return 2,
        _ => return 3,
    }
    return 3
}

fn tool_health_code(health: ToolHealth) -> i32 {
    match health {
        ToolHealth::ToolUnknown => return 0,
        ToolHealth::ToolHealthy => return 1,
        ToolHealth::ToolDegraded => return 2,
        _ => return 3,
    }
    return 3
}

fn run_state_code(state: RunState) -> i32 {
    match state {
        RunState::RunQueued => return 0,
        RunState::RunRunning => return 1,
        RunState::RunCompleted => return 2,
        _ => return 3,
    }
    return 3
}

fn session_state_label(state: SessionState) -> str {
    match state {
        SessionState::SessionPending => return "pending",
        SessionState::SessionActive => return "active",
        SessionState::SessionClosing => return "closing",
        _ => return "failed",
    }
    return "failed"
}

fn run_state_label(state: RunState) -> str {
    match state {
        RunState::RunQueued => return "queued",
        RunState::RunRunning => return "running",
        RunState::RunCompleted => return "completed",
        _ => return "failed",
    }
    return "failed"
}

fn active_session_state_label() -> str {
    return session_state_label(SessionState::SessionActive)
}

fn completed_run_state_label() -> str {
    return run_state_label(RunState::RunCompleted)
}

fn control_status_label(status: ControlStatus) -> str {
    match status {
        ControlStatus::ControlOk => return "ok",
        _ => return "error",
    }
    return "error"
}

fn control_ok_label() -> str {
    return control_status_label(ControlStatus::ControlOk)
}

fn control_error_label() -> str {
    return control_status_label(ControlStatus::ControlError)
}

fn control_ok_status() -> ControlStatus {
    return ControlStatus::ControlOk
}

fn control_error_status() -> ControlStatus {
    return ControlStatus::ControlError
}

fn queue_phase_label(phase: QueuePhase) -> str {
    match phase {
        QueuePhase::QueueIdle => return "idle",
        QueuePhase::QueueQueued => return "queued",
        QueuePhase::QueueRunning => return "running",
        QueuePhase::QueueProcessed => return "processed",
        QueuePhase::QueueSpawned => return "spawned",
        QueuePhase::QueueCancelled => return "cancelled",
        QueuePhase::QueueKilled => return "killed",
        QueuePhase::QueueStatusView => return "status",
        QueuePhase::QueueMonitor => return "monitor_background",
        QueuePhase::QueueWorkerLimit => return "worker_limit_reached",
        _ => return "boot",
    }
    return "boot"
}

fn queue_idle_label() -> str {
    return queue_phase_label(QueuePhase::QueueIdle)
}

fn queue_queued_label() -> str {
    return queue_phase_label(QueuePhase::QueueQueued)
}

fn queue_running_label() -> str {
    return queue_phase_label(QueuePhase::QueueRunning)
}

fn queue_processed_label() -> str {
    return queue_phase_label(QueuePhase::QueueProcessed)
}

fn queue_spawned_label() -> str {
    return queue_phase_label(QueuePhase::QueueSpawned)
}

fn queue_cancelled_label() -> str {
    return queue_phase_label(QueuePhase::QueueCancelled)
}

fn queue_killed_label() -> str {
    return queue_phase_label(QueuePhase::QueueKilled)
}

fn queue_status_view_label() -> str {
    return queue_phase_label(QueuePhase::QueueStatusView)
}

fn queue_monitor_label() -> str {
    return queue_phase_label(QueuePhase::QueueMonitor)
}

fn queue_worker_limit_label() -> str {
    return queue_phase_label(QueuePhase::QueueWorkerLimit)
}

fn queue_boot_label() -> str {
    return queue_phase_label(QueuePhase::QueueBoot)
}

fn supervisor_phase_label(phase: SupervisorPhase) -> str {
    match phase {
        SupervisorPhase::SupervisorConfigured => return "configured",
        SupervisorPhase::SupervisorRunning => return "running",
        _ => return "shutdown",
    }
    return "shutdown"
}

fn supervisor_configured_label() -> str {
    return supervisor_phase_label(SupervisorPhase::SupervisorConfigured)
}

fn supervisor_running_label() -> str {
    return supervisor_phase_label(SupervisorPhase::SupervisorRunning)
}

fn supervisor_shutdown_label() -> str {
    return supervisor_phase_label(SupervisorPhase::SupervisorShutdown)
}

fn queue_record_state_label(state: QueueRecordState) -> str {
    match state {
        QueueRecordState::QueueRecordPending => return "pending",
        _ => return "completed",
    }
    return "completed"
}

fn queue_record_pending_label() -> str {
    return queue_record_state_label(QueueRecordState::QueueRecordPending)
}

fn queue_record_completed_label() -> str {
    return queue_record_state_label(QueueRecordState::QueueRecordCompleted)
}

fn run_state_from_status(status: str) -> RunState {
    if status == "queued" {
        return RunState::RunQueued
    }
    if status == "running" {
        return RunState::RunRunning
    }
    if status == "ok" || status == "completed" {
        return RunState::RunCompleted
    }
    return RunState::RunFailed
}

fn session_view(id: i32, state: SessionState) -> SessionView {
    let out = SessionView { id: id, state: state }
    return out
}

fn session_view_active(id: i32) -> SessionView {
    return session_view(id, SessionState::SessionActive)
}

fn tool_view(id: i32, health: ToolHealth) -> ToolView {
    let out = ToolView { id: id, health: health }
    return out
}

fn run_view(id: i32, state: RunState) -> RunView {
    let out = RunView { id: id, state: state }
    return out
}

fn encode_session_record(view: SessionView) -> SessionRecord {
    let out = SessionRecord { id: view.id, state: session_state_code(view.state) }
    return out
}

fn encode_tool_record(view: ToolView) -> ToolRecord {
    let out = ToolRecord { id: view.id, healthy: tool_health_code(view.health) }
    return out
}

fn encode_run_record(view: RunView) -> RunRecord {
    let out = RunRecord { id: view.id, state: run_state_code(view.state) }
    return out
}

fn schema_version() -> i32 {
    return 3
}

fn control_status_text(status: ControlStatus) -> str {
    return control_status_label(status)
}

fn session_doc_json(session_id: str, state: str, turn_count: str, last_run_id: str, last_user_message: str, last_assistant_message: str, last_request_id: str, tool_count: str, meta_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(control_ok_label()))
    discard map.set(payload, "session_id", json.str(session_id))
    discard map.set(payload, "state", json.str(state))
    discard map.set(payload, "turn_count", json.str(turn_count))
    discard map.set(payload, "last_run_id", json.str(last_run_id))
    discard map.set(payload, "last_request_id", json.str(last_request_id))
    discard map.set(payload, "last_user_message", json.str(last_user_message))
    discard map.set(payload, "last_assistant_message", json.str(last_assistant_message))
    discard map.set(payload, "tool_count", json.str(tool_count))
    discard map.set(payload, "meta", json.raw(meta_json))
    return json.object(payload)
}

fn session_meta_json(updated_at: str, provider: str, model: str, history_path: str, runs_path: str) -> str {
    return util.json_obj5(
        "updated_at", json.str(updated_at),
        "provider", json.str(provider),
        "model", json.str(model),
        "history_path", json.str(history_path),
        "runs_path", json.str(runs_path),
    )
}

