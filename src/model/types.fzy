    discard map.set(payload, "done_criteria", json.str(done_criteria))
    discard map.set(payload, "step_type", json.str(step_type))
    discard map.set(payload, "evidence_mode", json.str(evidence_mode))
    discard map.set(payload, "completion_signal", json.str(completion_signal))
    discard map.set(payload, "step_outlook", json.str(step_outlook))
    discard map.set(payload, "target_turns", json.str(target_turns))
    return json.object(payload)
}

fn longrange_plan_json(run_id: str, goal_summary: str, finished_definition: str, difficulty: str, estimated_effort: str, current_step_id: str, plan_summary: str, steps_json: str, updated_at: str, task_class: str, completion_mode: str, expected_total_turns: str, execution_outlook: str, planning_style: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(control_ok_label()))
    discard map.set(payload, "run_id", json.str(run_id))
    discard map.set(payload, "goal_summary", json.str(goal_summary))
    discard map.set(payload, "finished_definition", json.str(finished_definition))
    discard map.set(payload, "difficulty", json.str(difficulty))
    discard map.set(payload, "estimated_effort", json.str(estimated_effort))
    discard map.set(payload, "task_class", json.str(task_class))
    discard map.set(payload, "completion_mode", json.str(completion_mode))
    discard map.set(payload, "expected_total_turns", json.str(expected_total_turns))
    discard map.set(payload, "execution_outlook", json.str(execution_outlook))
    discard map.set(payload, "planning_style", json.str(planning_style))
    discard map.set(payload, "plan_summary", json.str(plan_summary))
    discard map.set(payload, "steps", apputil.json_value_or(steps_json, "[]"))
    discard map.set(payload, "updated_at", json.str(updated_at))
    if current_step_id != "" {
        discard map.set(payload, "current_step_id", json.str(current_step_id))
    }
    return json.object(payload)
}

fn longrange_run_state_json(run_id: str, session_id: str, goal: str, status: str, plan_status: str, current_step_id: str, last_request_id: str, turns_completed: str, failure_count: str, auto_continue_pending: str, active_message_kind: str, latest_summary: str, created_at: str, updated_at: str, completed_at: str, task_class: str, last_progress_score: str, consecutive_low_score: str, last_evidence_count: str, completed_step_count: str) -> str {
    let mut payload = "{\"status\":"
    payload = str.concat(payload, json.str(control_ok_label()))
    payload = str.concat(payload, str.concat(",\"run_id\":", json.str(run_id)))
    payload = str.concat(payload, str.concat(",\"session_id\":", json.str(session_id)))
    payload = str.concat(payload, str.concat(",\"goal\":", json.str(goal)))
    payload = str.concat(payload, str.concat(",\"run_status\":", json.str(status)))
    payload = str.concat(payload, str.concat(",\"plan_status\":", json.str(plan_status)))
    payload = str.concat(payload, str.concat(",\"task_class\":", json.str(task_class)))
    payload = str.concat(payload, str.concat(",\"turns_completed\":", json.str(turns_completed)))
    payload = str.concat(payload, str.concat(",\"failure_count\":", json.str(failure_count)))
    payload = str.concat(payload, str.concat(",\"last_progress_score\":", json.str(last_progress_score)))
    payload = str.concat(payload, str.concat(",\"consecutive_low_score\":", json.str(consecutive_low_score)))
    payload = str.concat(payload, str.concat(",\"last_evidence_count\":", json.str(last_evidence_count)))
    payload = str.concat(payload, str.concat(",\"completed_step_count\":", json.str(completed_step_count)))
    payload = str.concat(payload, str.concat(",\"auto_continue_pending\":", json.str(auto_continue_pending)))
    payload = str.concat(payload, str.concat(",\"active_message_kind\":", json.str(active_message_kind)))
    payload = str.concat(payload, str.concat(",\"latest_summary\":", json.str(latest_summary)))
    payload = str.concat(payload, str.concat(",\"created_at\":", json.str(created_at)))
    payload = str.concat(payload, str.concat(",\"updated_at\":", json.str(updated_at)))
    if current_step_id != "" {
        payload = str.concat(payload, str.concat(",\"current_step_id\":", json.str(current_step_id)))
    }
    if last_request_id != "" {
        payload = str.concat(payload, str.concat(",\"last_request_id\":", json.str(last_request_id)))
    }
    if completed_at != "" {
        payload = str.concat(payload, str.concat(",\"completed_at\":", json.str(completed_at)))
    }
    return str.concat(payload, "}")
}

