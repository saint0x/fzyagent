        "host", json.str(host),
        "port", json.str(port),
    )
}

fn telemetry_payload_json(event: str, status: str, clock: str, runtime_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "event", json.str(event))
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "clock", json.str(clock))
    if runtime_json != "" {
        discard map.set(payload, "runtime", json.raw(runtime_json))
    }
    return json.object(payload)
}

