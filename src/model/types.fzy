    )
}

fn registry_lookup_error_json(tool_id: str, message: str) -> str {
    return util.json_obj3("status", json.str(control_error_label()), "tool_id", json.str(tool_id), "message", json.str(message))
}

fn audit_record_json(event: str, status: str, clock: str, summary_path: str) -> str {
    return util.json_obj4("event", json.str(event), "status", json.str(status), "clock", json.str(clock), "summary_path", json.str(summary_path))
}

fn ffi_export_json(symbol: str, kind: str, mode: str) -> str {
    return util.json_obj3("symbol", json.str(symbol), "kind", json.str(kind), "mode", json.str(mode))
}

fn ffi_manifest_json(abi: str, project: str, exports_json: str, rpc_protocol: str, rpc_schemas_json: str, runtime_schemas_json: str, manifests_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "status", json.str(control_ok_label()))
    discard map.set(payload, "abi", json.str(abi))
    discard map.set(payload, "project", json.str(project))
    discard map.set(payload, "exports", json.raw(exports_json))
    discard map.set(payload, "rpc_protocol", json.str(rpc_protocol))
    discard map.set(payload, "rpc_schemas", json.raw(rpc_schemas_json))
    discard map.set(payload, "runtime_schemas", json.raw(runtime_schemas_json))
    discard map.set(payload, "manifests", json.raw(manifests_json))
    return json.object(payload)
}

fn runtime_config_json(host: str, port: str, workers: str, background_mode: str, observability_mode: str) -> str {
