    payload = str.concat(payload, str.concat(",\"state\":", json.str(state)))
    payload = str.concat(payload, str.concat(",\"updated_at\":", json.str(updated_at)))
    payload = str.concat(payload, str.concat(",\"session_path\":", json.str(session_path)))
    return str.concat(payload, "}")
}

