fn http_shutdown_json(status: str, phase: str, requested_at: str) -> str {
    return util.json_obj3("status", json.str(status), "phase", json.str(phase), "requested_at", json.str(requested_at))
}

fn runtime_control_payload_json(tool: str, status: str, phase: str, message: str, checkpoint_json: str, recovery_json: str, supervisor_json: str, shutdown_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool))
    discard map.set(payload, "status", json.str(status))
    discard map.set(payload, "phase", json.str(phase))
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if checkpoint_json != "" {
        discard map.set(payload, "checkpoint", json.raw(checkpoint_json))
    }
    if recovery_json != "" {
        discard map.set(payload, "recovery", json.raw(recovery_json))
    }
    if supervisor_json != "" {
        discard map.set(payload, "supervisor", json.raw(supervisor_json))
    }
    if shutdown_json != "" {
        discard map.set(payload, "shutdown", json.raw(shutdown_json))
    }
    return json.object(payload)
}
