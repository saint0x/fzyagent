use core.fs;
use core.thread;

fn preflight() -> i32 {
    require_tool_schema()
    return 0
}

fn require_active_session() -> i32 {
    let session = env.get("AGENT_SESSION_ID")
    if session == "" {
        checkpoint()
    }
    return 0
}

fn require_tool_schema() -> i32 {
    if fs.exists("/tmp/fzyagent/registry.json") == 0 {
        checkpoint()
    }
    return 0
}
