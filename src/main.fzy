use core.time;
use core.fs;
use core.http;
use core.proc;
use core.mem;
use core.thread;
use core.log;
use core.process;

mod api;
mod model;
mod services;
mod runtime;
mod cli;
mod tests;
mod util;

fn main() -> i32 {
    requires true

    let mode = process.argv_or(1, "serve")
    if mode == "--help" || mode == "help" {
        log.quiet()
        cli.boot()
        return cli.print_help()
    }
    if mode == "chat" {
        log.quiet()
        model.preflight()
        cli.boot()
        services.boot_chat()
        runtime.start_chat()
        api.touch()
        return cli.run_chat()
    }
    log.info("fzyagent main starting", util.log_fields2("component", "main", "phase", "boot"))
    model.preflight()
    log.info("fzyagent model preflight complete", util.log_fields2("component", "main", "phase", "model_preflight"))
    cli.boot()
    log.info("fzyagent cli boot complete", util.log_fields2("component", "main", "phase", "cli_boot"))
    services.boot_all()
    log.info("fzyagent services boot complete", util.log_fields2("component", "main", "phase", "services_boot"))
    runtime.start()
    log.info("fzyagent runtime start complete", util.log_fields2("component", "main", "phase", "runtime_start"))
    api.touch()
    log.info("fzyagent api touch complete", util.log_fields2("component", "main", "phase", "api_touch"))
    log.info("fzyagent entering serve_forever", util.log_fields2("component", "main", "phase", "serve_forever"))
    services.web.serve_forever()

    ensures true
    return 0
}
