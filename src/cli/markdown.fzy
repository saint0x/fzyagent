fn next_newline_index(text: str, start: i32) -> i32 {
    let mut idx = start
    while idx < str.len(text) {
        if str.slice(text, idx, idx + 1) == "\n" {
            return idx
        }
        idx += 1
    }
    return str.len(text)
}

fn append_piece(left: str, right: str) -> str {
    if left == "" {
        return right
    }
    if right == "" {
        return left
    }
    return str.concat(left, right)
}

fn append_line(doc: str, line: str) -> str {
    if doc == "" {
        return line
    }
    return str.concat(str.concat(doc, "\n"), line)
}

fn find_from(text: str, pattern: str, start: i32) -> i32 {
    let pattern_len = str.len(pattern)
    let mut idx = start
    while idx + pattern_len <= str.len(text) {
        if str.slice(text, idx, idx + pattern_len) == pattern {
            return idx
        }
        idx += 1
    }
    return -1
}

fn digits_only(text: str) -> i32 {
    if text == "" {
        return 0
    }
    let mut idx = 0
    while idx < str.len(text) {
        let ch = str.slice(text, idx, idx + 1)
        if ch < "0" || ch > "9" {
            return 0
        }
        idx += 1
    }
    return 1
}

fn rule_line(line: str) -> i32 {
    return if line == "---" || line == "***" { 1 } else { 0 }
}

fn heading_level(line: str) -> i32 {
    let mut idx = 0
    while idx < str.len(line) {
        if str.slice(line, idx, idx + 1) != "#" {
            break
        }
        idx += 1
    }
    if idx == 0 || idx >= str.len(line) {
        return 0
    }
    if str.slice(line, idx, idx + 1) != " " {
        return 0
    }
    return idx
}

fn bullet_body(line: str) -> str {
    if str.starts_with(line, "- ") == 1 || str.starts_with(line, "* ") == 1 {
        return str.slice(line, 2, str.len(line))
    }
    return ""
}

fn numbered_list_prefix(line: str) -> str {
    let dot = find_from(line, ". ", 0)
    if dot <= 0 {
        return ""
    }
    let prefix = str.slice(line, 0, dot)
    if digits_only(prefix) == 1 {
        return prefix
    }
    return ""
}

fn code_fence_lang(line: str) -> str {
    if str.starts_with(line, "```") == 0 {
        return ""
    }
    if str.len(line) <= 3 {
        return ""
    }
    return str.slice(line, 3, str.len(line))
}

fn image_alt(line: str, start: i32) -> str {
    let alt_end = find_from(line, "](", start + 2)
    if alt_end < 0 {
        return ""
    }
    return str.slice(line, start + 2, alt_end)
}

fn image_url(line: str, start: i32) -> str {
    let alt_end = find_from(line, "](", start + 2)
    if alt_end < 0 {
        return ""
    }
    let url_end = find_from(line, ")", alt_end + 2)
    if url_end < 0 {
        return ""
    }
    return str.slice(line, alt_end + 2, url_end)
}

fn image_close_index(line: str, start: i32) -> i32 {
    let alt_end = find_from(line, "](", start + 2)
    if alt_end < 0 {
        return -1
    }
    return find_from(line, ")", alt_end + 2)
}

fn link_label(line: str, start: i32) -> str {
    let label_end = find_from(line, "](", start + 1)
    if label_end < 0 {
        return ""
    }
    return str.slice(line, start + 1, label_end)
}

fn link_url(line: str, start: i32) -> str {
    let label_end = find_from(line, "](", start + 1)
    if label_end < 0 {
        return ""
    }
    let url_end = find_from(line, ")", label_end + 2)
    if url_end < 0 {
        return ""
    }
    return str.slice(line, label_end + 2, url_end)
}

fn link_close_index(line: str, start: i32) -> i32 {
    let label_end = find_from(line, "](", start + 1)
    if label_end < 0 {
        return -1
    }
    return find_from(line, ")", label_end + 2)
}

fn render_inline(line: str) -> str {
    let mut out = ""
    let mut idx = 0
    while idx < str.len(line) {
        if idx + 2 <= str.len(line) && str.slice(line, idx, idx + 2) == "![" {
            let close = image_close_index(line, idx)
            if close >= 0 {
                let alt = image_alt(line, idx)
                let url = image_url(line, idx)
                out = append_piece(out, logger.muted(str.concat("[image: ", alt, "]")))
                if url != "" {
                    out = append_piece(out, str.concat(" ", logger.command(url)))
                }
                idx = close + 1
                continue
            }
        }
        if idx + 2 <= str.len(line) && str.slice(line, idx, idx + 2) == "**" {
            let close = find_from(line, "**", idx + 2)
            if close >= 0 {
                out = append_piece(out, logger.strong(str.slice(line, idx + 2, close)))
                idx = close + 2
                continue
            }
        }
        if str.slice(line, idx, idx + 1) == "`" {
            let close = find_from(line, "`", idx + 1)
            if close >= 0 {
                out = append_piece(out, logger.command(str.slice(line, idx + 1, close)))
                idx = close + 1
                continue
            }
        }
        if str.slice(line, idx, idx + 1) == "[" {
            let close = link_close_index(line, idx)
            if close >= 0 {
                let label = link_label(line, idx)
                let url = link_url(line, idx)
                out = append_piece(out, logger.strong(label))
                if url != "" {
                    out = append_piece(out, str.concat(" ", logger.command(str.concat("(", str.concat(url, ")")))))
                }
                idx = close + 1
                continue
            }
        }
        out = append_piece(out, str.slice(line, idx, idx + 1))
        idx += 1
    }
    return out
}

pub fn render(text: str) -> str {
    if text == "" {
        return ""
    }
    let mut doc = ""
    let mut start = 0
    let mut in_code: i32 = 0
    let mut previous_blank: i32 = 0
    while start < str.len(text) {
        let end = next_newline_index(text, start)
        let line = str.slice(text, start, end)
        start = if end < str.len(text) { end + 1 } else { str.len(text) }

        if in_code == 1 {
            if str.starts_with(line, "```") == 1 {
                in_code = 0
                previous_blank = 0
                continue
            }
            doc = append_line(doc, str.concat("    ", logger.command(line)))
            previous_blank = 0
            continue
        }

        if line == "" {
            if previous_blank == 0 {
                doc = append_line(doc, "")
            }
            previous_blank = 1
            continue
        }

        previous_blank = 0

        if str.starts_with(line, "```") == 1 {
            in_code = 1
            let lang = code_fence_lang(line)
            if lang == "" {
                doc = append_line(doc, logger.muted("[code]"))
            } else {
                doc = append_line(doc, logger.muted(str.concat("[code ", str.concat(lang, "]"))))
            }
            continue
        }

        if rule_line(line) == 1 {
            doc = append_line(doc, logger.muted("----------------------------------------"))
            continue
        }

        let level = heading_level(line)
        if level > 0 {
            let heading = render_inline(str.slice(line, level + 1, str.len(line)))
            doc = append_line(doc, logger.accent(heading))
            continue
        }

        if str.starts_with(line, "> ") == 1 {
            doc = append_line(doc, str.concat("  ", logger.muted("| "), render_inline(str.slice(line, 2, str.len(line)))))
            continue
        }

        let bullet = bullet_body(line)
        if bullet != "" {
            doc = append_line(doc, str.concat("  - ", render_inline(bullet)))
            continue
        }

        let number_prefix = numbered_list_prefix(line)
        if number_prefix != "" {
            let body = str.slice(line, str.len(number_prefix) + 2, str.len(line))
            doc = append_line(doc, str.concat("  ", str.concat(number_prefix, str.concat(". ", render_inline(body)))))
            continue
        }

        doc = append_line(doc, render_inline(line))
    }
    return doc
}
