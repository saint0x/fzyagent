use core.fs;

fn sandbox_path() -> str {
    return "/tmp/fzyagent/runtime.sandbox.json"
}

fn env_or(key: str, fallback: str) -> str {
    let value = env.get(key)
    if value == "" {
        return fallback
    }
    return value
}

fn sandbox_mode() -> str {
    return env_or("AGENT_SANDBOX_MODE", "standard")
}

fn write_policy(policy: str, scope: str) -> i32 {
    fs.mkdir("/tmp/fzyagent")
    let payload = model.types.runtime_sandbox_json(policy, scope, sandbox_mode())
    fs.write_file(sandbox_path(), payload)
    return 0
}

fn apply_default_policy() -> i32 {
    return write_policy("default", "runtime")
}

fn allow_tool_scope() -> i32 {
    return write_policy("allow", "tools")
}

fn deny_tool_scope() -> i32 {
    return write_policy("deny", "tools")
}
