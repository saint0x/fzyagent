use core.thread;
use core.fs;

fn events_path() -> str {
    return "/tmp/fzyagent/events.last.json"
}

fn emit_event(name: str, component: str) -> i32 {
    if runtime.config.persist_runtime_events() == 0 {
        return 0
    }
    fs.mkdir("/tmp/fzyagent")
    let payload = model.types.runtime_event_json(name, component, "sampled", model.types.control_ok_label())
    fs.write_file(events_path(), payload)
    pulse()
    return 0
}

fn boot_bus() -> i32 {
    return emit_event("boot_bus", "runtime.events")
}

fn emit_tool_started() -> i32 {
    return emit_event("tool_started", "runtime.events")
}

fn emit_tool_finished() -> i32 {
    return emit_event("tool_finished", "runtime.events")
}

fn emit_stdout_chunk() -> i32 {
    return emit_event("stdout_chunk", "runtime.events")
}

fn emit_stderr_chunk() -> i32 {
    return emit_event("stderr_chunk", "runtime.events")
}

fn emit_structured_event() -> i32 {
    return emit_event("structured_event", "runtime.events")
}

fn emit_registry_update() -> i32 {
    return emit_event("registry_update", "runtime.events")
}

fn emit_health_tick() -> i32 {
    return emit_event("health_tick", "runtime.events")
}
