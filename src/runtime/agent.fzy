use core.fs;
use core.http;
use core.thread;
use core.log;


fn system_prompt_path() -> str {
    return runtime.config.agent_system_prompt_path()
}

fn runtime_overlay_prompt_path() -> str {
    return runtime.config.runtime_overlay_prompt_path()
}

fn longrange_overlay_prompt_path() -> str {
    return runtime.config.longrange_overlay_prompt_path()
}

fn debug_dir() -> str {
    return runtime.config.state_subdir("agent.debug")
}

fn debug_path(name: str) -> str {
    return str.concat(debug_dir(), str.concat("/", name))
}

fn write_debug(name: str, payload: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    fs.mkdir(debug_dir())
    discard fs.atomic_write(debug_path(name), payload)
    return 0
}

fn read_prompt_or_empty(path: str) -> str {
    if fs.exists(path) == 0 {
        return ""
    }
    let text = fs.read_file(path)
    if text == "" {
        return ""
    }
    return text
}

fn base_system_prompt() -> str {
    let text = read_prompt_or_empty(system_prompt_path())
    if text == "" {
        return "You are the fzyagent runtime. Be concise, grounded, and tool-aware."
    }
    return text
}

fn append_prompt_section(base: str, addition: str) -> str {
    if addition == "" {
        return base
    }
    if base == "" {
        return addition
    }
    return str.concat(base, str.concat("\n\n", addition))
}

fn load_system_prompt_for(prompt: str) -> str {
    let mut text = base_system_prompt()
    text = append_prompt_section(text, read_prompt_or_empty(runtime_overlay_prompt_path()))
    if is_automated_longrange_prompt(prompt) == 1 {
        text = append_prompt_section(text, read_prompt_or_empty(longrange_overlay_prompt_path()))
    }
    return text
}

fn transcript_context(session_id: str) -> str {
    let excerpt = services.sessions.transcript_excerpt(session_id)
    if excerpt == "" {
        return "No prior conversation turns are recorded for this session yet."
    }
    return excerpt
}

fn prompt_excerpt(text_value: str, max_chars: i32) -> str {
    if str.len(text_value) <= max_chars {
        return text_value
    }
    return str.slice(text_value, str.len(text_value) - max_chars, str.len(text_value))
}

fn compact_transcript_value(text_value: str) -> str {
    if text_value == "" {
        return ""
    }
    if str.starts_with(text_value, "AUTOMATED LONG RANGE MESSAGE") == 1 {
        return "[automated long-range continuation omitted; rely on LONG RANGE CONTEXT]"
    }
    return prompt_excerpt(text_value, 400)
}

fn compact_longrange_transcript(session_id: str) -> str {
    let session = json.parse(services.persistence.load_session_json_for(session_id))
    let last_user = compact_transcript_value(services.persistence.session_last_user_message_value(session))
    let last_assistant = prompt_excerpt(services.persistence.session_last_assistant_message_value(session), 400)
    let turn_count = services.persistence.session_turn_count_value(session)
    let mut out = "Compact session summary for autonomous continuation.\n"
    out = str.concat(out, str.concat("turn_count: ", turn_count))
    if last_user != "" {
        out = str.concat(out, str.concat("\nlast_user: ", last_user))
    }
    if last_assistant != "" {
        out = str.concat(out, str.concat("\nlast_assistant: ", last_assistant))
    }
    return out
}

fn is_automated_longrange_prompt(prompt: str) -> i32 {
    if str.starts_with(prompt, "AUTOMATED LONG RANGE MESSAGE") == 1 {
        return 1
    }
    return 0
}

fn build_turn_prompt(session_id: str, prompt: str) -> str {
    let longrange_context = services.longrange.prompt_context(session_id)
    let transcript = if longrange_context != "" && is_automated_longrange_prompt(prompt) == 1 {
        compact_longrange_transcript(session_id)
    } else {
        transcript_context(session_id)
    }
    return str.concat(
        "SESSION TRANSCRIPT\n",
        transcript,
        if longrange_context == "" { "" } else { str.concat("\n\nLONG RANGE CONTEXT\n", longrange_context) },
        "\n\nLATEST USER MESSAGE\n",
        prompt,
    )
}

fn initial_messages_json(session_id: str, prompt: str) -> str {
    let message = apputil.json_obj2("role", json.str("user"), "content", json.str(build_turn_prompt(session_id, prompt)))
    let items = list.new()
    discard list.push(items, message)
    return json.array(items)
}

fn append_message_json(messages_json: str, message_json: str) -> str {
    let parsed = json.parse(if messages_json == "" { "[]" } else { messages_json })
    let items = list.new()
    let mut idx: i32 = 0
    while idx < 64 {
        let item = json.get(parsed, str.from_i32(idx))
        let raw = json.get_str(item, "raw")
        if raw == "" {
            break
        }
        discard list.push(items, apputil.json_value_or(raw, "{}"))
        idx = idx + 1
    }
    discard list.push(items, apputil.json_value_or(message_json, "{}"))
    return json.array(items)
}

fn append_array_json(left_json: str, right_json: str) -> str {
    let items = list.new()
    let left = json.parse(if left_json == "" { "[]" } else { left_json })
    let right = json.parse(if right_json == "" { "[]" } else { right_json })
    let mut idx: i32 = 0
    while idx < 64 {
        let item = json.get(left, str.from_i32(idx))
        let raw = json.get_str(item, "raw")
        if raw == "" {
            break
        }
        discard list.push(items, apputil.json_value_or(raw, "{}"))
        idx = idx + 1
    }
    idx = 0
    while idx < 64 {
        let item = json.get(right, str.from_i32(idx))
        let raw = json.get_str(item, "raw")
        if raw == "" {
            break
        }
        discard list.push(items, apputil.json_value_or(raw, "{}"))
        idx = idx + 1
    }
    return json.array(items)
}

fn text_index_of(hay: str, needle: str) -> i32 {
    if needle == "" {
        return 0
    }
    if str.len(needle) > str.len(hay) {
        return -1
    }
    let mut idx: i32 = 0
    while idx + str.len(needle) <= str.len(hay) {
        if str.slice(hay, idx, idx + str.len(needle)) == needle {
            return idx
        }
        idx = idx + 1
    }
    return -1
}

fn quoted_raw_field(raw: str, key: str) -> str {
    return apputil.json_field_or_empty(raw, key)
}

fn extract_balanced_json(raw: str, start_idx: i32) -> str {
    if raw == "" || start_idx < 0 || start_idx >= str.len(raw) {
        return ""
    }
    let opener = str.slice(raw, start_idx, start_idx + 1)
    let closer = if opener == "{" { "}" } else { if opener == "[" { "]" } else { "" } }
    if closer == "" {
        return ""
    }
    let mut idx: i32 = start_idx
    let mut depth: i32 = 0
    let mut in_string: i32 = 0
    let mut escaping: i32 = 0
    while idx < str.len(raw) {
        let ch = str.slice(raw, idx, idx + 1)
        if in_string == 1 {
            if escaping == 1 {
                escaping = 0
            } else if ch == "\\" {
                escaping = 1
            } else if ch == "\"" {
                in_string = 0
            }
        } else {
            if ch == "\"" {
                in_string = 1
            } else if ch == opener {
                depth = depth + 1
            } else if ch == closer {
                depth = depth - 1
                if depth == 0 {
                    return str.slice(raw, start_idx, idx + 1)
                }
            }
        }
        idx = idx + 1
    }
    return ""
}

fn content_raw(parsed: JsonHandle) -> str {
    return json.get_str(json.get(parsed, "content"), "raw")
}

fn content_block(parsed: JsonHandle, index: str) -> JsonHandle {
    let content = json.get(parsed, "content")
    return json.get(content, index)
}

fn content_block_type(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "type")
}

fn content_block_text(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "text")
}

fn content_block_tool_name(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "name")
}

fn content_block_tool_id(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "id")
}

fn content_block_tool_input_raw(parsed: JsonHandle, index: str) -> str {
    let input = json.get(content_block(parsed, index), "input")
    return json.get_str(input, "raw")
}

fn max_content_blocks() -> i32 {
    return 8
}

fn max_recursive_tool_depth() -> i32 {
    return 4
}

fn is_longrange_control_tool(tool_name: str) -> i32 {
    if tool_name == "longrange_start" || tool_name == "longrange_status" || tool_name == "longrange_cancel" || tool_name == "longrange_steer" || tool_name == "plan_create" || tool_name == "plan_update" || tool_name == "plan_view" || tool_name == "goal_complete" {
        return 1
    }
    return 0
}

fn control_tool_name_or_empty(parsed: JsonHandle, index: str) -> str {
    if content_block_type(parsed, index) != "tool_use" {
        return ""
    }
    let tool_name = content_block_tool_name(parsed, index)
    if is_longrange_control_tool(tool_name) == 1 {
        return tool_name
    }
    return ""
}

fn terminating_control_tool_name(parsed: JsonHandle) -> str {
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let name = control_tool_name_or_empty(parsed, str.from_i32(idx))
        if name != "" {
            return name
        }
        idx = idx + 1
    }
    return ""
}

fn successful_control_tool_summary(tool_events_json: str) -> str {
    if tool_events_json == "" || tool_events_json == "[]" {
        return ""
    }
    let parsed = json.parse(tool_events_json)
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let event = json.get(parsed, str.from_i32(idx))
        let tool_name = json.get_str(event, "tool")
        if tool_name == "" {
            idx = idx + 1
            continue
        }
        if is_longrange_control_tool(tool_name) == 1 {
            let outcome_status = json.get_str(event, "outcome_status")
            if outcome_status == "ok" {
                return str.concat("control_plane_tool_executed:", tool_name)
            }
            if outcome_status == "error" {
                return str.concat("control_plane_tool_failed:", tool_name)
            }
            return ""
        }
        idx = idx + 1
    }
    return ""
}

fn has_longrange_start_event(tool_events_json: str) -> i32 {
    if tool_events_json == "" || tool_events_json == "[]" {
        return 0
    }
    if str.contains(tool_events_json, "\"tool\":\"longrange_start\"") == 1 {
        return 1
    }
    return 0
}

fn first_control_tool_name(tool_events_json: str) -> str {
    if tool_events_json == "" || tool_events_json == "[]" {
        return ""
    }
    let parsed = json.parse(tool_events_json)
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let event = json.get(parsed, str.from_i32(idx))
        let tool_name = json.get_str(event, "tool")
        if tool_name != "" && is_longrange_control_tool(tool_name) == 1 {
            return tool_name
        }
        idx = idx + 1
    }
    return ""
}

fn first_control_tool_outcome(tool_events_json: str) -> str {
    if tool_events_json == "" || tool_events_json == "[]" {
        return ""
    }
    let parsed = json.parse(tool_events_json)
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let event = json.get(parsed, str.from_i32(idx))
        let tool_name = json.get_str(event, "tool")
        if tool_name != "" && is_longrange_control_tool(tool_name) == 1 {
            return json.get_str(event, "outcome_status")
        }
        idx = idx + 1
    }
    return ""
}

fn content_block_json(parsed: JsonHandle, index: str) -> str {
    let block_type = content_block_type(parsed, index)
    if block_type == "text" {
        return apputil.json_obj2("type", json.str("text"), "text", json.str(content_block_text(parsed, index)))
    }
    if block_type == "tool_use" {
        let payload = map.new()
        discard map.set(payload, "type", json.str("tool_use"))
        discard map.set(payload, "id", json.str(content_block_tool_id(parsed, index)))
        discard map.set(payload, "name", json.str(content_block_tool_name(parsed, index)))
        discard map.set(payload, "input", apputil.json_value_or(content_block_tool_input_raw(parsed, index), "{}"))
        return json.object(payload)
    }
    return ""
}

fn maybe_push_content_block(items: ListHandle, parsed: JsonHandle, index: str) -> i32 {
    let block = content_block_json(parsed, index)
    if block != "" {
        discard list.push(items, block)
    }
    return 0
}

fn assistant_message_json(parsed: JsonHandle) -> str {
    let raw = content_raw(parsed)
    if raw != "" {
        let payload = map.new()
        discard map.set(payload, "role", json.str("assistant"))
        discard map.set(payload, "content", apputil.json_value_or(raw, "[]"))
        return json.object(payload)
    }
    let items = list.new()
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        discard maybe_push_content_block(items, parsed, str.from_i32(idx))
        idx = idx + 1
    }
    return apputil.json_obj2("role", json.str("assistant"), "content", apputil.json_array_value(items))
}

fn content_block_text_or_empty(parsed: JsonHandle, index: str) -> str {
    if content_block_type(parsed, index) != "text" {
        return ""
    }
    return content_block_text(parsed, index)
}

fn extract_text_block(parsed: JsonHandle) -> str {
    let mut out = ""
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let text = content_block_text_or_empty(parsed, str.from_i32(idx))
        if text != "" {
            out = str.concat(out, text)
        }
        idx = idx + 1
    }
    if out != "" {
        return out
    }
    return json.get_str(parsed, "completion")
}

struct StreamBlock {
    block_type: str,
    text: str,
    tool_id: str,
    tool_name: str,
    input_raw: str,
}

fn empty_stream_block() -> StreamBlock {
    return StreamBlock {
        block_type: "",
        text: "",
        tool_id: "",
        tool_name: "",
        input_raw: "",
    }
}

fn stream_index_raw(parsed: JsonHandle) -> str {
    let raw = json.get_str(json.get(parsed, "index"), "raw")
    if raw != "" {
        return raw
    }
    return json.get_str(parsed, "index")
}

fn newline_index(text: str) -> i32 {
    let mut idx: i32 = 0
    while idx < str.len(text) {
        if str.slice(text, idx, idx + 1) == "\n" {
            return idx
        }
        idx = idx + 1
    }
    return -1
}

fn stream_block_from_start(content_block: JsonHandle) -> StreamBlock {
    let block_type = json.get_str(content_block, "type")
    if block_type == "text" {
        return StreamBlock {
            block_type: "text",
            text: json.get_str(content_block, "text"),
            tool_id: "",
            tool_name: "",
            input_raw: "",
        }
    }
    if block_type == "tool_use" {
        let input_raw = json.get_str(json.get(content_block, "input"), "raw")
        return StreamBlock {
            block_type: "tool_use",
            text: "",
            tool_id: json.get_str(content_block, "id"),
            tool_name: json.get_str(content_block, "name"),
            input_raw: if input_raw == "" || input_raw == "{}" { "" } else { input_raw },
        }
    }
    return empty_stream_block()
}

fn stream_block_apply_delta(block: StreamBlock, delta: JsonHandle) -> StreamBlock {
    let delta_type = json.get_str(delta, "type")
    if delta_type == "text_delta" {
        return StreamBlock {
            block_type: block.block_type,
            text: str.concat(block.text, json.get_str(delta, "text")),
            tool_id: block.tool_id,
            tool_name: block.tool_name,
            input_raw: block.input_raw,
        }
    }
    if delta_type == "input_json_delta" {
        let partial_json = json.get_str(delta, "partial_json")
        let next_input_raw = if block.input_raw == "" || block.input_raw == "{}" { partial_json } else { str.concat(block.input_raw, partial_json) }
        return StreamBlock {
            block_type: block.block_type,
            text: block.text,
            tool_id: block.tool_id,
            tool_name: block.tool_name,
            input_raw: next_input_raw,
        }
    }
    return block
}

fn stream_block_json(block: StreamBlock) -> str {
    if block.block_type == "text" {
        return apputil.json_obj2("type", json.str("text"), "text", json.str(block.text))
    }
    if block.block_type == "tool_use" {
        let payload = map.new()
        discard map.set(payload, "type", json.str("tool_use"))
        discard map.set(payload, "id", json.str(block.tool_id))
        discard map.set(payload, "name", json.str(block.tool_name))
        discard map.set(payload, "input", apputil.json_value_or(block.input_raw, "{}"))
        return json.object(payload)
    }
    return ""
}

fn maybe_push_stream_block(items: ListHandle, block: StreamBlock) -> i32 {
    let encoded = stream_block_json(block)
    if encoded != "" {
        discard list.push(items, encoded)
    }
    return 0
}

fn streamed_response_json(stop_reason: str, block0: StreamBlock, block1: StreamBlock, block2: StreamBlock, block3: StreamBlock) -> str {
    let items = list.new()
    discard maybe_push_stream_block(items, block0)
    discard maybe_push_stream_block(items, block1)
    discard maybe_push_stream_block(items, block2)
    discard maybe_push_stream_block(items, block3)
    let payload = map.new()
    discard map.set(payload, "type", json.str("message"))
    discard map.set(payload, "role", json.str("assistant"))
    discard map.set(payload, "content", apputil.json_array_value(items))
    discard map.set(payload, "stop_reason", json.str(stop_reason))
    return json.object(payload)
}

fn empty_streamed_response_json() -> str {
    return streamed_response_json("", empty_stream_block(), empty_stream_block(), empty_stream_block(), empty_stream_block())
}

fn parsed_message_has_content(parsed: JsonHandle) -> i32 {
    if extract_text_block(parsed) != "" {
        return 1
    }
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        if content_block_type(parsed, str.from_i32(idx)) != "" {
            return 1
        }
        idx = idx + 1
    }
    return 0
}

fn tool_event_summary(parsed: JsonHandle) -> str {
    let tool_id = json.get_str(parsed, "tool")
    if tool_id == "bash" {
        let command = json.get_str(json.get(parsed, "input"), "command")
        if command != "" {
            if is_read_only_bash_command(command) == 1 {
                if str.contains(apputil.lower_ascii(command), "readme") == 1 {
                    return "bash:readme_inspect"
                }
                return "bash:read_only_inspect"
            }
            return "bash:command"
        }
        return "bash"
    }
    if tool_id == "grep_search" {
        let query = json.get_str(json.get(parsed, "input"), "query")
        if query != "" {
            return "grep_search:query"
        }
        return "grep_search"
    }
    if tool_id != "" {
        return tool_id
    }
    return tool_id
}

fn synthetic_assistant_summary(tool_events_json: str) -> str {
    let parsed = json.parse(tool_events_json)
    let mut action_count: i32 = 0
    let mut items = list.new()
    let mut idx: i32 = 0
    while idx < 16 {
        let event = json.get(parsed, str.from_i32(idx))
        let summary = tool_event_summary(event)
        let tool_id = json.get_str(event, "tool")
        let outcome_request = if json.get_str(event, "outcome_request_id") != "" {
            json.get_str(event, "outcome_request_id")
        } else {
            json.get_str(json.get(event, "outcome"), "request_id")
        }
        if summary == "" && tool_id == "" && outcome_request == "" {
            break
        }
        action_count = action_count + 1
        if summary != "" && list.len(items) < 5 {
            discard list.push(items, summary)
        }
        idx = idx + 1
    }
    let mut joined = ""
    let mut item_idx: i32 = 0
    while item_idx < list.len(items) {
        let part = list.get(items, item_idx)
        if joined == "" {
            joined = part
        } else {
            joined = str.concat(joined, str.concat(" | ", part))
        }
        item_idx = item_idx + 1
    }
    let mut detail = str.concat(str.from_i32(action_count), " tool actions completed")
    if joined != "" {
        let mut suffix = ""
        if action_count > list.len(items) {
            suffix = str.concat(" +", str.from_i32(action_count - list.len(items)))
        }
        detail = str.concat(str.concat(str.from_i32(action_count), " tool actions completed; recent_tools="), str.concat(joined, suffix))
    }
    return str.concat("tool_work_completed_without_final_message: ", str.concat(detail, "; synthesize findings now"))
}

fn planning_required_prompt(messages_json: str) -> i32 {
    if messages_json == "" {
        return 0
    }
    if str.contains(messages_json, "No durable plan exists yet for this goal.") == 1 {
        return 1
    }
    if str.contains(messages_json, "Your next control-plane action must be `plan_create`.") == 1 {
        return 1
    }
    return 0
}

fn planning_required_summary() -> str {
    return "planning_required_before_tool_use: create the durable plan with plan_create before non-control work"
}

fn automated_longrange_prompt(messages_json: str) -> i32 {
    if messages_json == "" {
        return 0
    }
    if str.contains(messages_json, "AUTOMATED LONG RANGE MESSAGE") == 1 {
        return 1
    }
    return 0
}

fn tool_definitions_for(messages_json: str) -> str {
    if planning_required_prompt(messages_json) == 1 {
        return services.registry.longrange_planning_tool_definitions_json()
    }
    if automated_longrange_prompt(messages_json) == 1 {
        return services.registry.longrange_execution_tool_definitions_json()
    }
    return services.registry.list_tool_definitions_json()
}

fn is_read_only_bash_command(command: str) -> i32 {
    let lowered = apputil.lower_ascii(command)
    if str.contains(lowered, "rm ") == 1 || str.contains(lowered, "mv ") == 1 || str.contains(lowered, "cp ") == 1 || str.contains(lowered, "touch ") == 1 || str.contains(lowered, "mkdir ") == 1 || str.contains(lowered, ">>") == 1 || str.contains(lowered, "> ") == 1 {
        return 0
    }
    if str.contains(lowered, "readme") == 1 || str.contains(lowered, "cat ") == 1 || str.contains(lowered, "head ") == 1 || str.contains(lowered, "wc ") == 1 || str.contains(lowered, "find ") == 1 {
        return 1
    }
    return 0
}

fn read_only_bash_saturation(tool_events_json: str) -> i32 {
    if tool_events_json == "" || tool_events_json == "[]" {
        return 0
    }
    let parsed = json.parse(tool_events_json)
    let mut idx: i32 = 0
    let mut seen: i32 = 0
    while idx < max_content_blocks() {
        let event = json.get(parsed, str.from_i32(idx))
        let tool_name = json.get_str(event, "tool")
        if tool_name == "" {
            break
        }
        if tool_name != "bash" {
            return 0
        }
        let command = json.get_str(json.get(event, "input"), "command")
        if is_read_only_bash_command(command) == 0 {
            return 0
        }
        seen = seen + 1
        idx = idx + 1
    }
    if seen > 0 {
        return 1
    }
    return 0
}

fn upstream_error_raw_response(payload: str, streamed_raw: str) -> str {
    return streamed_raw
}

fn final_response_raw_response(payload: str, streamed_raw: str) -> str {
    return streamed_raw
}

enum TurnResponseKind {
    TurnResponseOk,
    TurnResponseError,
}

fn turn_response_status(parsed: JsonHandle) -> TurnResponseKind {
    let status_text = json.get_str(parsed, "status")
    if status_text == "ok" {
        return TurnResponseKind::TurnResponseOk
    }
    let raw = json.get_str(parsed, "raw")
    if raw != "" && str.contains(raw, "\"status\":\"ok\"") == 1 {
        return TurnResponseKind::TurnResponseOk
    }
    return TurnResponseKind::TurnResponseError
}

fn turn_response_is_ok(parsed: JsonHandle) -> i32 {
    let kind = turn_response_status(parsed)
    match kind {
        TurnResponseKind::TurnResponseOk => return 1,
        _ => return 0,
    }
    return 0
}

fn turn_response_text_is_ok(raw: str) -> i32 {
    if raw != "" && str.contains(raw, "\"status\":\"ok\"") == 1 {
        return 1
    }
    return 0
}

fn turn_assistant_text(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "assistant")
}

fn turn_raw_response_text(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "raw_response")
}

fn turn_tool_events_raw(parsed: JsonHandle) -> str {
    let events = json.get_str(json.get(parsed, "tool_events"), "raw")
    if events == "" {
        return "[]"
    }
    return events
}

fn turn_error_json(message: str, raw_response: str, transport_error: str, tool_events_json: str, http_status: str) -> str {
    return model.types.turn_result_json(model.types.control_error_status(), services.provider.current_provider_name(), "", raw_response, "", tool_events_json, http_status, message, transport_error, "error", "", "")
}

fn turn_success_json(assistant_text: str, raw_response: str, stop_reason: str, tool_events_json: str, http_status: str, result_kind: str, control_tool: str, control_outcome: str) -> str {
    return model.types.turn_result_json(model.types.control_ok_status(), services.provider.current_provider_name(), assistant_text, raw_response, stop_reason, tool_events_json, http_status, "", "", result_kind, control_tool, control_outcome)
}

fn turn_success_default(assistant_text: str, raw_response: str, stop_reason: str, tool_events_json: str, http_status: str) -> str {
    return turn_success_json(assistant_text, raw_response, stop_reason, tool_events_json, http_status, "assistant", "", "")
}

fn run_tool_from_input(tool_id: str, input_raw: str, session_id: str, request_id: str) -> str {
    let normalized = apputil.json_obj4(
        "request_id", json.str(request_id),
        "tool_id", json.str(tool_id),
        "input", apputil.json_value_or(input_raw, "{}"),
        "session_id", json.str(session_id),
    )
    let tool_status = services.tools.dispatch_tool_request(tool_id, normalized)

    let result = services.tools.last_run_json(tool_id)
    let status = api.rpc.tool_result_status(tool_status)
    let run_id = services.tools.run_id_for_tool(tool_id)
    discard services.sessions.record_tool_run_for(session_id, tool_id, run_id, status)
    let response = api.rpc.tool_response_json(request_id, tool_id, run_id, tool_status, services.tools.last_run_artifact_path(tool_id), result)
    discard services.persistence.save_named_run(run_id, response)
    return response
}

fn compact_longrange_tool_result_content(result_raw: str) -> str {
    let tool = quoted_raw_field(result_raw, "tool")
    if is_longrange_control_tool(tool) == 0 {
        return ""
    }
    let status = quoted_raw_field(result_raw, "status")
    let message = quoted_raw_field(result_raw, "message")
    let guidance = quoted_raw_field(result_raw, "guidance")
    let next_step = quoted_raw_field(result_raw, "next_step")
    let payload = map.new()
    discard map.set(payload, "tool", json.str(tool))
    discard map.set(payload, "status", json.str(status))
    if message != "" {
        discard map.set(payload, "message", json.str(message))
    }
    if guidance != "" {
        discard map.set(payload, "guidance", json.str(guidance))
    }
    if next_step != "" {
        discard map.set(payload, "next_step", json.str(next_step))
    }
    return json.object(payload)
}

fn tool_result_content(outcome_json: str) -> str {
    let safe_outcome = if str.trim(outcome_json) == "" { missing_tool_outcome_json("") } else { outcome_json }
    let parsed = json.parse(safe_outcome)
    let result_raw = api.rpc.response_result_raw(parsed)
    let compact_control = compact_longrange_tool_result_content(result_raw)
    if compact_control != "" {
        if api.rpc.response_is_ok(parsed) == 1 {
            return compact_control
        }
        return str.concat("tool_error ", compact_control)
    }
    let compact_result = compact_tool_result_content(result_raw)
    if api.rpc.response_is_ok(parsed) == 1 {
        return compact_result
    }
    return str.concat("tool_error ", compact_result)
}

fn missing_tool_outcome_json(tool_id: str) -> str {
    return apputil.json_obj3(
        "status", json.str("error"),
        "tool", json.str(tool_id),
        "message", json.str("tool artifact payload was empty"),
    )
}

fn tool_result_content_limit() -> i32 {
    return 2400
}

fn compact_tool_result_content(raw: str) -> str {
    if raw == "" {
        return ""
    }
    if str.len(raw) <= tool_result_content_limit() {
        return raw
    }
    let head = apputil.excerpt_head(raw, 1400)
    let tail = apputil.excerpt_tail(raw, 600)
    return apputil.json_obj4(
        "status", json.str("truncated"),
        "raw_chars", json.str(str.from_i32(str.len(raw))),
        "head", json.str(head),
        "tail", json.str(tail),
    )
}

fn tool_result_block_json(tool_use_id: str, outcome_json: str) -> str {
    let parsed = json.parse(outcome_json)
    let is_error = if api.rpc.response_is_ok(parsed) == 1 { "false" } else { "true" }
    return apputil.json_obj4(
        "type", json.str("tool_result"),
        "tool_use_id", json.str(tool_use_id),
        "content", json.str(tool_result_content(outcome_json)),
        "is_error", apputil.json_value_or(is_error, "false"),
    )
}

fn compact_tool_event_outcome_json(tool_id: str, outcome_json: str) -> str {
    let safe_outcome = if str.trim(outcome_json) == "" { missing_tool_outcome_json(tool_id) } else { outcome_json }
    let parsed = json.parse(safe_outcome)
    let result_raw = api.rpc.response_result_raw(parsed)
    let artifact_path = json.get_str(parsed, "artifact_path")
    let request_id = json.get_str(parsed, "request_id")
    let run_id = json.get_str(parsed, "run_id")
    let payload = map.new()
    discard map.set(payload, "request_id", json.str(request_id))
    discard map.set(payload, "status", json.str(api.rpc.response_status_text(parsed)))
    if run_id != "" {
        discard map.set(payload, "run_id", json.str(run_id))
    }
    if artifact_path != "" {
        discard map.set(payload, "artifact_path", json.str(artifact_path))
    }
    if result_raw != "" {
        discard map.set(payload, "result_excerpt", json.str(apputil.excerpt_head(tool_result_content(safe_outcome), 320)))
    }
    return json.object(payload)
}

fn tool_event_json(tool_id: str, tool_use_id: str, input_raw: str, outcome_json: str) -> str {
    let safe_input = if input_raw == "" { "{}" } else { input_raw }
    let safe_outcome = if str.trim(outcome_json) == "" { missing_tool_outcome_json(tool_id) } else { outcome_json }
    let parsed_outcome = json.parse(safe_outcome)
    let compact_outcome = json.parse(compact_tool_event_outcome_json(tool_id, safe_outcome))
    let mut payload = "{"
    payload = str.concat(payload, str.concat("\"tool\":", json.str(tool_id)))
    payload = str.concat(payload, str.concat(",\"tool_use_id\":", json.str(tool_use_id)))
    payload = str.concat(payload, str.concat(",\"input\":", apputil.json_value_or(safe_input, "{}")))
    payload = str.concat(payload, str.concat(",\"outcome_status\":", json.str(api.rpc.response_status_text(parsed_outcome))))
    let outcome_request_id = json.get_str(compact_outcome, "request_id")
    if outcome_request_id != "" {
        payload = str.concat(payload, str.concat(",\"outcome_request_id\":", json.str(outcome_request_id)))
    }
    let outcome_run_id = json.get_str(compact_outcome, "run_id")
    if outcome_run_id != "" {
        payload = str.concat(payload, str.concat(",\"outcome_run_id\":", json.str(outcome_run_id)))
    }
    let artifact_path = json.get_str(compact_outcome, "artifact_path")
    if artifact_path != "" {
        payload = str.concat(payload, str.concat(",\"artifact_path\":", json.str(artifact_path)))
    }
    let result_excerpt = json.get_str(compact_outcome, "result_excerpt")
    if result_excerpt != "" {
        payload = str.concat(payload, str.concat(",\"result_excerpt\":", json.str(result_excerpt)))
    }
    return str.concat(payload, "}")
}

fn maybe_push_tool_result(items: ListHandle, events: ListHandle, parsed: JsonHandle, index: str, session_id: str, request_id: str, stream_mode: i32) -> i32 {
    if content_block_type(parsed, index) != "tool_use" {
        return 0
    }
    let name = content_block_tool_name(parsed, index)
    let tool_use_id = content_block_tool_id(parsed, index)
    let input_raw = content_block_tool_input_raw(parsed, index)
    let outcome = run_tool_from_input(name, input_raw, session_id, request_id)
    if stream_mode == 1 {
        let outcome_parsed = json.parse(outcome)
        discard cli.render.print_tool_call(name, if input_raw == "" { "{}" } else { input_raw })
        discard cli.render.print_tool_result(name, api.rpc.response_status_text(outcome_parsed), api.rpc.response_result_raw(outcome_parsed))
    }
    discard list.push(items, tool_result_block_json(tool_use_id, outcome))
    discard list.push(events, tool_event_json(name, tool_use_id, input_raw, outcome))
    return 1
}

fn collect_tool_results_and_events(tool_results: ListHandle, tool_events: ListHandle, parsed: JsonHandle, session_id: str, request_id: str, stream_mode: i32) -> i32 {
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        discard maybe_push_tool_result(tool_results, tool_events, parsed, str.from_i32(idx), session_id, request_id, stream_mode)
        idx = idx + 1
    }
    if list.len(tool_events) == 0 {
        discard collect_tool_results_from_raw_content(tool_results, tool_events, parsed, session_id, request_id, stream_mode)
    }
    return 0
}

fn raw_tool_use_block(content_json: str) -> str {
    let marker = "\"type\":\"tool_use\""
    let marker_idx = text_index_of(content_json, marker)
    if marker_idx < 0 {
        return ""
    }
    let mut start = marker_idx
    while start > 0 {
        let probe = str.slice(content_json, start, start + 1)
        if probe == "{" {
            return extract_balanced_json(content_json, start)
        }
        start = start - 1
    }
    return ""
}

fn raw_tool_input(block_raw: str) -> str {
    let marker = "\"input\":"
    let start = text_index_of(block_raw, marker)
    if start < 0 {
        return ""
    }
    let mut idx: i32 = start + str.len(marker)
    while idx < str.len(block_raw) {
        let ch = str.slice(block_raw, idx, idx + 1)
        if ch == "{" || ch == "[" {
            return extract_balanced_json(block_raw, idx)
        }
        idx = idx + 1
    }
    return ""
}

fn collect_tool_results_from_raw_content(tool_results: ListHandle, tool_events: ListHandle, parsed: JsonHandle, session_id: str, request_id: str, stream_mode: i32) -> i32 {
    let raw = content_raw(parsed)
    if raw == "" {
        return 0
    }
    let content = json.parse(raw)
    let mut idx: i32 = 0
    while idx < max_content_blocks() {
        let block = json.get(content, str.from_i32(idx))
        if json.get_str(block, "type") == "tool_use" {
            let name = json.get_str(block, "name")
            let tool_use_id = json.get_str(block, "id")
            let input_raw = apputil.json_nested_field_or_empty(block, "input")
            if name == "" || tool_use_id == "" {
                return 0
            }
            let outcome = run_tool_from_input(name, input_raw, session_id, request_id)
            if stream_mode == 1 {
                let outcome_parsed = json.parse(outcome)
                discard cli.render.print_tool_call(name, if input_raw == "" { "{}" } else { input_raw })
                discard cli.render.print_tool_result(name, api.rpc.response_status_text(outcome_parsed), api.rpc.response_result_raw(outcome_parsed))
            }
            discard list.push(tool_results, tool_result_block_json(tool_use_id, outcome))
            discard list.push(tool_events, tool_event_json(name, tool_use_id, input_raw, outcome))
            return 1
        }
        idx = idx + 1
    }
    return 0
}

fn run_session_turn_loop(session_id: str, request_id: str, messages_json: str, depth: i32, accumulated_events_json: str, stream_mode: i32, system_prompt: str) -> str {
    let payload = messages_json
    let tool_defs = tool_definitions_for(messages_json)
    write_debug(str.concat("messages_", str.concat(request_id, str.concat("_", str.concat(str.from_i32(depth), ".json")))), messages_json)
    write_debug(str.concat("tools_", str.concat(request_id, str.concat("_", str.concat(str.from_i32(depth), ".json")))), tool_defs)
    log.info(
        "runtime.agent turn request",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "depth", str.from_i32(depth))
    )
    let raw = services.provider.request_messages_sync(messages_json, tool_defs, system_prompt)
    let status = services.provider.last_status()
    write_debug(str.concat("raw_response_", str.from_i32(depth), ".json"), raw)
    log.info(
        "runtime.agent turn response",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "status", str.from_i32(status))
    )
    if status < 200 || status >= 300 {
        let error_message = if raw == "" && services.provider.last_error() == "" { "provider_request_failed_before_response" } else { "" }
        let upstream_raw = upstream_error_raw_response(payload, raw)
        let transport_error = if raw == "" { services.provider.last_error() } else { raw }
        log.warn(
            "runtime.agent upstream error",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "transport_error", apputil.excerpt_head(transport_error, 220))
        )
        return turn_error_json(error_message, upstream_raw, transport_error, accumulated_events_json, str.from_i32(status))
    }

    let parsed = json.parse(raw)
    if json.get_str(parsed, "status") == "error" {
        log.warn(
            "runtime.agent provider status error",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "error", apputil.excerpt_head(json.get_str(parsed, "error"), 220))
        )
        return turn_error_json("", raw, json.get_str(parsed, "error"), accumulated_events_json, str.from_i32(status))
    }
    let stop_reason = json.get_str(parsed, "stop_reason")
    log.info(
        "runtime.agent parsed response",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "stop_reason", stop_reason)
    )
    if stop_reason != "tool_use" {
        let final_raw = final_response_raw_response(payload, raw)
        let final_parsed = json.parse(final_raw)
        if parsed_message_has_content(final_parsed) == 0 {
            if accumulated_events_json != "[]" {
                let synthetic = synthetic_assistant_summary(accumulated_events_json)
                log.warn(
                    "runtime.agent synthetic fallback",
                    apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", apputil.excerpt_head(synthetic, 220))
                )
                discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
                return turn_success_json(synthetic, final_raw, json.get_str(final_parsed, "stop_reason"), accumulated_events_json, str.from_i32(status), "synthetic_assistant", "", "")
            }
            log.warn(
                "runtime.agent empty assistant",
                apputil.log_fields3("session_id", session_id, "request_id", request_id, "stop_reason", json.get_str(final_parsed, "stop_reason"))
            )
            return turn_error_json("empty_assistant_response", final_raw, "", accumulated_events_json, str.from_i32(status))
        }
        let response_text = extract_text_block(final_parsed)
        let assistant_text = if response_text == "" { final_raw } else { response_text }
        log.info(
            "runtime.agent assistant text",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "excerpt", apputil.excerpt_head(assistant_text, 220))
        )
        discard services.sessions.record_assistant_for(session_id, assistant_text, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_default(assistant_text, final_raw, json.get_str(final_parsed, "stop_reason"), accumulated_events_json, str.from_i32(status))
    }

    let tool_results = list.new()
    let tool_events = list.new()
    discard collect_tool_results_and_events(tool_results, tool_events, parsed, session_id, request_id, stream_mode)
    let tool_events_array = json.array(tool_events)
    write_debug("tool_events.json", tool_events_array)
    log.info(
        "runtime.agent tool results",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "tool_events", apputil.excerpt_head(tool_events_array, 220))
    )
    let control_summary = successful_control_tool_summary(tool_events_array)
    if planning_required_prompt(messages_json) == 1 && control_summary == "" {
        let synthetic = planning_required_summary()
        log.warn(
            "runtime.agent planning contract",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", synthetic)
        )
        discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_json(synthetic, raw, "planning_contract", tool_events_array, str.from_i32(status), "planning_required", "", "")
    }
    if depth >= 1 && read_only_bash_saturation(tool_events_array) == 1 {
        let synthetic = synthetic_assistant_summary(tool_events_array)
        log.warn(
            "runtime.agent read-only saturation",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", apputil.excerpt_head(synthetic, 220))
        )
        discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_json(synthetic, raw, "tool_read_saturation", tool_events_array, str.from_i32(status), "tool_read_saturation", "", "")
    }
    log.info(
        "runtime.agent control summary",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "control_summary", control_summary)
    )
    if control_summary == "" && depth == 0 && has_longrange_start_event(tool_events_array) == 1 && services.longrange.active_run_id_for_session(session_id) != "" {
        let synthetic = synthetic_assistant_summary(tool_events_array)
        log.warn(
            "runtime.agent longrange start handoff",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", apputil.excerpt_head(synthetic, 220))
        )
        discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_json(synthetic, raw, "tool_use", tool_events_array, str.from_i32(status), "tool_handoff", "longrange_start", "ok")
    }
    if control_summary != "" {
        return turn_success_json(control_summary, raw, "tool_use", tool_events_array, str.from_i32(status), "control_tool", first_control_tool_name(tool_events_array), first_control_tool_outcome(tool_events_array))
    }
    if automated_longrange_prompt(messages_json) == 1 {
        let synthetic = synthetic_assistant_summary(tool_events_array)
        log.info(
            "runtime.agent automated longrange handoff",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", apputil.excerpt_head(synthetic, 220))
        )
        discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_json(synthetic, raw, "tool_use", tool_events_array, str.from_i32(status), "tool_handoff", "", "")
    }
    let next_events = append_array_json(accumulated_events_json, tool_events_array)
    let assistant_message = assistant_message_json(parsed)
    write_debug("assistant_message.json", assistant_message)
    let tool_results_array = json.array(tool_results)
    write_debug("tool_results.json", tool_results_array)
    let tool_result_message = apputil.json_obj2("role", json.str("user"), "content", apputil.json_value_or(tool_results_array, "[]"))
    write_debug("tool_result_message.json", tool_result_message)
    let next_messages = append_message_json(append_message_json(messages_json, assistant_message), tool_result_message)
    write_debug("next_messages.json", next_messages)
    if depth + 1 >= max_recursive_tool_depth() {
        let synthetic = synthetic_assistant_summary(next_events)
        log.warn(
            "runtime.agent tool depth limit",
            apputil.log_fields3("session_id", session_id, "request_id", request_id, "summary", apputil.excerpt_head(synthetic, 220))
        )
        discard services.sessions.record_assistant_for(session_id, synthetic, request_id, services.provider.latest_model_label(), str.from_i32(depth))
        return turn_success_json(synthetic, raw, "tool_depth_limit", next_events, str.from_i32(status), "tool_depth_limit", "", "")
    }
    log.info(
        "runtime.agent recurse",
        apputil.log_fields3("session_id", session_id, "request_id", request_id, "next_depth", str.from_i32(depth + 1))
    )
    return run_session_turn_loop(session_id, request_id, next_messages, depth + 1, next_events, stream_mode, system_prompt)
}

fn run_session_turn(session_id: str, prompt: str, request_id: str) -> str {
    let messages_json = initial_messages_json(session_id, prompt)
    return run_session_turn_loop(session_id, request_id, messages_json, 0, "[]", 0, load_system_prompt_for(prompt))
}

fn direct_prompt_messages_json(prompt: str) -> str {
    let message = apputil.json_obj2("role", json.str("user"), "content", json.str(prompt))
    let items = list.new()
    discard list.push(items, message)
    return json.array(items)
}

fn run_automated_longrange_turn(session_id: str, prompt: str, request_id: str) -> str {
    return run_session_turn_loop(session_id, request_id, direct_prompt_messages_json(prompt), 0, "[]", 0, load_system_prompt_for(prompt))
}

fn run_session_turn_streamed(session_id: str, prompt: str, request_id: str) -> str {
    let messages_json = initial_messages_json(session_id, prompt)
    return run_session_turn_loop(session_id, request_id, messages_json, 0, "[]", 1, load_system_prompt_for(prompt))
}

fn run_loop() -> i32 {
    log.info("runtime.agent started", apputil.log_fields2("component", "runtime.agent", "phase", "loop_start"))
    loop {
        turn_begin()
        checkpoint()
        yield()
    }
}

fn turn_begin() -> i32 {
    checkpoint()
    return 0
}

fn dispatch_parallel_tools() -> i32 {
    log.info("runtime.agent dispatching tools", apputil.log_fields2("component", "runtime.agent", "phase", "dispatch_parallel_tools"))
    services.tools.run_parallel()
    checkpoint()
    return 0
}

fn turn_finalize() -> i32 {
    runtime.events.emit_tool_finished()
    yield()
    return 0
}
