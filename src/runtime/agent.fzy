use core.fs;
use core.thread;
use core.log;

fn system_prompt_path() -> str {
    return "/Users/deepsaint/Desktop/fzyagent/config/agent_system_prompt.md"
}

fn max_agent_iterations() -> i32 {
    return 4
}

fn debug_dir() -> str {
    return "/tmp/fzyagent/agent.debug"
}

fn debug_path(name: str) -> str {
    return str.concat(debug_dir(), str.concat("/", name))
}

fn write_debug(name: str, payload: str) -> i32 {
    if runtime.config.persist_request_artifacts() == 0 {
        return 0
    }
    fs.mkdir(debug_dir())
    fs.write_file(debug_path(name), payload)
    return 0
}

fn load_system_prompt() -> str {
    if fs.exists(system_prompt_path()) == 0 {
        return "You are the fzyagent runtime. Be concise, grounded, and tool-aware."
    }
    let text = fs.read_file(system_prompt_path())
    if text == "" {
        return "You are the fzyagent runtime. Be concise, grounded, and tool-aware."
    }
    return text
}

fn transcript_context(session_id: str) -> str {
    let excerpt = services.sessions.transcript_excerpt(session_id)
    if excerpt == "" {
        return "No prior conversation turns are recorded for this session yet."
    }
    return excerpt
}

fn build_turn_prompt(session_id: str, prompt: str) -> str {
    let system_prompt = load_system_prompt()
    let transcript = transcript_context(session_id)
    return str.concat(
        "SYSTEM PROMPT\n",
        system_prompt,
        "\n\nSESSION TRANSCRIPT\n",
        transcript,
        "\n\nLATEST USER MESSAGE\n",
        prompt,
    )
}

fn initial_messages_json(session_id: str, prompt: str) -> str {
    let message = util.json_obj2("role", json.str("user"), "content", json.str(build_turn_prompt(session_id, prompt)))
    let items = list.new()
    discard list.push(items, message)
    return json.array(items)
}

fn append_message_json(messages_json: str, message_json: str) -> str {
    if messages_json == "[]" {
        let items = list.new()
        discard list.push(items, message_json)
        return json.array(items)
    }
    let prefix = str.slice(messages_json, 0, str.len(messages_json) - 1)
    return str.concat(str.concat(str.concat(prefix, ","), message_json), "]")
}

fn append_array_json(left_json: str, right_json: str) -> str {
    if left_json == "[]" {
        return right_json
    }
    if right_json == "[]" {
        return left_json
    }
    let left_prefix = str.slice(left_json, 0, str.len(left_json) - 1)
    let right_tail = str.slice(right_json, 1, str.len(right_json))
    return str.concat(str.concat(left_prefix, ","), right_tail)
}

fn content_block(parsed: JsonHandle, index: str) -> JsonHandle {
    let content = json.get(parsed, "content")
    return json.get(content, index)
}

fn content_block_type(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "type")
}

fn content_block_text(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "text")
}

fn content_block_tool_name(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "name")
}

fn content_block_tool_id(parsed: JsonHandle, index: str) -> str {
    return json.get_str(content_block(parsed, index), "id")
}

fn content_block_tool_input_raw(parsed: JsonHandle, index: str) -> str {
    let input = json.get(content_block(parsed, index), "input")
    return json.get_str(input, "raw")
}

fn content_block_json(parsed: JsonHandle, index: str) -> str {
    let block_type = content_block_type(parsed, index)
    if block_type == "text" {
        return util.json_obj2("type", json.str("text"), "text", json.str(content_block_text(parsed, index)))
    }
    if block_type == "tool_use" {
        let payload = map.new()
        discard map.set(payload, "type", json.str("tool_use"))
        discard map.set(payload, "id", json.str(content_block_tool_id(parsed, index)))
        discard map.set(payload, "name", json.str(content_block_tool_name(parsed, index)))
        discard map.set(payload, "input", json.raw(content_block_tool_input_raw(parsed, index)))
        return json.object(payload)
    }
    return ""
}

fn maybe_push_content_block(items: ListHandle, parsed: JsonHandle, index: str) -> i32 {
    let block = content_block_json(parsed, index)
    if block != "" {
        discard list.push(items, block)
    }
    return 0
}

fn assistant_message_json(parsed: JsonHandle) -> str {
    let items = list.new()
    discard maybe_push_content_block(items, parsed, "0")
    discard maybe_push_content_block(items, parsed, "1")
    discard maybe_push_content_block(items, parsed, "2")
    discard maybe_push_content_block(items, parsed, "3")
    return util.json_obj2("role", json.str("assistant"), "content", json.raw(json.array(items)))
}

fn content_block_text_or_empty(parsed: JsonHandle, index: str) -> str {
    if content_block_type(parsed, index) != "text" {
        return ""
    }
    return content_block_text(parsed, index)
}

fn extract_text_block(parsed: JsonHandle) -> str {
    let text0 = content_block_text_or_empty(parsed, "0")
    if text0 != "" {
        return text0
    }
    let text1 = content_block_text_or_empty(parsed, "1")
    if text1 != "" {
        return text1
    }
    let text2 = content_block_text_or_empty(parsed, "2")
    if text2 != "" {
        return text2
    }
    let text3 = content_block_text_or_empty(parsed, "3")
    if text3 != "" {
        return text3
    }
    return json.get_str(parsed, "completion")
}

fn request_payload_for(messages_json: str, tools_json: str) -> str {
    let payload = map.new()
    discard map.set(payload, "model", json.str(services.anthropic.default_model_name()))
    discard map.set(payload, "system", json.str(load_system_prompt()))
    discard map.set(payload, "max_tokens", json.raw("600"))
    discard map.set(payload, "messages", json.raw(messages_json))
    discard map.set(payload, "tools", json.raw(tools_json))
    return json.object(payload)
}

enum TurnResponseKind {
    TurnResponseOk,
    TurnResponseError,
}

fn turn_response_status(parsed: JsonHandle) -> TurnResponseKind {
    if json.get_str(parsed, "status") == "ok" {
        return TurnResponseKind::TurnResponseOk
    }
    return TurnResponseKind::TurnResponseError
}

fn turn_response_is_ok(parsed: JsonHandle) -> i32 {
    let kind = turn_response_status(parsed)
    match kind {
        TurnResponseKind::TurnResponseOk => return 1,
        _ => return 0,
    }
    return 0
}

fn turn_assistant_text(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "assistant")
}

fn turn_raw_response_text(parsed: JsonHandle) -> str {
    return json.get_str(parsed, "raw_response")
}

fn turn_tool_events_raw(parsed: JsonHandle) -> str {
    let events = json.get_str(json.get(parsed, "tool_events"), "raw")
    if events == "" {
        return "[]"
    }
    return events
}

fn turn_error_json(message: str, raw_response: str, transport_error: str, tool_events_json: str, http_status: str) -> str {
    return model.types.turn_result_json(model.types.ControlStatus::ControlError, "anthropic", "", raw_response, "", tool_events_json, http_status, message, transport_error)
}

fn turn_success_json(assistant_text: str, raw_response: str, stop_reason: str, tool_events_json: str, http_status: str) -> str {
    return model.types.turn_result_json(model.types.ControlStatus::ControlOk, "anthropic", assistant_text, raw_response, stop_reason, tool_events_json, http_status, "", "")
}

fn run_tool_from_input(tool_id: str, input_raw: str, session_id: str, request_id: str) -> str {
    let normalized = api.rpc.single_request_json(request_id, tool_id, if input_raw == "" { "{}" } else { input_raw })
    let tool_status = services.tools.dispatch_tool_request(tool_id, normalized)

    let result = services.tools.last_run_json(tool_id)
    let status = api.rpc.tool_result_status(tool_status)
    let run_id = services.tools.run_id_for_tool(tool_id)
    discard services.sessions.record_tool_run_for(session_id, tool_id, run_id, status)
    let response = api.rpc.tool_response_json(request_id, tool_id, run_id, tool_status, services.tools.last_run_artifact_path(tool_id), result)
    discard services.persistence.save_named_run(run_id, response)
    return response
}

fn tool_result_content(outcome_json: str) -> str {
    let parsed = json.parse(outcome_json)
    let result_raw = api.rpc.response_result_raw(parsed)
    if api.rpc.response_is_ok(parsed) == 1 {
        return result_raw
    }
    return str.concat("tool_error ", result_raw)
}

fn tool_result_block_json(tool_use_id: str, outcome_json: str) -> str {
    let parsed = json.parse(outcome_json)
    let is_error = if api.rpc.response_is_ok(parsed) == 1 { "false" } else { "true" }
    let block = map.new()
    discard map.set(block, "type", json.str("tool_result"))
    discard map.set(block, "tool_use_id", json.str(tool_use_id))
    discard map.set(block, "content", json.str(tool_result_content(outcome_json)))
    discard map.set(block, "is_error", json.raw(is_error))
    return json.object(block)
}

fn tool_event_json(tool_id: str, tool_use_id: str, input_raw: str, outcome_json: str) -> str {
    let event = map.new()
    let safe_input = if input_raw == "" { "{}" } else { input_raw }
    discard map.set(event, "tool", json.str(tool_id))
    discard map.set(event, "tool_use_id", json.str(tool_use_id))
    discard map.set(event, "input", json.raw(safe_input))
    discard map.set(event, "outcome", json.raw(outcome_json))
    return json.object(event)
}

fn maybe_push_tool_result(items: ListHandle, events: ListHandle, parsed: JsonHandle, index: str, session_id: str, request_id: str) -> i32 {
    if content_block_type(parsed, index) != "tool_use" {
        return 0
    }
    let name = content_block_tool_name(parsed, index)
    let tool_use_id = content_block_tool_id(parsed, index)
    let input_raw = content_block_tool_input_raw(parsed, index)
    let outcome = run_tool_from_input(name, input_raw, session_id, request_id)
    discard list.push(items, tool_result_block_json(tool_use_id, outcome))
    discard list.push(events, tool_event_json(name, tool_use_id, input_raw, outcome))
    return 1
}

fn build_tool_result_bundle(parsed: JsonHandle, session_id: str, request_id: str) -> str {
    let tool_results = list.new()
    let tool_events = list.new()
    discard maybe_push_tool_result(tool_results, tool_events, parsed, "0", session_id, request_id)
    discard maybe_push_tool_result(tool_results, tool_events, parsed, "1", session_id, request_id)
    discard maybe_push_tool_result(tool_results, tool_events, parsed, "2", session_id, request_id)
    discard maybe_push_tool_result(tool_results, tool_events, parsed, "3", session_id, request_id)
    let payload = map.new()
    let tool_results_json = json.array(tool_results)
    let tool_events_json = json.array(tool_events)
    write_debug("tool_results.json", tool_results_json)
    write_debug("tool_events.json", tool_events_json)
    discard map.set(payload, "tool_results", json.raw(tool_results_json))
    discard map.set(payload, "tool_events", json.raw(tool_events_json))
    return json.object(payload)
}

fn run_session_turn_loop(session_id: str, request_id: str, messages_json: str, depth: i32, accumulated_events_json: str) -> str {
    if depth >= max_agent_iterations() {
        return turn_error_json("tool_loop_exhausted", "", "", accumulated_events_json, "")
    }

    let payload = request_payload_for(messages_json, services.registry.list_tool_definitions_json())
    let raw = services.anthropic.request_messages_sync(payload)
    write_debug(str.concat("raw_response_", str.from_i32(depth), ".json"), raw)
    let status = services.anthropic.last_status()
    if status < 200 || status >= 300 {
        return turn_error_json("", raw, services.anthropic.last_error(), accumulated_events_json, str.from_i32(status))
    }

    let parsed = json.parse(raw)
    let stop_reason = json.get_str(parsed, "stop_reason")
    if stop_reason != "tool_use" {
        let response_text = extract_text_block(parsed)
        let assistant_text = if response_text == "" { raw } else { response_text }
        discard services.sessions.record_assistant_for(session_id, assistant_text, request_id, "anthropic_latest", str.from_i32(depth))
        return turn_success_json(assistant_text, raw, stop_reason, accumulated_events_json, str.from_i32(status))
    }

    let assistant_message = assistant_message_json(parsed)
    write_debug("assistant_message.json", assistant_message)
    let tool_bundle = build_tool_result_bundle(parsed, session_id, request_id)
    let bundle_parsed = json.parse(tool_bundle)
    let tool_results_array = json.get_str(json.get(bundle_parsed, "tool_results"), "raw")
    let tool_events_array = json.get_str(json.get(bundle_parsed, "tool_events"), "raw")
    let tool_result_message = util.json_obj2("role", json.str("user"), "content", json.raw(tool_results_array))
    write_debug("tool_result_message.json", tool_result_message)
    let next_messages = append_message_json(append_message_json(messages_json, assistant_message), tool_result_message)
    write_debug("next_messages.json", next_messages)
    let next_events = append_array_json(accumulated_events_json, tool_events_array)
    return run_session_turn_loop(session_id, request_id, next_messages, depth + 1, next_events)
}

fn run_session_turn(session_id: str, prompt: str, request_id: str) -> str {
    let messages_json = initial_messages_json(session_id, prompt)
    return run_session_turn_loop(session_id, request_id, messages_json, 0, "[]")
}

fn run_loop() -> i32 {
    log.info("runtime.agent started", util.log_fields2("component", "runtime.agent", "phase", "loop_start"))
    loop {
        turn_begin()
        checkpoint()
        yield()
    }
}

fn turn_begin() -> i32 {
    checkpoint()
    return 0
}

fn dispatch_parallel_tools() -> i32 {
    log.info("runtime.agent dispatching tools", util.log_fields2("component", "runtime.agent", "phase", "dispatch_parallel_tools"))
    services.tools.run_parallel()
    checkpoint()
    return 0
}

fn turn_finalize() -> i32 {
    runtime.events.emit_tool_finished()
    yield()
    return 0
}
