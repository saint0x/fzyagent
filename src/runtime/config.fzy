use core.fs;

fn env_or(key: str, fallback: str) -> str {
    let value = env.get(key)
    if value == "" {
        return fallback
    }
    return value
}

fn config_path() -> str {
    return "/tmp/fzyagent/runtime.config.json"
}

fn background_mode() -> str {
    return env_or("AGENT_BACKGROUND_MODE", "http")
}

fn observability_mode() -> str {
    return env_or("AGENT_OBSERVABILITY_MODE", "minimal")
}

fn enable_agent_loop() -> i32 {
    if background_mode() == "agent" {
        return 1
    }
    return 0
}

fn enable_background_runtime() -> i32 {
    if background_mode() == "agent" {
        return 1
    }
    return 0
}

fn persist_request_artifacts() -> i32 {
    if observability_mode() == "verbose" {
        return 1
    }
    return 0
}

fn persist_runtime_events() -> i32 {
    if observability_mode() == "verbose" {
        return 1
    }
    return 0
}

fn apply_server_config() -> i32 {
    fs.mkdir("/tmp/fzyagent")
    let host = env_or("AGENT_HOST", "127.0.0.1")
    let port = env_or("AGENT_PORT", "8787")
    let workers = env_or("AGENT_WORKERS", "4")
    let payload = util.json_obj5(
        "host", json.str(host),
        "port", json.str(port),
        "workers", json.str(workers),
        "background_mode", json.str(background_mode()),
        "observability_mode", json.str(observability_mode()),
    )
    fs.write_file(config_path(), payload)
    return 0
}

fn load_host() -> i32 {
    env.get("AGENT_HOST")
    return 0
}

fn load_port() -> i32 {
    env.get("AGENT_PORT")
    return 0
}

fn load_workers() -> i32 {
    env.get("AGENT_WORKERS")
    return 0
}
