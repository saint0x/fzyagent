use core.fs;

fn limits_path() -> str {
    return runtime.config.state_path("runtime.limits.json")
}

fn env_or(key: str, fallback: str) -> str {
    let value = env.get(key)
    if value == "" {
        return fallback
    }
    return value
}

fn thread_limit() -> str {
    return env_or("AGENT_THREAD_LIMIT", "64")
}

fn queue_limit() -> str {
    return env_or("AGENT_QUEUE_LIMIT", "256")
}

fn memory_limit() -> str {
    return env_or("AGENT_MEMORY_LIMIT", "536870912")
}

fn limits_json() -> str {
    return model.types.runtime_limits_json(thread_limit(), queue_limit(), memory_limit(), "configured")
}

fn apply_limits() -> i32 {
    runtime.config.ensure_state_root()
    fs.write_file(limits_path(), limits_json())
    return 0
}

fn enforce_thread_limit() -> i32 {
    return apply_limits()
}

fn enforce_queue_depth() -> i32 {
    return apply_limits()
}

fn enforce_memory_budget() -> i32 {
    return apply_limits()
}
