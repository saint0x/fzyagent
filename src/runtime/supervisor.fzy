use core.fs;
use core.log;

fn shutdown_signal_path() -> str {
    return runtime.config.state_path("shutdown.signal")
}

fn supervisor_path() -> str {
    return runtime.config.state_path("runtime.supervisor.json")
}

fn supervisor_state_path() -> str {
    return supervisor_path()
}

fn supervisor_state_json(phase: str, shutdown: str) -> str {
    return model.types.supervisor_state_payload_json(
        model.types.control_ok_label(),
        phase,
        shutdown,
        runtime.limits.limits_json(),
        fs.read_file(runtime.sandbox.sandbox_path()),
        services.tools.queue_summary_json(),
        services.longrange.summary_json(),
    )
}

fn refresh_state() -> i32 {
    let phase = if shutdown_requested() == 1 { model.types.supervisor_shutdown_label() } else { model.types.supervisor_running_label() }
    let shutdown = if shutdown_requested() == 1 { "true" } else { "false" }
    fs.write_file(supervisor_path(), supervisor_state_json(phase, shutdown))
    return 0
}

fn configure_limits() -> i32 {
    log.info("runtime.supervisor configure_limits", apputil.log_fields2("component", "runtime.supervisor", "phase", "configure_limits"))
    runtime.config.ensure_state_root()
    if fs.exists(shutdown_signal_path()) == 1 {
        discard fs.remove_file(shutdown_signal_path())
    }
    runtime.limits.apply_limits()
    runtime.sandbox.apply_default_policy()
    runtime.sandbox.allow_tool_scope()
    fs.write_file(supervisor_path(), supervisor_state_json(model.types.supervisor_configured_label(), "false"))
    return 0
}

fn begin_shutdown() -> i32 {
    runtime.config.ensure_state_root()
    fs.write_file(shutdown_signal_path(), "requested")
    runtime.sandbox.deny_tool_scope()
    services.http.graceful_stop()
    runtime.recovery.recover_inflight_jobs()
    fs.write_file(supervisor_path(), supervisor_state_json(model.types.supervisor_shutdown_label(), "true"))
    return 0
}

fn shutdown_requested() -> i32 {
    if fs.exists(shutdown_signal_path()) == 1 {
        return 1
    }
    return 0
}

fn run_forever() -> i32 {
    log.info("runtime.supervisor started", apputil.log_fields2("component", "runtime.supervisor", "phase", "loop_start"))
    loop {
        runtime.events.emit_health_tick()
        discard refresh_state()
        checkpoint()
    }
}
