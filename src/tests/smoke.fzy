use core.thread;

fn lang_id(v: i32) -> i32 {
    return v;
}

trait LangScore {
    fn score(v: i32) -> i32;
}

trait LangCode {
    fn code(v: i32) -> i32;
}

struct LangProbe {
    value: i32,
}

impl LangScore for LangProbe {
    fn score(v: i32) -> i32 {
        return v + 1;
    }
}

impl LangCode for LangProbe {
    fn code(v: i32) -> i32 {
        return v + 2;
    }
}

fn lang_keep<T: LangScore + LangCode>(v: T) -> T {
    return v;
}

fn lang_passthrough(v: i32) -> i32 {
    return v;
}

fn lang_apply(cb: fn(i32) -> i32, value: i32) -> i32 {
    discard cb;
    return lang_id(value);
}

fn next_surface_counter() -> i32 {
    return 1;
}

test "det_boot" {
    model.state.init_all();
    services.store.init();
    runtime.events.boot_bus();
}

test "det_registry" {
    services.registry.load_builtin();
    services.registry.register_tool();
    services.registry.update_tool();
    services.registry.list_tools();
    services.registry.heartbeat();
    services.registry.record_invocation_decision();
    services.registry.unregister_tool();
    services.registry.evict_stale();
}

test "det_parallel_tools" {
    services.tools.init_tool_queue();
    services.tools.enqueue_tool_named("bash", "queue_bash_latest");
    services.tools.process_background();
    services.tools.monitor_background();
    services.tools.cancel_tool_run();
    services.tools.kill_background();
    services.tools.run_parallel();
    services.tools.pipe_stdout_events();
    services.tools.pipe_stderr_events();
    services.tools.pipe_structured_events();
    services.tools.retry_with_backoff();
    runtime.agent.dispatch_parallel_tools();
}

test "det_longrange_control" {
    services.longrange.boot();
    let run_id = services.longrange.create_run("det-longrange", "Ship long-range mode", "det-longrange-start");
    services.longrange.enqueue_message(run_id, "steer", "keep going", "det-longrange-steer", 0);
    services.longrange.apply_plan_create(run_id, "Ship long-range mode", "All required runtime, tools, and tests land", "high", "multi-turn", "step-1", "Build the runtime and verify it", "[{\"step_id\":\"step-1\",\"title\":\"Plan\",\"description\":\"Create the plan\",\"status\":\"in_progress\",\"done_criteria\":\"plan recorded\"}]", "det-plan-create");
    services.longrange.apply_plan_update(run_id, "", "", "", "", "step-2", "Advance to implementation", "[{\"step_id\":\"step-2\",\"title\":\"Implement\",\"description\":\"Build the feature\",\"status\":\"in_progress\",\"done_criteria\":\"feature works\"}]", "det-plan-update");
    services.longrange.prompt_context("det-longrange");
    services.longrange.summary_json();
    services.longrange.cancel_run(run_id, "deterministic cleanup", "det-longrange-cancel");
}

