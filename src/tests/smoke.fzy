test "det_recovery_and_failures" {
    runtime.config.apply_server_config();
    runtime.sandbox.apply_default_policy();
    runtime.sandbox.allow_tool_scope();
    runtime.sandbox.deny_tool_scope();
    runtime.recovery.save_checkpoint();
    runtime.recovery.restore_checkpoint();
    runtime.recovery.recover_inflight_jobs();
    runtime.failures.classify_spawn_failure();
    runtime.failures.classify_timeout();
    runtime.failures.classify_nonzero_exit();
    runtime.failures.classify_malformed_output();
    services.tools.classify_failure();
}

test "det_chaos_paths" {
    services.chaos.inject_slow_tool();
    services.chaos.inject_malformed_payload();
    services.chaos.inject_provider_latency();
}

test "det_language_surface" {
    let code = runtime.failures.failure_class_code(runtime.failures.classify_timeout());
    let mask: i32 = (~7) ^ 3;
    let selected: fn(i32) -> i32 = lang_id;
    discard lang_passthrough;
    let mut idx = 1;
    idx = idx + 1;
    let values = [3, 5, 10, 13];
    let picked = values[idx];
    let add = |x: i32| x + picked;
    let applied = lang_apply(selected, 9);
    let bumped = add(applied) + next_surface_counter();
    let routed: i32 = mask % 5;
    let class: i32 = match routed {
        0 => 7,
        1 => 11,
        _ => 13,
    };
    let probe = LangProbe { value: 7 };
    let kept = lang_keep<LangProbe>(probe);
    discard kept;
    let trait_score = LangProbe.score(7);
    let trait_code = LangProbe.code(7);
    discard loop {
        break class;
    };
    let ok: bool = !(routed == 0);
    discard lang_id(routed);
    if ok {
        pulse();
    } else {
        pulse();
    }
    if code == 12 {
        pulse();
    } else {
        pulse();
    }
    if bumped > 0 {
        pulse();
    } else {
        pulse();
    }
    if class > 0 {
        pulse();
    } else {
        pulse();
    }
    if trait_score > 0 && trait_code > 0 {
        pulse();
    } else {
        pulse();
    }
    timeout(5);
    cancel();
}
